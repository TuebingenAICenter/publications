@misc{buchholz_multi-armed_2025,
	title = {Multi-{Armed} {Bandits} and {Quantum} {Channel} {Oracles}},
	url = {https://quantum-journal.org/papers/q-2025-03-25-1672/},
	doi = {10.22331/q-2025-03-25-1672},
	abstract = {In this paper, we study the problem of multi-armed bandits where the arms are represented by quantum channels. We analyze the setting where a learner can sequentially select a channel and then perform an experiment by applying the channel to a state of their choice and performing a measurement. The goal is to maximize the sum of the expected measurement outcomes, which we call the reward. For a single target channel, this describes the problem of finding the application and measurement that leads to the largest expected reward, which is a known problem in quantum information. In our paper, we are interested in the exploration-exploitation trade-off when several channels are available. In the case where the learner can apply each channel to a different, potentially entangled, state, we prove that the problem can be reduced to the classical multi-armed bandit problem. However, for the more interesting case where use of entanglement is restricted, we show that when the learner may apply the channel to only one half of an entangled state, the problem changes significantly. We show that the best strategy may involve entangled states and measurements, and we provide an algorithm that achieves a regret of O({\textbackslash}sqrt\{TK{\textbackslash}log T\}) for K channels and T timesteps.},
	language = {en},
	publisher = {Verein zur Förderung des Open Access Publizierens in den Quantenwissenschaften},
	author = {Buchholz, Simon and Kübler, Jonas M. and Schölkopf, Bernhard},
	month = mar,
	year = {2025},
	keywords = {agentRevised, Channel (broadcasting), Computer network, Computer science, Physics, processed, Quantum, Quantum mechanics},
}

