@misc{bischoff_velotest_2025,
	title = {velotest: {Statistical} assessment of {RNA} velocity embeddings reveals quality differences for reliable trajectory visualizations},
	shorttitle = {velotest},
	url = {https://www.biorxiv.org/content/10.1101/2025.10.26.683064v1},
	doi = {10.1101/2025.10.26.683064},
	abstract = {Single-cell RNA velocity analysis has emerged as a powerful tool for inferring transient cellular dynamics from transcriptomic data. Typically, it is visualized as a low-dimensional embedding where displacement vectors indicate the predicted differentiation direction. However, such visualizations can be misleading, as they may suggest clear trajectories even when the underlying velocity signals are weak or inconsistent with the observed transcriptomic states. Here, we present velotest, a flexible statistical framework for assessing the quality and consistency of RNA velocity embeddings. velotest introduces quantitative scores and statistical hypothesis tests to identify regions where velocity estimates are unreliable or misaligned with the transcriptomic density. We showcase its diagnostic capabilities on multiple datasets, demonstrating how data-processing choices and projection methods impact the reliability of the resulting visualizations. velotest provides a rigorous foundation for evaluating RNA velocity analysis, making trajectory inference in single-cell studies more robust and transparent.},
	language = {en},
	publisher = {Cold Spring Harbor Laboratory},
	author = {Bischoff, Sebastian and Poliāar, Pavlin G. and Mukherjee, Soham and Macke, Jakob H. and Claassen, Manfred and Schröder, Cornelius},
