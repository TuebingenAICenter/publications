@misc{reizinger_cross-entropy_2025,
	title = {Cross-{Entropy} {Is} {All} {You} {Need} {To} {Invert} the {Data} {Generating} {Process}},
	url = {https://arxiv.org/pdf/2410.21869},
	doi = {10.48550/arXiv.2410.21869},
	abstract = {Identifying the latent components of the data generating process is a central goal in many scientific disciplines, but remains a major challenge. Traditionally, this is addressed via generative modeling (e.g., VAEs) which is known to require strong assumptions on the latent prior and the mixing function. Recently, several works have shown that high-performance discriminative models (e.g., ImageNet-pretrained VITs) are and should be able to identify these same components. However, this is currently only understood for a limited set of specialized loss functions. To bridge this gap, we study the standard cross-entropy loss and prove that for any multiclass classification task, the learned representation must be a diffeomorphism of the latent components (under mild conditions). Our theoretical results cover both linear and nonlinear mixing, provide a unified framework for several existing identifiability results, and clarify the role of the number of classes. We support our theory with controlled experiments on synthetic and complex data, demonstrating that standard cross-entropy training indeed leads to the inversion of the data generating process.},
	language = {en},
	author = {Reizinger, Patrik and Bizeul, Alice and Juhos, Attila and Vogt, Julia E. and Balestriero, Randall and Brendel, Wieland and Klindt, David},
	year = {2025},
	keywords = {Cross entropy, ELLIS Institute Tübingen, mentionsAICenter, MPI-IS, processed},
}

@misc{mayilvahanan_llms_2025,
	title = {{LLMs} on the {Line}: {Data} {Determines} {Loss}-to-{Loss} {Scaling} {Laws}},
	url = {https://arxiv.org/abs/2502.12120},
	doi = {10.48550/arXiv.2502.12120},
	abstract = {Scaling laws describe the predictable decrease in test loss with increasing compute, parameters, or data. Recent research has shown that the loss on one dataset (e.g., SlimPajama) often follows a linear relationship with the loss on another dataset (e.g., C4) when compute is varied. This phenomenon, which we refer to as loss-to-loss scaling, is observed across models trained on the same data distribution but differs for models trained on different data distributions. In this work, we investigate the factors that determine loss-to-loss scaling laws. We first show that these scaling laws are consistent across a wide range of model architectures (e.g., Transformers, RWKVs, State-Space Models) and model sizes if they are trained on the same data. In contrast, the data distribution has a significant impact: even subtle changes in data composition lead to distinct lines. Through a series of controlled experiments, we show that the slope and intercept of the loss-to-loss scaling law are determined by the relative data quality and the data overlap between the training and test distributions. Our findings suggest that loss-to-loss scaling laws can serve as a powerful tool to characterize and compare data distributions, offering a lens through which to understand the complex interplay between data and model performance.},
	language = {en},
	publisher = {MPI-IS and University of Tübingen},
	author = {Mayilvahanan, Prasanna and Wiedemer, Thaddäus and Mallick, Sayak and Bethge, Matthias and Brendel, Wieland},
	year = {2025},
	keywords = {Line (geometry), Line (geometry) Scaling law, mentionsAICenter, Scaling law},
}

