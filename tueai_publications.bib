@article{manzano-patron_uncertainty_2025,
	title = {Uncertainty mapping and probabilistic tractography using {Simulation}-based {Inference} in diffusion {MRI}: {A} comparison with classical {Bayes}},
	volume = {102},
	issn = {1361-8415},
	url = {https://www.sciencedirect.com/science/article/pii/S1361841525001276},
	doi = {10.1016/j.media.2025.103580},
	abstract = {Quantifying uncertainty in tractography is essential for the reliable mapping of anatomical connectivity in the human brain. Probabilistic tractography, which propagates local uncertainty to global pathways, provides a means of doing so. Conventionally, local uncertainty is estimated using classical Bayesian inference. These methods often require simplifying assumptions on the noise or the underlying biological model to remain computationally tractable and are typically implemented as independent voxel-wise analyses. In this study, we propose the use of Simulation-Based Inference (SBI) for local uncertainty mapping in dMRI. SBI leverages neural networks to learn the posterior distribution of model parameters directly from simulated data, effectively bypassing the need for an explicit likelihood and enabling flexible, amortized inference. We apply SBI to the fibre orientation distribution (FOD) model and demonstrate that it provides uncertainty estimates comparable to classical Bayes (Laplace approximation) in synthetic data, while being orders of magnitude faster at inference time. Using in vivo data from the Human Connectome Project, we show that SBI results in more consistent orientation estimates across multiple scan sessions and improved tractography outcomes. Our findings indicate that SBI offers a robust, efficient alternative for uncertainty quantification in dMRI, with the potential to scale to more complex biophysical models where classical Bayesian methods are either inefficient or inapplicable.},
	language = {en},
	journal = {Medical Image Analysis},
	publisher = {Elsevier},
	author = {Manzano-Patron, J. P. and Deistler, Michael and Schröder, Cornelius and Kypraios, Theodore and Gonçalves, Pedro J. and Macke, Jakob H. and Sotiropoulos, Stamatios N.},
	month = may,
	year = {2025},
	keywords = {mentionsAICenter, MPI-IS, Statistical Inference, University of Tübingen},
	pages = {103580},
}

@article{boelts_sbi_2025,
	title = {sbi reloaded: a toolkit for simulation-based inference workflows},
	volume = {10},
	copyright = {Creative Commons Attribution 4.0 International License},
	issn = {2475-9066},
	url = {https://joss.theoj.org/papers/10.21105/joss.07754},
	doi = {10.21105/joss.07754},
	abstract = {Simulation-based inference (SBI) is a paradigm for Bayesian inference in scenarios where the likelihood of a given model is unknown or difficult to compute, but simulations can be generated for any parameter set. The Python package sbi is a widely used toolkit that implements various neural SBI algorithms. We present sbi reloaded, a major update to the package that enhances its flexibility, performance, and accessibility. The update includes a redesigned API that separates simulation, training, and inference, enabling more complex and modular workflows. It also introduces support for multiple neural network architectures, improved diagnostics, and standardized interfaces for simulators and prior distributions. With these improvements, sbi reloaded provides a robust foundation for applying and developing state-of-the-art SBI methods across diverse scientific domains.},
	language = {en},
	number = {108},
	journal = {Journal of Open Source Software},
	publisher = {The Open Journal},
	author = {Boelts, Jan and Deistler, Michael and Gloeckler, Manuel and Tejero-Cantero, Álvaro and Lueckmann, Jan-Matthis and Moss, Guy and Steinbach, Peter and Moreau, Thomas and Muratore, Fabio and Linhart, Julia and Durkan, Conor and Vetter, Julius and Miller, Benjamin Kurt and Herold, Maternus and Ziaeemehr, Abolfazl and Pals, Matthijs and Gruner, Theo and Bischoff, Sebastian and Krouglova, Nastya and Gao, Richard and Lappalainen, Janne K. and Mucsányi, Bálint and Pei, Felix and Schulz, Auguste and Stefanidi, Zinovia and Rodrigues, Pedro and Schröder, Cornelius and Zaid, Faried Abu and Beck, Jonas and Kapoor, Jaivardhan and Greenberg, David S. and Gonçalves, Pedro J. and Macke, Jakob H.},
