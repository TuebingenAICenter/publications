@article{schulz_modeling_2025,
	title = {Modeling conditional distributions of neural and behavioral data with masked variational autoencoders},
	volume = {44},
	issn = {2211-1247},
	url = {https://www.cell.com/cell-reports/fulltext/S2211-1247(25)00109-3},
	doi = {10.1016/j.celrep.2025.115338},
	abstract = {Understanding the complex, non-linear relationships between stimuli, neural activity, and behavior remains a central challenge in neuroscience. While deep generative models, such as variational autoencoders (VAEs), can identify low-dimensional latent structures in neural and behavioral data, they are typically limited to learning the joint distribution of these data. Consequently, they do not accommodate many experimental paradigms where some variables (e.g., stimuli or neural activity) are treated as inputs and others (e.g., neural activity or behavior) as outputs. To address this, we present a masked VAE (mVAE) framework that allows for learning conditional distributions during both training and inference. We demonstrate the mVAE's utility by modeling large-scale neural and behavioral datasets, showing that it can perform tasks such as neural decoding and neural-activity-to-behavior prediction. The mVAE framework offers a flexible and efficient approach for investigating the intricate mappings between varied types of neuroscience data.},
	language = {en},
	number = {2},
	journal = {Cell Reports},
	publisher = {Elsevier},
	author = {Schulz, Auguste and Vetter, Julius and Gao, Richard and Morales, Daniel and Ríos, Victor Lobato and Ramdya, Pavan P. and Gonçalves, Pedro J. and Macke, Jakob H.},
	month = feb,
	year = {2025},
	keywords = {mentionsAICenter},
	pages = {115338},
}

