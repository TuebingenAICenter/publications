@misc{gupte_evidence_2024,
	title = {Evidence for eccentricity in the population of binary black holes observed by {LIGO}-{Virgo}-{KAGRA}},
	url = {https://journals.aps.org/prd/accepted/10.1103/vpyp-nvfp},
	doi = {10.1103/PhysRevD.110.123019},
	abstract = {Gravitational-wave (GW) observations of binary black holes (BBHs) by the LIGO-Virgo-KAGRA (LVK) Collaboration provide a unique window into the formation and evolution of these systems. While most BBH systems are expected to have circularized by the time they enter the frequency band of ground-based detectors, hierarchical mergers in dense stellar environments and dynamical captures can result in binaries with non-zero eccentricity. In this work, we search for evidence of eccentricity in the BBHs from the third LVK observing run (O3). We use a neural posterior estimation (NPE) pipeline to perform rapid Bayesian inference with the eccentric waveform model SEOBNRv4EHM. We find evidence for non-zero eccentricity in several events, with the strongest evidence for GW190521 and GW190620\_030421. We then perform a population-level analysis to constrain the distribution of eccentricity in the BBH population, finding that a significant fraction of systems may have non-zero eccentricity at 10 Hz. Our results highlight the importance of including eccentricity in GW data analysis to accurately characterize the properties and formation channels of BBH systems.},
	language = {en},
	publisher = {American Physical Society},
	author = {Gupte, Nihar and Ramos-Buades, Antoni and Buonanno, Alessandra and Gair, Jonathan and Miller, M. Coleman and Dax, Maximilian and Green, Stephen R. and Pürrer, Michael and Wildberger, Jonas and Macke, Jakob and Romero-Shaw, Isobel M. and Schölkopf, Bernhard},
	month = apr,
	year = {2024},
	keywords = {agentRevised, MPI-IS, processed},
}

