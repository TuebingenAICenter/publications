@inproceedings{dziadzio_how_2025,
	title = {How to {Merge} {Your} {Multimodal} {Models} {Over} {Time}?},
	shorttitle = {How to {Merge} {Your} {Multimodal} {Models} {Over} {Time}?},
	url = {https://arxiv.org/abs/2412.06712},
	doi = {10.1109/cvpr52734.2025.01907},
	abstract = {The rapid evolution of multimodal models has led to a proliferation of specialized versions, each fine-tuned for different tasks or data distributions. While model merging techniques have emerged as a powerful tool to combine these models without further training, they are typically designed for static snapshots. In this work, we introduce the problem of merging multimodal models over time, where we aim to combine a sequence of models that have been updated sequentially. We find that naive application of existing merging methods leads to catastrophic forgetting of earlier capabilities. To address this, we propose a novel framework, FluxMerge, which leverages the temporal structure of model updates to effectively merge models while preserving performance across the entire sequence. We demonstrate the effectiveness of our approach on a range of multimodal tasks, showing that it significantly outperforms existing baselines in both zero-shot and few-shot settings.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the {IEEE}/{CVF} {Conference} on {Computer} {Vision} and {Pattern} {Recognition} ({CVPR})},
	publisher = {University of Tübingen},
	author = {Dziadzio, Sebastian and Udandarao, Vishaal and Roth, Karsten and Prabhu, Ameya and Akata, Zeynep and Albanie, Samuel and Bethge, Matthias},
	year = {2025},
	keywords = {Merge (version control), Computer science, Information retrieval, processed, CVPR},
}
