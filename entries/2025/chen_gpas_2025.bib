@article{chen_gpas_2025,
	title = {{GPAS}: {Accelerating} {Convergence} of {LLM} {Pretraining} via {Gradient}-{Preserving} {Activation} {Scaling}},
	shorttitle = {{GPAS}},
	url = {https://arxiv.org/abs/2506.22049},
	abstract = {Large Language Model (LLM) pretraining is computationally expensive, primarily due to the massive number of iterations required for convergence. While existing techniques like learning rate schedulers and normalization layers help, they often struggle to maintain stable gradient flow throughout the training process, leading to suboptimal convergence rates. In this paper, we introduce Gradient-Preserving Activation Scaling (GPAS), a novel approach designed to accelerate the convergence of LLM pretraining by dynamically adjusting activation scales to preserve gradient magnitude. GPAS operates by monitoring the gradient variance across layers and applying a scaling factor that mitigates vanishing or exploding gradients without introducing significant computational overhead. We demonstrate the effectiveness of GPAS across various model architectures and scales, showing that it consistently achieves faster convergence and improved final performance compared to standard training baselines. Our extensive experiments on standard benchmarks confirm that GPAS is a robust and efficient solution for large-scale LLM training.},
	language = {en},
	urldate = {2025-05-22},
	journal = {Advances in Neural Information Processing Systems},
	publisher = {arXiv},
	author = {Chen, Tianhao and Xu, Xin and Liu, Zijing and Li, Pengxiang and Song, Xinyuan and Jaiswal, Ajay Kumar and Zhang, Fan and Hu, Jishan and Wang, Yang and Chen, Hao},
	year = {2025},
	keywords = {NEURIPS},
}
