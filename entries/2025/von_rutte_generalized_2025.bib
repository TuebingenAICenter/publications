@inproceedings{von_rutte_generalized_2025,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Generalized {Interpolating} {Discrete} {Diffusion}},
	shorttitle = {{GIDD}},
	url = {https://proceedings.mlr.press/v267/von-rutte25a.html},
	doi = {10.48550/arxiv.2503.04482},
	abstract = {Discrete diffusion models have emerged as a powerful framework for generative modeling of discrete data. However, existing approaches often rely on specific noise schedules or transition kernels, limiting their flexibility. In this work, we introduce Generalized Interpolating Discrete Diffusion (GIDD), a unified framework that generalizes discrete diffusion by formulating it as an interpolation process between a data distribution and a noise distribution. Our framework allows for arbitrary transition kernels and noise schedules, enabling the design of models that are better suited to the structure of the data. We demonstrate that GIDD encompasses several existing discrete diffusion models as special cases and provides a principled way to derive new ones. We further show that GIDD can be trained using a simple objective, and we provide theoretical guarantees for the convergence of the generative process. Finally, we empirically validate our approach on a range of discrete data generation tasks, showing that GIDD achieves state-of-the-art performance while offering greater flexibility and simplicity.},
	language = {en},
	urldate = {2025-07-24},
	booktitle = {Proceedings of the 42nd {International} {Conference} on {Machine} {Learning} ({ICML})},
	publisher = {PMLR},
	author = {von Rütte, Dimitri and Fluri, Janis and Ding, Yongmei and Orvieto, Antonio and Schölkopf, Bernhard and Hofmann, Thomas},
	editor = {Singh, Aarti and Fazel, Maryam and Hsu, Daniel and Lacoste-Julien, Simon and Berkenkamp, Felix and Maharaj, Tegan and Wagstaff, Kiri and Zhu, Jerry},
	month = jul,
	year = {2025},
	keywords = {Flexibility (engineering), Masking (illustration), Diffusion, Simplicity, Noise (video), Quality (philosophy), Interpolation (computer graphics), Autoregressive model, ICML},
}
