@article{hardt_performative_2025,
	title = {Performative {Prediction}: {Past} and {Future}},
	issn = {0883-4237},
	shorttitle = {Performative {Prediction}},
	url = {https://arxiv.org/abs/2310.16608},
	doi = {10.1214/25-sts986},
	abstract = {Performative prediction occurs when a predictive model influences the target variable it aims to predict. This phenomenon is ubiquitous in social and economic systems, where predictions about human behavior often shape that behavior. While the study of performative prediction has gained significant traction in machine learning and statistics in recent years, the underlying ideas have a long history in the social sciences, philosophy, and economics. In this paper, we provide a conceptual framework for performative prediction, tracing its roots in the social sciences and connecting them to recent developments in machine learning. We discuss the implications of performativity for predictive modeling, highlighting the challenges it poses for traditional statistical inference and the opportunities it creates for new algorithmic approaches. We conclude by outlining a research agenda for the future of performative prediction.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Statistical Science},
	publisher = {Institute of Mathematical Statistics},
	author = {Hardt, Moritz and Mendler-Dünner, Celestine},
	year = {2025},
	keywords = {Performative utterance, Performativity, Predictive power, Dirt, Conceptual framework, Computer science, Sass, Epistemology, Sociology, Power (physics), Artificial intelligence, Aesthetics, Engineering, Social science, Art, World Wide Web, Philosophy, Mechanical engineering, agentRevised, STS},
}
