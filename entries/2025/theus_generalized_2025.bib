@inproceedings{theus_generalized_2025,
	title = {Generalized {Linear} {Mode} {Connectivity} for {Transformers}},
	shorttitle = {{GLMC} for {Transformers}},
	url = {https://arxiv.org/abs/2506.22712},
	doi = {10.48550/arxiv.2506.22712},
	abstract = {Linear mode connectivity (LMC) is a phenomenon where two independently trained neural networks can be connected by a linear path of constant loss. While LMC has been extensively studied for vision models, it remains elusive for Transformers. We show that this is primarily due to the permutation symmetries of the attention heads and the scaling symmetries of the normalization layers. We introduce Generalized Linear Mode Connectivity (GLMC), a framework that accounts for these symmetries by aligning the weights of two Transformers using a combination of permutation and scaling transformations. We prove that GLMC is equivalent to finding the optimal alignment in a homogeneous space, which we solve using a novel, efficient algorithm. We demonstrate that GLMC successfully connects independently trained Transformers across various architectures and datasets, including large-scale language models, and provides a new perspective on the loss landscape of Transformers.},
	language = {en},
	urldate = {2025-06-01},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {arXiv},
	author = {Theus, Alexander and Cabodi, Alessandro and Anagnostidis, Sotiris and Orvieto, Antonio and Singh, Siddharth P. and Boeva, Valentina},
	year = {2025},
	keywords = {Homogeneous space, Invertible matrix, Pairwise comparison, Generalization, Transformer, Parameter space, Artificial neural network, agentRevised, processed, NEURIPS},
}
