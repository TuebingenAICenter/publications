@inproceedings{witt_flexibly_2025,
	title = {Flexibly biased learning rates in social learning},
	shorttitle = {Flexibly biased learning rates},
	url = {https://charleywu.github.io/downloads/witt2025flexibly.pdf},
	doi = {10.31234/osf.io/bcrw9_v1},
	abstract = {Social learning allows individuals to acquire information from others, but it also introduces the risk of adopting suboptimal or incorrect information. A key challenge is determining when to trust social information versus one's own experience. We propose that humans solve this problem by employing flexibly biased learning rates, where the weight given to social information is dynamically adjusted based on the reliability of the social source and the individual's own uncertainty. We test this hypothesis using a social reinforcement learning task where participants learn from a social partner whose reliability varies over time. We find that participants exhibit a confirmation bias, overweighting social information that aligns with their prior beliefs, and that this bias is modulated by the perceived reliability of the social source. Our results suggest that social learning is not a passive process of information integration, but an active, biased process that balances the benefits of social information with the need for individual accuracy.},
	language = {en},
	urldate = {2025-05-22},
	booktitle = {Proceedings of the 47th {Annual} {Conference} of the {Cognitive} {Science} {Society}},
	publisher = {Cognitive Science Society},
	author = {Witt, Alexandra and Palminteri, Stefano and Wu, Charley M.},
	editor = {Ruggeri, A. and Barner, D. and Walker, C. and Bramley, N.},
	year = {2025},
	keywords = {Social learning, Psychology, Odds, Social psychology, Cognitive psychology, Computer science, Machine learning, Social Learning, University of Tübingen, COGSCI},
}
