@inproceedings{vetter_effortless_2025,
	title = {Effortless, {Simulation}-{Efficient} {Bayesian} {Inference} using {Tabular} {Foundation} {Models}},
	shorttitle = {Effortless, {Simulation}-{Efficient} {Bayesian} {Inference} using {Tabular} {Foundation} {Models}},
	url = {https://arxiv.org/abs/2504.17660},
	doi = {10.48550/arxiv.2504.17660},
	abstract = {Simulation-based inference (SBI) allows for Bayesian inference in models where the likelihood is intractable but simulation is possible. However, current methods often require significant expert effort to design and train specialized neural density estimators for each new problem. We propose a novel approach to SBI that leverages pre-trained tabular foundation models (TFMs) to perform inference without the need for task-specific training. By treating the simulation-based inference problem as a conditional density estimation task on tabular data, we show that TFMs can be used as zero-shot or few-shot density estimators. We demonstrate that our method, which we call TFM-SBI, achieves competitive performance on a range of benchmark problems while being significantly more simulation-efficient and easier to use than existing methods. Our results suggest that foundation models can play a transformative role in making Bayesian inference more accessible and efficient across scientific domains.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 38},
	publisher = {arXiv},
	author = {Vetter, J. and Gloeckler, M. and Gedon, D. and Macke, J. H.},
	month = dec,
	year = {2025},
	keywords = {Inference, Frequentist inference, Artificial neural network, Robustness (evolution), Estimator, Bayesian inference, Bayesian probability, Range (aeronautics), Predictive inference, agentRevised, processed, NEURIPS},
}
