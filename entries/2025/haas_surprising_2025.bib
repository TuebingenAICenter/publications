@inproceedings{haas_surprising_2025,
	title = {On the {Surprising} {Effectiveness} of {Large} {Learning} {Rates} under {Standard} {Width} {Scaling}},
	shorttitle = {On the {Surprising} {Effectiveness} of {Large} {Learning} {Rates}},
	url = {https://arxiv.org/abs/2505.22491},
	doi = {10.48550/arxiv.2505.22491},
	abstract = {Standard width scaling in deep learning, where the learning rate is kept constant as the network width increases, is often considered suboptimal compared to the NTK-parameterization, which requires scaling the learning rate by the width. In this paper, we show that standard width scaling is surprisingly effective. We prove that for a wide range of architectures, standard width scaling leads to a stable training dynamics in the limit of infinite width, provided the learning rate is chosen appropriately. We further show that this limit is not the NTK, but a different, non-linear limit. We provide empirical evidence that this limit is more expressive than the NTK and can achieve better performance on standard benchmarks.},
	language = {en},
	urldate = {2025-06-01},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {arXiv},
	author = {Haas, Moritz and Bordt, Sebastian and von Luxburg, Ulrike and Vankadara, Leena Chennuru},
	year = {2025},
	keywords = {Divergence (linguistics), Initialization, Scaling, Stability (learning theory), Feature (linguistics), Limit (mathematics), Artificial neural network, agentRevised, processed, NEURIPS},
}
