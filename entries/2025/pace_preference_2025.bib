@misc{pace_preference_2025,
	title = {Preference {Elicitation} for {Offline} {Reinforcement} {Learning}},
	url = {https://arxiv.org/abs/2406.18450},
	doi = {10.48550/arxiv.2406.18450},
	abstract = {Offline reinforcement learning (RL) aims to learn optimal policies from static datasets without further environment interaction. However, defining a reward function that accurately reflects human intent is notoriously difficult. Preference-based RL addresses this by learning a reward model from human feedback, typically in the form of pairwise comparisons. In this work, we study the problem of preference elicitation in the offline setting. We propose a framework that actively selects pairs of trajectories to query from a human, aiming to minimize the uncertainty of the reward model while maximizing the performance of the resulting policy. We provide theoretical guarantees on the convergence of our approach and demonstrate its effectiveness on a range of offline RL benchmarks, showing that it can significantly improve policy performance compared to passive or random query selection strategies.},
	language = {en},
	urldate = {2025-05-14},
	author = {Pace, Alizée and Schölkopf, Bernhard and Rätsch, Gunnar and Ramponi, Giorgia},
	month = apr,
	year = {2025},
	keywords = {Preference, Preference elicitation, Reinforcement learning, Reinforcement, Preference learning, Computer science, Artificial intelligence, Psychology, Machine learning, Cognitive psychology, Social psychology, Economics, Microeconomics, ICLR},
}
