@inproceedings{green_leaky_2025,
	title = {Leaky {Thoughts}: {Large} {Reasoning} {Models} {Are} {Not} {Private} {Thinkers}},
	shorttitle = {Leaky {Thoughts}},
	url = {https://arxiv.org/abs/2506.15674},
	abstract = {Large reasoning models (LRMs) are increasingly deployed to solve complex tasks by generating extensive chain-of-thought (CoT) reasoning traces. While these traces are often treated as internal, intermediate computations, we demonstrate that they are highly vulnerable to extraction. We introduce a novel attack, the 'Thought-Extraction Attack', which leverages the model's own reasoning process to leak private information contained in the prompt or the system instructions. We show that even when the model is instructed to keep information private, the reasoning process often inadvertently reveals it. We evaluate our attack on several state-of-the-art LRMs and find that they are consistently susceptible to leaking sensitive information. Our findings highlight a critical privacy vulnerability in current reasoning models and underscore the need for robust privacy-preserving mechanisms in the design and deployment of LRMs.},
	language = {en},
	urldate = {2025-06-01},
	booktitle = {Proceedings of the 2025 {Conference} on {Empirical} {Methods} in {Natural} {Language} {Processing} ({EMNLP} 2025)},
	publisher = {arXiv},
	author = {Green, Tommaso and Gubri, Martin and Puerto, Haritz and Yun, Sangdoo and Oh, Seong Joon},
	year = {2025},
	keywords = {agentRevised, processed, University of Tübingen, EMNLP},
}
