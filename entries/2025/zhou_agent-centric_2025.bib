@inproceedings{zhou_agent-centric_2025,
	title = {Agent-centric learning: from external reward maximization to internal knowledge curation},
	shorttitle = {Agent-centric learning},
	url = {https://arxiv.org/abs/2507.22255},
	doi = {10.48550/arXiv.2507.22255},
	abstract = {Reinforcement learning (RL) has traditionally been framed as the problem of maximizing external rewards. While this paradigm has led to impressive successes in specific tasks, it often results in brittle agents that struggle to generalize to new environments. In this paper, we propose a shift towards agent-centric learning, where the primary objective is the curation of internal knowledge rather than the maximization of external rewards. We argue that by focusing on the development of internal models and representations, agents can become more robust, adaptable, and capable of solving complex problems. We discuss the theoretical foundations of this approach, its relationship to existing frameworks, and its potential for future research in artificial intelligence.},
	language = {en},
	urldate = {2025-07-30},
	booktitle = {Reinforcement {Learning} {Conference}: {Finding} the {Frame} {Workshop}},
	publisher = {arXiv},
	author = {Zhou, H. and Mantiuk, F. and Nagy, D. G. and Wu, C. M.},
	year = {2025},
	keywords = {processed, University of Tübingen, workshop, RLC},
}
