@article{nagy_adaptive_2025,
	title = {Adaptive compression as a unifying framework for episodic and semantic memory},
	issn = {2731-0574},
	shorttitle = {Adaptive compression},
	url = {https://doi.org/10.1038/s44159-025-00458-6},
	doi = {10.1038/s44159-025-00458-6},
	abstract = {The distinction between episodic and semantic memory is a cornerstone of cognitive science, yet the mechanisms that bridge these systems remain debated. We propose that adaptive compression—the process of efficiently encoding information by identifying and exploiting statistical regularities—serves as a unifying framework for both memory systems. We argue that episodic memory functions as a high-fidelity, context-dependent buffer that captures unique experiences, whereas semantic memory emerges as a compressed, generalized representation of these experiences. By framing memory as an adaptive compression problem, we show how the brain balances the trade-off between the need for precise retrieval of specific events and the need for efficient, abstract knowledge representation. This framework provides a computational account of memory consolidation, schema formation and the developmental trajectory of memory systems, offering a parsimonious explanation for how the brain transforms fleeting experiences into enduring knowledge.},
	language = {en},
	urldate = {2025-05-22},
	journal = {Nature Reviews Psychology},
	publisher = {Nature Portfolio},
	author = {Nagy, Dávid and Orbán, Gergő and Wu, Charley M.},
	year = {2025},
	keywords = {Episodic memory, Semantic memory, Computer science, Cognitive science, Compression (physics), Cognitive psychology, Natural language processing, Artificial intelligence, Psychology, Neuroscience, Cognition, processed, University of Tübingen},
}
