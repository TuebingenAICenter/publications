@article{araujo_cav-mae_2025,
	title = {{CAV}-{MAE} {Sync}: {Improving} {Contrastive} {Audio}-{Visual} {Mask} {Autoencoders} via {Fine}-{Grained} {Alignment}},
	shorttitle = {{CAV}-{MAE} {Sync}},
	url = {https://openaccess.thecvf.com/content/CVPR2025/html/Araujo_CAV-MAE_Sync_Improving_Contrastive_Audio-Visual_Mask_Autoencoders_via_Fine-Grained_Alignment_CVPR_2025_paper.html},
	abstract = {Contrastive Audio-Visual Masked Autoencoders (CAV-MAE) have shown great promise in learning joint audio-visual representations by masking patches of both modalities and reconstructing them. However, current approaches often rely on global contrastive losses that fail to capture fine-grained temporal and spatial correspondences between audio and visual signals. In this paper, we propose CAV-MAE Sync, a novel framework that improves the alignment of audio-visual representations by introducing a fine-grained synchronization objective. Specifically, we leverage the inherent temporal structure of audio and video to enforce local alignment between audio segments and visual patches. We demonstrate that our approach significantly improves performance on downstream tasks, including audio-visual classification and retrieval, while maintaining the efficiency of the original CAV-MAE architecture.},
	language = {en},
	urldate = {2025-06-01},
	journal = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
	publisher = {IEEE},
	author = {Araujo, Edson and Rouditchenko, Andrew and Gong, Yuan and Bhati, Saurabhchand and Thomas, Samuel and Kingsbury, Brian and Karlinsky, Leonid and Feris, Rogerio and Glass, James R. and Kuehne, Hilde},
	year = {2025},
	keywords = {CVPR},
}
