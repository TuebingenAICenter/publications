@inproceedings{ormaniec_what_2025,
	title = {What {Does} {It} {Mean} to {Be} a {Transformer}? {Insights} from a {Theoretical} {Hessian} {Analysis}},
	shorttitle = {What {Does} {It} {Mean} to {Be} a {Transformer}?},
	url = {https://arxiv.org/abs/2410.10986},
	abstract = {Transformers have become the de facto standard architecture for deep learning. Despite their empirical success, a theoretical understanding of why they perform so well remains elusive. In this work, we investigate the loss landscape of Transformers by analyzing the Hessian of the loss with respect to the model parameters. We derive a closed-form expression for the Hessian of a Transformer, which reveals that the curvature is dominated by the interaction between the attention mechanism and the feed-forward layers. We show that this interaction leads to a specific structure in the Hessian, which we call the 'attention-induced curvature'. We demonstrate that this structure is present in both pre-trained and randomly initialized models, and that it is robust to changes in the model architecture. Finally, we use our theoretical insights to explain several empirical phenomena, such as the effectiveness of layer normalization and the role of the attention mechanism in training stability.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {The {Thirteenth} {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Ormaniec, W. and Dangel, F. and Singh, S. P.},
	month = apr,
	year = {2025},
	keywords = {ICLR},
}
