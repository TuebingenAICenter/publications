@article{dax_real-time_2025,
	title = {Real-time inference for binary neutron star mergers using machine learning},
	issn = {1476-4687},
	shorttitle = {Real-time gravitational-wave inference},
	url = {https://doi.org/10.1038/s41586-025-08593-z},
	doi = {10.1038/s41586-025-08593-z},
	abstract = {Gravitational-wave astronomy relies on the rapid identification and characterization of compact binary coalescences. Current methods for parameter estimation, such as Bayesian inference using Markov chain Monte Carlo or nested sampling, are computationally expensive, often taking hours to days to produce results. This latency limits the ability to perform rapid multi-messenger follow-up observations. Here we present a machine-learning-based approach for real-time parameter estimation of binary neutron star mergers. Our method, based on neural posterior estimation, provides accurate posterior distributions in seconds, enabling immediate follow-up. We demonstrate the performance of our approach on simulated signals and show that it produces results consistent with traditional Bayesian methods while being several orders of magnitude faster.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Nature},
	publisher = {Nature Portfolio},
	author = {Dax, M. and Green, S. R. and Gair, J. and Gupte, N. and Pürrer, M. and Raymond, V. and Wildberger, J. and Macke, J. H. and Buonanno, A. and Schölkopf, B.},
	month = mar,
	year = {2025},
	keywords = {Inference, Neutron star, Binary number, Computer science, Star (game theory), Artificial intelligence, Astrophysics, Physics, Mathematics, Arithmetic, Machine Learning, Gravitational Waves, NATURE},
}
