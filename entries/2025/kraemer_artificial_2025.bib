@article{kraemer_artificial_2025,
	title = {Artificial intelligence for modelling infectious disease epidemics},
	issn = {0028-0836},
	shorttitle = {Artificial intelligence for modelling infectious disease epidemics},
	url = {https://www.nature.com/articles/s41586-024-08564-w#Abs1},
	doi = {10.1038/s41586-024-08564-w},
	abstract = {The COVID-19 pandemic highlighted the need for rapid, accurate and scalable tools to support public health decision-making. Artificial intelligence (AI) and machine learning (ML) have emerged as powerful approaches for modelling infectious disease dynamics, offering the potential to improve our understanding of transmission, predict future trends and evaluate the impact of interventions. However, the integration of AI into public health practice remains challenging. Here we review the current state of AI-driven infectious disease modelling, highlighting its strengths, limitations and the critical barriers to its effective deployment. We discuss the importance of data quality, model interpretability, uncertainty quantification and the need for robust validation frameworks. We also outline a roadmap for the future, emphasizing the importance of interdisciplinary collaboration, ethical considerations and the development of AI tools that are transparent, equitable and actionable for public health authorities.},
	language = {en},
	urldate = {2025-05-22},
	journal = {Nature},
	publisher = {Nature Portfolio},
	author = {Kraemer, M. U. G. and Tsui, J. L.-H. and Chang, S. Y. and Lytras, S. and Khurana, M. P. and Vanderslott, S. and Bajaj, S. and Scheidwasser, N. and Curran-Sebastian, J. L. and Semenova, E. and Zhang, M. and Unwin, H. J. T. and Watson, O. J. and Mills, C. and Dasgupta, A. and Ferretti, L. and Scarpino, S. V. and Koua, E. and Morgan, O. and Tegally, H. and Paquet, U. and Moutsianas, L. and Fraser, C. and Ferguson, N. M. and Topol, E. J. and Duchêne, D. A. and Stadler, T. and Kingori, P. and Parker, M. J. and Dominici, F. and Shadbolt, N. and Suchard, M. A. and Ratmann, O. and Flaxman, S. and Holmes, E. C. and Gomez-Rodriguez, M. and Schölkopf, B. and Donnelly, C. A. and Pybus, O. G. and Cauchemez, S. and Bhatt, S.},
	month = feb,
	year = {2025},
	keywords = {Infectious disease (medical specialty), Virology, Disease, Computer science, Biology, Medicine, Pathology, ELLIS Institute Tübingen, MPI-IS, processed},
}
