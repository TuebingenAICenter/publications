@inproceedings{rubinstein_are_2025,
	title = {Are {We} {Done} with {Object}-{Centric} {Learning}?},
	url = {https://arxiv.org/abs/2504.07092},
	doi = {10.48550/arxiv.2504.07092},
	abstract = {Object-centric learning (OCL) aims to decompose scenes into individual objects, promising better generalization, interpretability, and data efficiency. Despite years of research, OCL models still struggle to scale to complex, real-world data. In this paper, we perform a systematic evaluation of state-of-the-art OCL models on a diverse set of benchmarks. We find that while OCL models perform well on synthetic datasets, their performance drops significantly on real-world data. We identify key bottlenecks in current OCL architectures and propose a new framework, OCCAM, that addresses these limitations. Our results show that OCCAM achieves state-of-the-art performance on multiple benchmarks, suggesting that we are not done with OCL, but rather that we need to rethink our approach to scaling it.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Workshop on {Spurious} {Correlation} and {Shortcut} {Learning}: {Foundations} and {Solutions} ({ICLR} 2025)},
	publisher = {arXiv},
	author = {Rubinstein, Alexander and Prabhu, Ameya and Bethge, Matthias and Oh, Seong Joon},
	year = {2025},
	keywords = {Encoding (memory), Toolbox, Object (grammar), ENCODE, Representation (politics), Generalization, Scalability, Focus (optics), Code (set theory), agentRevised, workshop, ICLR},
}
