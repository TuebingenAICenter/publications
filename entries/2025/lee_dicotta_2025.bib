@misc{lee_dicotta_2025,
	title = {{DiCoTTA}: {Domain}-invariant {Learning} for {Continual} {Test}-time {Adaptation}},
	shorttitle = {{DiCoTTA}},
	url = {https://arxiv.org/abs/2504.04981},
	doi = {10.48550/arXiv.2504.04981},
	abstract = {Continual Test-time Adaptation (CTTA) aims to adapt a pre-trained model to a sequence of target domains without accessing source data. Existing methods often suffer from catastrophic forgetting or error accumulation due to the lack of source supervision and the non-stationary nature of target domains. In this paper, we propose Domain-invariant Learning for Continual Test-time Adaptation (DiCoTTA), which leverages domain-invariant features to mitigate these issues. Specifically, we introduce a novel objective that encourages the model to learn representations that are invariant across different target domains, thereby enhancing the robustness of the adaptation process. Furthermore, we propose a dynamic memory mechanism to store and retrieve domain-specific information, which helps in preserving knowledge from previous domains. Extensive experiments on various benchmarks demonstrate that DiCoTTA consistently outperforms state-of-the-art methods in CTTA scenarios.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Lee, Sohyun and Kim, Nayeong and Kang, Juwon and Oh, Seong Joon and Kwak, Suha},
	month = apr,
	year = {2025},
	keywords = {arXiv},
}
