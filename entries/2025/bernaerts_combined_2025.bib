@article{bernaerts_combined_2025,
	title = {Combined statistical-biophysical modeling links ion channel genes to physiology of cortical neuron types},
	issn = {2666-3899},
	url = {https://doi.org/10.1016/j.patter.2025.101171},
	doi = {10.1016/j.patter.2025.101171},
	abstract = {The diversity of cortical neuron types is characterized by distinct electrophysiological properties, which are thought to be shaped by the differential expression of ion channel genes. However, linking gene expression to neuronal physiology remains challenging due to the complex, non-linear relationship between ion channel conductances and firing patterns. Here, we present a statistical-biophysical modeling framework that integrates single-cell transcriptomics and electrophysiology to infer the functional impact of ion channel gene expression. We apply this framework to cortical neurons and show that it can predict electrophysiological features from gene expression data. Our model reveals that the expression of specific ion channel genes is predictive of neuronal firing patterns and that this relationship is conserved across different cortical layers. These findings provide a mechanistic link between the molecular identity of neurons and their functional properties, offering a powerful tool for understanding the cellular basis of cortical circuit diversity.},
	language = {en},
	urldate = {2025-05-22},
	journal = {Patterns},
	publisher = {Elsevier},
	author = {Bernaerts, Yves and Deistler, Michael and Gonçalves, Pedro J. and Beck, Jonas and Stimberg, Marcel and Scala, Federico and Tolias, Andreas S. and Macke, Jakob H. and Kobak, Dmitry and Berens, Philipp},
	year = {2025},
	keywords = {Ion channel, Neuroscience, Neuron, Channel (broadcasting), Biology, Computational biology, Computer science, Evolutionary biology, Genetics, Computer network, Gene, agentRevised},
}
