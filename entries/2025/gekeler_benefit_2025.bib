@inproceedings{gekeler_benefit_2025,
	title = {Benefit of {Weather} {Integration} for {Industrial} {Electric} {Load} {Forecasting} - {A} {Benchmark} {Study}},
	shorttitle = {Benefit of {Weather} {Integration} for {Industrial} {Electric} {Load} {Forecasting}},
	url = {https://ieeexplore.ieee.org/document/11327705},
	doi = {10.1109/ACCESS.2025.3532770},
	abstract = {Accurate industrial electric load forecasting is essential for efficient energy management and cost reduction in manufacturing. While weather data is often considered a key driver for load variations, its actual benefit for industrial load forecasting remains under-researched. This paper presents a comprehensive benchmark study evaluating the impact of weather integration on the forecasting performance of various machine learning models across different industrial sectors. We analyze a diverse dataset of industrial load profiles and corresponding weather data, comparing models with and without weather features. Our results provide empirical evidence on the conditions under which weather integration yields significant improvements and where it provides negligible or even detrimental effects. These findings offer practical guidance for practitioners in selecting appropriate forecasting strategies for industrial energy systems.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {{IEEE} {Access}},
	publisher = {IEEE},
	author = {Gekeler, David and Baur, Lukas and Schnell, Felix and Hennig, Philipp and Sauer, Alexander},
	year = {2025},
	keywords = {IEEE ACCESS},
}
