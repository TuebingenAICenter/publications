@misc{meder_dopamine_2025,
	title = {Dopamine depletion in {Parkinson}’s increases directed but not random exploration},
	url = {https://osf.io/preprints/psyarxiv/y2buv_v1},
	doi = {10.31234/osf.io/y2buv_v1},
	abstract = {Exploration is essential for learning and decision-making in uncertain environments. Theoretical accounts suggest that dopamine plays a key role in modulating exploration, but empirical evidence remains mixed. We investigated the effect of dopamine depletion on exploration in patients with Parkinson’s disease (PD) using a multi-armed bandit task. We decomposed exploration into directed exploration (driven by uncertainty) and random exploration (driven by noise). We found that dopamine depletion in PD patients increased directed exploration, while random exploration remained unaffected. These results suggest that dopamine specifically modulates directed exploration, providing new insights into the neurobiological mechanisms of exploration and their alteration in Parkinson’s disease.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PsyArXiv},
	author = {Meder, Björn and Sterf, Martha and Wu, Charley M. and Guggenmos, Matthias},
	year = {2025},
	keywords = {Dopamine, Generalization, Dopaminergic, Disease, Control (management), agentRevised, processed},
}
