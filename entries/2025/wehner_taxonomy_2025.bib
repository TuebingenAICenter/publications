@misc{wehner_taxonomy_2025,
	title = {Taxonomy, {Opportunities}, and {Challenges} of {Representation} {Engineering} for {Large} {Language} {Models}},
	shorttitle = {Taxonomy, {Opportunities}, and {Challenges} of {Representation} {Engineering}},
	url = {https://arxiv.org/abs/2502.19649},
	doi = {10.48550/arXiv.2502.19649},
	abstract = {Representation Engineering (RepE) has emerged as a promising paradigm for interpreting and steering Large Language Models (LLMs) by manipulating their internal representations. Despite its growing popularity, the field lacks a unified framework, making it difficult to compare methods, understand their capabilities, and identify open challenges. In this survey, we provide a comprehensive taxonomy of RepE, categorizing existing methods based on their core mechanisms: reading, intervening, and training. We systematically analyze the opportunities RepE offers for model interpretability, safety, and control, while also critically evaluating the current limitations and open research questions. By synthesizing the state-of-the-art, we aim to provide a structured foundation for future research in this rapidly evolving domain.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Wehner, Jan and Abdelnabi, Sahar and Tan, Daniel and Krueger, David and Fritz, Mario},
	year = {2025},
	keywords = {Representation (politics), Construct (python library), Key (lock), Pipeline (software), Strengths and weaknesses, TMLR},
}
