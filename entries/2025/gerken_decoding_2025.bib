@misc{gerken_decoding_2025,
	title = {Decoding movie content from neuronal population activity in the human medial temporal lobe},
	copyright = {CC BY 4.0},
	shorttitle = {Decoding movie content},
	url = {https://doi.org/10.7554/elife.106758},
	doi = {10.7554/elife.106758},
	abstract = {The human medial temporal lobe (MTL) is crucial for memory formation, yet the nature of the information represented by neuronal populations in this region remains debated. Here, we show that neuronal population activity in the human MTL contains rich information about the content of complex, naturalistic stimuli. We recorded single-unit activity from the MTL of neurosurgical patients while they watched movie clips. Using a deep learning-based decoding framework, we demonstrate that we can decode movie content from the population activity of MTL neurons with high accuracy. Our results suggest that the human MTL represents complex, naturalistic information in a distributed manner, providing a neural basis for the encoding of episodic memories.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {eLife},
	author = {Gerken, Franziska and Darcher, Alana and Gonçalves, Pedro J. and Rapp, Rachel and Elezi, Ismail and Niediek, Johannes and Kehl, M. S. and Reber, Thomas P. and Liebe, S. and Macke, Jakob H. and Mormann, Florian and Leal-Taixé, Laura},
	year = {2025},
	keywords = {Temporal lobe, Decoding methods, Content (measure theory), Population, Neuroscience, Psychology, Computer science, Medicine, Telecommunications, Mathematics},
}
