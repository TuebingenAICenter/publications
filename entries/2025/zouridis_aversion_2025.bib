@article{zouridis_aversion_2025,
	title = {Aversion {Encoding} and {Behavioral} {State} {Modulation} of {Physiologically} {Defined} {Cell} {Types} in the {Lateral} {Habenula}},
	issn = {0953-816X},
	url = {https://onlinelibrary.wiley.com/doi/full/10.1111/ejn.70302},
	doi = {10.1111/ejn.70302},
	abstract = {The lateral habenula (LHb) is a key node in the brain's reward and aversion circuitry, yet the functional diversity of its constituent cell types remains poorly understood. Here, we performed in vivo extracellular recordings in the mouse LHb and classified neurons into physiologically distinct types based on their firing patterns and waveforms. We found that these cell types exhibit differential responses to aversive stimuli and are modulated by the animal's behavioral state. Specifically, we identified a population of neurons that show robust aversion-related activity, which is further modulated by the animal's arousal level. Our findings provide a comprehensive characterization of LHb neuronal diversity and suggest that distinct cell types contribute differentially to the processing of aversive information and the regulation of behavioral states.},
	language = {en},
	urldate = {2025-06-01},
	journal = {European Journal of Neuroscience},
	publisher = {Wiley},
	author = {Zouridis, Ioannis S. and Schmors, Lisa and Lecca, Salvatore and Congiu, Mauro and Mameli, Manuel and Berens, Philipp and Monteiro, Fabio and Preston-Ferrer, Patricia and Burgalossi, Andrea},
	month = nov,
	year = {2025},
	keywords = {Bursting, Electrophysiology, Habenula, Stimulation, Premovement neuronal activity, Local field potential, Nerve net, Wakefulness, agentRevised, EJN},
}
