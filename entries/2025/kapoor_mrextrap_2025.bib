@article{kapoor_mrextrap_2025,
	title = {{MRExtrap}: {Longitudinal} {Aging} of {Brain} {MRIs} using {Linear} {Modeling} in {Latent} {Space}},
	shorttitle = {{MRExtrap}},
	url = {https://arxiv.org/abs/2508.19482},
	doi = {10.48550/arXiv.2508.19482},
	abstract = {Longitudinal analysis of brain magnetic resonance images (MRIs) is crucial for understanding neurodegenerative diseases and healthy aging. However, longitudinal datasets are often limited by irregular sampling, missing time points, and the high dimensionality of 3D medical images. We propose MRExtrap, a framework for longitudinal MRI analysis that learns a compact, disentangled latent representation of brain anatomy. By modeling aging as a linear trajectory in this latent space, MRExtrap enables the extrapolation of brain states to unseen time points and the interpolation of missing data. We demonstrate that our method outperforms existing approaches in predicting future brain states and provides interpretable insights into age-related morphological changes.},
	language = {en},
	urldate = {2025-05-14},
	journal = {arXiv},
	publisher = {arXiv},
	author = {Kapoor, Jatin and Macke, Jakob H. and Baumgartner, Christian F.},
	year = {2025},
	keywords = {ARXIV},
}
