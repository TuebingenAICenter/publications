@inproceedings{zhang_how_2025-1,
	title = {How does the optimizer implicitly bias the model merging loss landscape?},
	shorttitle = {How does the optimizer implicitly bias the model merging loss landscape?},
	url = {https://arxiv.org/pdf/2510.04686v1},
	doi = {10.48550/arXiv.2510.04686},
	abstract = {Model merging has emerged as a powerful technique to combine multiple fine-tuned models into a single, high-performing model without further training. Despite its empirical success, the theoretical understanding of why merging works remains limited. In this work, we investigate the role of the optimizer in shaping the loss landscape of merged models. We show that the optimizer's implicit bias—specifically, its tendency to converge to flat minima—plays a crucial role in the success of model merging. We provide a theoretical framework that characterizes how the optimizer's choice of hyperparameters and the geometry of the loss landscape influence the merging performance. Our findings suggest that merging is not merely a geometric operation but is deeply intertwined with the optimization process. We validate our theoretical insights with extensive experiments on various architectures and tasks, demonstrating that our framework can guide the selection of models for merging and improve the performance of merged models.},
	language = {en},
	urldate = {2025-06-01},
	booktitle = {The {Thirteenth} {International} {Conference} on {Learning} {Representations}},
	publisher = {arXiv},
	author = {Zhang, Chenxiang and Theus, Alexander and Teney, Damien and Orvieto, Antonio and Pang, Jun and Mauw, Sjouke},
	year = {2025},
	keywords = {Inference, Noise (video), Generalization, Task (project management), Process (computing), Function (biology), Base (topology), Scale (ratio), ICLR},
}
