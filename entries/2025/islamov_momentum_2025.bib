@inproceedings{islamov_momentum_2025,
	title = {Momentum {Adaptation} of {The} {NGN} {Step}-size},
	shorttitle = {Momentum {Adaptation} of {The} {NGN} {Step}-size},
	url = {https://arxiv.org/abs/2508.15071},
	doi = {10.48550/arXiv.2508.15071},
	abstract = {The Nesterov's Accelerated Gradient (NAG) method is a cornerstone of optimization in machine learning. Recently, the Nesterov's Gradient Normalization (NGN) method has been proposed as a robust alternative, which is invariant to the scale of the gradient. However, NGN requires a careful choice of the step-size, which is often difficult to tune. In this paper, we propose a momentum-based adaptation of the NGN step-size, which we call Momentum-NGN (M-NGN). We show that M-NGN is robust to the choice of the step-size and achieves state-of-the-art performance on a variety of optimization problems, including deep learning and convex optimization. We also provide a theoretical analysis of the convergence of M-NGN and show that it achieves the optimal convergence rate for smooth convex functions.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {arXiv},
	author = {Islamov, Rustem and Ajroldi, Nico and Orvieto, Antonio and Lucchi, Aurélien},
	year = {2025},
	keywords = {NEURIPS},
}
