@article{vogel_videogem_2025,
	title = {{VideoGEM}: {Training}-free {Action} {Grounding} in {Videos}},
	shorttitle = {{VideoGEM}},
	url = {https://openaccess.thecvf.com/content/CVPR2025/html/Vogel_VideoGEM_Training-free_Action_Grounding_in_Videos_CVPR_2025_paper.html},
	doi = {10.1109/CVPR59658.2025.00338},
	abstract = {Action grounding in videos aims to localize the temporal extent of an action described by a natural language query. While recent approaches have achieved impressive results, they often rely on extensive training on large-scale annotated datasets, which is costly and limits their generalization to unseen domains. In this work, we propose VideoGEM, a training-free approach for action grounding in videos. VideoGEM leverages the inherent capabilities of pre-trained vision-language models to align video segments with text queries without any task-specific training. Specifically, we introduce a novel mechanism that utilizes the geometric structure of the feature space to identify the most relevant video segments for a given query. Our method achieves competitive performance on standard benchmarks while being significantly more efficient and flexible than existing supervised methods. We demonstrate the effectiveness of VideoGEM on multiple datasets, showing that it can generalize well to unseen actions and domains.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
	publisher = {IEEE},
	author = {Vogel, Felix and Bousselham, Walid and Kukleva, Anna and Shvetsova, Nina and Kuehne, Hilde},
	year = {2025},
	keywords = {CVPR},
}
