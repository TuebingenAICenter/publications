@inproceedings{uselis_intermediate_2025,
	title = {Intermediate {Layer} {Classifiers} for {OOD} {Generalization}},
	shorttitle = {Intermediate {Layer} {Classifiers}},
	url = {https://arxiv.org/abs/2504.05461},
	doi = {10.48550/arXiv.2504.05461},
	abstract = {Deep neural networks often rely on spurious correlations, leading to poor out-of-distribution (OOD) generalization. While recent works have explored using intermediate layers to mitigate this, they often require architectural modifications or complex training objectives. In this work, we propose Intermediate Layer Classifiers (ILC), a simple yet effective approach that trains classifiers on intermediate representations of a pre-trained model. We show that ILCs can significantly improve OOD generalization by leveraging features that are less prone to spurious correlations. We provide theoretical insights into why ILCs work and demonstrate their effectiveness across various OOD benchmarks, including ImageNet-C, ImageNet-R, and DomainBed.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {International {Conference} on {Learning} {Representations}},
	publisher = {arXiv},
	author = {Uselis, Arnas and Oh, Seong Joon},
	year = {2025},
	keywords = {Spurious relationship, Layer (electronics), Generalization, Representation (politics), Distribution (mathematics), Perceptron, agentRevised, ICLR},
}
