@article{li_mix-ln_2025,
	title = {Mix-{LN}: {Unleashing} the {Power} of {Deeper} {Layers} by {Combining} {Pre}-{LN} and {Post}-{LN}},
	shorttitle = {Mix-{LN}},
	url = {https://arxiv.org/abs/2412.13795},
	abstract = {Layer Normalization (LN) is a critical component in Transformer architectures. Existing variants, primarily Pre-LN and Post-LN, exhibit a fundamental trade-off: Pre-LN is stable for training but often underperforms in terms of final model quality, while Post-LN achieves better performance but suffers from training instability, especially in deeper models. In this paper, we propose Mix-LN, a novel normalization strategy that dynamically combines the benefits of both Pre-LN and Post-LN. By integrating a learnable mixing mechanism, Mix-LN allows the model to adaptively leverage the stability of Pre-LN in early layers and the superior performance of Post-LN in deeper layers. We provide theoretical insights into why this combination is effective and conduct extensive experiments across various tasks, including language modeling and vision tasks. Our results demonstrate that Mix-LN consistently outperforms both Pre-LN and Post-LN, enabling the training of significantly deeper models without sacrificing stability or performance.},
	language = {en},
	urldate = {2025-05-14},
	journal = {International Conference on Learning Representations (ICLR)},
	publisher = {arXiv},
	author = {Li, Pengxiang and Yin, Lu and Liu, Shiwei},
	year = {2025},
	keywords = {ICLR},
}
