@inproceedings{movahedi_fixed-point_2025-1,
	title = {Fixed-{Point} {RNNs}: {From} {Diagonal} to {Dense} in a {Few} {Iterations}},
	shorttitle = {Fixed-{Point} {RNNs}},
	url = {https://arxiv.org/abs/2503.10799},
	abstract = {Recurrent Neural Networks (RNNs) are often criticized for their sequential nature, which hinders parallelization during training. While recent architectures like State Space Models (SSMs) have addressed this by leveraging linear recurrence, they often rely on diagonal transition matrices to maintain efficiency, which can limit their expressive power. In this work, we introduce Fixed-Point RNNs (FP-RNNs), a novel class of RNNs that bridge the gap between diagonal and dense transition matrices. By formulating the hidden state update as a fixed-point iteration, we show that FP-RNNs can approximate dense transitions using only a few iterations of a diagonal-like operator. We provide theoretical guarantees on the convergence and expressivity of our approach and demonstrate its effectiveness on a range of sequence modeling tasks, where FP-RNNs achieve competitive performance with dense models while maintaining the computational efficiency of diagonal ones.},
	language = {en},
	urldate = {2025-06-01},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	author = {Movahedi, S. and Sarnthein, F. and Cirone, N. Muca and Orvieto, Antonio},
	year = {2025},
	keywords = {agentRevised, processed, workshop, NEURIPS},
}
