@inproceedings{lin_scalable_2025,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Scalable {Gaussian} {Processes} with {Latent} {Kronecker} {Structure}},
	shorttitle = {Scalable {Gaussian} {Processes} with {Latent} {Kronecker} {Structure}},
	url = {https://proceedings.mlr.press/v267/lin25a.html},
	abstract = {Gaussian processes (GPs) are powerful tools for uncertainty quantification, but their computational cost scales cubically with the number of data points. While structured kernels (e.g., Kronecker products) can reduce this cost, they are often limited to grid-structured data. We introduce Latent Kronecker GPs (LK-GPs), a framework that learns a latent mapping from arbitrary input locations to a grid, enabling the use of efficient Kronecker algebra for non-grid data. We propose a variational inference approach to jointly learn the latent mapping and the GP hyperparameters. Our method achieves state-of-the-art performance on large-scale regression tasks while maintaining the benefits of exact GP inference in the latent space. We demonstrate the scalability and effectiveness of LK-GPs on datasets with up to one million observations.},
	language = {en},
	booktitle = {Proceedings of the 42nd {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Lin, J. A. and Ament, A. and Balandat, M. and Eriksson, D. and Hernández-Lobato, J. M. and Bakshy, E.},
	editor = {Singh, Aarti and Fazel, Maryam and Hsu, Daniel and Lacoste-Julien, Simon and Berkenkamp, Felix and Maharaj, Tegan and Wagstaff, Kiri and Zhu, Jerry},
	month = jul,
	year = {2025},
	keywords = {ICML},
}
