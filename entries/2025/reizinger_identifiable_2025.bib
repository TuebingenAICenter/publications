@inproceedings{reizinger_identifiable_2025,
	title = {Identifiable {Exchangeable} {Mechanisms} for {Causal} {Structure} and {Representation} {Learning}},
	shorttitle = {Identifiable {Exchangeable} {Mechanisms}},
	url = {https://arxiv.org/abs/2406.14302},
	doi = {10.48550/arxiv.2406.14302},
	abstract = {We study the problem of learning causal representations from observational data. A key challenge in this domain is identifiability: under what conditions can we recover the true causal variables and their structural relationships from data? We introduce the framework of exchangeable mechanisms, a class of causal models where the causal mechanisms are invariant under permutations of the causal variables. We show that this symmetry allows for the identifiability of the causal structure and the underlying representations up to permutation and element-wise transformations. We provide theoretical guarantees for identifiability and demonstrate the effectiveness of our approach on synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-22},
	booktitle = {The {Thirteenth} {International} {Conference} on {Learning} {Representations} ({ICLR})},
	publisher = {arXiv},
	author = {Reizinger, Patrik and Guo, Siyuan and Huszár, Ferenc and Schölkopf, Bernhard and Brendel, Wieland},
	month = apr,
	year = {2025},
	keywords = {Representation (politics), Causal structure, Computer science, Cognitive science, Artificial intelligence, Cognitive psychology, Psychology, Physics, Political science, processed, MPI-IS, ELLIS Institute Tübingen, Representation Causal structure, ICLR},
}
