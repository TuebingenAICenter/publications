@misc{chintaluri_ion_2025,
	title = {An ion channel omnimodel for standardized biophysical neuron modelling},
	shorttitle = {An ion channel omnimodel},
	url = {https://www.biorxiv.org/content/10.1101/2025.10.03.680368v1},
	doi = {10.1101/2025.10.03.680368},
	abstract = {Biophysical neuron models are essential for understanding the computational principles of the brain. However, the diversity of ion channel models and the lack of standardized, interoperable formats hinder the reproducibility and scalability of these models. Here, we present the 'omnimodel', a unified, standardized framework for ion channel modelling. The omnimodel integrates a vast library of ion channel kinetics into a single, machine-readable format, enabling seamless integration into existing simulation environments. We demonstrate the utility of the omnimodel by reproducing a wide range of neuronal firing patterns and by facilitating the automated inference of ion channel parameters from experimental data. Our approach provides a foundation for large-scale, reproducible biophysical modelling and paves the way for more robust and scalable computational neuroscience.},
	language = {en},
	urldate = {2025-06-01},
	publisher = {bioRxiv},
	author = {Chintaluri, Chaitanya and Podlaski, William F. and Bozelos, Panagiotis and Gonçalves, Pedro J. and Lueckmann, Jan-Matthis and Macke, Jakob H. and Vogels, Tim P.},
	month = oct,
	year = {2025},
	keywords = {Ion channel, Channel (broadcasting), Inference, Formalism (music), Ion, agentRevised, processed},
}
