@misc{sreckovic_revisiting_2025,
	title = {Revisiting the {Adam}-{SGD} gap in language modeling: {Is} your batch size the problem?},
	shorttitle = {Revisiting the {Adam}-{SGD} gap in language modeling},
	url = {https://arxiv.org/pdf/2505.21829},
	doi = {10.48550/arXiv.2505.21829},
	abstract = {The Adam optimizer is the de facto standard for training large language models (LLMs), while SGD is often preferred for smaller models or specific tasks. A common observation is that Adam often outperforms SGD in terms of final performance, a phenomenon often attributed to Adam's adaptive learning rate mechanism. In this work, we revisit this gap and show that the performance difference between Adam and SGD is largely driven by the choice of batch size. We demonstrate that when the batch size is appropriately tuned, SGD can match or even outperform Adam in language modeling tasks. We provide a theoretical analysis of the Adam-SGD gap and show that the gap is related to the curvature of the loss landscape and the noise in the gradient estimates. Our findings suggest that the perceived superiority of Adam may be partly due to its robustness to the choice of batch size, rather than an inherent advantage in optimization performance.},
	language = {en},
	urldate = {2025-05-22},
	publisher = {arXiv},
	author = {Srećković, T. and Geiping, J. and Orvieto, A.},
	year = {2025},
	keywords = {ARXIV},
}
