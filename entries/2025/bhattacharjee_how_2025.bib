@inproceedings{bhattacharjee_how_2025,
	title = {How to safely discard features based on aggregate {SHAP} values},
	shorttitle = {How to safely discard features},
	url = {https://arxiv.org/abs/2503.23111},
	doi = {10.48550/arxiv.2503.23111},
	abstract = {SHAP values are a popular tool for explaining machine learning models. A common practice is to use aggregate SHAP values (e.g., the mean absolute SHAP value) to rank features and discard those with low importance. However, it is not well understood when this procedure is safe, i.e., when it does not significantly degrade the model's performance. In this paper, we provide a theoretical framework to analyze the safety of feature discarding based on aggregate SHAP values. We show that for linear models, the procedure is safe under certain conditions on the feature distribution and the model coefficients. We also provide counterexamples where the procedure fails, and we propose a modified procedure that is more robust. Our theoretical findings are supported by experiments on synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-06-01},
	booktitle = {Proceedings of the 38th {Conference} on {Learning} {Theory}},
	publisher = {PMLR},
	author = {Bhattacharjee, Robi and Frohnapfel, Karolin and von Luxburg, Ulrike},
	year = {2025},
	keywords = {Aggregate (composite), Feature (linguistics), Soundness, Value (mathematics), Function (biology), Product (mathematics), agentRevised, processed, COLT},
}
