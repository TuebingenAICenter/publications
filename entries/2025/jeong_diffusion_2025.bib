@inproceedings{jeong_diffusion_2025,
	title = {Diffusion {Classifiers} {Understand} {Compositionality}, but {Conditions} {Apply}},
	shorttitle = {Diffusion {Classifiers} {Understand} {Compositionality}},
	url = {https://arxiv.org/abs/2505.17955},
	abstract = {Diffusion models have recently emerged as powerful generative tools, but their potential as discriminative classifiers remains underexplored. In this work, we investigate the compositional reasoning capabilities of diffusion classifiers—classifiers derived from pre-trained diffusion models. We find that diffusion classifiers exhibit strong compositional understanding, often outperforming standard discriminative models on compositional benchmarks. However, this performance is highly sensitive to the choice of conditioning and the sampling process. We identify key conditions under which diffusion classifiers excel and where they struggle, providing insights into the interplay between generative modeling and compositional classification. Our findings suggest that while diffusion models are promising for compositional tasks, careful design of the classification pipeline is essential to fully leverage their capabilities.},
	language = {en},
	urldate = {2025-06-01},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {University of Tübingen},
	author = {Jeong, Yujin and Uselis, Arnas and Oh, Seong Joon and Rohrbach, Anna},
	year = {2025},
	keywords = {agentRevised, processed, University of Tübingen, NEURIPS},
}
