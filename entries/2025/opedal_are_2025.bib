@inproceedings{opedal_are_2025,
	title = {Are {Language} {Models} {Efficient} {Reasoners}? {A} {Perspective} from {Logic} {Programming}},
	shorttitle = {Are {Language} {Models} {Efficient} {Reasoners}?},
	url = {https://arxiv.org/abs/2510.25626},
	abstract = {We investigate the efficiency of language models (LMs) as reasoners by framing reasoning as a search problem in a logic programming context. We show that LMs can be viewed as search heuristics for logic programs, and we analyze the computational complexity of this search. We find that LMs are often inefficient reasoners, as they struggle to explore the search space effectively, leading to exponential time complexity in the worst case. We propose a framework for improving the efficiency of LMs as reasoners by incorporating logic programming techniques, such as pruning and backtracking, and we demonstrate the effectiveness of our approach on several reasoning tasks.},
	language = {en},
	urldate = {2025-06-01},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 38},
	publisher = {MPI-IS},
	author = {Opedal, A. and Zengaffinen, Y. and Shirakami, H. and Pasti, C. and Sachan, M. and Saparov, A. and Cotterell, R. and Schölkopf, B.},
	month = dec,
	year = {2025},
	keywords = {agentRevised, MPI-IS, processed, NEURIPS},
}
