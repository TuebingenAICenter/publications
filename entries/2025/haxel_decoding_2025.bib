@article{haxel_decoding_2025,
	title = {Decoding {Motor} {Excitability} in {TMS} using {EEG}-{Features}: {An} {Exploratory} {Machine} {Learning} {Approach}},
	issn = {1558-0210},
	url = {https://ieeexplore.ieee.org/document/10795227},
	doi = {10.1109/TNSRE.2024.3516393},
	abstract = {Transcranial magnetic stimulation (TMS) is a powerful tool for non-invasive brain stimulation, but its effects are highly variable. This variability is partly due to fluctuations in the excitability of the motor cortex. Real-time monitoring of these fluctuations could allow for closed-loop TMS protocols that adapt stimulation parameters to the current state of the brain. Here, we investigate whether features extracted from the electroencephalogram (EEG) recorded during TMS can be used to decode the excitability of the motor cortex. We recorded EEG during TMS of the motor cortex in 15 healthy participants and used machine learning models to predict the amplitude of the motor evoked potential (MEP), a proxy for motor excitability. We found that EEG features, particularly in the alpha and beta frequency bands, contain information about the excitability of the motor cortex. Our models achieved a significant, albeit modest, prediction accuracy, suggesting that EEG-based decoding of motor excitability is feasible. We discuss the implications of these findings for the development of closed-loop TMS protocols and the challenges that remain to be addressed.},
	language = {en},
	journal = {IEEE Transactions on Neural Systems and Rehabilitation Engineering},
	publisher = {IEEE},
	author = {Haxel, Lisa and Ahola, Oskari and Belardinelli, Paolo and Ermolova, Maria and Humaidan, Dania and Macke, Jakob H. and Ziemann, Ulf},
	year = {2025},
	keywords = {processed, University of Tübingen, TNSRE},
}
