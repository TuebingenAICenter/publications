@inproceedings{li_owlore_2025,
	title = {{OwLore}: {Outlier}-weighed {Layerwise} {Sampled} {Low}-{Rank} {Projection} for {Memory}-{Efficient} {LLM} {Fine}-tuning},
	shorttitle = {{OwLore}},
	url = {https://arxiv.org/abs/2405.18380},
	abstract = {Large Language Models (LLMs) have demonstrated remarkable capabilities across various domains. However, fine-tuning these models is computationally expensive, often requiring significant memory resources. Parameter-Efficient Fine-Tuning (PEFT) methods, such as Low-Rank Adaptation (LoRA), have been proposed to mitigate this issue by updating only a small subset of parameters. Despite their success, LoRA and its variants often struggle to capture the full complexity of the model's weight updates, potentially limiting performance. In this paper, we propose OwLore, an Outlier-weighed Layerwise sampled Low-rank projection method for memory-efficient LLM fine-tuning. OwLore leverages the observation that weight updates are often sparse and contain significant outliers. By identifying and prioritizing these outliers, OwLore achieves more effective parameter updates with a smaller memory footprint. We evaluate OwLore on a range of LLM fine-tuning tasks and demonstrate that it consistently outperforms existing PEFT methods in terms of both performance and memory efficiency.},
	language = {en},
	urldate = {2025-05-22},
	booktitle = {The {Thirteenth} {International} {Conference} on {Learning} {Representations}},
	publisher = {arXiv},
	author = {Li, Pengxiang and Yin, Lu and Gao, Xiaowei and Liu, Shiwei},
	year = {2025},
	keywords = {ACL, ICLR},
}
