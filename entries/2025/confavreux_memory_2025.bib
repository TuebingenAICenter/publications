@misc{confavreux_memory_2025,
	title = {Memory by a thousand rules: {Automated} discovery of functional multi-type plasticity rules reveals variety and degeneracy at the heart of learning},
	shorttitle = {Memory by a thousand rules},
	url = {https://www.biorxiv.org/content/10.1101/2025.05.28.656584v2},
	doi = {10.1101/2025.05.28.656584},
	abstract = {Synaptic plasticity is the primary mechanism of learning and memory in the brain. Over several decades, experimental and theoretical studies have revealed many types of plasticity, categorized by the properties of the pre- and postsynaptic neurons they involve. However, distinct types are typically studied in isolation, yet they always interact. This interaction has never been examined at scale because of the astronomical number of potential mechanisms. Here, we present a mathematical framework and an automated software tool to discover sets of rules – encompassing excitatory, inhibitory, and homeostatic plasticity – that enable a specific circuit function. We apply this tool to the problem of learning associative memory in a spiking recurrent neural network. We discover thousands of distinct and functional multi-type rule-sets, which satisfy the task while maintaining biological plausibility. These rule-sets differ substantially in their constituent rules, but collectively form a low-dimensional manifold in the space of all possible mechanisms. Notably, different rule-sets achieve a functional memory through diverse circuit mechanisms, where different synapse types contribute differently to memory storage and circuit stability. Our findings reveal a fundamental degeneracy in the plasticity rules that can support learning, suggesting that the brain might employ a wide variety of solutions to the same functional challenge.},
	language = {en},
	urldate = {2025-06-01},
	publisher = {Cold Spring Harbor Laboratory},
	author = {Confavreux, Basile and Harrington, Zoe P. M. and Kania, M. and Ramesh, Poornima and Krouglova, Anastasia N. and Bozelos, Panagiotis and Macke, Jakob H. and Saxe, Andrew and Gonçalves, Pedro J. and Vogels, Tim P.},
	month = may,
	year = {2025},
	keywords = {Variety (cybernetics), Degeneracy (biology), Computer science, Type (biology), Artificial intelligence, Cognitive science, Psychology, Machine learning, Neuroscience, Cognitive psychology, Biology, Bioinformatics, Paleontology, agentRevised, processed},
}
