@inproceedings{forte_contact-aware_2025,
	title = {Contact-{Aware} {Refinement} of {Human} {Pose} {Pseudo}-{Ground} {Truth} via {Bioimpedance} {Sensing}},
	url = {https://openaccess.thecvf.com/content/ICCV2025/html/Forte_Contact-Aware_Refinement_of_Human_Pose_Pseudo-Ground_Truth_via_Bioimpedance_Sensing_ICCV_2025_paper.html},
	doi = {https://doi.org/10.48550/arxiv.2512.04862},
	abstract = {Estimating accurate 3D human pose from monocular video is a fundamental task in computer vision. While large-scale datasets have enabled significant progress, they often rely on pseudo-ground truth (PGT) generated by multi-view optimization, which can be inaccurate, especially in the presence of self-occlusion or complex contact. In this paper, we introduce BioTUCH, a novel approach to refine human pose PGT by leveraging bioimpedance sensing. Bioimpedance provides a direct, contact-aware signal that is independent of visual occlusions. We propose a method to integrate this signal into the optimization process, effectively correcting pose errors that are invisible to cameras. Our experiments demonstrate that BioTUCH significantly improves the accuracy of PGT, leading to better performance in downstream pose estimation tasks. We also release a new dataset, BioTUCH-Dataset, containing synchronized video and bioimpedance data to facilitate future research in this direction.},
	language = {en},
	urldate = {2025-06-01},
	booktitle = {Proceedings of the {IEEE}/{CVF} {International} {Conference} on {Computer} {Vision} ({ICCV})},
	publisher = {IEEE},
	author = {Forte, Maria-Paola and Athanasiou, Nikos and Ballardini, Giulia and Bartels, Jan Ulrich and Kuchenbecker, Katherine J. and Black, Michael J.},
	year = {2025},
	keywords = {Pose, Motion capture, 3D pose estimation, Estimator, Wearable computer, Reprojection error, RGB color model, Measure (data warehouse), Ground truth, agentRevised, processed, ICCV},
}
