@misc{abdelnabi_firewalls_2025,
	title = {Firewalls to {Secure} {Dynamic} {LLM} {Agentic} {Networks}},
	shorttitle = {Firewalls to {Secure} {Dynamic} {LLM} {Agentic} {Networks}},
	url = {https://arxiv.org/abs/2502.01822},
	doi = {10.48550/arxiv.2502.01822},
	abstract = {Large Language Model (LLM) agents are increasingly being deployed in complex, dynamic networks to automate tasks. However, these agentic networks are vulnerable to various security threats, including prompt injection, unauthorized tool usage, and data exfiltration. In this paper, we introduce a firewall framework designed to secure dynamic LLM agentic networks. Our firewall operates by intercepting and inspecting the communication between agents and their environment, enforcing security policies in real-time. We demonstrate the effectiveness of our approach through a series of experiments, showing that our firewall can mitigate a wide range of attacks while maintaining the functionality and performance of the agentic networks.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Abdelnabi, Sahar and Gomaa, Amr and Bagdasarian, Eugene and Kristensson, Per Ola and Shokri, Reza},
	month = feb,
	year = {2025},
	keywords = {Computer security, Computer science, Internet privacy, Computer network, ARXIV},
}
