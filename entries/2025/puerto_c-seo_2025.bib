@inproceedings{puerto_c-seo_2025,
	title = {C-{SEO} {Bench}: {Does} {Conversational} {SEO} {Work}?},
	shorttitle = {C-{SEO} {Bench}},
	url = {https://arxiv.org/abs/2506.11097},
	abstract = {The rise of conversational search engines (CSEs) like ChatGPT, Perplexity, and Gemini has fundamentally changed how users discover information. This shift has given birth to Conversational Search Engine Optimization (C-SEO), the practice of optimizing content to be cited by these models. However, the field lacks a systematic way to evaluate C-SEO strategies. In this work, we introduce C-SEO Bench, the first comprehensive benchmark to evaluate C-SEO. We curate a dataset of 1,000 queries across diverse domains and develop a robust evaluation framework that measures the impact of various optimization techniques on citation rates. Our findings reveal that while some traditional SEO practices remain effective, others are counterproductive in the conversational era. We provide a detailed analysis of the factors influencing citation, offering actionable insights for content creators and researchers. We release our dataset, evaluation code, and a leaderboard to foster further research in this emerging field.},
	language = {en},
	urldate = {2025-06-01},
	booktitle = {{NeurIPS} 2025 {Datasets} \& {Benchmarks} {Track}},
	publisher = {arXiv},
	author = {Puerto, Haritz and Gubri, Martin and Green, Tommaso and Oh, Seong Joon and Yun, Sangdoo},
	year = {2025},
	keywords = {agentRevised, processed, NEURIPS},
}
