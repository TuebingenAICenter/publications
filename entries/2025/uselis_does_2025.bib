@inproceedings{uselis_does_2025,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Does {Data} {Scaling} {Lead} to {Visual} {Compositional} {Generalization}?},
	shorttitle = {Does {Data} {Scaling} {Lead} to {Visual} {Compositional} {Generalization}?},
	url = {https://arxiv.org/abs/2507.07102},
	abstract = {Compositional generalization—the ability to recognize novel combinations of known concepts—is a hallmark of human intelligence. While deep learning models have achieved remarkable success in various tasks, their ability to generalize compositionally remains a subject of intense debate. A common hypothesis is that scaling data and model size will eventually lead to emergent compositional generalization. In this work, we systematically investigate this hypothesis in the visual domain. We curate a large-scale dataset of compositional visual tasks and evaluate a wide range of vision models, from small-scale CNNs to large-scale Vision Transformers (ViTs) trained on billions of images. Our results show that while scaling improves performance on standard benchmarks, it does not necessarily lead to systematic compositional generalization. We find that even the largest models struggle to generalize to novel combinations of concepts, suggesting that scaling alone may not be sufficient to bridge the gap between current AI and human-like compositional reasoning.},
	language = {en},
	urldate = {2025-07-17},
	booktitle = {Proceedings of the 42nd {International} {Conference} on {Machine} {Learning}},
	publisher = {University of Tübingen},
	author = {Uselis, Arnas and Dittadi, Andrea and Oh, Seong Joon},
	year = {2025},
	keywords = {ICML},
}
