@misc{gunther_informative_2025,
	title = {Informative {Post}-{Hoc} {Explanations} {Only} {Exist} for {Simple} {Functions}},
	url = {http://arxiv.org/abs/2508.11441},
	abstract = {Post-hoc explanation methods are widely used to interpret complex machine learning models. However, it is often unclear whether these explanations are faithful to the underlying model or if they are merely artifacts of the explanation method itself. In this paper, we provide a theoretical framework to study the informativeness of post-hoc explanations. We show that for a wide class of explanation methods, informative explanations—defined as explanations that allow for a reconstruction of the model's predictions—only exist if the underlying model is 'simple' in a specific sense. Our results suggest that for complex models, post-hoc explanations may be inherently limited in their ability to provide meaningful insights, potentially leading to a false sense of interpretability.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {University of Tübingen},
	author = {Günther, Eric and Szabados, Balázs and Bhattacharjee, Robi and Bordt, Sebastian and von Luxburg, Ulrike},
	year = {2025},
	keywords = {agentRevised},
}
