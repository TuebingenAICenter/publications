@inproceedings{zhu_looking-ahead_2025,
	title = {Looking-{Ahead} {Reasoning} on {Learning} {Platforms}},
	shorttitle = {Looking-{Ahead} {Reasoning}},
	url = {https://arxiv.org/abs/2511.14745},
	abstract = {Learning platforms often rely on algorithmic recommendations to guide users through educational content. While these systems are typically designed to optimize immediate engagement or performance, they may inadvertently shape the long-term learning trajectories of users. In this work, we study the impact of recommendation policies on user learning outcomes by modeling the interaction as a sequential decision-making problem. We introduce a framework for 'looking-ahead' reasoning, where the platform anticipates the future consequences of its recommendations on the user's knowledge state. We characterize the conditions under which looking-ahead policies improve long-term learning compared to myopic baselines and provide empirical evidence on synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-06-01},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {MPI-IS},
	author = {Zhu, H. and Zrnic, T. and Mendler-Dünner, C.},
	year = {2025},
	keywords = {agentRevised, NEURIPS},
}
