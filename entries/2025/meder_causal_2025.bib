@article{meder_causal_2025,
	title = {Causal analysis of absolute and relative risk reductions},
	issn = {0022-2496},
	shorttitle = {Causal analysis of absolute and relative risk reductions},
	url = {https://doi.org/10.1016/j.jmp.2025.102942},
	doi = {10.1016/j.jmp.2025.102942},
	abstract = {Absolute risk reduction (ARR) and relative risk reduction (RRR) are two common metrics for communicating the effectiveness of medical treatments. Despite their importance, they are often misunderstood, leading to biased decision-making. In this paper, we provide a formal causal analysis of ARR and RRR using the framework of structural causal models. We show that both metrics are functions of the causal effect of a treatment on an outcome, but they differ in their sensitivity to the baseline risk. We demonstrate that RRR is a ratio of causal effects, whereas ARR is a difference of causal effects. We further show that the choice between ARR and RRR depends on the underlying causal structure of the decision problem. Our analysis provides a theoretical foundation for understanding the conditions under which ARR and RRR are appropriate and how they should be interpreted in clinical practice.},
	language = {en},
	urldate = {2025-05-22},
	journal = {Journal of Mathematical Psychology},
	publisher = {Elsevier},
	author = {Meder, Björn and Wu, Charley M. and Rebitschek, Felix G.},
	year = {2025},
	keywords = {Absolute (philosophy), Mathematics, Absolute risk reduction, Econometrics, Statistics, Philosophy, Epistemology, Confidence interval, Absolute (philosophy) Absolute risk reduction, agentRevised, processed, JMP},
}
