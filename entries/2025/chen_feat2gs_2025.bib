@inproceedings{chen_feat2gs_2025,
	title = {Feat2GS: {Probing} {Visual} {Foundation} {Models} with {Gaussian} {Splatting}},
	shorttitle = {Feat2GS},
	url = {https://arxiv.org/abs/2412.09606},
	doi = {10.1109/cvpr52734.2025.00595},
	abstract = {Visual Foundation Models (VFMs) have demonstrated remarkable capabilities in understanding 2D images. However, their potential for 3D scene understanding remains under-explored. In this paper, we introduce Feat2GS, a novel framework that probes the 3D representation capabilities of VFMs by lifting their 2D features into 3D space using 3D Gaussian Splatting (3DGS). Unlike existing methods that rely on explicit 3D supervision or complex multi-view consistency, Feat2GS leverages the inherent feature consistency of VFMs to optimize a 3D feature field. We demonstrate that the lifted 3D features are not only consistent across views but also preserve the semantic richness of the original 2D features. We show that Feat2GS can be used for a variety of downstream tasks, including 3D semantic segmentation, 3D object localization, and 3D scene editing, all without any task-specific fine-tuning. Our results suggest that VFMs already possess a strong understanding of 3D geometry and semantics, which can be effectively unlocked through 3DGS.},
	language = {en},
	urldate = {2025-05-22},
	booktitle = {Proceedings of the {IEEE}/{CVF} {Conference} on {Computer} {Vision} and {Pattern} {Recognition} ({CVPR})},
	publisher = {IEEE},
	author = {Chen, Yue and Chen, Xingyu and Chen, Anpei and Pons-Moll, Gerard and Xiu, Yuliang},
	year = {2025},
	keywords = {Foundation (evidence), Computer science, Gaussian, Geography, Physics, Archaeology, processed, University of Tübingen, MPI-IS, agentRevised, Artificial intelligence, Computer graphics (images), Computer vision, CVPR},
}
