@inproceedings{moss_fnope_2025,
	title = {{FNOPE}: {Simulation}-based inference on function spaces with {Fourier} {Neural} {Operators}},
	shorttitle = {{FNOPE}},
	url = {https://arxiv.org/abs/2505.22573},
	doi = {10.48550/arxiv.2505.22573},
	abstract = {Simulation-based inference (SBI) aims to perform Bayesian inference on parameters of complex simulators where the likelihood is intractable. While traditional SBI methods operate on finite-dimensional parameter spaces, many scientific problems involve inferring latent functions, such as fields or processes. Current approaches for function-space inference often rely on discretization, which can lead to high-dimensional parameter spaces and poor scaling with resolution. We introduce FNOPE (Fourier Neural Operator Posterior Estimation), a novel framework for SBI on function spaces. FNOPE leverages the resolution-invariance and efficient spectral representation of Fourier Neural Operators to learn posterior distributions over function spaces directly. We demonstrate that FNOPE achieves state-of-the-art performance on several challenging benchmarks, including inferring latent fields in partial differential equations and stochastic processes, while maintaining computational efficiency and resolution-invariance.},
	language = {en},
	urldate = {2025-05-22},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 38},
	publisher = {arXiv},
	author = {Moss, G. and Muhle, L. S. and Drews, R. and Macke, J. H. and Schröder, C.},
	month = dec,
	year = {2025},
	keywords = {Inference, Frequentist inference, Bayesian inference, Fiducial inference, Statistical inference, Benchmark (surveying), Parametric statistics, Operator (biology), Matching (statistics), agentRevised, processed, NEURIPS},
}
