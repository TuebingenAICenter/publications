@inproceedings{schneider_generative_2025,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Generative {Intervention} {Models} for {Causal} {Perturbation} {Modeling}},
	url = {https://proceedings.mlr.press/v267/schneider25a.html},
	doi = {10.48550/arxiv.2411.14003},
	abstract = {Causal models are typically learned from observational data, but their primary utility lies in predicting the effects of interventions. While structural causal models (SCMs) provide a rigorous framework for this, they often rely on strong parametric assumptions or require access to the full causal graph. In this work, we propose Generative Intervention Models (GIMs), a framework for learning causal perturbation models that can predict the effects of interventions without requiring a fully specified SCM. GIMs leverage generative modeling to learn the conditional distribution of variables under intervention, conditioned on the intervention target and value. We demonstrate that GIMs can effectively model causal perturbations in complex, high-dimensional settings, and provide theoretical guarantees on their performance. We evaluate our approach on a range of synthetic and real-world datasets, showing that GIMs outperform existing methods in predicting the effects of interventions.},
	language = {en},
	urldate = {2025-07-24},
	booktitle = {Proceedings of the 42nd {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Schneider, Nora and Lorch, Lars and Kilbertus, Niki and Schölkopf, Bernhard and Krause, Andreas},
	editor = {Singh, Aarti and Fazel, Maryam and Hsu, Daniel and Lacoste-Julien, Simon and Berkenkamp, Felix and Maharaj, Tegan and Wagstaff, Kiri and Zhu, Jerry},
	month = jul,
	year = {2025},
	keywords = {Generative grammar, Intervention (counseling), Perturbation (astronomy), Computer science, Psychology, Geography, Artificial intelligence, Physics, ELLIS Institute Tübingen, MPI-IS, processed, ICML},
}
