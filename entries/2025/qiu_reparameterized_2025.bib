@inproceedings{qiu_reparameterized_2025,
	title = {Reparameterized {LLM} {Training} via {Orthogonal} {Equivalence} {Transformation}},
	shorttitle = {Reparameterized {LLM} {Training}},
	url = {https://is.mpg.de/ei/publications/qiuetal25b},
	doi = {10.48550/arxiv.2506.08001},
	abstract = {Large language model (LLM) training is often hindered by the ill-conditioning of weight matrices, which can lead to unstable gradients and slow convergence. In this paper, we propose a novel reparameterization technique, Orthogonal Equivalence Transformation (OET), to improve the conditioning of weight matrices during training. OET leverages the fact that the output of a linear layer is invariant to orthogonal transformations of the weight matrix, provided the input is transformed accordingly. By maintaining an orthogonal basis for the weight matrix, we can effectively decouple the scale and direction of the weights, leading to more stable and efficient training. We demonstrate the effectiveness of OET on a range of LLM training tasks, showing that it consistently improves convergence speed and final performance compared to standard training methods.},
	language = {en},
	urldate = {2025-06-18},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 38 ({NeurIPS} 2025)},
	publisher = {MPI-IS},
	author = {Qiu, Z. and Buchholz, S. and Xiao, T. and Dax, M. and Schölkopf, B. and Liu, W.},
	month = dec,
	year = {2025},
	keywords = {Equivalence (formal languages), Scalability, Orthogonal transformation, Training (meteorology), Training set, Transformation (genetics), Function (biology), agentRevised, processed, NEURIPS},
}
