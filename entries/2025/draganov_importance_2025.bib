@inproceedings{draganov_importance_2025,
	title = {On the {Importance} of {Embedding} {Norms} in {Self}-{Supervised} {Learning}},
	shorttitle = {On the {Importance} of {Embedding} {Norms} in {Self}-{Supervised} {Learning}},
	url = {https://openreview.net/forum?id=L8YhRgEcZp},
	abstract = {Self-supervised learning (SSL) methods often rely on contrastive or non-contrastive objectives to learn representations. While the role of the alignment and uniformity of embeddings is well-studied, the role of the embedding norm is often overlooked. In this work, we investigate the importance of embedding norms in SSL. We show that the norm of the embeddings is not just a nuisance parameter but carries significant information about the data. We demonstrate that standard SSL methods often suffer from a collapse of the embedding norms, which can be mitigated by simple architectural or objective modifications. We further show that preserving the norm information leads to improved performance on downstream tasks and better robustness to distribution shifts.},
	language = {en},
	urldate = {2025-07-23},
	booktitle = {Proceedings of the 42nd {International} {Conference} on {Machine} {Learning}},
	author = {Draganov, Alexander and Vadgama, Sagar and Damrich, Sebastian and Böhm, Jan Niklas and Maes, Lukas and Kobak, Dmitry and Bekkers, Erik},
	month = jul,
	year = {2025},
	keywords = {ICML},
}
