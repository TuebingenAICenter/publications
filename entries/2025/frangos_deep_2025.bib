@article{frangos_deep_2025,
	title = {Deep learning image analysis for continuous single-cell imaging of dynamic processes in {Plasmodium} falciparum-infected erythrocytes},
	copyright = {© 2025 The Author(s)},
	issn = {2399-3642},
	shorttitle = {Deep learning image analysis for continuous single-cell imaging},
	url = {https://www.nature.com/articles/s42003-025-07894-3},
	doi = {10.1038/s42003-025-07894-3},
	abstract = {The malaria parasite Plasmodium falciparum undergoes complex morphological changes during its intraerythrocytic development. Continuous live-cell imaging is essential to capture these dynamic processes, but the resulting large-scale datasets require automated analysis. Here, we present a deep learning-based pipeline for the automated segmentation and tracking of P. falciparum-infected erythrocytes in time-lapse microscopy data. Our approach, based on a U-Net architecture, achieves high accuracy in segmenting infected cells and enables the quantification of parasite growth and morphological transitions over time. We demonstrate the utility of our method by characterizing the dynamics of parasite egress and invasion, providing new insights into the timing and variability of these critical steps in the parasite life cycle.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Communications Biology},
	publisher = {Nature Portfolio},
	author = {Frangos, S. M. and Damrich, S. and Gueiber, D. and Sanchez, C. P. and Wiedemann, P. and Schwarz, U. S. and Lanzer, M.},
	month = mar,
	year = {2025},
	keywords = {COMMBIO},
}
