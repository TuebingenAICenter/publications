@inproceedings{sonthalia_rankability_2025,
	title = {On the {Rankability} of {Visual} {Embeddings}},
	shorttitle = {On the {Rankability} of {Visual} {Embeddings}},
	url = {https://arxiv.org/abs/2507.03683},
	abstract = {Visual embeddings are ubiquitous in modern computer vision, serving as the foundation for tasks ranging from image retrieval to zero-shot classification. While these embeddings are often evaluated on downstream tasks, there is a lack of understanding of their intrinsic properties. In this work, we introduce the concept of rankability: the extent to which the relative order of similarities between embeddings aligns with the relative order of semantic distances. We propose a metric to quantify rankability and demonstrate that it is a strong predictor of downstream performance across various tasks and architectures. We further analyze the factors that influence rankability, such as the training objective and the data distribution, and show that rankability can be improved through simple post-processing techniques. Our findings provide a new perspective on the evaluation and design of visual embeddings.},
	language = {en},
	urldate = {2025-07-15},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {arXiv},
	author = {Sonthalia, Ankit and Uselis, Arnas and Oh, Seong Joon},
	year = {2025},
	keywords = {agentRevised, processed, NEURIPS},
}
