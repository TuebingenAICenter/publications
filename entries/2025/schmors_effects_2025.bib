@article{schmors_effects_2025,
	title = {Effects of corticothalamic feedback depend on visual responsiveness and stimulus type},
	copyright = {© 2025 The Author(s).},
	issn = {2589-0042},
	url = {https://www.cell.com/iscience/fulltext/S2589-0042(25)00742-4},
	doi = {10.1016/j.isci.2025.112481},
	abstract = {The primary visual cortex (V1) sends massive feedback to the dorsal lateral geniculate nucleus (dLGN), the thalamic relay of visual information. While this corticothalamic (CT) feedback is known to modulate dLGN activity, its functional role remains debated. Here, we show that the impact of CT feedback on dLGN responses in mice is highly heterogeneous and depends on the visual responsiveness of dLGN neurons and the stimulus type. We find that CT feedback enhances the responses of dLGN neurons to drifting gratings, but this effect is restricted to neurons with high visual responsiveness. In contrast, responses to naturalistic stimuli are largely unaffected by CT feedback. Our results suggest that CT feedback acts as a gain control mechanism that is selectively recruited depending on the stimulus statistics and the functional properties of the target neurons.},
	language = {en},
	urldate = {2025-07-08},
	journal = {iScience},
	publisher = {Elsevier},
	author = {Schmors, Lisa and Kotkat, Ann H. and Bauer, Yannik and Huang, Ziwei and Crombie, Davide and Meyerolbersleben, Lukas and Sokoloski, Sacha and Berens, Philipp and Busse, Laura},
	month = jun,
	year = {2025},
	keywords = {Stimulus (psychology), Neuroscience, Psychology, Cognitive psychology},
}
