@article{haxel_personalized_2025,
	title = {Personalized real-time inference of momentary excitability from human {EEG}},
	issn = {1053-8119},
	shorttitle = {Personalized real-time inference of momentary excitability},
	url = {https://doi.org/10.1016/j.neuroimage.2025.121547},
	doi = {10.1016/j.neuroimage.2025.121547},
	abstract = {The excitability of the human cortex fluctuates over time, influencing how we perceive and respond to sensory stimuli. While non-invasive brain stimulation can probe these fluctuations, real-time tracking of cortical excitability from electroencephalography (EEG) remains challenging due to the high dimensionality and non-stationarity of EEG signals. Here, we present a framework for the personalized, real-time inference of momentary cortical excitability from human EEG. We combine a biophysical model of cortical excitability with a deep learning-based inference engine to estimate excitability states from short segments of resting-state EEG. We validate our approach using concurrent transcranial magnetic stimulation (TMS) and EEG, demonstrating that our model can predict the amplitude of motor-evoked potentials (MEPs) in real-time. Our framework provides a robust and flexible tool for closed-loop brain stimulation, enabling the targeting of specific excitability states to modulate neural processing and behavior.},
	language = {en},
	urldate = {2025-05-22},
	journal = {NeuroImage},
	publisher = {Elsevier},
	author = {Haxel, Lisa and Ahola, Oskari and Kapoor, Jaivardhan and Ziemann, Ulf and Macke, Jakob H.},
	year = {2025},
	keywords = {Electroencephalography, Inference, Computer science, Psychology, Cognitive psychology, Artificial intelligence, Neuroscience, agentRevised, processed},
}
