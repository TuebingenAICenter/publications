@article{kobak_delving_2025,
	title = {Delving into {LLM}-assisted writing in biomedical publications through excess vocabulary},
	issn = {2375-2548},
	shorttitle = {Delving into {LLM}-assisted writing},
	url = {https://www.science.org/doi/full/10.1126/sciadv.adt3813},
	doi = {10.1126/sciadv.adt3813},
	abstract = {The rapid adoption of large language models (LLMs) has transformed scientific writing. We show that the use of LLMs in biomedical publications can be detected by analyzing the frequency of specific words that are overrepresented in LLM-generated text. We identify a set of 'excess vocabulary'—words that have become significantly more frequent in PubMed abstracts since the release of ChatGPT—and demonstrate that their usage is highly correlated with the probability of a paper being LLM-assisted. Our findings suggest that a substantial fraction of recent biomedical literature is written with the help of LLMs, with the highest prevalence in papers from countries with low English proficiency. We provide a tool to quantify the 'LLM-ness' of a text and discuss the implications of this trend for scientific integrity and the future of academic publishing.},
	language = {en},
	urldate = {2025-07-02},
	journal = {Science Advances},
	publisher = {American Association for the Advancement of Science},
	author = {Kobak, Dmitry and González-Márquez, R. and Horvát, Erzsébet Á. and Lause, J.},
	month = jul,
	year = {2025},
	keywords = {SCIENCE ADVANCES},
}
