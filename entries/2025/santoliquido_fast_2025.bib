@article{santoliquido_fast_2025,
	title = {Fast and accurate parameter estimation of high-redshift sources with the {Einstein} {Telescope}},
	url = {https://arxiv.org/abs/2504.21087},
	doi = {10.1103/wf1k-p5cl},
	abstract = {The Einstein Telescope (ET) will be a third-generation gravitational-wave observatory capable of detecting binary black hole mergers up to high redshifts (z 20). The large number of expected detections and the high signal-to-noise ratio of these events pose significant challenges for standard Bayesian inference methods, which are computationally expensive. We present a fast and accurate parameter estimation pipeline for ET based on neural posterior estimation (NPE). We demonstrate that our method can recover the parameters of high-redshift binary black hole mergers with high accuracy and precision, while being several orders of magnitude faster than traditional sampling methods. We apply our pipeline to a population of simulated ET sources and show that it can efficiently characterize the properties of high-redshift mergers, providing a powerful tool for future gravitational-wave cosmology and astrophysics.},
	language = {en},
	urldate = {2025-05-14},
	journal = {arXiv},
	publisher = {arXiv},
	author = {Santoliquido, Filippo and Tissino, Jacopo and Dupletsa, Ulyana and Branchesi, Marica and Harms, Jan and Sedda, Manuel Arca and Dax, Maximilian and Kofler, Annalena and Green, Stephen R. and Gupte, Nihar},
	month = apr,
	year = {2025},
	keywords = {Sky, Bayesian probability, Sampling (signal processing), Inference, Luminosity, Detector, Bayesian inference, Estimation theory},
}
