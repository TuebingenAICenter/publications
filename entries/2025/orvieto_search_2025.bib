@inproceedings{orvieto_search_2025,
	title = {In {Search} of {Adam}'s {Secret} {Sauce}},
	shorttitle = {In {Search} of {Adam}'s {Secret} {Sauce}},
	url = {https://arxiv.org/pdf/2505.21829},
	abstract = {The Adam optimizer is the de facto standard for training deep neural networks. Despite its popularity, the reasons for its success remain elusive. We investigate the role of the adaptive learning rate and the momentum terms in Adam. We show that the adaptive learning rate acts as a preconditioner that adapts to the local geometry of the loss landscape, while the momentum terms provide a form of variance reduction. We provide a theoretical analysis of Adam's convergence properties and show that it can be viewed as a stochastic gradient descent method with a specific preconditioner. We also provide empirical evidence that our theoretical findings hold in practice.},
	language = {en},
	urldate = {2025-06-01},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {MPI-IS},
	author = {Orvieto, Antonio and Gower, Robert M.},
	year = {2025},
	keywords = {ELLIS Institute Tübingen, MPI-IS, NEURIPS},
}
