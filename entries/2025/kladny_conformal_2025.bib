@inproceedings{kladny_conformal_2025,
	title = {Conformal {Generative} {Modeling} with {Improved} {Sample} {Efficiency} through {Sequential} {Greedy} {Filtering}},
	shorttitle = {Conformal {Generative} {Modeling}},
	url = {https://arxiv.org/abs/2410.01660},
	doi = {10.48550/arxiv.2410.01660},
	abstract = {Generative models are increasingly used to generate synthetic data for downstream tasks. However, ensuring that the generated data is statistically valid and representative of the underlying distribution remains a challenge. We propose a framework for conformal generative modeling that provides finite-sample coverage guarantees for the generated data. Our approach leverages sequential greedy filtering to improve sample efficiency, allowing for the generation of high-quality samples with fewer calibration points. We demonstrate the effectiveness of our method on various generative modeling tasks, showing that it achieves tighter coverage bounds compared to existing conformal generative approaches.},
	language = {en},
	urldate = {2025-05-22},
	booktitle = {The {Thirteenth} {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Kladny, Klaus-Rudolf and Schölkopf, Bernhard and Muehlebach, Michael},
	month = apr,
	year = {2025},
	keywords = {Generative grammar, Sample (material), Conformal map, Computer science, Greedy algorithm, Generative model, Sample size determination, Mathematics, Artificial intelligence, Algorithm, Statistics, Physics, Geometry, ELLIS Institute Tübingen, MPI-IS, processed, Sample (material) Generative model, ICLR},
}
