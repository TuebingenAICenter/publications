@article{scimeca_mitigating_2025,
	title = {Mitigating {Shortcut} {Learning} with {Diffusion} {Counterfactuals} and {Diverse} {Ensembles}},
	shorttitle = {Mitigating {Shortcut} {Learning}},
	url = {https://arxiv.org/abs/2311.16176},
	abstract = {Deep learning models often rely on spurious correlations, or 'shortcuts', to make predictions, leading to poor generalization on out-of-distribution data. We propose a method to mitigate shortcut learning by generating counterfactual examples that preserve the target label while removing the shortcut features. We use a diffusion model to perform these counterfactual edits, and we train an ensemble of models on the original and counterfactual data. Our approach, which we call Diffusion-based Counterfactual Ensemble (DCE), significantly improves robustness to shortcut learning on several benchmarks, including synthetic datasets and real-world image classification tasks.},
	language = {en},
	urldate = {2025-05-14},
	journal = {arXiv preprint arXiv:2311.16176},
	publisher = {arXiv},
	author = {Scimeca, Luca and Rubinstein, Alexander and Teney, Damien and Oh, Seong Joon and Bengio, Yoshua},
	year = {2025},
	keywords = {ICLR},
}
