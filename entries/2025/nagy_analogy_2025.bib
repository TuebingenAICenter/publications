@inproceedings{nagy_analogy_2025,
	title = {Analogy making as amortised model construction},
	url = {https://arxiv.org/abs/2507.16511},
	doi = {10.48550/arXiv.2507.16511},
	abstract = {Analogy making is a cornerstone of human cognition, allowing us to transfer knowledge from familiar domains to novel ones. While computational models of analogy have a long history, they often struggle with the flexibility and efficiency required for real-world problem solving. We propose a framework that treats analogy making as amortised model construction. By leveraging amortised inference, our model learns to rapidly construct structural mappings between domains, effectively amortising the cost of search over a lifetime of experience. We demonstrate that this approach can solve complex analogy problems and provides a compelling account of human-like analogical reasoning.},
	language = {en},
	urldate = {2025-07-28},
	booktitle = {Reinforcement {Learning} {Conference}: {Finding} the {Frame} {Workshop}},
	publisher = {arXiv},
	author = {Nagy, D. G. and Shen, T. and Zhou, H. and Wu, C. M. and Dayan, P.},
	year = {2025},
	keywords = {Construct (python library), Analogy, Sketch, Modular design, Reuse, Markov chain, Component (thermodynamics), RLC},
}
