@misc{ciganda_learning_2025,
	title = {Learning {Individual} {Reproductive} {Behavior} from {Aggregate} {Fertility} {Rates} via {Neural} {Posterior} {Estimation}},
	shorttitle = {Learning {Individual} {Reproductive} {Behavior}},
	url = {https://arxiv.org/abs/2506.22607},
	doi = {10.1093/jrsssa/qnag045},
	abstract = {Aggregate fertility rates, such as the Total Fertility Rate (TFR), are widely used to monitor population dynamics. However, they are summary statistics that mask the underlying heterogeneity of individual reproductive behaviors. Inferring individual-level parameters from aggregate data is a classic inverse problem in demography, often hindered by the computational complexity of likelihood-based methods. We propose a simulation-based inference framework using Neural Posterior Estimation (NPE) to recover the distribution of individual reproductive behaviors from aggregate fertility data. Our approach allows for the estimation of complex, non-linear models of fertility without requiring an explicit likelihood function. We demonstrate the effectiveness of our method by recovering individual-level parameters from synthetic aggregate data and applying it to real-world fertility data. Our results show that NPE can accurately infer the underlying distribution of reproductive behaviors, providing a powerful tool for demographic analysis and policy evaluation.},
	language = {en},
	urldate = {2025-06-01},
	publisher = {arXiv},
	author = {Ciganda, Daniel and Campón, Iñaki and Permanyer, Iñaki and Macke, Jakob H.},
	year = {2025},
	keywords = {Fertility, Aggregate (composite), Estimation, Bayesian probability, Total fertility rate, Core (optical fiber), Bayesian inference, Posterior probability, Bayes' theorem, agentRevised, processed},
}
