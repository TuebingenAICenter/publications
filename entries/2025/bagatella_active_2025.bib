@inproceedings{bagatella_active_2025,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Active {Fine}-{Tuning} of {Multi}-{Task} {Policies}},
	shorttitle = {Active {Fine}-{Tuning} of {Multi}-{Task} {Policies}},
	url = {https://proceedings.mlr.press/v267/bagatella25a.html},
	doi = {10.48550/arxiv.2410.05026},
	abstract = {Multi-task reinforcement learning (MTRL) aims to learn policies that generalize across a distribution of tasks. While pre-training on a large set of tasks is effective, fine-tuning on a new, unseen task remains challenging due to the high cost of environment interactions. We propose Active Fine-Tuning (AFT), a framework that selects the most informative tasks to fine-tune on, given a budget of environment interactions. AFT leverages the structure of the task distribution to identify tasks that are most likely to improve the policy's performance on the target task. We demonstrate that AFT significantly outperforms standard fine-tuning and existing active learning baselines in various MTRL benchmarks.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 42nd {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Bagatella, M. and Hübotter, J. and Martius, G. and Krause, A.},
	editor = {Singh, Aarti and Fazel, Maryam and Hsu, Daniel and Lacoste-Julien, Simon and Berkenkamp, Felix and Maharaj, Tegan and Wagstaff, Kiri and Zhu, Jerry},
	month = jul,
	year = {2025},
	keywords = {Relevance (law), Task (project management), Adaptation (eye), Policy learning, Imitation, Robot, Key (lock), Generalist and specialist species, Fine-tuning, Business, Natural resource economics, Economics, Ecology, Biology, Physics, Habitat, ICML},
