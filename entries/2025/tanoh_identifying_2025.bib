@inproceedings{tanoh_identifying_2025,
	title = {Identifying multi-compartment {Hodgkin}-{Huxley} models with high-density extracellular voltage recordings},
	shorttitle = {Identifying multi-compartment {Hodgkin}-{Huxley} models},
	url = {https://arxiv.org/abs/2506.20233},
	abstract = {High-density extracellular recordings provide a rich source of information about the electrical activity of neurons. However, inferring the underlying biophysical parameters of multi-compartment Hodgkin-Huxley (HH) models from these recordings remains a significant challenge due to the high dimensionality of the parameter space and the computational cost of simulating these models. We propose a simulation-based inference (SBI) framework to identify the parameters of multi-compartment HH models from high-density extracellular voltage recordings. Our approach leverages a neural posterior estimator to learn the mapping from extracellular voltage traces to the posterior distribution over biophysical parameters. We demonstrate that our method can accurately recover the parameters of multi-compartment models in synthetic data and show that it can be applied to experimental recordings from retinal ganglion cells. Our framework provides a scalable and efficient tool for characterizing the biophysical properties of neurons from extracellular recordings.},
	language = {en},
	urldate = {2025-05-22},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 38},
	publisher = {University of Tübingen},
	author = {Tanoh, I. C. and Deistler, M. and Macke, J. H. and Linderman, S.},
	month = dec,
	year = {2025},
	keywords = {Voltage, Sampling (signal processing), Kalman filter, Extracellular, Position (finance), Computation, Artificial neural network, Basis (linear algebra), agentRevised, processed, NEURIPS},
}
