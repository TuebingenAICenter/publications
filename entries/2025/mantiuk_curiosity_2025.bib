@inproceedings{mantiuk_curiosity_2025,
	title = {From {Curiosity} to {Competence}: {How} {World} {Models} {Interact} with the {Dynamics} of {Exploration}},
	shorttitle = {From {Curiosity} to {Competence}},
	url = {https://arxiv.org/abs/2507.08210},
	doi = {10.48550/arXiv.2507.08210},
	abstract = {Curiosity is a fundamental driver of learning, yet the mechanisms by which it guides exploration remain debated. We investigate how world models—internal representations of environmental dynamics—interact with curiosity-driven exploration. We propose a framework where agents use world models to predict future states, and curiosity is modulated by the model's predictive uncertainty. Through a series of experiments, we demonstrate that this interaction leads to a transition from broad, novelty-seeking exploration to targeted, competence-building behavior. Our results suggest that the development of a robust world model is essential for shifting from curiosity to competence, providing a computational account of how agents balance exploration and exploitation in complex environments.},
	language = {en},
	urldate = {2025-07-20},
	booktitle = {Proceedings of the 47th {Annual} {Conference} of the {Cognitive} {Science} {Society}},
	publisher = {Cognitive Science Society},
	author = {Mantiuk, F. and Zhou, H. and Wu, C. M.},
	editor = {Ruggeri, A. and Barner, D. and Walker, C. and Bramley, N.},
	year = {2025},
	keywords = {COGSCI},
}
