@inproceedings{konig_performative_2025,
	title = {Performative {Validity} of {Recourse} {Explanations}},
	shorttitle = {Performative {Validity} of {Recourse} {Explanations}},
	url = {https://arxiv.org/abs/2506.15366},
	doi = {10.48550/arxiv.2506.15366},
	abstract = {Recourse explanations aim to provide individuals with actionable advice on how to change an unfavorable model decision. However, the validity of these explanations is often assessed in a static setting, ignoring that the model itself might change in response to the actions taken by individuals. In this paper, we introduce the concept of performative validity for recourse explanations. We show that an explanation that is valid for a static model can become invalid when the model is updated based on the actions taken by individuals. We formalize this phenomenon and provide conditions under which recourse explanations remain valid under performative model updates. Our theoretical results are complemented by empirical evaluations on synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-06-27},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} ({NeurIPS})},
	publisher = {MPI-IS},
	author = {König, Gunnar and Fokkema, Hidde and Freiesleben, Timo and Mendler-Dünner, Celestine and Luxburg, Ulrike},
	year = {2025},
	keywords = {Counterfactual thinking, Counterfactual conditional, Performative utterance, Key (lock), Phenomenon, Anticipation (artificial intelligence), agentRevised, ELLIS Institute Tübingen, MPI-IS, processed, University of Tübingen, NEURIPS},
}
