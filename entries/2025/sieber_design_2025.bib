@misc{sieber_design_2025,
	title = {Design {Principles} for {Sequence} {Models} via {Coefficient} {Dynamics}},
	url = {https://arxiv.org/abs/2510.09389},
	doi = {10.48550/arxiv.2510.09389},
	abstract = {State Space Models (SSMs) and their variants have emerged as powerful alternatives to Transformers for sequence modeling. Despite their empirical success, the theoretical principles governing their design remain fragmented. We propose a unified framework for analyzing sequence models through the lens of coefficient dynamics, which describes how the model's internal state evolves as a function of the input sequence. By characterizing the stability and expressivity of these dynamics, we derive principled design guidelines for sequence models. We show that many popular architectures, including Mamba and S4, can be interpreted as specific instances of our framework. Furthermore, we demonstrate that our framework allows for the systematic construction of new sequence models with improved performance and efficiency.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Sieber, Jérôme and Orvieto, Antonio and Zeilinger, Melanie N. and Alonso, Carmen Amo},
	year = {2025},
	keywords = {Sequence (biology), Linear model, Softmax function, Linear system, Computation, Linear programming, Fidelity, agentRevised, ELLIS Institute Tübingen, processed},
}
