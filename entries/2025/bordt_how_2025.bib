@misc{bordt_how_2025,
	title = {How {Much} {Can} {We} {Forget} about {Data} {Contamination}?},
	shorttitle = {How {Much} {Can} {We} {Forget} about {Data} {Contamination}?},
	url = {https://arxiv.org/abs/2410.03249},
	doi = {10.48550/arXiv.2410.03249},
	abstract = {Data contamination, where test data leaks into the training set, is a major concern for large language models (LLMs). While many detection methods have been proposed, they often rely on heuristics or specific assumptions about the contamination process. In this paper, we provide a theoretical framework to understand the impact of data contamination on model performance. We show that the effect of contamination is surprisingly limited under standard conditions, and that models can 'forget' contaminated data if the training process is sufficiently long or if the data is not perfectly memorized. We provide theoretical bounds on the generalization error and validate our findings with empirical experiments on synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Bordt, Sebastian and Srinivas, Suraj and Boreiko, Valentyn and von Luxburg, Ulrike},
	year = {2025},
	keywords = {Contamination, Environmental science, Computer science, Data science, Biology, ICML},
}
