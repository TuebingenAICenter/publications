@inproceedings{pahk_decoupled_2025,
	title = {Decoupled {Finetuning} for {Domain} {Generalizable} {Semantic} {Segmentation}},
	shorttitle = {{DeFine}},
	url = {https://openreview.net/forum?id=qZEdmyqCHF},
	abstract = {Domain Generalizable (DG) semantic segmentation aims to train a model on source domains that generalizes well to unseen target domains. Recent approaches often rely on heavy data augmentation or complex architectural designs to improve robustness. In this paper, we revisit the standard finetuning paradigm and identify that the coupled nature of feature representation and classifier learning in standard finetuning hinders generalization. To address this, we propose Decoupled Finetuning (DeFine), a simple yet effective framework that decouples the learning of feature representations and the classifier. Specifically, we freeze the feature extractor and finetune only the classifier using a set of diverse, synthetic features generated by a frozen pre-trained model. This approach prevents the feature extractor from overfitting to the source domain while allowing the classifier to adapt to the target domain's distribution. We demonstrate that DeFine achieves state-of-the-art performance on various DG semantic segmentation benchmarks, outperforming existing methods with significantly lower computational cost.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {The {Thirteenth} {International} {Conference} on {Learning} {Representations}},
	publisher = {OpenReview},
	author = {Pahk, Jaehyun and Kwon, Donghyeon and Oh, Seong Joon and Kwak, Suha},
	year = {2025},
	keywords = {ICLR},
}
