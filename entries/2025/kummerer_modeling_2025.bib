@inproceedings{kummerer_modeling_2025,
	title = {Modeling {Saliency} {Dataset} {Bias}},
	url = {https://bethgelab.org/publication/2025_10_kuemmerer/},
	doi = {10.1109/iccv51701.2025.02050},
	abstract = {Saliency models are typically evaluated on datasets that contain strong biases, such as a center bias or a bias towards specific object categories. These biases can lead to an overestimation of model performance and a lack of generalization to real-world scenarios. In this paper, we propose a novel framework to model and quantify saliency dataset bias. We introduce a generative model that learns to disentangle the true saliency from the dataset-specific biases. Our approach allows us to evaluate models on debiased versions of existing datasets and to generate synthetic datasets with controlled biases. We demonstrate that our method significantly improves the evaluation of saliency models and provides insights into the nature of dataset biases.},
	language = {en},
	urldate = {2025-06-01},
	booktitle = {Proceedings of the {IEEE}/{CVF} {International} {Conference} on {Computer} {Vision} ({ICCV})},
	publisher = {IEEE},
	author = {Kümmerer, Matthias and Khanuja, Harneet Singh and Bethge, Matthias},
	year = {2025},
	keywords = {Generalization, Benchmark (surveying), Pattern recognition (psychology), Training set, Fraction (chemistry), Saliency map, agentRevised, processed, ICCV},
}
