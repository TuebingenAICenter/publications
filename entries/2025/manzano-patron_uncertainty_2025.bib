@article{manzano-patron_uncertainty_2025,
	title = {Uncertainty mapping and probabilistic tractography using {Simulation}-{Based} {Inference} in diffusion {MRI}: {A} comparison with classical {Bayes}},
	issn = {1361-8415},
	url = {https://www.sciencedirect.com/science/article/pii/S1361841525001276},
	doi = {10.1016/j.media.2025.103580},
	abstract = {Quantifying uncertainty in tractography is essential for the reliable mapping of anatomical connectivity in the human brain. Probabilistic tractography, which propagates local uncertainty to global pathways, provides a means of doing so. Conventionally, local uncertainty is estimated using classical Bayesian inference. These methods often require simplifying assumptions on the noise or the underlying biological model to remain computationally tractable and are typically implemented as independent voxel-wise analyses. In this study, we propose the use of Simulation-Based Inference (SBI) for local uncertainty mapping in dMRI. SBI leverages neural networks to learn the posterior distribution of model parameters directly from simulated data, effectively bypassing the need for an explicit likelihood and enabling flexible, amortized inference. We apply SBI to the fibre orientation distribution (FOD) model and demonstrate that it provides uncertainty estimates comparable to classical Bayes (Laplace approximation) in synthetic data, while being orders of magnitude faster at inference time. Using in vivo data from the Human Connectome Project, we show that SBI results in more consistent orientation estimates across multiple scan sessions and improved tractography outcomes. Our findings indicate that SBI offers a robust, efficient alternative for uncertainty quantification in dMRI, with the potential to scale to more complex biophysical models where classical Bayesian methods are either inefficient or inapplicable.},
	language = {en},
	urldate = {2025-05-22},
	journal = {Medical Image Analysis},
	publisher = {Elsevier},
	author = {Manzano-Patron, J. P. and Deistler, Michael and Schröder, Cornelius and Kypraios, Theodore and Gonçalves, Pedro J. and Macke, Jakob H. and Sotiropoulos, Stamatios N.},
	month = may,
	year = {2025},
	keywords = {Tractography, Bayes' theorem, Inference, Probabilistic logic, Diffusion MRI, Computer science, Artificial intelligence, Bayesian probability, Magnetic resonance imaging, Medicine, Radiology, MPI-IS, Statistical Inference, University of Tübingen, MEDIA},
}
