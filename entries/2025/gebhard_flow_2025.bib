@misc{gebhard_flow_2025,
	title = {Flow {Matching} for {Atmospheric} {Retrieval} of {Exoplanets}: {Where} {Reliability} meets {Adaptive} {Noise} {Levels}},
	shorttitle = {Flow {Matching} for {Atmospheric} {Retrieval} of {Exoplanets}},
	url = {https://doi.org/10.1051/0004-6361/202451861},
	doi = {10.1051/0004-6361/202451861},
	abstract = {Atmospheric retrieval is a cornerstone of exoplanetary science, aiming to infer the chemical composition and physical properties of exoplanetary atmospheres from observed spectra. Traditionally, this is achieved through Bayesian inference using nested sampling or Markov chain Monte Carlo methods, which are computationally expensive due to the need for thousands of forward model evaluations. Recent advances in simulation-based inference (SBI) have enabled faster retrieval by amortizing the inference process. However, these methods often struggle with the high dimensionality and complex likelihood landscapes of atmospheric models, and they frequently lack robust uncertainty quantification. In this work, we introduce a novel approach to atmospheric retrieval based on flow matching, a generative modeling framework that learns to map a simple base distribution to the posterior distribution. We demonstrate that flow matching provides a flexible and efficient way to perform SBI, offering superior performance in terms of accuracy and reliability compared to existing methods. Furthermore, we propose an adaptive noise level strategy that allows the model to handle varying levels of observational noise, leading to more robust and reliable retrievals. We validate our approach on synthetic and real-world exoplanetary spectra, showing that it achieves state-of-the-art performance while significantly reducing the computational cost of atmospheric retrieval.},
	language = {en},
	urldate = {2025-05-22},
	publisher = {EDP Sciences},
	author = {Gebhard, T. D. and Wildberger, J. and Dax, M. and Kofler, A. and Angerhausen, D. and Quanz, S. and Schölkopf, B.},
	month = jan,
	year = {2025},
	keywords = {Exoplanet, Noise (video), Reliability (semiconductor), Matching (statistics), Computer science, Flow (mathematics), Environmental science, Artificial intelligence, Physics, Mathematics, Computer vision, Statistics, Mechanics, A\&A},
}
