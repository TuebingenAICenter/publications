@inproceedings{kadhim_data_2025,
	title = {A data and task-constrained mechanistic model of the mouse outer retina shows robustness to contrast variations},
	url = {https://is.mpg.de/ei/publications/kadhimetal25},
	doi = {10.1101/2025.10.20.683356v1},
	abstract = {Current models of the early visual system often face a trade-off between realism and performance: whereas biologically inspired mechanistic models provide insights into visual processing but struggle to simulate complex tasks, deep learning models achieve high performance but are difficult to interpret. Here, we developed a system-identification approach to build a mechanistic model of the mouse outer retina that is both data-driven and task-performing. Our model parameters were constrained by large-scale calcium imaging and electrophysiology data from several cell types (photoreceptors, horizontal cells, and bipolar cells). To obtain a high-performance model, we optimized its remaining parameters to maximize the mutual information between the visual input and the model output (the bipolar cell layer). Using this constrained optimization, we found that the model achieved performance comparable to a deep neural network on a natural image reconstruction task. Intriguingly, our model naturally exhibited several hallmark properties of retinal processing, including adaptation to stimulus statistics. Specifically, the model showed robustness to changes in image contrast, which emerged through the non-linearities and feedback loops in the circuit. Our findings demonstrate that integrating biological constraints with task-based optimization provides a powerful framework for developing interpretable models that capture the computational principles of the early visual system.},
	language = {en},
	urldate = {2025-05-22},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 38},
	publisher = {University of Tübingen},
	author = {Kadhim, K. L. and Beck, J. and Huang, Z. and Macke, J. H. and Rieke, F. and Euler, T. and Deistler, M. and Berens, P.},
	month = dec,
	year = {2025},
	keywords = {Retina, Luminance, Contrast (vision), Excitatory postsynaptic potential, Visual phototransduction, Stimulus (psychology), Robustness (evolution), Receptive field, agentRevised, MPI-IS, processed, University of Tübingen, NEURIPS},
}
