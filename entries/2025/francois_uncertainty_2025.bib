@inproceedings{francois_uncertainty_2025,
	title = {An {Uncertainty} {Principle} for {Linear} {Recurrent} {Neural} {Networks}},
	shorttitle = {An {Uncertainty} {Principle} for {Linear} {Recurrent} {Neural} {Networks}},
	url = {https://arxiv.org/pdf/2502.09287},
	doi = {10.48550/arxiv.2502.09287},
	abstract = {Linear Recurrent Neural Networks (LRNNs) have recently emerged as a powerful alternative to Transformers for sequence modeling, offering linear scaling in sequence length. However, their training dynamics and expressivity remain poorly understood. In this paper, we establish an uncertainty principle for LRNNs: we show that there is a fundamental trade-off between the ability of an LRNN to memorize long-range dependencies and its ability to be trained efficiently via gradient descent. Specifically, we prove that for any LRNN, the product of the effective memory horizon and the condition number of the gradient of the loss function is lower-bounded by a constant related to the spectral properties of the transition matrix. We validate our theoretical findings with experiments on synthetic and real-world datasets, demonstrating that this trade-off is a significant bottleneck for current architectures.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the {Thirty} {Eighth} {Conference} on {Learning} {Theory}},
	publisher = {PMLR},
	author = {François, Alexandre and Orvieto, Antonio and Bach, Francis},
	year = {2025},
	keywords = {Artificial neural network, Computer science, Artificial intelligence, agentRevised, ELLIS Institute Tübingen, processed, COLT},
}
