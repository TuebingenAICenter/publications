@article{anh_4d_2025,
	title = {4D {Object}-{Mover}: {Distilling} {Pretrained} {Diffusion} {Priors} for {Object} {Animation}},
	shorttitle = {4D {Object}-{Mover}},
	url = {https://arxiv.org/abs/2509.16023},
	abstract = {We present 4D Object-Mover, a method for animating static 3D objects using pretrained diffusion priors. Given a single 3D object and a text prompt describing a motion, our method generates a 4D sequence of the object performing the motion. We leverage a pretrained video diffusion model as a motion prior and distill it into a 4D representation. To ensure temporal consistency and structural preservation, we introduce a novel motion-aware distillation loss and a structural guidance term. Our method produces high-quality, temporally consistent 4D animations from a single 3D input, outperforming existing baselines in both visual quality and motion fidelity.},
	language = {en},
	urldate = {2025-05-22},
	journal = {Conference on Computer Vision and Pattern Recognition (CVPR) Workshop on 4D Vision: Modeling the Dynamic World},
	author = {Anh, Tuan Tran and Lenssen, Jan Eric and Pons-Moll, Gerard and Chibane, Julian},
	year = {2025},
	keywords = {CVPR},
}
