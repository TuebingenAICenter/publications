@article{oesterle_task-specific_2025,
	title = {Task-specific regional circuit adaptations in distinct mouse retinal ganglion cells},
	issn = {2375-2548},
	shorttitle = {Task-specific regional circuit adaptations},
	url = {https://www.science.org/doi/full/10.1126/sciadv.adp7075},
	doi = {10.1126/sciadv.adp7075},
	abstract = {The retina is often considered a stereotyped sensory processor. However, recent evidence suggests that retinal circuits can adapt to the specific visual statistics of the environment. Here, we show that mouse retinal ganglion cells (RGCs) of the same type exhibit distinct functional properties depending on their location in the retina. Using large-scale two-photon calcium imaging of RGC populations in the intact mouse retina, we found that the receptive field properties of several RGC types vary systematically along the dorsoventral axis. These regional differences are not merely a consequence of varying photoreceptor input but are shaped by local circuit adaptations. We show that these adaptations are task-specific, as they optimize the RGCs for the visual statistics of the corresponding part of the visual field. Our results demonstrate that the retina is a highly flexible system that adjusts its processing strategy to the specific requirements of the visual environment.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Science Advances},
	publisher = {American Association for the Advancement of Science},
	author = {Oesterle, Jonathan and Ran, Yanli and Stahr, Paul and Kerr, Jason N. and Schubert, Timm and Berens, Philipp and Euler, Thomas},
	month = apr,
	year = {2025},
	keywords = {Neuroscience, Receptive field, Retinal waves, Biology, Retina, Intrinsically photosensitive retinal ganglion cells, Parasol cell, Population, Giant retinal ganglion cells, Ganglion, Postsynaptic potential, Retinal, Bistratified cell, Anatomy, Retinal ganglion cell, Medicine, Retinal waves Parasol cell Bistratified cell, SCIADV},
}
