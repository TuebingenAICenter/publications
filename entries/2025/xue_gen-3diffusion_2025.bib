@article{xue_gen-3diffusion_2025,
	title = {Gen-3Diffusion: {Realistic} {Image}-to-3D {Generation} via 2D \& 3D {Diffusion} {Synergy}},
	issn = {0162-8828},
	shorttitle = {Gen-3Diffusion},
	url = {https://doi.org/10.1109/TPAMI.2025.3577067},
	doi = {10.1109/TPAMI.2025.3577067},
	abstract = {We present Gen-3Diffusion, a novel framework for high-quality image-to-3D generation that leverages the synergy between 2D and 3D diffusion models. While 2D diffusion models excel at generating high-fidelity images, they often lack 3D consistency. Conversely, 3D diffusion models provide structural coherence but struggle with fine-grained details. Our approach bridges this gap by integrating a pre-trained 2D diffusion model as a prior for a 3D diffusion model, effectively combining the strengths of both. We introduce a novel 3D-aware conditioning mechanism that guides the 3D generation process using 2D features, ensuring both geometric consistency and visual realism. Extensive experiments demonstrate that Gen-3Diffusion outperforms existing state-of-the-art methods in terms of both visual quality and 3D consistency, producing realistic 3D assets from single images.},
	language = {en},
	urldate = {2025-05-22},
	journal = {IEEE Transactions on Pattern Analysis and Machine Intelligence},
	publisher = {IEEE},
	author = {Xue, Yuxuan and Xie, Xianghui and Marin, Riccardo and Pons-Moll, Gerard},
	year = {2025},
	keywords = {Image (mathematics), Diffusion, Computer science, Computer vision, Artificial intelligence, Computer graphics (images), Physics, processed, University of Tübingen, TPAMI},
}
