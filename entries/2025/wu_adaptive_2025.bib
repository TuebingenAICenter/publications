@article{wu_adaptive_2025,
	title = {Adaptive mechanisms of social and asocial learning in immersive foraging environments},
	shorttitle = {Adaptive mechanisms of social and asocial learning},
	url = {https://doi.org/10.1038/s41467-025-58365-6},
	doi = {10.1038/s41467-025-58365-6},
	abstract = {Social learning is a cornerstone of human success, yet the conditions under which individuals rely on social versus asocial information remain debated. While theoretical models suggest that social learning should be used when asocial learning is costly or unreliable, empirical evidence in complex, dynamic environments is limited. Here, we use a large-scale immersive foraging experiment in Minecraft to investigate how individuals adapt their reliance on social and asocial information. We find that participants dynamically adjust their learning strategies in response to environmental uncertainty and the reliability of social information. Specifically, participants increase their reliance on social information when asocial learning is difficult, but decrease it when social information is unreliable or when the environment is highly volatile. Our results provide empirical support for adaptive social learning strategies and demonstrate the utility of immersive, high-fidelity environments for studying complex human behavior.},
	language = {en},
	urldate = {2025-05-22},
	journal = {Nature Communications},
	publisher = {Nature Portfolio},
	author = {Wu, Charley M. and Deffner, Dominik and Kahl, Benjamin and Meder, Björn and Ho, Mark K. and Kurvers, Ralf H. J. M.},
	year = {2025},
	keywords = {Dynamics (music), Human–computer interaction, Computer science, Spatial learning, Cognitive psychology, Psychology, Neuroscience, Cognition, Adaptability, Social Learning, NATCOMM},
}
