@article{sivaprasad_theory_2025,
	title = {A {Theory} of {Response} {Sampling} in {LLMs}: {Part} {Descriptive} and {Part} {Prescriptive}},
	shorttitle = {A {Theory} of {Response} {Sampling} in {LLMs}},
	url = {https://arxiv.org/abs/2402.11005},
	doi = {10.18653/v1/2025.acl-long.1454},
	abstract = {Large Language Models (LLMs) are increasingly used as components in complex systems, where their outputs are sampled to generate responses. Despite the ubiquity of sampling, our understanding of its impact on the quality and reliability of LLM outputs remains largely empirical. In this work, we propose a theoretical framework for response sampling in LLMs. We first provide a descriptive analysis of the sampling process, characterizing the relationship between the sampling parameters and the distribution of the generated responses. We then provide a prescriptive analysis, deriving optimal sampling strategies for different objectives, such as maximizing the probability of generating a correct response or minimizing the variance of the generated responses. We validate our theoretical findings through extensive experiments on a variety of tasks and models, demonstrating that our framework provides a principled approach to response sampling in LLMs.},
	language = {en},
	urldate = {2025-07-15},
	journal = {Proceedings of the 63rd Annual Meeting of the Association for Computational Linguistics},
	publisher = {Association for Computational Linguistics},
	author = {Sivaprasad, Sarath and Kaushik, Pramod and Abdelnabi, Sahar and Fritz, Mario},
	year = {2025},
	keywords = {Computer science, Sampling (signal processing), Descriptive statistics, Statistics, Mathematics, Telecommunications, ACL},
}
