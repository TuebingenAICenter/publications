@inproceedings{opedal_mathgap_2025,
	title = {{MathGAP}: {Out}-of-{Distribution} {Evaluation} on {Problems} with {Arbitrarily} {Complex} {Proofs}},
	shorttitle = {{MathGAP}},
	url = {https://arxiv.org/abs/2410.13502},
	doi = {10.48550/arxiv.2410.13502},
	abstract = {Large language models (LLMs) have demonstrated impressive capabilities in solving mathematical problems. However, current benchmarks often suffer from data contamination and lack the ability to evaluate models on problems requiring arbitrarily long or complex proofs. We introduce MathGAP, a benchmark for evaluating LLMs on mathematical problems that require multi-step reasoning and proofs of arbitrary complexity. MathGAP is designed to be out-of-distribution (OOD) relative to the training data of most LLMs, ensuring a robust evaluation of their reasoning capabilities. We evaluate several state-of-the-art LLMs on MathGAP and find that they struggle with problems requiring long-chain reasoning, highlighting the need for further research in this direction.},
	language = {en},
	urldate = {2025-05-22},
	booktitle = {The {Thirteenth} {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Opedal, Andreas and Shirakami, Haruki and Schölkopf, Bernhard and Saparov, Abulhair and Sachan, Mrinmaya},
	month = apr,
	year = {2025},
	keywords = {Mathematical proof, Distribution (mathematics), Mathematics, Calculus (dental), Computer science, Geometry, Mathematical analysis, Medicine, MPI-IS, processed, ICLR},
}
