@misc{deistler_simulation-based_2025,
	title = {Simulation-based inference: {A} practical guide},
	shorttitle = {Simulation-based inference},
	url = {https://arxiv.org/abs/2508.12939},
	doi = {10.48550/arxiv.2508.12939},
	abstract = {Simulation-based inference (SBI) has emerged as a powerful framework for performing statistical inference in scientific models where the likelihood function is intractable but the model can be simulated. While the field has matured rapidly, the diversity of methods and software can be daunting for practitioners. This guide provides a comprehensive, practical introduction to SBI. We outline the core concepts, discuss the choice of inference methods, and provide a structured workflow for applying SBI to scientific problems. We further discuss common pitfalls, validation strategies, and the current state of the software ecosystem, aiming to provide a roadmap for researchers across disciplines to effectively leverage SBI in their work.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Deistler, Michael and Lueckmann, Jan-Matthis and Macke, Jakob},
	year = {2025},
	keywords = {Inference, Workflow, Frequentist inference, Bayesian inference, Suite, Artificial neural network, Process (computing), Causal inference, agentRevised},
}
