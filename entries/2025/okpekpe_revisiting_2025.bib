@article{okpekpe_revisiting_2025,
	title = {Revisiting associative recall in modern recurrent models},
	url = {https://arxiv.org/abs/2508.19029},
	doi = {10.48550/arxiv.2508.19029},
	abstract = {Associative recall is a fundamental task for evaluating the memory capabilities of sequence models. While Transformers are known to excel at this task, the performance of modern recurrent models (such as SSMs and RNNs) remains less understood. In this work, we revisit associative recall in modern recurrent models. We show that standard recurrent architectures struggle with associative recall due to their limited state capacity and the way they process information. We propose a simple modification to these models that significantly improves their associative recall performance, enabling them to match or outperform Transformers on this task. Our findings suggest that the limitations of recurrent models in associative recall are not inherent to their recurrent nature but rather to their specific architectural design.},
	language = {en},
	urldate = {2025-05-14},
	journal = {arXiv},
	publisher = {arXiv},
	author = {Okpekpe, D. and Orvieto, A.},
	year = {2025},
	keywords = {Recall, Memorization, Associative property, Transformer, Scaling, Security token, Language model, ELLIS Institute Tübingen, workshop, ELLIS Institute T\&uuml, bingen, ICLR},
}
