@article{djoumessi_inherently_2025,
	title = {An inherently interpretable {AI} model improves screening speed and accuracy for early diabetic retinopathy},
	copyright = {© 2025 Djoumessi et al. This is an open access article distributed under the terms of the Creative Commons Attribution License, which permits unrestricted use, distribution, and reproduction in any medium, provided the original author and source are credited.},
	issn = {2767-3170},
	shorttitle = {An inherently interpretable {AI} model},
	url = {https://doi.org/10.1371/journal.pdig.0000831},
	doi = {10.1371/journal.pdig.0000831},
	abstract = {Diabetic retinopathy (DR) is a leading cause of vision loss globally. Early detection is crucial for preventing blindness, but screening programs are often limited by the availability of ophthalmologists. Artificial intelligence (AI) systems have shown promise in automating DR screening, but their adoption in clinical practice is often hindered by a lack of interpretability. Here, we present an inherently interpretable AI model for the detection of early DR in fundus images. Our model, based on a prototype-based architecture, provides both a classification decision and visual explanations in the form of prototypical image patches. We evaluated our model on a large-scale dataset of fundus images and found that it achieves high diagnostic accuracy, comparable to state-of-the-art black-box models. Furthermore, we conducted a reader study with ophthalmologists and found that the model's explanations significantly improved their screening speed and accuracy compared to using a black-box model or no AI assistance. Our results demonstrate that inherently interpretable AI models can be both accurate and clinically useful, potentially facilitating the integration of AI into routine DR screening.},
	language = {en},
	urldate = {2025-05-12},
	journal = {PLOS Digital Health},
	publisher = {Public Library of Science},
	author = {Djoumessi, Kerol and Huang, Ziwei and Kühlewein, Laura and Rickmann, Annekatrin and Simon, Natalia and Koch, Lisa M. and Berens, Philipp},
	month = may,
	year = {2025},
	keywords = {Diabetic retinopathy, Computer science, Artificial intelligence, Retinopathy, Medicine, Machine learning, Diabetes mellitus, Endocrinology, processed, University of Tübingen},
}
