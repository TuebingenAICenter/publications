@inproceedings{sanyal_accuracy_2025,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Accuracy on the wrong line: {On} the pitfalls of noisy data for out-of-distribution generalisation},
	shorttitle = {Accuracy on the wrong line},
	url = {https://proceedings.mlr.press/v258/sanyal25a.html},
	doi = {10.48550/arxiv.2406.19049},
	abstract = {We study the effect of noisy data on out-of-distribution (OOD) generalisation. We show that even small amounts of label noise can lead to models that achieve high accuracy on the training distribution but fail catastrophically on OOD data. We identify a phenomenon we call 'accuracy on the wrong line', where the model learns a decision boundary that is accurate on the training data but is misaligned with the underlying causal structure of the data. We provide theoretical insights into why this happens and propose a simple yet effective method to mitigate this issue.},
	language = {en},
	urldate = {2025-05-22},
	booktitle = {Proceedings of the 28th {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Sanyal, A. and Hu, Y. and Yu, Y. and Ma, Y. and Wang, Y. and Schölkopf, B.},
	editor = {Li, Yingzhen and Mandt, Stephan and Agrawal, Shipra and Khan, Emtiyaz},
	month = may,
	year = {2025},
	keywords = {Distribution (mathematics), Line (geometry), Computer science, Econometrics, Artificial intelligence, Algorithm, Mathematics, Data mining, Mathematical analysis, Geometry, MPI-IS, processed, Through-the-lens metering, ICML, AISTATS},
}
