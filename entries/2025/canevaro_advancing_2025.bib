@inproceedings{canevaro_advancing_2025,
	title = {Advancing {Out}-of-{Distribution} {Detection} via {Local} {Neuroplasticity}},
	url = {https://arxiv.org/abs/2502.15833},
	doi = {10.48550/arxiv.2502.15833},
	abstract = {Out-of-distribution (OOD) detection is a critical requirement for the safe deployment of machine learning models in real-world environments. While many existing methods rely on post-hoc analysis of pre-trained models, they often struggle to capture the nuanced features necessary to distinguish between in-distribution and OOD data. In this work, we propose a novel approach to OOD detection inspired by the concept of local neuroplasticity. By introducing a local learning mechanism that allows individual neurons to adapt to the input distribution during inference, we enable the model to dynamically adjust its internal representations. This adaptation process provides a robust signal for OOD detection, as the degree of change in the model's internal state serves as a reliable indicator of distributional shift. We demonstrate the effectiveness of our approach across a range of benchmarks, showing that it consistently outperforms state-of-the-art methods in both detection accuracy and computational efficiency.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {The {Thirteenth} {International} {Conference} on {Learning} {Representations} ({ICLR})},
	publisher = {University of Tübingen},
	author = {Canevaro, A. and Schmidt, J. and Marvi, M. S. and Yu, H. and Martius, G. and Jordan, J.},
	month = apr,
	year = {2025},
	keywords = {Robustness (evolution), Reliability (semiconductor), Neuroplasticity, Property (philosophy), Domain (mathematical analysis), processed, University of Tübingen, ICLR},
}
