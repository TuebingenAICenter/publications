@inproceedings{xue_infinihuman_2025,
	title = {{InfiniHuman}: {Infinite} 3D {Human} {Creation} with {Precise} {Control}},
	shorttitle = {{InfiniHuman}},
	url = {https://yuxuan-xue.com/infini-human/},
	doi = {10.1145/3757377.3763815},
	abstract = {We present InfiniHuman, a generative model for creating realistic 3D humans with diverse appearances and precise geometric control. Previous 3D human generative models either lack realistic appearance or suffer from a lack of precise control. In this work, we address these limitations by modeling 3D humans with a latent 3D diffusion model on top of a canonical surface-aligned representation. To handle the diverse hairstyles and clothing (e.g. skirts, gowns, and coats) our method learns a localized, articulation-aware implicit representation which is aligned to the SMPL-X body surface. This alignment allows for precise control of 3D human generation with body shape and artist-defined poses. Compared to existing 3D human generative models, our method can generate highly diverse and realistic 3D humans. Our model also supports various downstream applications, including human animation, shape and pose-controlled generation, and text-to-3D human creation.},
	language = {en},
	urldate = {2025-05-22},
	booktitle = {{SIGGRAPH} {Asia} 2025 {Conference} {Papers}},
	publisher = {Association for Computing Machinery},
	author = {Xue, Yuxuan and Xie, Xianghui and Kostyrko, Margaret and Pons-Moll, Gerard},
	year = {2025},
	keywords = {Avatar, Pipeline (software), Generative grammar, Clothing, Generative model, Identity (music), Control (management), Representation (politics), agentRevised, SIGGRAPH},
}
