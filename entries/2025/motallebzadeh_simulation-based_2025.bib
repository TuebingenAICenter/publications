@article{motallebzadeh_simulation-based_2025,
	title = {Simulation-based inference for subject-specific tuning of middle ear finite-element models towards personalized objective diagnosis},
	copyright = {© 2025 The Author(s)},
	issn = {2045-2322},
	shorttitle = {Simulation-based inference for subject-specific tuning},
	url = {https://doi.org/10.1038/s41598-025-93098-6},
	doi = {10.1038/s41598-025-93098-6},
	abstract = {Finite-element (FE) models of the human middle ear are powerful tools for understanding hearing mechanics and diagnosing pathologies. However, their clinical utility is limited by the difficulty of tuning model parameters to match subject-specific measurements, a process that is computationally expensive and often relies on manual, subjective adjustments. Here, we propose a simulation-based inference (SBI) framework to automate the subject-specific tuning of middle ear FE models. By training a neural density estimator on synthetic data generated from a population-based FE model, we can rapidly infer the posterior distribution of subject-specific parameters given clinical measurements, such as wideband acoustic immittance. We demonstrate the efficacy of our approach on synthetic data and clinical measurements from human subjects. Our framework provides a robust, objective, and computationally efficient method for personalized middle ear modeling, paving the way for improved diagnostic accuracy in clinical practice.},
	language = {en},
	urldate = {2025-06-01},
	journal = {Scientific Reports},
	publisher = {Nature Portfolio},
	author = {Motallebzadeh, Hamid and Deistler, Michael and Schönleitner, Florian M. and Macke, Jakob H. and Puria, Sunil},
	year = {2025},
	keywords = {Inference, Sensitivity (control systems), Artificial neural network, Set (abstract data type), Noise (video), Estimation theory, Posterior probability, Prior probability, Probability distribution, agentRevised, SCIREP},
}
