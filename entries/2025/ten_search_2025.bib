@misc{ten_search_2025,
	title = {In search of lost memories: {Modeling} exploration with forgetful generalization},
	shorttitle = {In search of lost memories},
	url = {https://doi.org/10.31234/osf.io/hupq5_v1},
	doi = {10.31234/osf.io/hupq5_v1},
	abstract = {Human exploration is often guided by memory. However, memory is not perfect; we forget. How does forgetting influence exploration? We propose a model of exploration based on Gaussian process regression with a forgetful generalization mechanism, where the precision of past observations decays over time. We test this model across three experiments involving spatial and non-spatial search tasks. We find that the forgetful generalization model provides a better account of human behavior than models with perfect memory or models that ignore the structure of the environment. Our results suggest that forgetting is not merely a failure of memory, but a functional adaptation that allows for flexible exploration in dynamic environments.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PsyArXiv},
	author = {Ten, Alexandru and Sakaki, Michiko and Breit, Sebastian and Chandrasekaran, Arjun and Murayama, Kou and Wu, Charley M.},
	year = {2025},
	keywords = {agentRevised, processed, University of Tübingen},
}
