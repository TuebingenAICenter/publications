@article{bousselham_legrad_2025,
	title = {{LeGrad}: {An} {Explainability} {Method} for {Vision} {Transformers} via {Feature} {Formation} {Sensitivity}},
	shorttitle = {{LeGrad}},
	url = {https://arxiv.org/abs/2404.03214},
	abstract = {Vision Transformers (ViTs) have become the state-of-the-art architecture for computer vision tasks. However, their internal decision-making process remains largely opaque. Existing explainability methods for ViTs often rely on attention maps or gradient-based techniques, which can be noisy or fail to capture the complex interactions between tokens. In this paper, we introduce LeGrad, a novel explainability method for ViTs that leverages the sensitivity of feature formation to input perturbations. By analyzing how the internal representations are constructed through the transformer blocks, LeGrad identifies the most influential input patches for a given prediction. We demonstrate that LeGrad provides more faithful and interpretable explanations compared to existing methods, as evaluated on standard benchmarks. Furthermore, we show that LeGrad is computationally efficient and can be applied to various ViT architectures without requiring architectural modifications.},
	language = {en},
	urldate = {2025-05-22},
	journal = {Proceedings of the IEEE/CVF International Conference on Computer Vision (ICCV)},
	publisher = {IEEE},
	author = {Bousselham, Walid and Boggust, Angie and Chaybouti, Sofian and Strobelt, Hendrik and Kuehne, Hilde},
	year = {2025},
	keywords = {ICCV},
}
