@article{akata_playing_2025,
	title = {Playing repeated games with large language models},
	issn = {2397-3374},
	shorttitle = {Playing repeated games with {LLMs}},
	url = {https://www.nature.com/articles/s41562-025-02172-y},
	doi = {10.1038/s41562-025-02172-y},
	abstract = {Large language models (LLMs) are increasingly used as agents in social interactions. However, it remains unclear whether they can engage in strategic, long-term social interaction. Here we show that LLMs can play repeated games—a cornerstone of social psychology and game theory—at a level comparable to or better than humans. We test LLMs across a range of repeated games, including the prisoner’s dilemma, the stag hunt and the snowdrift game. We find that LLMs can adapt their strategies to different opponents, learn from past interactions and cooperate in social dilemmas. Our results suggest that LLMs are capable of sophisticated social reasoning and can be used to study human social behaviour in a controlled, scalable and reproducible manner.},
	language = {en},
	urldate = {2025-05-22},
	journal = {Nature Human Behaviour},
	publisher = {Nature Publishing Group},
	author = {Akata, Elif and Schulz, Lion and Coda-Forno, Julian and Oh, Seong Joon and Bethge, Matthias and Schulz, Eric},
	year = {2025},
	keywords = {Prisoner's dilemma, Dilemma, Iterated function, Set (abstract data type), Game theory, Psychology, Computer science, Social psychology, Computer security, Microeconomics, Economics, Mathematics, Adversary, agentRevised, Battle, Cognitive psychology, Social dilemma, NHB},
}
