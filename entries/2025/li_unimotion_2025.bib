@misc{li_unimotion_2025,
	title = {Unimotion: {Unifying} 3D {Human} {Motion} {Synthesis} and {Understanding}},
	shorttitle = {Unimotion},
	url = {https://arxiv.org/abs/2409.15904},
	doi = {10.48550/arxiv.2409.15904},
	abstract = {Human motion modeling has traditionally been split into two distinct paradigms: motion synthesis, which focuses on generating realistic motion sequences, and motion understanding, which focuses on analyzing and interpreting existing motion data. While both tasks share the underlying goal of learning a rich representation of human movement, they are typically addressed by separate architectures and training objectives. In this paper, we propose UniMotion, a unified framework that bridges these two paradigms. UniMotion leverages a single transformer-based architecture to perform both motion synthesis and understanding tasks. By treating motion as a sequence of tokens and employing a shared latent space, our model learns to both generate diverse and plausible motion sequences from various conditions and extract meaningful representations for downstream tasks such as motion classification and retrieval. We demonstrate that UniMotion achieves state-of-the-art performance on multiple benchmarks for both synthesis and understanding, highlighting the benefits of a unified approach to human motion modeling.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Li, Chuqiao and Chibane, Julian and He, Yannan and Pearl, Naama and Geiger, Andreas and Pons-Moll, Gerard},
	year = {2025},
	keywords = {Computer science, Motion (physics), Human motion, Human–computer interaction, Artificial intelligence, Cognitive science, Psychology, 3DV},
}
