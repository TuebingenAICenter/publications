@inproceedings{orujlu_reframing_2025,
	title = {Reframing attention as a reinforcement learning problem for causal discovery},
	shorttitle = {Reframing attention as a reinforcement learning problem},
	url = {https://arxiv.org/abs/2507.13920},
	doi = {10.48550/arXiv.2507.13920},
	abstract = {Causal discovery aims to identify the underlying causal structure of a system from observational data. Recent approaches have increasingly leveraged deep learning, particularly attention-based architectures, to learn causal structures. However, these models often rely on static attention mechanisms that may not fully capture the dynamic and iterative nature of causal discovery. In this work, we reframe the attention mechanism as a reinforcement learning (RL) problem. We propose a framework where an agent learns to attend to relevant variables to iteratively construct a causal graph. By treating attention as a sequential decision-making process, our model can adaptively focus on informative features, leading to more robust and interpretable causal discovery. We demonstrate the effectiveness of our approach on synthetic and real-world datasets, showing that it outperforms existing methods in terms of accuracy and computational efficiency.},
	language = {en},
	urldate = {2025-08-07},
	booktitle = {Reinforcement {Learning} {Conference}: {Causal} {Reinforcement} {Learning} {Workshop}},
	publisher = {arXiv},
	author = {Orujlu, T. and Gumbsch, C. and Butz, M. V. and Wu, C. M.},
	year = {2025},
	keywords = {processed, University of Tübingen, RLC},
}
