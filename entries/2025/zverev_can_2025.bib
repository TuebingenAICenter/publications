@article{zverev_can_2025,
	title = {Can {LLMs} {Separate} {Instructions} {From} {Data}? {And} {What} {Do} {We} {Even} {Mean} {By} {That}?},
	shorttitle = {Can {LLMs} {Separate} {Instructions} {From} {Data}?},
	url = {https://arxiv.org/abs/2403.06833},
	abstract = {Large Language Models (LLMs) are increasingly used as components in complex systems, where they process inputs that contain both instructions and data. A common security concern is that an LLM might fail to distinguish between the two, leading to prompt injection attacks. In this work, we investigate the problem of instruction-data separation in LLMs. We first formalize the concept of instruction-data separation and propose a taxonomy of failure modes. We then introduce a benchmark for evaluating the ability of LLMs to separate instructions from data. Our experiments reveal that even state-of-the-art LLMs struggle with this task, and that the problem is more nuanced than previously thought. We conclude by discussing potential mitigation strategies and future research directions.},
	language = {en},
	urldate = {2025-05-22},
	journal = {The Thirteenth International Conference on Learning Representations},
	publisher = {arXiv},
	author = {Zverev, Egor and Abdelnabi, Sahar and Tabesh, Soroush and Fritz, Mario and Lampert, Christoph H.},
	year = {2025},
	keywords = {ICLR},
}
