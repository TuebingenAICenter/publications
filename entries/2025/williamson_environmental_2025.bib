@article{williamson_environmental_2025,
	title = {Environmental {Intelligence}: {Context} and {Rhetoric}},
	issn = {2644-2353},
	shorttitle = {Environmental {Intelligence}},
	url = {https://fm.ls/publications/environmental-intelligence-context-and-rhetoric},
	doi = {10.1162/99608f92.73ccb788},
	abstract = {The term 'environmental intelligence' is increasingly used to describe the application of artificial intelligence to environmental problems. However, the term is often used in a way that is disconnected from the history of the concept of 'environment' in cybernetics and the philosophy of technology. This article argues that a more robust understanding of environmental intelligence requires a shift from a focus on 'intelligence' as a property of an agent to a focus on 'intelligence' as a property of a system in its context. This shift requires a re-evaluation of the role of rhetoric in the development of AI and a more nuanced understanding of the relationship between technology and the environment.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Harvard Data Science Review},
	publisher = {MIT Press},
	author = {Williamson, Robert C.},
	year = {2025},
	keywords = {Explication, Cognitive reframing, Context (archaeology), Philosophy of technology, Rhetoric, Cybernetics, Field (mathematics), Situated, Perspective (graphical), HDSR},
}
