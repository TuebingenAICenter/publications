@article{zhuang_mask-enhanced_2025,
	title = {Mask-{Enhanced} {Autoregressive} {Prediction}: {Pay} {Less} {Attention} to {Learn} {More}},
	shorttitle = {{MEAP}},
	url = {https://arxiv.org/abs/2502.07490},
	abstract = {Autoregressive (AR) models have demonstrated remarkable capabilities in sequence modeling. However, they often suffer from high computational costs and limited long-range dependency modeling due to the causal attention mechanism. In this paper, we propose Mask-Enhanced Autoregressive Prediction (MEAP), a novel framework that enhances the efficiency and effectiveness of AR models. MEAP introduces a mask-enhanced training objective that encourages the model to learn more robust representations by predicting masked tokens from a sparse context. By leveraging a sparse attention mechanism, MEAP significantly reduces the computational overhead while maintaining or even improving performance on various downstream tasks. We provide theoretical analysis and extensive empirical results to demonstrate the superiority of MEAP over existing AR models.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 42nd International Conference on Machine Learning},
	publisher = {arXiv},
	author = {Zhuang, Xialie and Jia, Zhikai and Li, Jianjin and Zhang, Zhenyu and Shen, Li and Cao, Zheng and Liu, Shiwei},
	year = {2025},
	keywords = {ICML},
}
