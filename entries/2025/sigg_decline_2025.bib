@inproceedings{sigg_decline_2025,
	title = {Decline {Now}: {A} {Combinatorial} {Model} for {Algorithmic} {Collective} {Action}},
	shorttitle = {Decline {Now}},
	url = {https://arxiv.org/pdf/2410.12633},
	doi = {10.48550/arxiv.2410.12633},
	abstract = {We study the potential for collective action among workers in algorithmic labor markets. We propose a combinatorial model of a platform where workers can choose to decline tasks. We analyze the conditions under which a group of workers can successfully exert pressure on the platform to improve their conditions. We find that the ability to coordinate is a critical factor, and that the platform's response to collective action can be complex and non-linear. Our model provides a framework for understanding the dynamics of algorithmic collective action and the potential for workers to leverage their collective power.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 2025 {CHI} {Conference} on {Human} {Factors} in {Computing} {Systems}},
	publisher = {ACM},
	author = {Sigg, Dorothee and Hardt, Moritz and Mendler-Dünner, Celestine},
	year = {2025},
	keywords = {Collective action, Action (physics), Computer science, Mathematical economics, Mathematics, Political science, Physics, Politics, Law, processed, ELLIS Institute Tübingen, Collective Action, CHI},
}
