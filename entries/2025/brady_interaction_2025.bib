@inproceedings{brady_interaction_2025,
	title = {Interaction {Asymmetry}: {A} {General} {Principle} for {Learning} {Composable} {Abstractions}},
	shorttitle = {Interaction {Asymmetry}},
	url = {https://arxiv.org/abs/2411.07784},
	doi = {10.48550/arXiv.2411.07784},
	abstract = {The ability to decompose complex systems into modular, reusable components is a hallmark of human intelligence. While recent advances in representation learning have made progress in learning disentangled representations, they often struggle to capture the compositional structure of the world. We propose Interaction Asymmetry (IA) as a general principle for learning composable abstractions. IA posits that the causal influence between components of a system is often asymmetric, and that this asymmetry can be exploited to learn modular representations. We formalize this principle and show that it leads to a natural decomposition of systems into independent, reusable modules. We demonstrate the effectiveness of our approach on a range of synthetic and real-world tasks, showing that it outperforms existing methods in terms of both sample efficiency and generalization.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {The {Thirteenth} {International} {Conference} on {Learning} {Representations} ({ICLR})},
	publisher = {arXiv},
	author = {Brady, J. and von Kügelgen, J. and Lachapelle, S. and Buchholz, S. and Kipf, T. and Brendel, W.},
	month = apr,
	year = {2025},
	keywords = {Asymmetry, Computer science, Cognitive science, Human–computer interaction, Psychology, Physics, ICLR},
}
