@misc{haxel_edapt_2025,
	title = {{EDAPT}: {Towards} {Calibration}-{Free} {BCIs} with {Continual} {Online} {Adaptation}},
	shorttitle = {{EDAPT}},
	url = {https://arxiv.org/abs/2508.10474},
	doi = {10.48550/arXiv.2508.10474},
	abstract = {Brain-Computer Interfaces (BCIs) hold great promise for restoring communication and motor function in patients with severe motor impairments. However, their clinical translation is hindered by the need for lengthy, daily calibration sessions to account for non-stationarities in neural signals. To address this, we propose EDAPT, a framework for continual online adaptation in BCIs. EDAPT leverages a self-supervised objective to continuously update the decoder parameters without requiring explicit user feedback or calibration trials. We evaluate EDAPT on large-scale electrocorticography (ECoG) datasets and demonstrate that it achieves performance comparable to supervised calibration while significantly reducing the burden on the user. Our results suggest that EDAPT is a promising step towards practical, calibration-free BCIs.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Haxel, Lukas and Kapoor, Jatin and Ziemann, Ulf and Macke, Jakob H.},
	year = {2025},
	keywords = {agentRevised},
}
