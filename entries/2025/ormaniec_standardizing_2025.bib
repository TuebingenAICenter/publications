@inproceedings{ormaniec_standardizing_2025,
	title = {Standardizing {Structural} {Causal} {Models}},
	url = {https://is.mpg.de/ei/publications/ormaniecetal25},
	doi = {10.48550/arxiv.2406.11601},
	abstract = {Structural Causal Models (SCMs) are a cornerstone of causal inference, yet their definition varies across disciplines and software implementations. This lack of standardization hinders the reproducibility of causal analyses and the interoperability of causal discovery and inference tools. In this work, we propose a standardized framework for SCMs that encompasses both functional and probabilistic aspects. We introduce a formal specification for SCMs that is agnostic to the underlying functional forms and distributions, and we provide a reference implementation in Python. Our framework supports a wide range of causal models, including those with latent variables, cycles, and non-parametric functional forms. We demonstrate the utility of our framework by implementing several existing causal discovery and inference algorithms and showing that they can be seamlessly integrated and compared within our standardized environment.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {The {Thirteenth} {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Ormaniec, Weronika and Sussex, Scott and Lorch, Lars and Schölkopf, Bernhard and Krause, Andreas},
	month = apr,
	year = {2025},
	keywords = {Computer science, Econometrics, Economics, MPI-IS, processed, ICLR},
}
