@inproceedings{szocs_forest_2025,
	title = {The {Forest} for the {Trees}: {Global} vs. {Local} {Advice} in {Human}-{AI} {Interaction}},
	shorttitle = {The {Forest} for the {Trees}},
	url = {https://charleywu.github.io/downloads/szocs2025forest.pdf},
	doi = {10.31234/osf.io/ha6nr_v1},
	abstract = {Human-AI collaboration often involves receiving advice from AI systems. This advice can be either global (e.g., a general strategy or rule) or local (e.g., a specific recommendation for a single decision). We investigate how the granularity of AI advice affects human decision-making in a sequential search task. Participants were tasked with finding the maximum value in a hidden landscape, receiving either global advice about the landscape's structure or local advice about the next best move. We find that while both types of advice improve performance compared to a no-advice baseline, they do so through different mechanisms. Global advice helps participants build a better mental model of the environment, leading to more exploratory behavior, whereas local advice acts as a direct heuristic, leading to more exploitative behavior. These results suggest that the optimal granularity of AI advice depends on the user's goal and the nature of the task.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 47th {Annual} {Conference} of the {Cognitive} {Science} {Society}},
	publisher = {Cognitive Science Society},
	author = {Szőcs, Orsolya and Zhou, Huiwen and Wu, Charley M.},
	editor = {Ruggeri, A. and Barner, D. and Walker, C. and Bramley, N.},
	year = {2025},
	keywords = {COGSCI},
}
