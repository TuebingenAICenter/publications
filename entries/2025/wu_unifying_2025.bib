@article{wu_unifying_2025,
	title = {Unifying principles of generalization: past, present, and future},
	issn = {0066-4308},
	shorttitle = {Unifying principles of generalization},
	url = {https://doi.org/10.1146/annurev-psych-021524-110810},
	doi = {10.1146/annurev-psych-021524-110810},
	abstract = {Generalization—the ability to apply knowledge from past experiences to new situations—is a cornerstone of human and artificial intelligence. Despite its importance, research on generalization has been fragmented across diverse fields, including psychology, neuroscience, machine learning, and statistics. This review provides a unifying framework for understanding generalization by identifying three core principles: similarity, structure, and strategy. We trace the historical development of these principles, examine their current state in both human and machine learning, and outline future directions for research. By synthesizing these perspectives, we aim to provide a common language for researchers across disciplines to study the mechanisms that allow agents to navigate an uncertain world.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Annual Review of Psychology},
	publisher = {Annual Reviews},
	author = {Wu, Charley M. and Meder, Björn and Schulz, Eric},
	year = {2025},
	keywords = {Generalization, Similarity (geometry), Artificial intelligence, Computer science, Leverage (statistics), Cornerstone, Machine learning, Cognitive science, Epistemology, Psychology, processed, Similarity (geometry) Leverage (statistics) Cornerstone, University of Tübingen, ARPSYCH},
}
