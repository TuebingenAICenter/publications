@article{dax_synthesizing_2025,
	title = {Synthesizing 3D {Abstractions} by {Inverting} {Procedural} {Buildings} with {Transformers}},
	shorttitle = {Synthesizing 3D {Abstractions}},
	url = {https://arxiv.org/abs/2501.17044},
	abstract = {We present a method for synthesizing 3D abstractions of buildings from single images. Our approach leverages a procedural building model and a transformer-based architecture to invert the procedural parameters from an input image. By learning to map images to the latent space of a procedural generator, we can recover compact, editable, and semantically meaningful 3D representations. We demonstrate that our method produces high-quality 3D abstractions that are consistent with the input images and can be easily manipulated for downstream tasks.},
	language = {en},
	urldate = {2025-05-22},
	journal = {CVPR Workshop on Synthetic Data for Computer Vision},
	publisher = {arXiv},
	author = {Dax, Maximilian and Serrano Berbel, Jordi and Stria, Jan and Guibas, Leonidas and Bergmann, Urs M},
	month = jun,
	year = {2025},
	keywords = {CVPR},
}
