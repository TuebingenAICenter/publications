@inproceedings{singh_almost_2025,
	title = {({Almost}) {Free} {Modality} {Stitching} of {Foundation} {Models}},
	shorttitle = {({Almost}) {Free} {Modality} {Stitching}},
	url = {https://www.arxiv.org/abs/2507.10015},
	doi = {10.18653/v1/2025.emnlp-main.1001},
	abstract = {Foundation models are typically trained on a single modality (e.g., text or images). Stitching these models together to create multimodal systems usually requires extensive training or fine-tuning. We propose a method for modality stitching that is almost free, requiring minimal computational resources and no additional training of the foundation models themselves. Our approach leverages the latent space alignment of pre-trained models to enable cross-modal tasks with high efficiency.},
	language = {en},
	urldate = {2025-07-22},
	booktitle = {Proceedings of the 2025 {Conference} on {Empirical} {Methods} in {Natural} {Language} {Processing}},
	publisher = {Association for Computational Linguistics},
	author = {Singh, J. and Misra, D. and Knyazev, B. and Orvieto, A.},
	year = {2025},
	keywords = {Image stitching, Modality (human–computer interaction), Foundation (evidence), Object (grammar), agentRevised, processed, EMNLP},
}
