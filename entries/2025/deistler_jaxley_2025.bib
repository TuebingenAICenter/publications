@article{deistler_jaxley_2025,
	title = {Jaxley: differentiable simulation enables large-scale training of detailed biophysical models of neural dynamics},
	copyright = {© 2025, The Author(s)},
	issn = {1548-7091},
	shorttitle = {Jaxley},
	url = {https://www.nature.com/articles/s41592-025-02895-w},
	doi = {10.1038/s41592-025-02895-w},
	abstract = {Biophysical models of neurons are essential for understanding how cellular properties and morphology shape neural computation. However, fitting these models to experimental data is computationally expensive and often requires manual tuning. Here we present Jaxley, a software framework for differentiable simulation of biophysical neural models. Jaxley leverages JAX to provide high-performance, GPU-accelerated simulations that are fully differentiable. This allows for the use of gradient-based optimization to fit complex, multi-compartmental models to experimental data at scale. We demonstrate that Jaxley can fit models with thousands of parameters in minutes, enabling the systematic exploration of parameter spaces and the training of biophysical models on large-scale datasets.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Nature Methods},
	publisher = {Nature Portfolio},
	author = {Deistler, Michael and Kadhim, K. L. and Pals, M. and Beck, J. and Huang, Z. and Gloeckler, M.},
	year = {2025},
	keywords = {Computer science, Task (project management), Artificial intelligence, Artificial neural network, Feed forward, Computational neuroscience, Scale (ratio), Computation, Computational model, Machine learning, Algorithm, Control engineering, Physics, agentRevised, Neocortex, Excitatory postsynaptic potential, Visual cortex, Neuroscience, Dendritic spine, Biology, Inhibitory postsynaptic potential, HertieAI, University of Tübingen, NATCOMM, NATMETHODS},
}
