@article{ilanchezian_development_2025,
	title = {Development and validation of an {AI} algorithm to generate realistic and meaningful counterfactuals for retinal imaging based on diffusion models},
	copyright = {© 2025 Ilanchezian et al. This is an open access article distributed under the terms of the Creative Commons Attribution License, which permits unrestricted use, distribution, and reproduction in any medium, provided the original author and source are credited.},
	issn = {2767-3170},
	url = {https://journals.plos.org/digitalhealth/article?id=10.1371/journal.pdig.0000853},
	doi = {10.1371/journal.pdig.0000853},
	abstract = {Counterfactual explanations are a promising approach to make deep learning models in medical imaging more interpretable. They aim to answer the question: “How would this image change if the diagnosis were different?” While existing methods often struggle with the high dimensionality and complex structure of medical images, diffusion models have recently shown great potential for high-quality image generation. In this work, we present a novel framework for generating counterfactuals for retinal images using diffusion models. We propose a method that allows for the generation of realistic and meaningful counterfactuals by conditioning the diffusion process on both the original image and the target diagnosis. We validate our approach on a large dataset of retinal images and demonstrate that our method generates counterfactuals that are not only visually realistic but also preserve the identity of the patient while successfully changing the diagnostic features. We further show that our method can be used to improve the interpretability of existing diagnostic models and provide insights into the features that drive their predictions.},
	language = {en},
	urldate = {2025-05-22},
	journal = {PLOS Digital Health},
	publisher = {Public Library of Science},
	author = {Ilanchezian, Indu and Boreiko, Valentyn and Kühlewein, Laura and Huang, Ziwei and Ayhan, Murat Seçkin and Hein, Matthias and Koch, Lisa M. and Berens, Philipp},
	month = may,
	year = {2025},
	keywords = {Counterfactual thinking, Counterfactual conditional, Artificial intelligence, Computer science, Classifier (UML), Fundus (uterus), Computer vision, Optical coherence tomography, Machine learning, Medicine, Ophthalmology, Psychology},
}
