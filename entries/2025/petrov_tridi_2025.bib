@misc{petrov_tridi_2025,
	title = {{TriDi}: {Trilateral} {Diffusion} of 3D {Humans}, {Objects}, and {Interactions}},
	shorttitle = {{TriDi}},
	url = {https://arxiv.org/abs/2412.06334},
	doi = {10.48550/arXiv.2412.06334},
	abstract = {Generating realistic 3D human-object interactions is a fundamental challenge in computer vision and graphics. Existing methods often struggle to model the complex, long-range dependencies between humans and objects, or rely on simplified representations that fail to capture the nuances of physical contact. We introduce TriDi, a novel generative framework for 3D human-object interaction synthesis. TriDi leverages a trilateral diffusion process that jointly models the human, the object, and their interaction. By factorizing the diffusion process into three interconnected branches, our model effectively captures the spatial and semantic relationships between the entities. We demonstrate that TriDi outperforms state-of-the-art methods in generating diverse and physically plausible 3D human-object interactions, as evaluated on standard benchmarks.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {IEEE},
	author = {Petrov, Ilya A. and Marin, Riccardo and Chibane, Julian and Pons-Moll, Gerard},
	year = {2025},
	keywords = {Diffusion, Computer science, Economic geography, Geography, Physics, Thermodynamics, ICCV},
}
