@misc{wiedemer_pretraining_2025,
	title = {Pretraining {Frequency} {Predicts} {Compositional} {Generalization} of {CLIP} on {Real}-{World} {Tasks}},
	shorttitle = {Pretraining {Frequency} {Predicts} {Compositional} {Generalization}},
	url = {https://brendel-group.github.io/publication/2025_02_wiedemer/},
	doi = {10.48550/arxiv.2502.18326},
	abstract = {Compositional generalization—the ability to recognize novel combinations of known concepts—is a hallmark of human intelligence. While large-scale vision-language models like CLIP have shown impressive zero-shot performance, their ability to generalize compositionally remains a subject of debate. In this work, we investigate the factors that drive compositional generalization in CLIP models. We find that the frequency of concept co-occurrence in the pretraining data is a strong predictor of compositional generalization performance. Specifically, we show that models trained on datasets with higher co-occurrence frequencies of compositional pairs exhibit better zero-shot compositional generalization. We further demonstrate that this relationship holds across a variety of real-world tasks and datasets, suggesting that data compositionality is a key driver of model performance. Our findings provide insights into the data requirements for building models that can generalize compositionally and suggest strategies for improving the compositional robustness of future vision-language models.},
	language = {en},
	urldate = {2025-05-22},
	publisher = {arXiv},
	author = {Wiedemer, Thaddäus and Sharma, Yash and Prabhu, Ameya and Bethge, Matthias and Brendel, Wieland},
	year = {2025},
	keywords = {Generalization, Object (grammar), Filter (signal processing), Scaling, Pattern recognition (psychology)},
}
