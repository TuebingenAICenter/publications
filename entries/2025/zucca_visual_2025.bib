@article{zucca_visual_2025,
	title = {Visual loom caused by self-movement or object-movement elicits distinct responses in mouse superior colliculus},
	copyright = {© 2025 Elsevier Inc.},
	issn = {0960-9822},
	shorttitle = {Visual loom caused by self-movement or object-movement},
	url = {https://www.cell.com/current-biology/fulltext/S0960-9822(25)00879-6},
	doi = {10.1016/j.cub.2025.07.013},
	abstract = {Visual looming stimuli, which signal an approaching object, are potent triggers for defensive behaviors. However, looming-like visual flow is also generated by self-movement toward objects. How the brain distinguishes between these two sources of looming flow is unknown. Here, we show that neurons in the mouse superior colliculus (SC) respond differently to looming stimuli depending on whether they are caused by object movement or self-movement. We find that SC neurons are more sensitive to object-movement-induced looms than to self-movement-induced looms. This difference is not explained by differences in the visual statistics of the stimuli but rather by the integration of non-visual signals related to self-movement. Our results suggest that the SC acts as a gate for defensive responses, prioritizing stimuli that are likely to be external threats over those generated by the animal's own actions.},
	language = {en},
	urldate = {2025-08-14},
	journal = {Current Biology},
	publisher = {Elsevier},
	author = {Zucca, Stefano and Schulz, Auguste and Gonçalves, Pedro J. and Macke, Jakob H. and Saleem, Aman B. and Solomon, Samuel G.},
	year = {2025},
	keywords = {Biology, Superior colliculus, Movement (music), LOOM, Neuroscience, Object (grammar), Communication, Artificial intelligence, Psychology, Computer science, agentRevised, CURR BIOL},
}
