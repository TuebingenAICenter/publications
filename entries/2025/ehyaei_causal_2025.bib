@misc{ehyaei_causal_2025,
	title = {Causal fair metric: {Bridging} causality, individual fairness, and adversarial robustness},
	shorttitle = {Causal fair metric},
	url = {https://is.mpg.de/hml/publications/ahmadcausalfair},
	doi = {10.48550/arxiv.2310.19391},
	abstract = {Individual fairness requires that similar individuals be treated similarly. However, defining similarity is challenging, especially in the presence of causal relationships. In this paper, we propose a novel causal fair metric that leverages causal models to define similarity between individuals. We show that our metric is robust to adversarial perturbations and can be used to train fair models. We demonstrate the effectiveness of our approach on several real-world datasets.},
	language = {en},
	urldate = {2025-05-22},
	author = {Ehyaei, Ahmad Reza and Farnadi, Golnoosh and Samadi, Samira},
	year = {2025},
	keywords = {Adversarial system, Computer science, Counterfactual thinking, Robustness (evolution), Causal model, Machine learning, Metric (unit), Artificial intelligence, Data mining, Econometrics, Mathematics, Psychology, Social psychology, Statistics, Economics, TMLR},
}
