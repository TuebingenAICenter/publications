@misc{laing_adam_2025,
	title = {Adam {Simplified}: {Bias} {Correction} {Debunked}},
	shorttitle = {Adam {Simplified}},
	url = {https://arxiv.org/pdf/2511.20516},
	doi = {10.48550/arxiv.2511.20516},
	abstract = {The Adam optimizer is the de facto standard for training deep learning models. Its update rule includes a bias correction term, intended to compensate for the initialization of the moving averages at zero. In this work, we show that this term is unnecessary. We prove that for a wide range of hyperparameters, the bias correction term does not affect the convergence rate of Adam. We further provide empirical evidence that removing the bias correction term does not degrade performance on standard benchmarks, including language modeling and image classification. Our results suggest that the bias correction term can be safely removed, simplifying the implementation and analysis of Adam.},
	language = {en},
	urldate = {2025-05-22},
	publisher = {MPI-IS},
	author = {Laing, Sam and Orvieto, Antonio},
	year = {2025},
	keywords = {Cornerstone, Smoothing, Inclusion (mineral), Feature (linguistics), Empirical evidence, Scheduling (production processes), agentRevised, NEURIPS},
}
