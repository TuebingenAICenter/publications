@inproceedings{reizinger_cross-entropy_2025,
	title = {Cross-{Entropy} {Is} {All} {You} {Need} to {Invert} the {Data} {Generating} {Process}},
	shorttitle = {Cross-{Entropy} {Is} {All} {You} {Need}},
	url = {https://arxiv.org/abs/2410.21869},
	doi = {10.48550/arXiv.2410.21869},
	abstract = {Generative modeling has recently been dominated by diffusion models, which learn to invert the data generating process by predicting the noise added to a sample. This approach requires a specific training objective, typically mean squared error, and a carefully designed noise schedule. In this work, we show that these design choices are not necessary. We demonstrate that any generative model can be trained to invert the data generating process using only the cross-entropy loss, provided the data is discretized. This formulation allows us to unify diffusion models and autoregressive models under a single framework. We show that our approach, which we call Cross-Entropy Diffusion (CED), achieves state-of-the-art performance on several benchmarks, while being simpler to implement and more stable to train than existing diffusion models.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {The {Thirteenth} {International} {Conference} on {Learning} {Representations} ({ICLR})},
	publisher = {arXiv},
	author = {Reizinger, P. and Bizeul, A. and Juhos, A. and Vogt, J. E. and Balestriero, R. and Brendel, W. and Klindt, D.},
	month = apr,
	year = {2025},
	keywords = {Cross entropy, Process (computing), Computer science, Statistical physics, Mathematics, Statistics, Principle of maximum entropy, Physics, Programming language, ELLIS Institute Tübingen, MPI-IS, processed, ICLR},
}
