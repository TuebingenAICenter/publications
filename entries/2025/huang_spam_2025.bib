@article{huang_spam_2025,
	title = {{SPAM}: {Spike}-{Aware} {Adam} with {Momentum} {Reset} for {Stable} {LLM} {Training}},
	shorttitle = {{SPAM}},
	url = {https://arxiv.org/abs/2501.06842},
	abstract = {Large Language Model (LLM) training is frequently interrupted by loss spikes, which can lead to training instability or even divergence. Existing solutions often rely on gradient clipping or learning rate warm-up, which may not be sufficient to mitigate severe spikes. In this paper, we propose Spike-Aware Adam with Momentum (SPAM), a novel optimizer that detects loss spikes and resets the momentum buffer to stabilize training. SPAM identifies spikes by monitoring the loss trajectory and resets the momentum when a spike is detected, effectively preventing the optimizer from overshooting. We demonstrate that SPAM significantly improves the stability of LLM training across various architectures and scales, outperforming standard Adam and other stabilization techniques. Our code is available at https://github.com/TianjinYellow/SPAM-Optimizer.},
	language = {en},
	urldate = {2025-05-14},
	journal = {The Thirteenth International Conference on Learning Representations},
	publisher = {arXiv},
	author = {Huang, Tianjin and Zhu, Ziquan and Jin, Gaojie and Liu, Lu and Wang, Zhangyang and Liu, Shiwei},
	year = {2025},
	keywords = {ICLR},
}
