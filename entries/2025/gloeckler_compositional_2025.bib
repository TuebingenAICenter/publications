@inproceedings{gloeckler_compositional_2025,
	title = {Compositional simulation-based inference for time series},
	shorttitle = {Compositional simulation-based inference for time series},
	url = {https://arxiv.org/abs/2411.02728},
	doi = {10.48550/arXiv.2411.02728},
	abstract = {Simulation-based inference (SBI) has become a powerful tool for performing Bayesian inference in models where the likelihood is intractable but simulation is possible. However, standard SBI methods often struggle with high-dimensional time series data, as they typically rely on summary statistics or embedding networks that may not capture the temporal dependencies effectively. In this paper, we propose a compositional approach to SBI for time series, which decomposes the inference problem into a sequence of smaller, more manageable tasks. By leveraging the Markov property of the underlying generative process, we construct a compositional posterior estimator that can be trained on short segments of the time series. We demonstrate that our method achieves state-of-the-art performance on a range of challenging time series models, including those with complex temporal dynamics and high-dimensional observations.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {The {Thirteenth} {International} {Conference} on {Learning} {Representations} ({ICLR})},
	publisher = {arXiv},
	author = {Gloeckler, M. and Toyota, S. and Fukumizu, K. and Macke, J. H.},
	month = apr,
	year = {2025},
	keywords = {Series (stratigraphy), Inference, Computer science, Time series, Artificial intelligence, Machine learning, Geology, processed, University of Tübingen, MPI-IS, ICLR},
}
