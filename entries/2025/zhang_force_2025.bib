@article{zhang_force_2025,
	title = {{FORCE}: {Dataset} and {Method} for {Intuitive} {Physics} {Guided} {Human}-object {Interaction}},
	shorttitle = {{FORCE}},
	url = {https://virtualhumans.mpi-inf.mpg.de/force/zhang2024force.pdf},
	abstract = {Human-object interaction (HOI) is a fundamental task in computer vision and graphics. While recent methods have made significant progress in reconstructing 3D human motion and object geometry, they often struggle to produce physically plausible interactions, frequently resulting in interpenetration or floating artifacts. In this paper, we introduce FORCE, a novel dataset and method for intuitive physics-guided human-object interaction. Our dataset contains 100 diverse human-object interaction sequences with high-quality 3D human and object meshes, along with ground-truth contact information and interaction forces. We propose a physics-guided optimization framework that leverages our dataset to synthesize physically plausible HOI. Our method effectively resolves interpenetration and improves the physical consistency of the interaction. We demonstrate the effectiveness of our approach on both synthetic and real-world data, showing significant improvements over state-of-the-art methods.},
	language = {en},
	urldate = {2025-05-22},
	journal = {International Conference on 3D Vision (3DV)},
	author = {Zhang, Xiaohan and Bhatnagar, Bharat Lal and Starke, Sebastian and Petrov, Ilya A. and Guzov, Vladimir and Dhamo, Helisa and Pérez Pellitero, Eduardo and Pons-Moll, Gerard},
	year = {2025},
	keywords = {3DV},
}
