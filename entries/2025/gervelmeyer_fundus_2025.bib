@article{gervelmeyer_fundus_2025,
	title = {Fundus {Image} {Toolbox}: {A} {Python} package for fundus image processing},
	issn = {2475-9066},
	shorttitle = {Fundus {Image} {Toolbox}},
	url = {https://doi.org/10.21105/joss.07101},
	doi = {10.21105/joss.07101},
	abstract = {Fundus photography is a standard diagnostic tool in ophthalmology, providing high-resolution images of the retina. With the increasing use of deep learning in medical image analysis, there is a growing need for standardized, efficient, and reproducible preprocessing pipelines for fundus images. Existing tools are often fragmented, lack comprehensive documentation, or are not easily integrated into modern Python-based machine learning workflows. To address this, we introduce the Fundus Image Toolbox (FIT), an open-source Python package designed to streamline the preprocessing of fundus images. FIT provides a modular and extensible framework for common tasks such as image cropping, resizing, color normalization, and vessel segmentation. The toolbox is built on top of popular libraries like NumPy, OpenCV, and PyTorch, ensuring compatibility with standard data science stacks. By providing a unified interface for these operations, FIT aims to reduce the development time for researchers and facilitate the reproducibility of studies in retinal image analysis.},
	language = {en},
	journal = {Journal of Open Source Software},
	publisher = {Open Journals},
	author = {Gervelmeyer, Julius and Müller, Sarah and Huang, Ziwei and Berens, Philipp},
	month = apr,
	year = {2025},
	keywords = {Python (programming language), Toolbox, Computer science, Computer graphics (images), Artificial intelligence, Image processing, Fundus (uterus), Computer vision, Image (mathematics), Ophthalmology, Programming language, Medicine, processed, Python, Python Toolbox Fundus (uterus), JOSS},
}
