@inproceedings{xie_mvgbench_2025,
	title = {{MVGBench}: {Comprehensive} {Benchmark} for {Multi}-view {Generation} {Models}},
	shorttitle = {{MVGBench}},
	url = {https://virtualhumans.mpi-inf.mpg.de/MVGBench/MVGBench.pdf},
	doi = {10.1109/iccv51701.2025.00769},
	abstract = {Multi-view generation models have recently achieved remarkable progress in generating consistent multi-view images from a single input image. However, evaluating these models remains challenging due to the lack of a comprehensive benchmark and standardized evaluation metrics. Existing works often rely on limited datasets and inconsistent evaluation protocols, making it difficult to compare different methods fairly. To address this, we introduce MVGBench, a comprehensive benchmark for multi-view generation models. MVGBench consists of a large-scale, diverse dataset of 3D objects and scenes, covering a wide range of categories and complexities. We propose a set of standardized evaluation metrics that assess both the visual quality and the multi-view consistency of the generated images. We evaluate several state-of-the-art multi-view generation models on MVGBench and provide a detailed analysis of their performance. Our results reveal the strengths and weaknesses of existing models and highlight the challenges that remain in the field. We hope that MVGBench will serve as a valuable resource for the research community and facilitate the development of more robust and effective multi-view generation models.},
	language = {en},
	urldate = {2025-07-08},
	booktitle = {Proceedings of the {IEEE}/{CVF} {International} {Conference} on {Computer} {Vision} ({ICCV})},
	publisher = {IEEE},
	author = {Xie, Xianghui and Zou, Chuhang and Karumuri, Gitika Meher and Lenssen, Jan Eric and Pons-Moll, Gerard},
	year = {2025},
	keywords = {Benchmark (surveying), Context (archaeology), Feature (linguistics), Key (lock), Identification (biology), agentRevised, processed, ICCV},
}
