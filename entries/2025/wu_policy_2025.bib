	doi = {10.1145/3757887.3767683},
	abstract = {We study the design of policies in environments where agents' welfare evolves over time in response to policy interventions. We model this as a dynamic system where a policymaker chooses a sequence of policies to maximize a long-run welfare objective. We characterize the optimal policy design problem and show that it can be framed as a constrained optimization problem. We provide conditions under which the optimal policy is stationary and discuss the implications for policy design in practice.},
