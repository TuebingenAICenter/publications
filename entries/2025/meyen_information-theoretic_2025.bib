@article{meyen_information-theoretic_2025,
	title = {Information-{Theoretic} {Measures} of {Metacognition}: {Bounds} and {Relation} to {Group} {Performance}},
	issn = {2470-2986},
	shorttitle = {Information-{Theoretic} {Measures} of {Metacognition}},
	url = {https://doi.org/10.1162/OPMI.a.40},
	doi = {10.1162/OPMI.a.40},
	abstract = {Metacognition—the ability to monitor one's own performance—is a cornerstone of human cognition. While various measures of metacognition exist, they often lack a common theoretical foundation, making it difficult to compare results across studies. We propose a framework based on information theory to quantify metacognition. We define metacognition as the mutual information between a person's confidence and their performance. We show that this measure is related to the area under the receiver operating characteristic curve (AUROC) and the area under the confidence-accuracy characteristic curve (AUCAUC). We derive upper and lower bounds for this information-theoretic measure and show that it is related to the performance of a group of agents. Our framework provides a unified perspective on metacognition and allows for a principled comparison of different measures.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Open Mind},
	publisher = {MIT Press},
	author = {Meyen, Sascha and Göppert, Frieder and Schrenk, Carina and von Luxburg, Ulrike and Franz, Volker},
	year = {2025},
	keywords = {Type (biology), Binary number, Noise (video), Group (periodic table), Decoupling (probability), Upper and lower bounds, Relation (database), Pattern recognition (psychology), agentRevised},
}
