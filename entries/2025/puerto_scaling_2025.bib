@inproceedings{puerto_scaling_2025,
	title = {Scaling {Up} {Membership} {Inference}: {When} and {How} {Attacks} {Succeed} on {Large} {Language} {Models}},
	shorttitle = {Scaling {Up} {Membership} {Inference}},
	url = {https://aclanthology.org/2025.findings-naacl.234.pdf},
	doi = {10.48550/arXiv.2411.00154},
	abstract = {Membership Inference Attacks (MIAs) aim to determine whether a specific data point was used to train a machine learning model. While MIAs have been extensively studied for small-scale models, their effectiveness on Large Language Models (LLMs) remains under-explored. In this work, we conduct a comprehensive evaluation of MIAs on LLMs, scaling up to models with 70 billion parameters. We find that existing attacks often fail to scale, performing no better than random guessing on large models. To address this, we introduce a novel MIA framework that leverages the unique properties of LLMs, such as their autoregressive nature and the availability of log-probabilities. Our proposed attack, which we call 'Scaling-MIA', significantly outperforms existing methods, achieving high success rates even on massive models. We further analyze the factors that contribute to the success of MIAs, identifying key vulnerabilities in LLM training pipelines. Our findings provide critical insights into the privacy risks associated with LLMs and highlight the need for more robust defense mechanisms.},
	language = {en},
	urldate = {2025-05-22},
	booktitle = {Findings of the {Association} for {Computational} {Linguistics}: {NAACL} 2025},
	publisher = {Association for Computational Linguistics},
	author = {Puerto, Haritz and Gubri, Martin and Yun, Sangdoo and Oh, Seong Joon},
	year = {2025},
	keywords = {processed, University of Tübingen, NAACL},
}
