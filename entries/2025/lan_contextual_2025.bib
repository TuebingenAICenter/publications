@misc{lan_contextual_2025,
	title = {Contextual {Integrity} in {LLMs} via {Reasoning} and {Reinforcement} {Learning}},
	shorttitle = {Contextual {Integrity} in {LLMs}},
	url = {https://arxiv.org/abs/2506.04245},
	doi = {10.48550/arxiv.2506.04245},
	abstract = {Large Language Models (LLMs) are increasingly deployed in sensitive domains, necessitating strict adherence to privacy norms. Contextual Integrity (CI) provides a robust framework for evaluating privacy by considering the context in which information is shared. However, existing privacy alignment techniques for LLMs often rely on static rules or simple instruction tuning, which struggle to capture the nuanced, context-dependent nature of privacy. In this work, we introduce a novel framework to enforce Contextual Integrity in LLMs. We first formalize CI as a reasoning task, enabling models to evaluate information flows against context-specific norms. We then propose a reinforcement learning approach to align LLMs with these norms, leveraging a reward model trained on CI-based feedback. Our experiments demonstrate that our approach significantly improves the model's ability to adhere to privacy norms across diverse contexts while maintaining utility, outperforming existing baselines in both privacy preservation and reasoning capabilities.},
	language = {en},
	urldate = {2025-06-01},
	publisher = {arXiv},
	author = {Lan, Guangchen and Inan, Huseyin A. and Abdelnabi, Sahar and Kulkarni, Janardhan and Wutschitz, Lukas and Shokri, Reza and Brinton, Christopher G. and Sim, Robert B.},
	year = {2025},
	keywords = {Reinforcement learning, Task (project management), Context (archaeology), Code (set theory), Transfer of learning, Reinforcement, NEURIPS},
}
