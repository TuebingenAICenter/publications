@misc{davydov_llm_2025,
	title = {{LLM} generation novelty through the lens of semantic similarity},
	shorttitle = {{LLM} generation novelty},
	url = {https://arxiv.org/abs/2510.27313},
	doi = {10.48550/arXiv.2510.27313},
	abstract = {Large Language Models (LLMs) are increasingly used to generate content, raising questions about the novelty of their outputs. We propose a framework to quantify the novelty of LLM-generated text by measuring its semantic similarity to a reference corpus. We introduce a novel metric, Semantic Novelty, which leverages embedding-based similarity search to identify the most similar documents in a large-scale dataset. We demonstrate the utility of our approach by analyzing the novelty of generations from various LLMs across different domains and tasks. Our findings reveal that LLM novelty is highly dependent on the prompt, model architecture, and decoding strategy, and that semantic similarity provides a robust and interpretable measure of generation novelty.},
	language = {en},
	urldate = {2025-05-22},
	publisher = {arXiv},
	author = {Davydov, Philipp and Prabhu, Ameya and Bethge, Matthias and Nguyen, Elisa and Oh, Seong Joon},
	year = {2025},
	keywords = {Novelty, Key (lock), Search engine indexing, Semantic similarity, Embedding, Novelty detection, Similarity (geometry), Frame (networking)},
}
