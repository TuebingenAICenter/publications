@inproceedings{guzov_hmd2_2025,
	title = {{HMDˆ2}: {Environment}-aware {Motion} {Generation} from {Single} {Egocentric} {Head}-{Mounted} {Device}},
	shorttitle = {{HMDˆ2}},
	url = {https://arxiv.org/abs/2409.13426},
	doi = {10.48550/arxiv.2409.13426},
	abstract = {We present HMDˆ2, a novel framework for generating full-body human motion from a single egocentric head-mounted device (HMD). Existing methods for egocentric motion capture often struggle with the limited field-of-view of HMD cameras, leading to ambiguous poses and lack of interaction with the environment. HMDˆ2 addresses these challenges by leveraging a large-scale dataset of egocentric videos and a novel environment-aware motion generation model. Our model incorporates a spatial-temporal transformer architecture that effectively integrates egocentric visual features with environmental context, enabling the generation of physically plausible and environment-aware motions. We demonstrate that HMDˆ2 significantly outperforms state-of-the-art methods in terms of motion accuracy and environmental consistency, particularly in complex, cluttered scenes.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {International {Conference} on 3D {Vision} (3DV)},
	publisher = {University of Tübingen},
	author = {Guzov, Vladimir and Jiang, Yifeng and Hong, Fangzhou and Pons-Moll, Gerard and Newcombe, Richard and Liu, C. Karen and Ye, Yuting and Ma, Lingni},
	year = {2025},
	keywords = {Optical head-mounted display, Head (geology), Computer science, Motion (physics), Computer vision, Computer graphics (images), Artificial intelligence, Geology, Geomorphology, processed, University of Tübingen, 3DV},
}
