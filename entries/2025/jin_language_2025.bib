@misc{jin_language_2025,
	title = {Language {Model} {Alignment} in {Multilingual} {Trolley} {Problems}},
	url = {https://arxiv.org/abs/2407.02273},
	doi = {10.48550/arXiv.2407.02273},
	abstract = {As large language models (LLMs) are increasingly deployed globally, it is critical to understand whether their moral judgments align with human values across different cultures. We introduce a multilingual trolley problem dataset, covering 12 languages and 14 cultures, to evaluate the moral alignment of LLMs. We find that while LLMs show a high degree of moral consistency across languages, they also exhibit significant cultural biases. Our results suggest that current alignment techniques may not be sufficient to ensure cross-cultural moral alignment, and we propose a framework for future research in this direction.},
	language = {en},
	urldate = {2025-05-22},
	author = {Jin, Zhijing and Kleiman-Weiner, Max and Piatti, Giorgio and Levine, Sydney and Liu, Jiarui and Gonzalez, Fernando and Ortu, Francesco and Strausz, András and Sachan, Mrinmaya and Mihalcea, Rada and Choi, Yejin and Schölkopf, Bernhard},
	month = apr,
	year = {2025},
	keywords = {Computer science, Linguistics, Natural language processing, Philosophy, ICLR},
}
