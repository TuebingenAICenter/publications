@inproceedings{hwang_ovs_2025,
	title = {{OVS} {Meets} {Continual} {Learning}: {Towards} {Sustainable} {Open}-{Vocabulary} {Segmentation}},
	shorttitle = {{OVS} {Meets} {Continual} {Learning}},
	url = {https://arxiv.org/abs/2410.11536},
	abstract = {Existing Open-Vocabulary Segmentation (OVS) models operate with a fixed vision-language (VL) model as a backbone, limiting their ability to incorporate new categories or adapt to new domains without full retraining. In this paper, we introduce a new setting, Continual Open-Vocabulary Segmentation (COVS), where models must learn to incorporate new knowledge from incremental data streams while maintaining existing OVS capabilities. We present a baseline for COVS that leverages existing OVS architectures and addresses the challenges of catastrophic forgetting and knowledge drift. Our extensive experiments across various benchmarks demonstrate the efficiency and sustainability of the proposed approach for real-world segmentation tasks.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {University of Tübingen},
	author = {Hwang, Dongjun and Kim, Yejin and Lee, Minyoung and Oh, Seong Joon and Choe, Junsuk},
	year = {2025},
	keywords = {agentRevised, processed, NEURIPS},
}
