@inproceedings{movahedi_geometric_2025,
	title = {Geometric {Inductive} {Biases} of {Deep} {Networks}: {Role} of {Data} and {Architecture}},
	shorttitle = {Geometric {Inductive} {Biases} of {Deep} {Networks}},
	url = {https://arxiv.org/abs/2410.12025},
	doi = {10.48550/arXiv.2410.12025},
	abstract = {Deep learning models exhibit remarkable generalization capabilities, often attributed to their inductive biases. While recent work has focused on the role of architecture in shaping these biases, the interplay between data geometry and architectural choices remains less understood. In this paper, we investigate the geometric inductive biases of deep networks by analyzing how the interaction between the data manifold and the network architecture influences the learned representations. We propose a framework to quantify these biases and demonstrate that they are not solely determined by the architecture but are significantly shaped by the underlying geometry of the data. Our empirical results across various architectures and datasets highlight the importance of aligning architectural inductive biases with the geometric properties of the data to improve generalization.},
	language = {en},
	urldate = {2025-05-22},
	booktitle = {The {Thirteenth} {International} {Conference} on {Learning} {Representations}},
	publisher = {arXiv},
	author = {Movahedi, Sajad and Orvieto, Antonio and Moosavi-Dezfooli, Seyed-Mohsen},
	year = {2025},
	keywords = {Architecture, Computer science, Inductive bias, Artificial intelligence, Geography, Engineering, Systems engineering, Archaeology, processed, MPI-IS, ELLIS Institute Tübingen, ICLR},
}
