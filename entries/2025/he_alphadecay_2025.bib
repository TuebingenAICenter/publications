@article{he_alphadecay_2025,
	title = {{AlphaDecay}: {Module}-wise {Weight} {Decay} for {Heavy}-{Tailed} {Balancing} in {LLMs}},
	shorttitle = {{AlphaDecay}},
	url = {https://arxiv.org/abs/2506.14562},
	abstract = {Large Language Models (LLMs) often exhibit a heavy-tailed distribution in their weight magnitudes, where a small fraction of weights possess significantly larger values than the rest. While these large weights are crucial for model performance, they are often prone to overfitting and can lead to instability during training. In this paper, we propose AlphaDecay, a novel module-wise weight decay strategy designed to balance the heavy-tailed distribution of weights in LLMs. AlphaDecay dynamically adjusts the weight decay strength for each module based on the distribution of its weights, effectively regularizing the large weights while preserving the smaller ones. We demonstrate the effectiveness of AlphaDecay across various LLM architectures and tasks, showing that it consistently improves model performance and stability compared to standard weight decay methods.},
	language = {en},
	urldate = {2025-06-25},
	journal = {Advances in Neural Information Processing Systems},
	publisher = {arXiv},
	author = {He, Di and Jaiswal, Ajay and Tu, Songjun and Shen, Li and Yuan, Ganzhao and Liu, Shiwei and Yin, Lu},
	year = {2025},
	keywords = {NeurIPS},
}
