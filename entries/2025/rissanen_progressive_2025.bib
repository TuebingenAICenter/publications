@inproceedings{rissanen_progressive_2025,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Progressive {Tempering} {Sampler} with {Diffusion}},
	shorttitle = {Progressive {Tempering} {Sampler} with {Diffusion}},
	url = {https://proceedings.mlr.press/v267/rissanen25a.html},
	abstract = {We introduce Progressive Tempering Sampler (PTS), a novel MCMC method that leverages diffusion models to sample from complex, multimodal target distributions. PTS constructs a sequence of tempered distributions by interpolating between a simple base distribution and the target distribution using a diffusion process. By learning a score-based transition kernel that adapts to the tempering schedule, PTS effectively bridges the gap between modes, overcoming the limitations of traditional tempering methods. We demonstrate the efficacy of PTS on a range of challenging sampling tasks, including high-dimensional Bayesian inference and generative modeling, where it consistently outperforms existing state-of-the-art samplers.},
	language = {en},
	booktitle = {Proceedings of the 42nd {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Rissanen, S. and OuYang, R. and He, J. and Chen, W. and Heinonen, M. and Solin, A. and Hernández-Lobato, J. M.},
	editor = {Singh, Aarti and Fazel, Maryam and Hsu, Daniel and Lacoste-Julien, Simon and Berkenkamp, Felix and Maharaj, Tegan and Wagstaff, Kiri and Zhu, Jerry},
	month = jul,
