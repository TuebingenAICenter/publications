@article{li_sos1_2025,
	title = {{SoS1}: {O1} and {R1}-{Like} {Reasoning} {LLMs} are {Sum}-of-{Square} {Solvers}},
	shorttitle = {{SoS1}},
	url = {https://arxiv.org/abs/2502.20545},
	abstract = {Reasoning Large Language Models (LLMs) like OpenAI's o1 and DeepSeek's R1 have demonstrated remarkable capabilities in solving complex mathematical and logical problems. However, the underlying mechanism of their reasoning process remains largely a black box. In this paper, we propose a novel perspective: we hypothesize that these reasoning LLMs act as Sum-of-Squares (SoS) solvers. The SoS hierarchy is a powerful framework in optimization that provides a systematic way to generate certificates of non-negativity for polynomials, which can be used to solve a wide range of hard optimization problems. We provide empirical evidence that the chain-of-thought (CoT) generated by these models can be interpreted as a sequence of steps that construct an SoS proof. We further demonstrate that by prompting these models to explicitly follow the SoS framework, we can significantly improve their performance on challenging optimization tasks. Our findings suggest that the reasoning capabilities of modern LLMs may be deeply connected to the mathematical structure of the SoS hierarchy, opening new avenues for understanding and improving their reasoning abilities.},
	language = {en},
	urldate = {2025-05-14},
	journal = {arXiv preprint arXiv:2502.20545},
	publisher = {arXiv},
	author = {Li, Kechen and Zhu, Wenqi and Cartis, Coralia and Ji, Tianbo and Liu, Shiwei},
	month = feb,
	year = {2025},
	keywords = {ARXIV},
}
