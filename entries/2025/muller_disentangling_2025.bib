@article{muller_disentangling_2025,
	title = {Disentangling representations of retinal images with generative models},
	issn = {1361-8415},
	url = {https://www.sciencedirect.com/science/article/pii/S1361841525001756},
	doi = {10.1016/j.media.2025.103441},
	abstract = {Retinal imaging is a cornerstone of ophthalmological diagnostics. While deep learning models have achieved high performance in automated disease classification, they often act as black boxes, providing little insight into the underlying features that drive their decisions. Disentangled representation learning offers a promising path towards more interpretable models by learning to separate independent factors of variation in the data. In this work, we investigate the use of generative models for disentangling representations of retinal images. We propose a framework that leverages a variational autoencoder with a disentangled latent space to learn interpretable features from retinal fundus images. We demonstrate that our model can disentangle anatomical and pathological factors of variation, such as the optic disc position, vessel structure, and the presence of lesions. Furthermore, we show that the learned representations are useful for downstream tasks, including disease classification and image synthesis, while providing insights into the features relevant for these tasks. Our results suggest that disentangled representation learning is a powerful tool for enhancing the interpretability of deep learning models in medical imaging.},
	language = {en},
	urldate = {2025-07-10},
	journal = {Medical Image Analysis},
	publisher = {Elsevier},
	author = {Müller, Sarah and Koch, Lisa M. and Lensch, Hendrik P. and Berens, Philipp},
	month = oct,
	year = {2025},
	keywords = {Pattern recognition (psychology), Generative model, Retinal, Feature (linguistics), Representation (politics), processed, University of Tübingen, MEDIA},
}
