@inproceedings{schmors_trace_2025,
	title = {{TRACE}: {Contrastive} learning for multi-trial time-series data in neuroscience},
	shorttitle = {{TRACE}},
	url = {https://arxiv.org/abs/2506.04906},
	doi = {10.48550/arxiv.2506.04906},
	abstract = {Neuroscience experiments often record neural activity across multiple trials of the same stimulus or behavior. While this multi-trial structure is a hallmark of neural data, most representation learning methods treat trials as independent samples, failing to exploit the shared structure across trials. We introduce TRACE (Trial-aligned Contrastive Embedding), a self-supervised framework designed to learn representations of neural time-series by leveraging trial-to-trial variability. TRACE uses a contrastive objective that encourages the model to align representations of the same stimulus across different trials while pushing apart representations of different stimuli. We demonstrate that TRACE learns robust, interpretable representations that outperform standard self-supervised and supervised baselines on downstream tasks, including stimulus decoding and behavioral prediction, across multiple datasets and recording modalities.},
	language = {en},
	urldate = {2025-06-15},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {arXiv},
	author = {Schmors, L. and Gonschorek, D. and Böhm, J. N. and Qiu, Y. and Zhou, N. and Kobak, D. and Berens, P.},
	month = dec,
	year = {2025},
	keywords = {TRACE (psycholinguistics), Exploit, Artificial neural network, Feature learning, Quality (philosophy), Neural activity, Contrast (vision), agentRevised, processed, NEURIPS},
}
