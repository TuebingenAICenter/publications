@article{reichstein_early_2025,
	title = {Early warning of complex climate risk with integrated artificial intelligence},
	issn = {2041-1723},
	shorttitle = {Early warning of complex climate risk},
	url = {https://www.nature.com/articles/s41467-025-57640-w},
	doi = {10.1038/s41467-025-57640-w},
	abstract = {Climate change is increasing the frequency and intensity of extreme weather events, leading to complex, cascading risks that threaten human and natural systems. Traditional early warning systems often struggle to capture the non-linear, multi-scale, and interconnected nature of these risks. Here, we propose an integrated artificial intelligence (AI) framework for early warning of complex climate risks. This framework leverages advances in machine learning, including causal inference, graph neural networks, and foundation models, to improve the detection, attribution, and prediction of climate-related hazards and their impacts. We discuss the challenges and opportunities of integrating AI into existing early warning systems, emphasizing the need for transparency, accountability, and interdisciplinary collaboration. By combining physical understanding with data-driven insights, this approach can enhance our ability to anticipate and mitigate the impacts of a changing climate.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Nature Communications},
	publisher = {Nature Publishing Group},
	author = {Reichstein, M. and Benson, V. and Blunk, J. and Camps-Valls, G. and Creutzig, F. and Fearnley, C. J. and Han, B. and Kornhuber, K. and Rahaman, N. and Schölkopf, B. and Tárraga, J. M. and Vinuesa, R. and Dall, K. and Denzler, J. and Frank, D. and Martini, G. and Nganga, N. and Maddix, D. C. and Weldemariam, K.},
	month = mar,
	year = {2025},
	keywords = {Warning system, Computer science, Risk analysis (engineering), Accountability, Hazard, Climate change, Transparency (behavior), Geospatial analysis, Data science, Environmental resource management, Computer security, Business, Political science, Geography, Ecology, ELLIS Institute Tübingen, MPI-IS, processed},
