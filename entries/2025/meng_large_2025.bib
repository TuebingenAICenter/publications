@misc{meng_large_2025,
	title = {Do {Large} {Step}-{Sizes} {Work} with {Data} on the {Sphere}?},
	shorttitle = {Do {Large} {Step}-{Sizes} {Work} with {Data} on the {Sphere}?},
	url = {https://arxiv.org/abs/2507.11228},
	abstract = {We study the convergence of gradient descent (GD) for logistic regression with data points constrained to the unit sphere. While it is well-known that GD with a constant step-size can diverge for logistic regression on general datasets, we show that when data is restricted to the sphere, GD with a constant step-size converges to the global minimizer for any step-size smaller than 2. This result is surprising as it suggests that the geometry of the data can significantly improve the stability of optimization algorithms. We provide a theoretical analysis of this phenomenon and support our findings with numerical experiments.},
	language = {en},
	urldate = {2025-07-24},
	publisher = {arXiv},
	author = {Meng, S. Yi and Goujaud, B. and Orvieto, A. and De Sa, C.},
	year = {2025},
	keywords = {cs.LG},
}
