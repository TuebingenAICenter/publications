@inproceedings{shvetsova_unbiasing_2025,
	title = {Unbiasing through {Textual} {Descriptions}: {Mitigating} {Representation} {Bias} in {Video} {Benchmarks}},
	shorttitle = {Unbiasing through {Textual} {Descriptions}},
	url = {https://openaccess.thecvf.com/content/CVPR2025/html/Shvetsova_Unbiasing_through_Textual_Descriptions_Mitigating_Representation_Bias_in_Video_Benchmarks_CVPR_2025_paper.html},
	abstract = {Video benchmarks are often plagued by representation bias, where models learn to rely on spurious correlations rather than the actual action content. In this work, we propose a novel approach to mitigate this bias by leveraging textual descriptions. We introduce a framework that uses language models to generate descriptive captions for video clips, which are then used to train models that are more robust to representation bias. Our experiments demonstrate that our approach significantly improves performance on several video benchmarks, while also providing better interpretability.},
	language = {en},
	urldate = {2025-05-22},
	booktitle = {Proceedings of the {IEEE}/{CVF} {Conference} on {Computer} {Vision} and {Pattern} {Recognition} ({CVPR})},
	publisher = {IEEE/CVF},
	author = {Shvetsova, Nina and Nagrani, Arsha and Schiele, Bernt and Kuehne, Hilde and Rupprecht, Christian},
	year = {2025},
	keywords = {CVPR},
}
