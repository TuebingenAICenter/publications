@misc{lueckmann_multifidelity_2025,
	title = {Multifidelity {Simulation}-based {Inference} for {Computationally} {Expensive} {Simulators}},
	shorttitle = {Multifidelity {Simulation}-based {Inference}},
	url = {https://arxiv.org/abs/2502.08416},
	doi = {10.48550/arXiv.2502.08416},
	abstract = {Simulation-based inference (SBI) has become a powerful tool for performing Bayesian inference in scientific models where the likelihood is intractable but the simulator is available. However, SBI often requires a large number of simulations, which can be prohibitively expensive for complex models. Multifidelity methods address this by leveraging a large number of cheap, low-fidelity simulations alongside a small number of expensive, high-fidelity simulations. In this work, we introduce a novel multifidelity SBI framework that learns to map low-fidelity simulations to high-fidelity ones, allowing for efficient posterior estimation. We demonstrate the effectiveness of our approach on several benchmarks and a complex climate model, showing that it can achieve significant speedups while maintaining high accuracy.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Lueckmann, Jan-Matthis and Macke, Jakob},
	month = feb,
	year = {2025},
	keywords = {ARXIV},
}
