@inproceedings{konig_disentangling_2025,
	title = {Disentangling {Interactions} and {Dependencies} in {Feature} {Attribution}},
	shorttitle = {Disentangling {Interactions} and {Dependencies}},
	url = {https://arxiv.org/pdf/2410.23772},
	doi = {10.48550/arXiv.2410.23772},
	abstract = {Feature attribution methods are widely used to explain the predictions of machine learning models. However, these methods often struggle to distinguish between the direct influence of a feature and its indirect influence mediated by dependencies with other features. In this paper, we propose a framework to disentangle these effects. We define a causal notion of feature attribution that separates the direct effect of a feature from the effects mediated by other features. We show that existing attribution methods can be interpreted as different ways of aggregating these effects, and we provide a unified perspective that clarifies their differences. We also propose a new attribution method that explicitly disentangles these effects and demonstrate its effectiveness on synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 28th {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {arXiv},
	author = {König, Gunnar and Günther, Eric and von Luxburg, Ulrike},
	year = {2025},
	keywords = {Feature (linguistics), Attribution, Computer science, Artificial intelligence, Psychology, Social psychology, Linguistics, processed, University of Tübingen, AISTATS},
}
