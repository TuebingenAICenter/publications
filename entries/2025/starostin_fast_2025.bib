@article{starostin_fast_2025,
	title = {Fast and reliable probabilistic reflectometry inversion with prior-amortized neural posterior estimation},
	copyright = {© 2025 The Authors, some rights reserved; exclusive licensee American Association for the Advancement of Science. No claim to original U.S. Government Works. Distributed under a Creative Commons Attribution License 4.0 (CC BY).},
	issn = {2375-2548},
	shorttitle = {Fast and reliable probabilistic reflectometry inversion},
	url = {https://doi.org/10.1126/sciadv.adr9668},
	doi = {10.1126/sciadv.adr9668},
	abstract = {Reflectometry is a powerful technique for characterizing thin-film structures, but the inversion of reflectometry data—inferring the physical parameters of a sample from its reflectivity curve—is a notoriously difficult inverse problem. It is often ill-posed, computationally expensive, and prone to local minima. We present a method for probabilistic reflectometry inversion based on prior-amortized neural posterior estimation (NPE). Our approach learns to map reflectivity curves to the full posterior distribution of physical parameters, conditioned on a prior. Once trained, the model provides instantaneous, reliable, and uncertainty-aware parameter estimation. We demonstrate the performance of our method on synthetic and experimental data, showing that it outperforms traditional optimization-based approaches in terms of speed, robustness, and the ability to quantify uncertainty. Our method is general and can be applied to various reflectometry modalities and complex sample architectures.},
	language = {en},
	urldate = {2025-06-13},
	journal = {Science Advances},
	publisher = {American Association for the Advancement of Science},
	author = {Starostin, Vladimir and Dax, Maximilian and Gerlach, Alexander and Hinderhofer, Alexander and Tejero-Cantero, Álvaro and Schreiber, Frank},
	month = jun,
	year = {2025},
	keywords = {Inference, Computer science, Reflectometry, Probabilistic logic, Inverse problem, Prior probability, Key (lock), Artificial neural network, Algorithm, Inversion (geology), Bayesian inference, Artificial intelligence, Machine learning, Bayesian probability, Mathematics, Geology, Computer vision},
}
