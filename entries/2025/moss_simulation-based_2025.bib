@article{moss_simulation-based_2025,
	title = {Simulation-{Based} {Inference} of {Surface} {Accumulation} and {Basal} {Melt} {Rates} of an {Antarctic} {Ice} {Shelf} from {Isochronal} {Layers}},
	url = {https://www.doi.org/10.1017/jog.2025.13},
	doi = {10.1017/jog.2025.13},
	abstract = {Ice shelves are critical components of the Antarctic ice sheet, regulating the flow of inland ice into the ocean. Their stability is largely determined by surface accumulation and basal melt rates. However, these rates are difficult to constrain due to the lack of direct observations. Here, we present a simulation-based inference (SBI) framework to estimate surface accumulation and basal melt rates from isochronal layers observed in ice-penetrating radar data. We use a 2D ice-flow model to simulate the evolution of isochronal layers and a neural density estimator to perform Bayesian inference. We demonstrate our approach on a synthetic case study and apply it to radar data from the Ekström Ice Shelf, Antarctica. Our results show that SBI can accurately recover surface accumulation and basal melt rates, providing a powerful tool for quantifying the mass balance of ice shelves.},
	language = {en},
	urldate = {2025-06-01},
	journal = {Journal of Glaciology},
	publisher = {Cambridge University Press},
	author = {Moss, Guy and Višnjević, Vjeran and Eisen, Olaf and Oraschewski, Falk M. and Schröder, Cornelius and Macke, Jakob H. and Drews, Reinhard},
	year = {2025},
	keywords = {Ice shelf, Geology, Basal (medicine), Inference, Oceanography, Sea ice, Cryosphere, Computer science, Biology},
}
