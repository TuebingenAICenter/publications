@inproceedings{xie_intertrack_2025,
	title = {{InterTrack}: {Tracking} {Human} {Object} {Interaction} {Without} {Object} {Templates}},
	shorttitle = {{InterTrack}},
	url = {https://virtualhumans.mpi-inf.mpg.de/InterTrack/},
	doi = {10.1109/3dv66043.2025.00135},
	abstract = {We tackle the problem of tracking humans and objects in interaction from a single RGB video. Previous methods rely on known object templates or 3D models, limiting their applicability to a few categories and instances. In this paper, we propose InterTrack, a template-free approach for tracking human-object interactions. Our method jointly estimates the 3D human pose, the 3D shape and pose of unknown objects, and the contact between them, directly from video. To achieve this, we leverage a category-agnostic object representation and a human-object interaction prior. We introduce a novel optimization-based framework that refines the estimated human and object parameters over time, ensuring physical plausibility and temporal consistency. Experimental results on challenging datasets demonstrate that InterTrack achieves state-of-the-art performance in tracking diverse objects in interaction, without requiring any object-specific templates.},
	language = {en},
	urldate = {2025-06-01},
	booktitle = {2025 {International} {Conference} on 3D {Vision} (3DV)},
	publisher = {IEEE},
	author = {Xie, Xianghui and Lenssen, Jan Eric and Pons-Moll, Gerard},
	year = {2025},
	keywords = {Template, Object (grammar), Computer science, Artificial intelligence, Computer vision, Object model, Tracking (education), Psychology, Programming language, agentRevised, Video tracking, 3DV},
}
