@misc{abdelnabi_llmail-inject_2025,
	title = {{LLMail}-{Inject}: {A} {Dataset} from a {Realistic} {Adaptive} {Prompt} {Injection} {Challenge}},
	shorttitle = {{LLMail}-{Inject}},
	url = {https://arxiv.org/abs/2506.09956},
	doi = {10.48550/arxiv.2506.09956},
	abstract = {Large Language Models (LLMs) are increasingly integrated into applications that process untrusted user-provided content, such as emails. This integration introduces a significant security risk: indirect prompt injection, where an attacker embeds malicious instructions in content (e.g., an email) to hijack the LLM's behavior. Despite the severity of this threat, existing datasets for evaluating indirect prompt injection are often synthetic, lack realism, or do not capture the adaptive nature of real-world attacks. To address this, we introduce LLMail-Inject, a dataset derived from a realistic, multi-stage adaptive prompt injection challenge. The challenge simulated an LLM-powered email assistant, requiring participants to craft attacks that bypass security filters and achieve specific objectives. The resulting dataset contains over 1,000 successful, human-crafted, and adaptive injection attacks, along with the corresponding target system responses. We provide a detailed analysis of the attack strategies, the effectiveness of different injection techniques, and the challenges in defending against them. Our dataset serves as a valuable resource for researchers to develop more robust defenses against indirect prompt injection in LLM-integrated applications.},
	language = {en},
	urldate = {2025-06-18},
	publisher = {arXiv},
	author = {Abdelnabi, Sahar and Fay, Aideen and Salem, Ahmed and Zverev, Egor and Liao, K.F. and Liu, C.C. and Kuo, Chun-Chih and Weigend, Jannis and Manlangit, Danyael and Apostolov, Alex and Umair, Haris and Donato, Joao and Kawakita, Masayuki and Mahboob, Athar and Bach, Tran Huu and Chiang, Tsun-Han and Cho, Myeongjin and Choi, Hajin and Kim, Byeonghyeon and Lee, H. and Pannell, Benjamin K. and McCauley, Conor and Russinovich, Mark and Paverd, Andrew and Cherubin, Giovanni},
	year = {2025},
	keywords = {Exploit, Order (exchange), Foundation (evidence), Identification (biology), Key (lock)},
}
