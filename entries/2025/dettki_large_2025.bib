@inproceedings{dettki_large_2025,
	title = {Do {Large} {Language} {Models} {Reason} {Causally} {Like} {Us}? {Even} {Better}?},
	shorttitle = {Do {Large} {Language} {Models} {Reason} {Causally} {Like} {Us}?},
	url = {https://charleywu.github.io/downloads/dettki2025large.pdf},
	doi = {10.48550/arXiv.2502.10215},
	abstract = {Causal reasoning is central to human cognition, enabling us to act in complex environments and learn from sparse data. Human causal reasoning is notably influenced by prior knowledge and by cognitive constraints that favor simplicity. In contrast, the causal reasoning capabilities of Large Language Models (LLMs) remain a subject of active debate. While some argue that LLMs possess human-like or even superior reasoning skills, others claim they merely rely on surface-level associations. We address this question by comparing human and LLM performance across four types of causal reasoning tasks: prediction, intervention, ablation, and counterfactuals. We found that LLMs often outperformed humans in accuracy on prediction and counterfactual tasks, yet most models struggled with the ablation task. Moreover, humans and LLMs exhibited similar patterns of errors, and both displayed a simplicity bias, favoring simpler explanations over more complex ones. These findings suggest that LLMs are not only capable of sophisticated causal reasoning but also share some of the same inductive biases as humans.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 47th {Annual} {Conference} of the {Cognitive} {Science} {Society}},
	publisher = {Cognitive Science Society},
	author = {Dettki, Hanna M. and Lake, Brenden M. and Wu, Charley M. and Rehder, Bob},
	editor = {Ruggeri, A. and Barner, D. and Walker, C. and Bramley, N.},
	year = {2025},
	keywords = {Linguistics, Psychology, Computer science, Cognitive psychology, Philosophy, agentRevised, processed, COGSCI},
}
