@article{kerber_deep_2023,
	title = {Deep learning-based age estimation from clinical {Computed} {Tomography} image data of the thorax and abdomen in the adult population},
	copyright = {CC BY 4.0},
	issn = {1932-6203},
	shorttitle = {Deep learning-based age estimation},
	url = {https://journals.plos.org/plosone/article?id=10.1371/journal.pone.0292993},
	doi = {10.1371/journal.pone.0292993},
	abstract = {Age estimation from medical imaging is a task of increasing importance in forensic medicine and clinical research. While deep learning-based methods have shown promising results for age estimation from hand radiographs, their application to clinical Computed Tomography (CT) data of the adult population remains limited. In this study, we developed and evaluated a deep learning-based approach for age estimation from clinical CT images of the thorax and abdomen. We utilized a large-scale dataset of 10,000 clinical CT scans from 5,000 adult patients. We trained a 3D convolutional neural network (CNN) to predict the chronological age of the patients. Our model achieved a mean absolute error (MAE) of 4.8 years on the test set. We further analyzed the influence of different anatomical regions and image modalities on the age estimation performance. Our results demonstrate that deep learning models can accurately estimate age from clinical CT data, providing a potential tool for forensic and clinical applications.},
	language = {en},
	urldate = {2024-05-22},
	journal = {PLOS ONE},
	publisher = {Public Library of Science},
	author = {Kerber, B. and Hepp, T. and Küstner, T. and Gatidis, S.},
	month = nov,
	year = {2023},
}
