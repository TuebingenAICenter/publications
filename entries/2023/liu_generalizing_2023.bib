@misc{liu_generalizing_2023,
	title = {Generalizing and {Decoupling} {Neural} {Collapse} via {Hyperspherical} {Uniformity} {Gap}},
	url = {https://openreview.net/pdf?id=inU2quhGdNU},
	doi = {10.48550/arxiv.2303.06484},
	abstract = {Neural collapse (NC) is a recently observed phenomenon where the last-layer features of deep neural networks collapse to their class means, and these means form a simplex equiangular tight frame (ETF) during the terminal phase of training. While NC has been extensively studied for cross-entropy loss, it remains unclear whether it holds for other losses and how it relates to the geometry of the feature space. In this paper, we generalize NC to a broader class of losses and architectures by introducing the hyperspherical uniformity gap (HUG). We show that HUG provides a unified perspective to understand NC and its decoupling from the classification layer. Specifically, we prove that minimizing HUG is equivalent to achieving NC, and that this can be decoupled from the classification layer by using a hyperspherical projection. Our theoretical results are supported by extensive experiments on various datasets and architectures, demonstrating that our approach consistently achieves better generalization and robustness.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {International Conference on Learning Representations},
	author = {Liu, Weiyang and Yu, Longhui and Weller, Adrian and Schölkopf, Bernhard},
	month = may,
	year = {2023},
	keywords = {Hypersphere, Simplex, Robustness (evolution), Artificial neural network, Decoupling (probability), Computer science, Entropy (arrow of time), Deep neural networks, Mathematics, Algorithm, Applied mathematics, Artificial intelligence, Combinatorics, Physics, ICLR},
}
