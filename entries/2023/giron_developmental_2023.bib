@article{giron_developmental_2023,
	title = {Developmental changes in exploration resemble stochastic optimization},
	issn = {2397-3374},
	shorttitle = {Developmental changes in exploration},
	url = {https://doi.org/10.1038/s41562-023-01662-1},
	doi = {10.1038/s41562-023-01662-1},
	abstract = {How do children and adolescents learn to explore their environment? While previous research has focused on age-related changes in exploration strategies, the underlying computational mechanisms remain poorly understood. Here we show that developmental changes in exploration can be characterized as a process of stochastic optimization. We tested 155 participants aged 8–25 years in a multi-armed bandit task and found that exploration becomes more directed and efficient with age. Using a computational model of stochastic optimization, we demonstrate that these developmental changes are best explained by a reduction in the noise of the optimization process, rather than a shift in the exploration strategy itself. Our results suggest that the development of exploration is driven by an increasing ability to effectively navigate the trade-off between exploration and exploitation, providing a new framework for understanding cognitive development.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Nature Human Behaviour},
	publisher = {Nature Portfolio},
	author = {Giron, Anna P. and Ciranka, Simon and Schulz, Eric and van den Bos, Wouter and Ruggeri, Azzurra and Meder, Björn and Wu, Charley M.},
	year = {2023},
	keywords = {Randomness, Stochastic optimization, Generalization, Convergence (economics), Ambiguity, Process (computing), Task (project management), Computer science, Mathematical optimization, Optimization problem, Stochastic process, Artificial intelligence, Mathematics, Machine learning, Statistics, Engineering, NHB},
}
