@article{jerbi_quantum_2023,
	title = {Quantum machine learning beyond kernel methods},
	copyright = {© The Author(s) 2023},
	issn = {2041-1723},
	shorttitle = {Quantum machine learning beyond kernel methods},
	url = {https://www.nature.com/articles/s41467-023-36159-y},
	doi = {10.1038/s41467-023-36159-y},
	abstract = {Quantum machine learning (QML) is often associated with the quantum kernel method, where a quantum computer is used to compute the inner product of data points in a high-dimensional feature space. While this approach is well-understood and provides a clear path to quantum advantage, it is not the only way to use quantum computers for machine learning. Here, we show that quantum machine learning can go beyond kernel methods by considering quantum models that are not equivalent to any kernel method. We introduce a class of quantum models, which we call quantum neural networks, and show that they can be trained to perform tasks that are hard for any kernel method. We provide a theoretical framework for understanding the power of these models and demonstrate their performance on a variety of tasks.},
	language = {en},
	urldate = {2024-05-23},
	journal = {Nature Communications},
	publisher = {Nature Portfolio},
	author = {Jerbi, Sofiene and Fiderer, Lukas J. and Poulsen Nautrup, Hendrik and Kübler, Johannes M. and Briegel, Hans J. and Dunjko, Vedran},
	month = jan,
	year = {2023},
	keywords = {NATURE COMMUNICATIONS},
}
