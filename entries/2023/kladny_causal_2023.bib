@misc{kladny_causal_2023,
	title = {Causal {Effect} {Estimation} from {Observational} and {Interventional} {Data} {Through} {Matrix} {Weighted} {Linear} {Estimators}},
	shorttitle = {Causal {Effect} {Estimation}},
	url = {https://proceedings.mlr.press/v216/kladny23a.html},
	doi = {10.48550/arxiv.2306.06002},
	abstract = {We consider the problem of estimating causal effects from a combination of observational and interventional data. We propose a class of matrix-weighted linear estimators that combine these data sources to minimize the mean squared error of the causal effect estimate. Our approach generalizes existing methods, such as the combination of observational data with randomized controlled trials, and allows for the integration of multiple interventional datasets. We provide theoretical guarantees on the performance of our estimators and demonstrate their effectiveness in numerical experiments.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Kladny, Klaus-Rudolf and von Kügelgen, Julius and Schölkopf, Bernhard and Muehlebach, Michael},
	editor = {Evans, Robin J. and Shpitser, Ilya},
	month = aug,
	year = {2023},
	keywords = {Observational study, Estimator, Statistics, Mathematics, Confounding, Mean squared error, Sample size determination, Linear model, Linear regression, Econometrics, UAI},
}
