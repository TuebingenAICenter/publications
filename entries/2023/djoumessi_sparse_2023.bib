@article{djoumessi_sparse_2023,
	title = {Sparse {Activations} for {Interpretable} {Disease} {Grading}},
	url = {https://openreview.net/forum?id=us8BFTsWOq},
	doi = {10.1101/2023.03.07.23286895},
	abstract = {Deep learning models have achieved state-of-the-art performance in medical image analysis, but their lack of interpretability remains a major barrier to clinical adoption. While post-hoc explanation methods are commonly used, they often provide unreliable or misleading insights. In this work, we propose a novel approach to interpretability by enforcing sparsity in the latent activations of a deep neural network. We demonstrate that this constraint leads to the emergence of interpretable features that correspond to clinically relevant patterns in medical images. We evaluate our method on two disease grading tasks: diabetic retinopathy and chest X-ray classification. Our results show that sparse activations provide more faithful and intuitive explanations than standard post-hoc methods, while maintaining competitive predictive performance.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of Medical Imaging with Deep Learning},
	publisher = {PMLR},
	author = {Djoumessi, Kevin R. D. and Ilanchezian, I. and Kühlewein, L. and Faber, H. and Baumgartner, C. F. and Bah, B. and Berens, P. and Koch, L. M.},
	month = jul,
	year = {2023},
	keywords = {Interpretability, Computer science, Artificial intelligence, Machine learning, Deep learning, Mechanism (biology), Constraint (computer-aided design), Pattern recognition (psychology), MIDL},
}
