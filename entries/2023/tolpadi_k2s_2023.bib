@article{tolpadi_k2s_2023,
	title = {K2S {Challenge}: {From} {Undersampled} {K}-{Space} to {Automatic} {Segmentation}},
	copyright = {© 2023 by the authors. Licensee MDPI, Basel, Switzerland. This article is an open access article distributed under the terms and conditions of the Creative Commons Attribution (CC BY) license.},
	issn = {2306-5354},
	shorttitle = {K2S {Challenge}},
	url = {https://www.mdpi.com/2306-5354/10/2/267},
	doi = {10.3390/bioengineering10020267},
	abstract = {The K2S challenge was organized in conjunction with the 2022 International Society for Magnetic Resonance in Medicine (ISMRM) annual meeting. The challenge aimed to evaluate the performance of deep learning models for the task of automatic segmentation of knee MRI from undersampled k-space data. The challenge provided a large-scale dataset of knee MRI scans, including both fully sampled and undersampled k-space data, as well as corresponding segmentations. A total of 14 teams participated in the challenge, with methods ranging from traditional iterative reconstruction to end-to-end deep learning approaches. The results showed that deep learning models can achieve high segmentation accuracy even from highly undersampled k-space data, with performance comparable to that achieved from fully sampled data. The challenge highlights the potential of deep learning for accelerating MRI acquisition and improving the efficiency of clinical workflows.},
	language = {en},
	journal = {Bioengineering},
	publisher = {MDPI},
	author = {Tolpadi, Aniket and Bharadwaj, Upasana and Gao, Kenneth T. and Bhattacharjee, Rupsa and Gassert, Felix G. and Luitjens, Johanna and Giesler, Paul and Morshuis, Jan Nikolas and Fischer, Paul and Hein, Matthias and Baumgartner, Christian and Razumov, Artem and Dylov, Dmitry and van Lohuizen, Quintin and Fransen, Stefan J. and Zhang, Xiaoxia and Tibrewala, Radhika and de Moura, Hector L. and Liu, Kangning and Zibetti, Marcelo V. W. and Regatte, Ravinder and Majumdar, Sharmila and Pedoia, Valentina},
	year = {2023},
	keywords = {Computer science, Segmentation, Computer vision, Artificial intelligence, Iterative reconstruction, Image segmentation, Ground truth, High fidelity, Engineering},
}
