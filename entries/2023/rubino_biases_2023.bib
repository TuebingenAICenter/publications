@article{rubino_biases_2023,
	title = {Biases towards compositionally simpler hypotheses are robust and unaffected by learning},
	shorttitle = {Biases towards compositionally simpler hypotheses},
	url = {https://charleywu.github.io/downloads/rubino2023biases.pdf},
	doi = {10.32470/ccn.2023.1392-0},
	abstract = {Human learners exhibit a strong preference for compositionally simpler hypotheses when learning concepts. However, it remains unclear whether this bias is innate or learned through experience. We investigate this question by testing whether participants' preference for simpler hypotheses changes after extensive training on either simple or complex concepts. We find that the bias towards simplicity is remarkably robust and remains unchanged even after training, suggesting that it may be a fundamental constraint on human cognition rather than a product of learning.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 2023 Conference on Cognitive Computational Neuroscience},
	publisher = {Cognitive Computational Neuroscience},
	author = {Rubino, Valerio and Dayan, Peter and Wu, Charley M.},
	editor = {Hunt, L. and Summerfield, C. and Konkle, T. and Fedorenko, E. and Naselaris, T.},
	year = {2023},
	keywords = {Computer science, Artificial intelligence, CCN},
}
