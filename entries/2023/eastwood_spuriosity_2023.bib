@article{eastwood_spuriosity_2023,
	title = {Spuriosity {Didn}'t {Kill} the {Classifier}: {Using} {Invariant} {Predictions} to {Harness} {Spurious} {Features}},
	shorttitle = {Spuriosity {Didn}'t {Kill} the {Classifier}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2023/file/3acbe9dc3a1e8d48a57b16e9aef91879-Paper-Conference.pdf},
	doi = {10.48550/arxiv.2307.09933},
	abstract = {Machine learning models often rely on spurious features—correlations that hold in training data but fail to generalize to new environments. While such features are often viewed as a nuisance to be removed, we show that they can be harnessed to improve performance. We propose a framework that uses invariant predictions to identify and leverage spurious features. Our approach, which we call Invariant Feature Harnessing (IFH), uses a small amount of labeled data from multiple environments to learn a predictor that is invariant to the spurious features, while simultaneously learning a predictor that uses the spurious features to improve performance on the training distribution. We demonstrate that IFH achieves state-of-the-art performance on several benchmarks, including those with severe distribution shifts.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Advances in Neural Information Processing Systems 36},
	publisher = {Curran Associates Inc.},
	author = {Eastwood, Cian and Singh, Shashank and Nicolicioiu, Andrei L. and Vlastelica, Marin and von Kügelgen, Julius and Schölkopf, Bernhard},
	year = {2023},
	keywords = {Spurious relationship, Boosting (machine learning), Classifier (UML), Invariant (physics), Computer science, Artificial intelligence, Feature (linguistics), Pattern recognition (psychology), Domain (mathematical analysis), Machine learning, Test data, Algorithm, Mathematics, NEURIPS},
}
