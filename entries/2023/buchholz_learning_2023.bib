@misc{buchholz_learning_2023,
	title = {Learning {Linear} {Causal} {Representations} from {Interventions} under {General} {Nonlinear} {Mixing}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2023/file/8e5de4cb639ef718f44060dc257cb04f-Paper-Conference.pdf},
	doi = {10.48550/arxiv.2306.02235},
	abstract = {We consider the problem of learning causal representations from high-dimensional data. Specifically, we assume that observed data are generated by a nonlinear mixing of underlying latent variables, which are themselves related via a linear structural causal model (SCM). We show that if we have access to interventional data, we can identify the latent causal variables and the underlying SCM up to a permutation and scaling, even when the mixing function is unknown and highly nonlinear. Our approach relies on the fact that interventions change the distribution of the latent variables in a structured way, which can be exploited to disentangle the latent factors. We provide theoretical guarantees for identifiability and propose a practical algorithm for learning the causal representations. We demonstrate the effectiveness of our method on synthetic and real-world datasets.},
	language = {en},
	publisher = {Curran Associates, Inc.},
	author = {Buchholz, Simon and Rajendran, Goutham and Rosenfeld, Elan and Aragam, Bryon and Schölkopf, Bernhard and Ravikumar, Pradeep},
	editor = {Oh, A. and Neumann, T. and Globerson, A. and Saenko, K. and Hardt, M. and Levine, S.},
	year = {2023},
	keywords = {Identifiability, Counterfactual thinking, Latent variable, Gaussian, Mathematics, Quadratic equation, Mixing (physics), Artificial intelligence, Computer science, Machine learning, Applied mathematics, Algorithm, Psychology, Social psychology, NEURIPS},
}
