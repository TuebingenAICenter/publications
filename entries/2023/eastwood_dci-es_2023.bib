@misc{eastwood_dci-es_2023,
	title = {{DCI}-{ES}: {An} {Extended} {Disentanglement} {Framework} with {Connections} to {Identifiability}},
	shorttitle = {{DCI}-{ES}},
	url = {https://openreview.net/pdf?id=462z-gLgSht},
	doi = {10.48550/arxiv.2210.00364},
	abstract = {The DCI framework (Disentanglement, Completeness, Informativeness) has become a standard tool for evaluating disentangled representations. However, it is limited to linear relationships and does not account for the identifiability of the underlying factors. In this work, we extend the DCI framework to address these limitations. We introduce DCI-ES, which extends the original framework to non-linear relationships and provides a theoretical connection to identifiability. We demonstrate the utility of our framework on a range of synthetic and real-world datasets, showing that it provides a more comprehensive and accurate assessment of disentangled representations.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {International Conference on Learning Representations},
	author = {Eastwood, Cian and Nicolicioiu, Andrei Liviu and von Kügelgen, Julius and Kekić, Armin and Träuble, Frederik and Dittadi, Andrea and Schölkopf, Bernhard},
	year = {2023},
	keywords = {Identifiability, Representation (politics), Computer science, Completeness (order theory), Relevance (law), Quality (philosophy), Field (mathematics), Variation (astronomy), Point (geometry), Theoretical computer science, Mathematics, Machine learning, Epistemology, Pure mathematics, ICLR},
}
