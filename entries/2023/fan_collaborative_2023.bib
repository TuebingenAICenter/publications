@misc{fan_collaborative_2023,
	title = {Collaborative {Learning} via {Prediction} {Consensus}},
	shorttitle = {Collaborative {Learning} via {Prediction} {Consensus}},
	url = {https://arxiv.org/abs/2305.18497},
	doi = {10.48550/arXiv.2305.18497},
	abstract = {We study the problem of collaborative learning where multiple parties aim to improve their local models by leveraging data from others, without sharing their raw data. Existing approaches often rely on sharing model parameters or gradients, which can be communication-intensive and may leak private information. In this work, we propose a novel framework, Collaborative Learning via Prediction Consensus (CLPC), which instead relies on sharing predictions on a small set of public data. We show that CLPC is communication-efficient and provides strong privacy guarantees. We provide theoretical convergence guarantees for our method and demonstrate its effectiveness through extensive experiments on various datasets and models, showing that it achieves competitive performance compared to state-of-the-art collaborative learning methods while significantly reducing communication overhead.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Fan, Dongyang and Mendler-Dünner, Celestine and Jaggi, Martin},
	year = {2023},
	keywords = {Computer science, Weighting, Overhead (engineering), Scheme (mathematics), Federated learning, Collaborative learning, Machine learning, Domain (mathematical analysis), Artificial intelligence, Data mining, Knowledge management, NEURIPS},
}
