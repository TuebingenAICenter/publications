@misc{boreiko_identifying_2023,
	title = {Identifying {Systematic} {Errors} in {Object} {Detectors} with the {SCROD} {Pipeline}},
	shorttitle = {{SCROD}},
	url = {https://arxiv.org/abs/2309.13489},
	doi = {10.48550/arXiv.2309.13489},
	abstract = {Object detectors are typically evaluated using aggregate metrics like mean Average Precision (mAP). However, these metrics fail to provide insights into the specific conditions under which a model fails, which is critical for safety-critical applications. We propose SCROD (Systematic Characterization of Robustness in Object Detection), a pipeline that identifies systematic errors in object detectors. SCROD automatically discovers clusters of images where a model consistently underperforms, characterizes these clusters by identifying common visual attributes, and provides a human-interpretable description of the failure modes. We demonstrate the effectiveness of SCROD on several state-of-the-art object detectors and show that it uncovers meaningful failure modes that are not captured by standard evaluation metrics.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Boreiko, Valentyn and Hein, Matthias and Metzen, Jan-Hendrik},
	year = {2023},
	keywords = {Computer science, Pipeline (software), Scalability, Benchmark (surveying), Software deployment, Artificial intelligence, Object (grammar), Resource (disambiguation), Identification (biology), Field (mathematics), Orientation (vector space), Scale (ratio), Computer vision, Machine learning, Software engineering, Database},
}
