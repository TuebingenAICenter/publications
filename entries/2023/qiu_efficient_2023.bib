@misc{qiu_efficient_2023,
	title = {Efficient coding of natural scenes improves neural system identification},
	copyright = {CC BY 4.0},
	shorttitle = {Efficient coding of natural scenes},
	url = {https://doi.org/10.1371/journal.pcbi.1011037},
	doi = {10.1371/journal.pcbi.1011037},
	abstract = {The goal of neural system identification is to build models that predict neural responses to arbitrary stimuli. While deep learning models have achieved state-of-the-art performance in predicting responses of neurons in the visual system, they often require large amounts of data and are prone to overfitting. Here, we show that incorporating the principle of efficient coding—the idea that sensory systems are adapted to the statistics of natural scenes—improves neural system identification. We propose a framework that combines a deep neural network with an efficient coding objective, which encourages the model to learn representations that are informative about the stimulus while minimizing redundancy. We demonstrate that this approach leads to better predictive performance on neural data from the mouse retina and primary visual cortex, especially in data-limited regimes. Our results suggest that efficient coding is a powerful inductive bias for neural system identification and that it can help bridge the gap between normative theories of sensory processing and data-driven models.},
	language = {en},
	type = {{journalArticle}},
	urldate = {2025-05-14},
	publisher = {Public Library of Science},
	author = {Qiu, Yongrong and Klindt, David A. and Szatko, Klaudia P. and Gonschorek, Dominic and Hoefling, Larissa and Schubert, Timm and Busse, Laura and Bethge, Matthias and Euler, Thomas},
	year = {2023},
	keywords = {Coding (social sciences), Identification (biology), Computer science, Artificial intelligence, Natural (archaeology), Computer vision, Pattern recognition (psychology), Biology, Mathematics, Ecology, Paleontology, Statistics},
}
