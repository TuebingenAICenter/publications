@article{zilio_altered_2023,
	title = {Altered brain dynamics index levels of arousal in complete locked-in syndrome},
	issn = {2399-3642},
	shorttitle = {Altered brain dynamics index levels of arousal in complete locked-in syndrome},
	url = {https://doi.org/10.1038/s42003-023-05109-1},
	doi = {10.1038/s42003-023-05109-1},
	abstract = {Complete locked-in syndrome (CLIS) is a condition where patients are fully conscious but unable to move or communicate. The neural mechanisms underlying the maintenance of consciousness in CLIS remain poorly understood. Here, we investigated the brain dynamics of CLIS patients using resting-state electroencephalography (EEG). We found that the temporal complexity of the EEG signal, as measured by multiscale entropy, was significantly reduced in CLIS patients compared to healthy controls. This reduction was most pronounced in the alpha and beta frequency bands and was associated with the patients' level of arousal. Our findings suggest that the maintenance of consciousness in CLIS is supported by a specific pattern of brain dynamics, which is altered in the absence of behavioral output.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Communications Biology},
	publisher = {Nature Portfolio},
	author = {Zilio, Federico and Gomez-Pilar, Javier and Chaudhary, Ujwal and Fogel, Stuart and Fomina, Tatyana and Synofzik, Matthis and Schöls, Ludger and Cao, Shuai and Zhang, Jing and Huang, Zirui and Birbaumer, Niels and Northoff, Georg},
	year = {2023},
	keywords = {COMMBIO},
}
