@article{haas_mind_2023,
	title = {Mind the spikes: {Benign} overfitting of kernels and neural networks in fixed dimension},
	shorttitle = {Mind the spikes},
	url = {https://arxiv.org/abs/2305.14077},
	doi = {10.48550/arXiv.2305.14077},
	abstract = {It is a well-known phenomenon that overparameterized models can interpolate noisy training data while still achieving good generalization performance. This phenomenon, called benign overfitting, has been extensively studied in the context of linear regression and kernel methods in high-dimensional settings, where the number of features d is larger than the number of samples n. In this paper, we study benign overfitting in fixed dimension d, where the number of samples n goes to infinity. We show that for kernel methods and neural networks, benign overfitting can occur if the model is allowed to place 'spikes' at the training data points. These spikes allow the model to interpolate the noise while the 'smooth' part of the function learns the underlying signal. We provide a theoretical analysis of this phenomenon and show that it can lead to good generalization performance even in fixed dimension. We also provide empirical evidence supporting our theoretical findings.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Advances in Neural Information Processing Systems},
	publisher = {Curran Associates, Inc.},
	author = {Haas, Moritz and Holzmüller, David and von Luxburg, Ulrike and Steinwart, Ingo},
	year = {2023},
	keywords = {Overfitting, Dimension (graph theory), Artificial neural network, Pattern recognition (psychology), Generalization, Feature (linguistics), NEURIPS},
}
