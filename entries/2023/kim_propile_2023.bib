@article{kim_propile_2023,
	title = {{ProPILE}: {Probing} {Privacy} {Leakage} in {Large} {Language} {Models}},
	shorttitle = {{ProPILE}},
	url = {https://arxiv.org/abs/2307.01881},
	doi = {10.48550/arXiv.2307.01881},
	abstract = {Large language models (LLMs) are known to memorize training data, which raises privacy concerns. Existing membership inference attacks (MIAs) for LLMs often rely on the assumption that the attacker has access to the model's training data or that the model is trained on a specific dataset. However, in many real-world scenarios, these assumptions do not hold. In this paper, we propose ProPILE, a novel framework for probing privacy leakage in LLMs without such assumptions. ProPILE leverages the observation that LLMs tend to assign higher probabilities to sequences that they have seen during training. We show that ProPILE can effectively detect whether a given sequence was part of the training data of an LLM, even when the model is only accessible via a black-box API. We evaluate ProPILE on various LLMs and datasets, and demonstrate that it outperforms existing state-of-the-art MIAs in terms of both accuracy and efficiency.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Advances in Neural Information Processing Systems},
	publisher = {Curran Associates, Inc.},
	author = {Kim, Siwon and Yun, Sangdoo and Lee, Hwaran and Gubri, Martin and Yoon, Sungroh and Oh, Seong Joon},
	year = {2023},
	keywords = {NEURIPS},
}
