@misc{haas_pitfalls_2023,
	title = {Pitfalls of {Climate} {Network} {Construction}: {A} {Statistical} {Perspective}},
	shorttitle = {Pitfalls of {Climate} {Network} {Construction}},
	url = {http://tml.cs.uni-tuebingen.de/team/luxburg/publications/HaasGoswamiLuxburg2023_main_and_supplement.pdf},
	doi = {10.1175/JCLI-D-22-0549.1},
	abstract = {Climate networks are a popular tool for analyzing the complex dynamics of the climate system. They are typically constructed by calculating a correlation-based similarity measure between time series at different spatial locations and thresholding the resulting adjacency matrix. In this paper, we show that this standard construction procedure is prone to several statistical pitfalls. Specifically, we demonstrate that the resulting network topology is highly sensitive to the choice of the similarity measure, the thresholding method, and the preprocessing of the data. We show that many of the observed network properties are not robust and can be artifacts of the construction process rather than reflecting physical properties of the climate system. We provide a statistical framework to assess the robustness of climate networks and suggest best practices for their construction and analysis.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {American Meteorological Society},
	author = {Haas, Moritz and Goswami, Bedartha and von Luxburg, Ulrike},
	year = {2023},
	keywords = {Spurious relationship, Computer science, Robustness (evolution), Econometrics, Variance (accounting), Resampling, Inference, Data mining, Data science, Machine learning, Artificial intelligence, Mathematics, Economics},
}
