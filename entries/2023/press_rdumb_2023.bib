@misc{press_rdumb_2023,
	title = {{RDumb}: {A} simple approach that questions our progress in continual test-time adaptation},
	shorttitle = {{RDumb}},
	url = {https://arxiv.org/abs/2306.05401},
	doi = {10.48550/arxiv.2306.05401},
	abstract = {Continual test-time adaptation (CTTA) aims to adapt a pre-trained model to a continuously changing data distribution without access to the source data. While recent methods have shown impressive performance gains, we find that many of them are surprisingly sensitive to the specific implementation of the adaptation process. In this paper, we propose RDumb, a simple baseline that performs no adaptation at all, but instead uses a robustly pre-trained model. We show that RDumb achieves state-of-the-art performance on several standard CTTA benchmarks, often outperforming complex methods that require significant computational resources. Our results suggest that the progress in CTTA may be less about the adaptation algorithms themselves and more about the quality of the pre-trained models. We hope that our findings will encourage the community to re-evaluate the necessity of complex adaptation methods and to focus on more robust pre-training strategies.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Press, Ori and Schneider, Steffen and Kümmerer, Matthias and Bethge, Matthias},
	year = {2023},
	keywords = {Benchmark (surveying), Adaptation (eye), Computer science, Simple (philosophy), Field (mathematics), Software deployment, Measure (data warehouse), State (computer science), Work (physics), Baseline (sea), Machine learning, Artificial intelligence, Algorithm, Data mining, Mathematics, Engineering, NEURIPS},
}
