@misc{schreiber_encode_2023,
	title = {The {ENCODE} {Imputation} {Challenge}: a critical assessment of methods for cross-cell type imputation of epigenomic profiles},
	shorttitle = {The {ENCODE} {Imputation} {Challenge}},
	url = {https://doi.org/10.1186/s13059-023-02915-y},
	doi = {10.1186/s13059-023-02915-y},
	abstract = {The ENCODE Imputation Challenge was a community-wide experiment to assess the state of the art in computational methods for predicting epigenomic tracks across cell types. We provided a standardized dataset of 10 epigenomic marks across 10 cell types and evaluated 52 submissions from 15 teams. We found that while many methods performed well, there was no single best method; rather, performance varied depending on the mark and the cell type. We also found that the use of auxiliary data, such as gene expression or sequence information, did not consistently improve performance. Our results provide a comprehensive assessment of the current state of the field and suggest directions for future research.},
	language = {en},
	publisher = {BioMed Central},
	author = {Schreiber, Jacob and Boix, Carles and Lee, Jin wook and Li, Hong and Guan, Yuanfang and Chang, Chun-Chieh and Chang, Jen-Chien and Hawkins-Hooker, Alex and Schölkopf, Bernhard and Schweikert, Gabriele and Carulla, Mateo R. and Canakoglu, Arif and Guzzo, Francesco and Nanni, Luca and Masseroli, Marco and Carman, Mark J. and Pinoli, Pietro and Hong, Chenyang and Yip, Kevin Y. and Spence, Jeffrey P. and Batra, Sanjit S. and Song, Yun S. and Mahony, Shaun and Zhang, Zheng and Tan, Wuwei and Shen, Yang and Sun, Yuanfei and Shi, Minyi and Adrian, Jessika and Sandstrom, Richard and Farrell, Nina and Halow, Jessica and Lee, Kristen and Jiang, Lixia and Yang, Xinqiong and Epstein, Charles and Strattan, J. Seth and Bernstein, Bradley and Snyder, Michael and Kellis, Manolis and Stafford, William and Kundaje, Anshul and {ENCODE Imputation Challenge Participants}},
	month = apr,
	year = {2023},
	keywords = {Imputation (statistics), ENCODE, Computer science, Epigenomics, Data type, Redundancy (engineering), Data mining, Machine learning, Artificial intelligence, Missing data, Biology},
}
