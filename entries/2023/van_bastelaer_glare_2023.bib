@article{van_bastelaer_glare_2023,
	title = {Glare {Removal} for {Astronomical} {Images} with {High} {Local} {Dynamic} {Range}},
	shorttitle = {Glare {Removal} for {Astronomical} {Images}},
	url = {https://is.mpg.de/ei/publications/vanbastelaer2023},
	doi = {10.1109/ICCP56744.2023.10233804},
	abstract = {Astronomical images often suffer from glare, a phenomenon where light from bright sources is scattered by the optical system, obscuring faint details in their vicinity. This is particularly problematic in high-dynamic-range (HDR) scenes, where the intensity difference between the bright source and the faint details can span several orders of magnitude. We propose a novel method for glare removal that leverages a deep learning approach to model the point spread function (PSF) of the optical system. Our method is trained on a large dataset of synthetic astronomical images with realistic glare artifacts. We demonstrate that our approach effectively removes glare while preserving the structural integrity of faint astronomical objects, outperforming existing state-of-the-art methods on both synthetic and real-world astronomical data.},
	language = {en},
	urldate = {2025-05-14},
	journal = {IEEE International Conference on Computational Photography (ICCP)},
	publisher = {IEEE},
	author = {Van Bastelaer, Max-Olivier and Kremer, Heiner and Volchkov, Valentin and Passy, Jean-Claude and Schölkopf, Bernhard},
	month = jul,
	year = {2023},
	keywords = {High dynamic range, GLARE, High-dynamic-range imaging, Computer science, Dynamic range, Range (aeronautics), Computer vision, Remote sensing, Computer graphics (images), Artificial intelligence, Geology, Materials science, Engineering, Aerospace engineering, ICCP},
}
