@article{pan_learning_2023,
	title = {Learning {Endogenous} {Representation} in {Reinforcement} {Learning} via {Advantage} {Estimation}},
	url = {https://openreview.net/forum?id=aCiFCj4rEA},
	abstract = {Representation learning in reinforcement learning (RL) often aims to extract features that are useful for control. However, standard approaches often conflate exogenous noise (e.g., background changes) with endogenous information (e.g., agent-controlled dynamics). In this work, we propose a method to learn endogenous representations by leveraging the advantage function. We hypothesize that the advantage function, which measures the relative value of actions, is inherently tied to the endogenous dynamics of the environment. By training a representation to predict the advantage, we encourage the model to focus on features that are relevant to the agent's decision-making process, effectively filtering out exogenous noise. We demonstrate the effectiveness of our approach on several continuous control tasks, showing that it leads to more robust and sample-efficient learning compared to existing representation learning methods.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Causal Representation Learning Workshop at NeurIPS 2023},
	author = {Pan, H.-R. and Schölkopf, Bernhard},
	month = dec,
	year = {2023},
	keywords = {NEURIPS},
}
