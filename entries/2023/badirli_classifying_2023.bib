@article{badirli_classifying_2023,
	title = {Classifying the unknown: {Insect} identification with deep hierarchical {Bayesian} learning},
	issn = {2041-210X},
	shorttitle = {Classifying the unknown},
	url = {https://is.mpg.de/ei/publications/badirlietal23},
	doi = {10.1111/2041-210X.14104},
	abstract = {1. Automated insect identification is a critical task for biodiversity monitoring and agricultural pest management. However, the performance of deep learning models often degrades when they encounter species not present in the training set, a phenomenon known as open-set recognition. 2. We propose a deep hierarchical Bayesian learning framework that addresses the open-set recognition problem by explicitly modelling the hierarchical structure of insect taxonomy. Our approach combines a deep feature extractor with a hierarchical Bayesian model that learns to classify known species while simultaneously identifying unknown species as 'other' at different taxonomic levels. 3. We evaluate our method on a large-scale insect dataset and demonstrate that it significantly outperforms state-of-the-art open-set recognition methods in terms of both classification accuracy and the ability to detect unknown species. 4. Our framework provides a robust and scalable solution for automated insect identification in real-world scenarios where the presence of unknown species is inevitable.},
	language = {en},
	urldate = {2024-05-23},
	journal = {Methods in Ecology and Evolution},
	publisher = {Wiley},
	author = {Badirli, S. and Picard, C. J. and Mohler, G. and Richert, F. and Akata, Z. and Dundar, M.},
	month = jun,
	year = {2023},
	keywords = {MEE},
}
