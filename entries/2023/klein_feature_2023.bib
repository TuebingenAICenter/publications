@article{klein_feature_2023,
	title = {Feature {Visualizations} do not sufficiently explain hidden units of {Artificial} {Neural} {Networks}},
	issn = {1534-7362},
	shorttitle = {Feature {Visualizations} do not sufficiently explain hidden units},
	url = {https://jov.arvojournals.org/article.aspx?articleid=2791459},
	doi = {10.1167/jov.23.9.5062},
	abstract = {Feature visualization is a popular technique to interpret the internal representations of artificial neural networks (ANNs). It typically involves optimizing an input image to maximize the activation of a specific hidden unit. The resulting image is then interpreted as the 'feature' that the unit detects. However, it remains unclear to what extent these visualizations are faithful to the actual function of the unit. Here, we investigate the faithfulness of feature visualizations by testing whether they can predict the activation of hidden units on novel, natural images. We find that feature visualizations are surprisingly poor predictors of unit activations. This suggests that feature visualizations may not be as informative about the function of hidden units as previously assumed.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Vision},
	publisher = {Association for Research in Vision and Ophthalmology},
	author = {Klein, Thomas and Brendel, Wieland and Wichmann, Felix A.},
	year = {2023},
	keywords = {Interpretability, Computer science, Artificial intelligence, Set (abstract data type), Artificial neural network, Task (project management), Matching (statistics), Feature (linguistics), Pattern recognition (psychology), Visualization, Machine learning},
}
