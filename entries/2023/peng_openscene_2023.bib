@inproceedings{peng_openscene_2023,
	title = {{OpenScene}: 3D {Scene} {Understanding} with {Open} {Vocabularies}},
	shorttitle = {{OpenScene}},
	url = {https://ieeexplore.ieee.org/document/10203983},
	doi = {10.1109/CVPR52729.2023.00085},
	abstract = {We present OpenScene, a method for 3D scene understanding that supports open-vocabulary queries. Given a 3D scene, OpenScene learns to map 3D points to a feature space that is aligned with the feature space of a pre-trained 2D vision-language model (e.g., CLIP). This allows the model to perform a wide range of 3D scene understanding tasks, such as 3D semantic segmentation, local feature matching, and open-vocabulary 3D object detection, without requiring any task-specific training or 3D labels. We demonstrate that OpenScene achieves state-of-the-art performance on several 3D scene understanding benchmarks, while also enabling new capabilities such as querying 3D scenes with arbitrary text prompts.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Proceedings 2023 {IEEE}/{CVF} {Conference} on {Computer} {Vision} and {Pattern} {Recognition} ({CVPR})},
	publisher = {IEEE},
	author = {Peng, Songyou and Genova, Kyle and Jiang, Chiyu Max and Tagliasacchi, Andrea and Pollefeys, Marc and Funkhouser, Thomas},
	year = {2023},
	keywords = {CVPR},
}
