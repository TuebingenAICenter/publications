@inproceedings{achterhold_black-box_2023,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Black-{Box} vs. {Gray}-{Box}: {A} {Case} {Study} on {Learning} {Table} {Tennis} {Ball} {Trajectory} {Prediction} with {Spin} and {Impacts}},
	shorttitle = {Black-{Box} vs. {Gray}-{Box}},
	url = {https://proceedings.mlr.press/v211/achterhold23a.html},
	abstract = {Predicting the trajectory of a table tennis ball is a challenging task due to the high speed of the ball, the influence of aerodynamic forces like the Magnus effect, and the complex dynamics during impacts with the table and racket. In this work, we compare black-box and gray-box models for ball trajectory prediction. We propose a gray-box model that incorporates physical knowledge about the ball's flight dynamics, including air drag and the Magnus effect, while learning the impact dynamics from data. We evaluate our models on a real-world dataset of table tennis trajectories. Our results show that the gray-box model outperforms the black-box model in terms of prediction accuracy and generalization, especially when data is limited.},
	language = {en},
	booktitle = {Proceedings of {Machine} {Learning} {Research}},
	publisher = {PMLR},
	author = {Achterhold, Jan and Tobuschat, Philip and Ma, Hao and Büchler, Dieter and Muehlebach, Michael and Stueckler, Joerg},
	editor = {Matni, Nikolai and Morari, Manfred and Pappa, George J.},
	month = jun,
	year = {2023},
	keywords = {L4DC},
}
