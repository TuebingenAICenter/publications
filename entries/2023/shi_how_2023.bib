@inproceedings{shi_how_2023,
	title = {How robust is unsupervised representation learning to distribution shift?},
	shorttitle = {How robust is unsupervised representation learning to distribution shift?},
	url = {https://openreview.net/pdf?id=LiXDW7CF94J},
	abstract = {Unsupervised representation learning (URL) has achieved remarkable success in learning useful features from large-scale unlabeled data. However, a critical question remains: how robust are these learned representations to distribution shifts? In this paper, we conduct a systematic empirical study to evaluate the robustness of various URL methods under different types of distribution shifts. We find that while URL methods generally outperform supervised learning under distribution shift, their performance is highly sensitive to the choice of the pretext task and the architecture. Furthermore, we observe that the robustness of URL methods is not necessarily correlated with their performance on the original distribution. Our findings suggest that current URL methods are not inherently robust to distribution shift and highlight the need for more robust representation learning objectives.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {The {Eleventh} {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Shi, Y. and Daunhawer, I. and Vogt, J. E. and Torr, P. and Sanyal, A.},
	month = may,
	year = {2023},
	keywords = {ICLR},
}
