@inproceedings{javaloy_causal_2023,
	title = {Causal normalizing flows: from theory to practice},
	shorttitle = {Causal normalizing flows},
	url = {https://proceedings.neurips.cc/paper_files/paper/2023/file/b8402301e7f06bdc97a31bfaa653dc32-Paper-Conference.pdf},
	abstract = {Normalizing flows are a powerful tool for density estimation and generative modeling. However, they are typically designed to model the joint distribution of a set of variables without regard for the underlying causal structure. In this work, we introduce Causal Normalizing Flows (CNFs), a framework that allows for the integration of causal knowledge into normalizing flows. We provide a theoretical characterization of the conditions under which a flow can be considered causal, and we propose a practical implementation that leverages these conditions to learn causal models from observational data. We demonstrate the effectiveness of our approach on a variety of synthetic and real-world datasets, showing that CNFs can recover the underlying causal structure and perform accurate interventional inference.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 36 ({NeurIPS} 2023)},
	publisher = {Curran Associates, Inc.},
	author = {Javaloy, Adrian and Sanchez-Martin, Pablo and Valera, Isabel},
	editor = {Oh, A. and Neumann, T. and Globerson, A. and Saenko, K. and Hardt, M. and Levine, S.},
	month = dec,
	year = {2023},
	keywords = {NEURIPS},
}
