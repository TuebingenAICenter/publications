@misc{hagele_bacadi_2023,
	title = {{BaCaDI}: {Bayesian} {Causal} {Discovery} with {Unknown} {Interventions}},
	shorttitle = {{BaCaDI}},
	url = {https://proceedings.mlr.press/v206/hagele23a.html},
	doi = {10.48550/arxiv.2206.01665},
	abstract = {Causal discovery from observational and interventional data is a fundamental problem in science. However, in many real-world scenarios, such as biological experiments, the exact nature of the interventions is unknown. We propose BaCaDI, a Bayesian framework for causal discovery that treats the intervention targets as latent variables. BaCaDI performs joint inference over the causal structure and the intervention targets by leveraging a novel MCMC scheme that alternates between structure updates and intervention target updates. We demonstrate that BaCaDI outperforms existing methods on synthetic data and real-world biological datasets, providing a robust and scalable approach to causal discovery with unknown interventions.},
	language = {en},
	publisher = {PMLR},
	author = {Hägele, A. and Rothfuss, J. and Lorch, L. and Somnath, V. R. and Schölkopf, B. and Krause, A.},
	editor = {Ruiz, Francisco and Dy, Jennifer and van de Meent, Jan-Willem},
	year = {2023},
	keywords = {Causal inference, Causal structure, Computer science, Machine learning, Inference, Bayesian probability, Causal model, Bayesian network, Artificial intelligence, Drug discovery, Bayesian inference, Data mining, Computational biology, Bioinformatics, Biology, Mathematics, Econometrics, AISTATS},
}
