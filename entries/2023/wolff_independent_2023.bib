@article{wolff_independent_2023,
	title = {The {Independent} {Compositional} {Subspace} {Hypothesis} for the {Structure} of {CLIP}'s {Last} {Layer}},
	shorttitle = {The {Independent} {Compositional} {Subspace} {Hypothesis}},
	url = {https://openreview.net/forum?id=MmhGK8YkUKO},
	abstract = {We investigate the structure of the last layer of CLIP, a prominent vision-language model. We find that the last layer is not a monolithic representation but rather a collection of independent compositional subspaces. Each subspace corresponds to a specific semantic concept, and the model's predictions are formed by a linear combination of these subspaces. We propose the Independent Compositional Subspace Hypothesis, which posits that this structure is a key factor in the model's ability to generalize to unseen concepts. We provide empirical evidence for this hypothesis by showing that we can manipulate the model's predictions by intervening in these subspaces.},
	language = {en},
	urldate = {2025-05-14},
	journal = {ICLR 2023 Workshop on Mathematical and Empirical Understanding of Foundation Models},
	publisher = {OpenReview},
	author = {Wolff, Max and Brendel, Wieland and Wolff, Stuart},
	year = {2023},
	keywords = {ICLR},
}
