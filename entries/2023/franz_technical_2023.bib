@article{franz_technical_2023,
	title = {Technical comment on {Gunderson}, ten {Brinke}, and {Sokol}-{Hessner} (2023): {When} the body knows: {Interoceptive} accuracy enhances physiological but not explicit differentiation between liars and truth-tellers},
	issn = {0191-8869},
	shorttitle = {Technical comment on {Gunderson}, ten {Brinke}, and {Sokol}-{Hessner} (2023)},
	url = {https://doi.org/10.1016/j.paid.2023.112439},
	doi = {10.1016/j.paid.2023.112439},
	abstract = {Gunderson, ten Brinke, and Sokol-Hessner (2023) reported that interoceptive accuracy (IAcc) enhances physiological but not explicit differentiation between liars and truth-tellers. We re-analyzed their data and found that the reported effects are not robust. Specifically, the physiological differentiation effect disappears when controlling for the number of trials or when using a more appropriate statistical model. Furthermore, the explicit differentiation effect is not supported by the data. We conclude that the evidence for the claim that IAcc enhances physiological differentiation between liars and truth-tellers is weak.},
	language = {en},
	journal = {Personality and Individual Differences},
	publisher = {Elsevier},
	author = {Franz, Volker and Meyen, Sascha and von Luxburg, Ulrike},
	year = {2023},
	keywords = {Psychology, Lie detection, Interoception, Deception, Lying, Social psychology, Personality, Cognitive psychology, Perception},
}
