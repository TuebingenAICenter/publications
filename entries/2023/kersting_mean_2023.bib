@article{kersting_mean_2023,
	title = {Mean first exit times of {Ornstein}–{Uhlenbeck} processes in high-dimensional spaces},
	issn = {1751-8113},
	url = {https://doi.org/10.1088/1751-8121/acc559},
	doi = {10.1088/1751-8121/acc559},
	abstract = {We study the mean first exit time (MFET) of an Ornstein–Uhlenbeck (OU) process from a ball in high dimensions. We derive a new asymptotic expansion for the MFET as the dimension d tends to infinity. Our results show that the MFET is highly sensitive to the ratio between the radius of the ball and the stationary variance of the process. In particular, we identify a phase transition in the behavior of the MFET as this ratio crosses a critical threshold. We provide numerical evidence supporting our theoretical findings and discuss implications for the analysis of stochastic gradient descent.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Physics A: Mathematical and Theoretical},
	publisher = {IOP Publishing},
	author = {Kersting, Hans and Orvieto, Antonio and Proske, Frank and Lucchi, Aurélien},
	year = {2023},
	keywords = {Ornstein–Uhlenbeck process, Statistical physics, Mathematics, Physics, Stochastic process, Statistics},
}
