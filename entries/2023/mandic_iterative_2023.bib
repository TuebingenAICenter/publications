@article{mandic_iterative_2023,
	title = {Iterative weakly supervised learning for novel class object detection},
	url = {https://openreview.net/forum?id=FWohKbMhlo},
	abstract = {Weakly supervised object detection (WSOD) aims to learn object detectors from image-level labels only. While existing methods have achieved impressive results on standard benchmarks, they often struggle to generalize to novel classes not seen during training. In this paper, we propose an iterative weakly supervised learning framework for novel class object detection. Our approach leverages a pre-trained model to generate pseudo-labels for novel classes, which are then refined through an iterative process. We demonstrate that our method significantly outperforms existing WSOD baselines on novel classes while maintaining competitive performance on base classes.},
	language = {en},
	urldate = {2024-05-22},
	journal = {The Eleventh International Conference on Learning Representations},
	publisher = {OpenReview},
	author = {Mandić, Dejana and Brendel, Wieland and Michaelis, Claudio},
	year = {2023},
	keywords = {ICLR},
}
