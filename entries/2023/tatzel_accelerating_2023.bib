@article{tatzel_accelerating_2023,
	title = {Accelerating {Generalized} {Linear} {Models} by {Trading} off {Computation} for {Uncertainty}},
	shorttitle = {Accelerating {Generalized} {Linear} {Models}},
	url = {https://arxiv.org/abs/2310.20285},
	doi = {10.48550/arXiv.2310.20285},
	abstract = {Generalized linear models (GLMs) are a cornerstone of statistical modeling. However, their training via iterative optimization, such as Newton's method, can be computationally expensive for large datasets. We propose a method to accelerate the training of GLMs by trading off computational effort for uncertainty. Specifically, we replace the exact Hessian with a stochastic approximation that is cheaper to compute, while maintaining a probabilistic interpretation of the model parameters. We show that this approach leads to significant speedups in training time while providing well-calibrated uncertainty estimates. We demonstrate the effectiveness of our method on several real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	journal = {arXiv},
	publisher = {arXiv},
	author = {Tatzel, Lukas and Wenger, Jonathan and Schneider, Frank and Hennig, Philipp},
	year = {2023},
	keywords = {Computation, Econometrics, Computer science, Economics, Algorithm},
}
