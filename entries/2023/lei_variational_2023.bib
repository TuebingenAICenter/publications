@misc{lei_variational_2023,
	title = {Variational {Causal} {Dynamics}: {Discovering} {Modular} {World} {Models} from {Interventions}},
	shorttitle = {Variational {Causal} {Dynamics}},
	url = {https://openreview.net/forum?id=V9tQKYYNK1},
	doi = {10.48550/arxiv.2206.11131},
	abstract = {Learning world models that are both predictive and interpretable is a central challenge in artificial intelligence. While deep generative models have shown impressive performance in predicting future states, they often lack the modularity required for robust generalization and causal reasoning. In this work, we propose Variational Causal Dynamics (VCD), a framework for learning modular world models from observational and interventional data. VCD decomposes the world into a set of causal mechanisms, each represented by a latent variable, and learns to predict the dynamics of these mechanisms under interventions. We demonstrate that VCD can discover modular structures in complex environments and generalize to unseen interventions, outperforming existing methods in both predictive accuracy and causal interpretability.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Transactions on Machine Learning Research},
	author = {Lei, Anson and Schölkopf, Bernhard and Posner, Ingmar},
	year = {2023},
	keywords = {Computer science, Latent variable, Causal inference, Modular design, Representation (politics), Causal model, Inference, Artificial intelligence, Machine learning, Adaptation (eye), Theoretical computer science, Mathematics, Econometrics, Psychology, TMLR},
}
