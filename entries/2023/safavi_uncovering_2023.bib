@article{safavi_uncovering_2023,
	title = {Uncovering the {Organization} of {Neural} {Circuits} with {Generalized} {Phase} {Locking} {Analysis}},
	copyright = {CC-BY 4.0},
	issn = {1553-7358},
	shorttitle = {Uncovering the {Organization} of {Neural} {Circuits}},
	url = {https://journals.plos.org/ploscompbiol/article?id=10.1371/journal.pcbi.1010983},
	doi = {10.1371/journal.pcbi.1010983},
	abstract = {The brain is a complex system of interacting neural circuits. Understanding how these circuits are organized and how they communicate is a fundamental challenge in neuroscience. Here, we introduce Generalized Phase Locking Analysis (GPLA), a novel framework for identifying the organization of neural circuits from multi-channel electrophysiological recordings. GPLA generalizes the concept of phase locking to identify groups of neurons that exhibit consistent phase relationships, even in the presence of non-linear interactions and varying time delays. We demonstrate the utility of GPLA by applying it to simulated data and to recordings from the macaque primary visual cortex. Our results show that GPLA can effectively uncover the functional organization of neural circuits, revealing distinct clusters of neurons that correspond to known anatomical and functional structures. GPLA provides a powerful tool for investigating the principles of neural circuit organization and information processing in the brain.},
	language = {en},
	urldate = {2024-05-22},
	journal = {PLOS Computational Biology},
	publisher = {Public Library of Science},
	author = {Safavi, S. and Panagiotaropoulos, T. I. and Kapoor, V. and Ramirez-Villegas, J. F. and Logothetis, N. and Besserve, M.},
	month = apr,
	year = {2023},
	keywords = {PLOSCB},
}
