@inproceedings{yu_alert_2023,
	title = {{ALERT}: {Adapt} {Language} {Models} to {Reasoning} {Tasks}},
	shorttitle = {{ALERT}},
	url = {https://aclanthology.org/2023.acl-long.60},
	doi = {10.18653/v1/2023.acl-long.60},
	abstract = {Large Language Models (LLMs) have shown impressive performance on various natural language processing tasks. However, their ability to perform complex reasoning, especially in domains requiring specialized knowledge, remains limited. In this paper, we introduce ALERT, a benchmark for evaluating the reasoning capabilities of LLMs. ALERT consists of a diverse set of reasoning tasks, including logical, mathematical, and commonsense reasoning, across multiple domains. We evaluate several state-of-the-art LLMs on ALERT and find that they struggle with complex reasoning, particularly when it requires multi-step inference or domain-specific knowledge. We also propose a simple yet effective method to adapt LLMs to reasoning tasks by fine-tuning them on a small set of reasoning examples. Our results show that this approach significantly improves the reasoning performance of LLMs, suggesting that they can be effectively adapted to reasoning tasks with minimal supervision.},
	language = {en},
	booktitle = {Proceedings of the 61st {Annual} {Meeting} of the {Association} for {Computational} {Linguistics} ({ACL})},
	publisher = {Association for Computational Linguistics},
	author = {Yu, P. and Wang, T. and Golovneva, O. and AlKhamissi, B. and Verma, S. and Jin, Z. and Ghosh, G. and Diab, M. and Celikyilmaz, A.},
	editor = {Rogers, Anna and Boyd-Graber, Jordan and Okazaki, Naoaki},
	month = jul,
	year = {2023},
	keywords = {ACL},
}
