@article{athanassiadis_multiplane_2023,
	title = {Multiplane {Diffractive} {Acoustic} {Networks}},
	shorttitle = {Multiplane {Diffractive} {Acoustic} {Networks}},
	url = {https://doi.org/10.1109/TUFFC.2023.3255992},
	doi = {10.1109/TUFFC.2023.3255992},
	abstract = {Diffractive neural networks have emerged as a powerful framework for all-optical computing, where information is processed by light as it propagates through a series of diffractive layers. Here, we extend this concept to acoustics and introduce multiplane diffractive acoustic networks (MDANs). We show that by using multiple layers of acoustic diffractive elements, we can perform complex wave-field transformations, such as beam shaping and object classification, with high accuracy. We demonstrate the performance of MDANs through numerical simulations and experimental validation using 3D-printed acoustic diffractive layers in water. Our results show that MDANs can achieve high-fidelity acoustic beam shaping and classification, opening new avenues for acoustic signal processing and sensing.},
	language = {en},
	urldate = {2025-05-14},
	journal = {IEEE Transactions on Ultrasonics, Ferroelectrics, and Frequency Control},
	publisher = {IEEE},
	author = {Athanassiadis, Athanasios G. and Schlieder, Lennart and Melde, Kai and Volchkov, Valentin and Schölkopf, Bernhard and Fischer, Peer},
	month = mar,
	year = {2023},
	keywords = {Acoustics, Diffraction, Optoacoustic imaging, Physics, Computer science, Materials science, Optics, TUFFC},
}
