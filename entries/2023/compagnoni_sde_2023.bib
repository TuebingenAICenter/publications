@misc{compagnoni_sde_2023,
	title = {An {SDE} for {Modeling} {SAM}: {Theory} and {Insights}},
	shorttitle = {An {SDE} for {Modeling} {SAM}},
	url = {https://arxiv.org/abs/2301.08203},
	doi = {10.48550/arXiv.2301.08203},
	abstract = {Sharpness-Aware Minimization (SAM) has recently emerged as a powerful optimization method for training deep neural networks, consistently improving generalization performance. Despite its empirical success, a theoretical understanding of why SAM works remains elusive. In this work, we provide a theoretical framework for SAM by showing that its dynamics can be described by a Stochastic Differential Equation (SDE). Specifically, we prove that SAM's trajectory converges to a stationary distribution that favors flat minima, which are known to generalize well. We further provide a convergence analysis of SAM and show that it can be interpreted as a form of adaptive gradient descent. Finally, we provide empirical evidence supporting our theoretical findings and show that our SDE perspective allows for a more principled design of SAM-like algorithms.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Compagnoni, Enea Monzio and Biggio, Luca and Orvieto, Antonio and Kersting, Hans and Proske, Frank N. and Lucchi, Aurélien},
	year = {2023},
	keywords = {Hessian matrix, Maxima and minima, Saddle point, Scaling, Computer science, Saddle, Minification, Applied mathematics, Gradient descent, Noise (video), Mathematics, Mathematical optimization, Mathematical analysis, Artificial intelligence, Artificial neural network, Image (mathematics), Geometry, ICML},
}
