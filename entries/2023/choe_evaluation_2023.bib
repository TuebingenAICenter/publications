@article{choe_evaluation_2023,
	title = {Evaluation for {Weakly} {Supervised} {Object} {Localization}: {Protocol}, {Metrics}, and {Datasets}},
	shorttitle = {Evaluation for {Weakly} {Supervised} {Object} {Localization}},
	url = {https://ieeexplore.ieee.org/document/9762560},
	doi = {10.1109/TPAMI.2022.3169881},
	abstract = {Weakly supervised object localization (WSOL) aims to localize objects using only image-level labels. Despite the recent progress, the evaluation protocols for WSOL are inconsistent across the literature, making it difficult to compare different methods fairly. In this paper, we first identify the major issues in the current evaluation protocols, such as the lack of a standard evaluation metric and the use of different evaluation datasets. We then propose a new evaluation protocol for WSOL that addresses these issues. Our protocol includes a new evaluation metric, the localization-aware classification accuracy, and a new evaluation dataset, the CUB-200-2011-WSOL dataset. We also provide a comprehensive evaluation of existing WSOL methods using our new protocol and show that our protocol provides a more accurate and fair comparison of WSOL methods.},
	language = {en},
	journal = {IEEE Transactions on Pattern Analysis and Machine Intelligence},
	publisher = {IEEE},
	author = {Choe, J. and Oh, S. J. and Chun, S. and Lee, S. and Akata, Z. and Shim, H.},
	month = feb,
	year = {2023},
	keywords = {Computer science, Baseline (sea), Hyperparameter, Protocol (science), Artificial intelligence, Object (grammar), Set (abstract data type), Task (project management), Selection (genetic algorithm), Class (philosophy), Machine learning, Image (mathematics), Field (mathematics), Popularity, Pattern recognition (psychology), Computer vision, Mathematics, Psychology, Engineering, TPAMI},
}
