@inproceedings{noiato_advantage_2023,
	title = {On the {Advantage} of {Lion} {Compared} to {signSGD} with {Momentum}},
	shorttitle = {On the {Advantage} of {Lion}},
	url = {https://drive.google.com/file/d/1NDClMV7Ae19TbkU7DFXyMs95WK7ry-lS/view},
	abstract = {The Lion optimizer has recently gained significant attention due to its empirical success in training large-scale models. Despite its popularity, a theoretical understanding of why Lion outperforms standard sign-based methods like signSGD with momentum remains elusive. In this work, we provide a theoretical analysis of Lion in the context of high-dimensional learning. We show that Lion can be viewed as a specific instance of signSGD with momentum, but with a crucial difference in the update rule that allows it to better adapt to the geometry of the loss landscape. We provide convergence guarantees for Lion and demonstrate that it can achieve faster convergence rates than signSGD with momentum in certain settings. Our results provide a theoretical foundation for the empirical success of Lion and suggest new directions for the design of sign-based optimization algorithms.},
	language = {en},
	urldate = {2024-05-22},
	author = {Noiato, A. and Orvieto, A.},
	year = {2023},
	keywords = {ICML},
}
