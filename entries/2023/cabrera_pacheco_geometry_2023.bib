@misc{cabrera_pacheco_geometry_2023,
	title = {The {Geometry} of {Mixability}},
	url = {https://fm.ls/publications/geometry-mixability},
	doi = {10.48550/arxiv.2302.11905},
	abstract = {Mixable loss functions are of fundamental importance in the context of prediction with expert advice in the online setting since they characterize fast learning rates. By re-interpreting properness from the point of view of differential geometry, we provide a simple geometric characterization of mixability for the binary and multi-class cases: a proper loss function l is η-mixable if and only if the superpredition set spr(ηl) of the scaled loss function ηl slides freely inside the superprediction set spr(llog) of the log loss llog, under fairly general assumptions on the differentiability of l. Our approach provides a way to treat some concepts concerning loss functions (like properness) in a “coordinate-free” manner and reconciles previous results obtained for mixable loss functions for the binary and the multi-class cases.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Transactions on Machine Learning Research},
	author = {Cabrera Pacheco, Armando J. and Williamson, Robert C.},
	year = {2023},
	keywords = {Differentiable function, Class (philosophy), Context (archaeology), Mathematics, Simple (philosophy), Function (biology), Point (geometry), Binary number, Set (abstract data type), Geometry, Combinatorics, Discrete mathematics, Pure mathematics, Computer science, Artificial intelligence, Arithmetic, TMLR},
}
