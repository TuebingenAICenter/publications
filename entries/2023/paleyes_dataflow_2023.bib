@misc{paleyes_dataflow_2023,
	title = {Dataflow graphs as complete causal graphs},
	url = {https://doi.org/10.1109/CAIN58948.2023.00010},
	doi = {10.1109/CAIN58948.2023.00010},
	abstract = {Machine learning systems are increasingly complex, often involving multiple interconnected components. Understanding the causal relationships between these components is crucial for debugging, maintenance, and ensuring the reliability of these systems. In this paper, we propose to treat dataflow graphs, which are commonly used to represent machine learning pipelines, as complete causal graphs. We argue that the dataflow graph, when augmented with appropriate metadata, can provide a comprehensive view of the causal dependencies within a machine learning system. We demonstrate the utility of this approach through a case study and discuss the implications for AI engineering.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {IEEE},
	author = {Paleyes, Andrei and Guo, Siyuan and Schölkopf, Bernhard and Lawrence, Neil D.},
	month = apr,
	year = {2023},
	keywords = {Dataflow, Computer science, Software engineering, Software, Artifact (error), Component (thermodynamics), Programming language, Software development, Connection (principal bundle), Theoretical computer science, Artificial intelligence, Engineering, CAIN},
}
