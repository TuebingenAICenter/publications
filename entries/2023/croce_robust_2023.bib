@article{croce_robust_2023,
	title = {Robust {Semantic} {Segmentation}: {Strong} {Adversarial} {Attacks} and {Fast} {Training} of {Robust} {Models}},
	shorttitle = {Robust {Semantic} {Segmentation}},
	url = {https://arxiv.org/abs/2306.12941},
	doi = {10.48550/arXiv.2306.12941},
	abstract = {Adversarial robustness of semantic segmentation models is a critical requirement for safety-critical applications like autonomous driving. However, evaluating and training robust segmentation models is computationally expensive due to the high dimensionality of the output space. In this paper, we propose a new, efficient adversarial attack for semantic segmentation, which we call the 'Segmentation Attack' (SegAttack). SegAttack is based on a novel loss function that accounts for the spatial structure of the segmentation mask and is significantly faster than existing attacks. We further propose a fast training method for robust segmentation models, which we call 'Segmentation Adversarial Training' (SegAT). SegAT leverages the efficiency of SegAttack to train robust models in a fraction of the time required by standard adversarial training. We demonstrate the effectiveness of our approach on several standard benchmarks, showing that it achieves state-of-the-art robustness while being significantly faster to train than existing methods.},
	language = {en},
	urldate = {2025-05-14},
	journal = {arXiv},
	publisher = {arXiv},
	author = {Croce, Francesco and Singh, Naman D. and Hein, Matthias},
	year = {2023},
	keywords = {ARXIV},
}
