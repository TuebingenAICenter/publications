@article{jin_cladder_2023,
	title = {{CLadder}: {Assessing} {Causal} {Reasoning} in {Language} {Models}},
	shorttitle = {{CLadder}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2023/file/631bb9434d718ea309af82566347d607-Paper-Conference.pdf},
	abstract = {Large language models (LLMs) have demonstrated impressive performance on various reasoning tasks. However, their ability to perform causal reasoning remains under-explored. In this paper, we introduce CLadder, a benchmark designed to assess the causal reasoning capabilities of LLMs. CLadder consists of a diverse set of causal reasoning tasks, covering different levels of the causal hierarchy, including association, intervention, and counterfactuals. We evaluate several state-of-the-art LLMs on CLadder and find that while they perform well on associative tasks, they struggle with interventions and counterfactuals. Our results suggest that current LLMs lack a robust understanding of causal structures and that further research is needed to improve their causal reasoning abilities.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Advances in Neural Information Processing Systems 36},
	publisher = {Curran Associates, Inc.},
	author = {Jin, Z. and Chen, Y. and Leeb, F. and Gresele, L. and Kamal, O. and Lyu, Z. and Blin, K. and Gonzalez, F. and Kleiman-Weiner, M. and Sachan, M. and Schölkopf, B.},
	editor = {Oh, A. and Neumann, T. and Globerson, A. and Saenko, K. and Hardt, M. and Levine, S.},
	month = dec,
	year = {2023},
	keywords = {NEURIPS},
}
