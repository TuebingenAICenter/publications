@misc{gorecki_amortized_2023,
	title = {Amortized {Bayesian} {Decision} {Making} for simulation-based models},
	shorttitle = {Amortized {Bayesian} {Decision} {Making}},
	url = {https://arxiv.org/abs/2312.02674},
	doi = {10.48550/arXiv.2312.02674},
	abstract = {Bayesian decision making requires solving a nested optimization problem: finding the optimal action that maximizes the expected utility, where the expectation is taken over the posterior distribution. For simulation-based models, where the likelihood is intractable, this is typically computationally prohibitive. We propose a framework for amortized Bayesian decision making that learns to map observations directly to optimal actions. Our approach uses neural density estimation to amortize the posterior inference and a differentiable surrogate model to approximate the expected utility. We demonstrate that our method can solve complex decision-making tasks in simulation-based models, including experimental design and optimal control, with orders of magnitude speedups compared to traditional methods.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Gorecki, Mila and Macke, Jakob H. and Deistler, Michael},
	year = {2023},
	keywords = {Computer science, Posterior probability, Bayesian experimental design, Bayesian probability, Range (aeronautics), Inference, Bayesian inference, Machine learning, Prior probability, Benchmark (surveying), Artificial intelligence, Mathematical optimization, Bayesian statistics, Mathematics, ARXIV},
}
