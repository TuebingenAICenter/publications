@misc{karimi_relationship_2023,
	title = {On the {Relationship} {Between} {Explanation} and {Prediction}: {A} {Causal} {View}},
	url = {https://proceedings.mlr.press/v202/karimi23a.html},
	doi = {10.48550/arxiv.2212.06925},
	abstract = {The relationship between explanation and prediction is a subject of long-standing debate in science and philosophy. In machine learning, this debate has recently been reignited by the success of deep learning models, which are often highly predictive but difficult to interpret. In this paper, we provide a causal framework to study the relationship between explanation and prediction. We show that, under certain conditions, explanation and prediction are two sides of the same coin, and that a causal model can be used to bridge the gap between them. We also provide a set of desiderata for explanations and show that they are satisfied by our proposed causal framework. Finally, we demonstrate the utility of our framework on a range of synthetic and real-world tasks.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Karimi, Amir-Hossein and Muandet, Krikamol and Kornblith, Simon and Schölkopf, Bernhard and Kim, Been},
	editor = {Krause, A. and Brunskill, E. and Cho, K. and Engelhardt, B. and Sabato, S. and Scarlett, J.},
	year = {2023},
	keywords = {Hyperparameter, Causal inference, Metric (unit), Computer science, Initialization, Ideal (ethics), Inference, Causal model, Machine learning, Artificial intelligence, Econometrics, Psychology, Cognitive psychology, Mathematics, Statistics, Epistemology, Economics, ICML},
}
