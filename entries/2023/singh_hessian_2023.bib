@misc{singh_hessian_2023,
	title = {The {Hessian} perspective into the {Nature} of {Convolutional} {Neural} {Networks}},
	url = {https://proceedings.mlr.press/v202/singh23a.html},
	doi = {10.48550/arxiv.2305.09088},
	abstract = {We study the Hessian of the loss function of convolutional neural networks (CNNs). We show that the Hessian of a CNN is a structured matrix that can be decomposed into a sum of a low-rank matrix and a matrix with a specific block-diagonal structure. This structure is a consequence of the convolutional architecture and the weight sharing property. We use this perspective to explain several phenomena in CNNs, including the sharpness of the loss landscape, the generalization properties of CNNs, and the effectiveness of second-order optimization methods. We also provide a theoretical analysis of the Hessian's spectrum and show that it is related to the input data's geometry.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Singh, Sidak Pal and Hofmann, Thomas and Schölkopf, Bernhard},
	editor = {Krause, A. and Brunskill, E. and Cho, K. and Engelhardt, B. and Sabato, S. and Scarlett, J.},
	month = jul,
	year = {2023},
	keywords = {Hessian matrix, Rank (graph theory), Perspective (graphical), Convolutional neural network, Representation (politics), Pairwise comparison, Computer science, Hessian equation, Artificial intelligence, Mathematics, Theoretical computer science, Combinatorics, Applied mathematics, Mathematical analysis, ICML},
}
