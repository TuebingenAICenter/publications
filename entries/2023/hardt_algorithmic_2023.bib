@misc{hardt_algorithmic_2023,
	title = {Algorithmic {Collective} {Action} in {Machine} {Learning}},
	shorttitle = {Algorithmic {Collective} {Action}},
	url = {https://arxiv.org/abs/2302.04262},
	doi = {10.48550/arxiv.2302.04262},
	abstract = {We study the potential for collective action by individuals whose data is used to train machine learning models. We model the interaction between a learner and a population of individuals as a game. Individuals can choose to withhold their data or provide it to the learner. We show that when individuals act collectively, they can force the learner to adopt a model that is more favorable to them, even if the learner is not inherently inclined to do so. We characterize the conditions under which such collective action is effective and discuss the implications for the design of machine learning systems.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Hardt, Moritz and Mazumdar, Eric and Mendler-Dünner, Celestine and Zrnic, Tijana},
	year = {2023},
	keywords = {Computer science, Artificial intelligence, Machine learning, Collective action, Function (biology), Action (physics), Nonparametric statistics, Task (project management), Simple (philosophy), Empirical research, Parametric statistics, Mathematics, Epistemology, ICML},
}
