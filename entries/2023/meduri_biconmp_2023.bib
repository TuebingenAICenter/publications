@article{meduri_biconmp_2023,
	title = {{BiConMP}: {A} {Nonlinear} {Model} {Predictive} {Control} {Framework} for {Whole} {Body} {Motion} {Planning}},
	shorttitle = {{BiConMP}},
	url = {https://ieeexplore.ieee.org/document/10008229},
	doi = {10.1109/TRO.2022.3228390},
	abstract = {In this article, we present BiConMP, a nonlinear model predictive control (NMPC) framework for whole-body motion planning of legged robots. The framework is based on a hierarchical approach that combines a contact-implicit trajectory optimization with a whole-body controller. We propose a novel formulation of the contact-implicit trajectory optimization that allows for the generation of dynamic motions while maintaining computational efficiency. We demonstrate the effectiveness of our approach through extensive simulations and hardware experiments on a quadrupedal robot, showing that it can generate complex, dynamic behaviors such as trotting, bounding, and jumping in challenging environments.},
	language = {en},
	urldate = {2024-05-23},
	journal = {IEEE Transactions on Robotics},
	publisher = {IEEE},
	author = {Meduri, A. and Shah, P. and Viereck, J. and Khadiv, M. and Havoutis, I. and Righetti, L.},
	year = {2023},
	keywords = {TRO},
}
