@misc{dax_neural_2023,
	title = {Neural {Importance} {Sampling} for {Rapid} and {Reliable} {Gravitational}-{Wave} {Inference}},
	shorttitle = {Neural {Importance} {Sampling}},
	url = {https://doi.org/10.1103/PhysRevLett.130.171403},
	doi = {10.1103/PhysRevLett.130.171403},
	abstract = {Gravitational-wave inference is computationally expensive, requiring millions of waveform evaluations to map out the posterior distribution of source parameters. We introduce a method for rapid and reliable Bayesian inference that combines neural density estimation with importance sampling. We train a normalizing flow to approximate the posterior distribution, and then use importance sampling to correct for the approximation error, ensuring that the final results are statistically exact. We demonstrate that our method produces accurate posteriors for binary black hole mergers, with a speedup of several orders of magnitude compared to standard stochastic sampling methods.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {American Physical Society},
	author = {Dax, Maximilian and Green, Stephen R. and Gair, Jonathan and Pürrer, Michael and Wildberger, Jonas and Macke, Jakob H. and Buonanno, Alessandra and Schölkopf, Bernhard},
	month = apr,
	year = {2023},
	keywords = {Inference, LIGO, Computer science, Artificial neural network, Bayesian inference, Bayesian probability, Artificial intelligence, Posterior probability, Statistical inference, Sampling (signal processing), Sample (material), Machine learning, Frequentist inference, Statistics, Mathematics, Physics, Detector, Telecommunications, PRL},
}
