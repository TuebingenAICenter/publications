@article{kirchhof_probabilistic_2023,
	title = {Probabilistic {Contrastive} {Learning} {Recovers} the {Correct} {Aleatoric} {Uncertainty} of {Ambiguous} {Inputs}},
	shorttitle = {Probabilistic {Contrastive} {Learning}},
	url = {https://arxiv.org/abs/2302.02865},
	doi = {10.48550/arXiv.2302.02865},
	abstract = {Contrastive learning has emerged as a powerful paradigm for self-supervised representation learning. However, standard contrastive learning methods typically map inputs to point estimates in the latent space, failing to capture the inherent aleatoric uncertainty of ambiguous inputs. In this work, we propose Probabilistic Contrastive Learning (PCL), a framework that learns to map inputs to distributions in the latent space. We show that PCL naturally recovers the aleatoric uncertainty of ambiguous inputs by modeling the latent representations as Gaussian distributions. We provide a theoretical analysis showing that PCL is equivalent to maximizing a lower bound on the mutual information between the input and the latent representation, where the aleatoric uncertainty is captured by the variance of the latent distribution. We demonstrate the effectiveness of PCL on several benchmarks, showing that it achieves competitive performance on downstream tasks while providing well-calibrated uncertainty estimates.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 40th International Conference on Machine Learning},
	publisher = {PMLR},
	author = {Kirchhof, Michael and Kasneci, Enkelejda and Oh, Seong Joon},
	year = {2023},
	keywords = {ICML},
}
