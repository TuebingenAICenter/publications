@misc{schneider_investigating_2023,
	title = {Investigating the {Impact} of {Action} {Representations} in {Policy} {Gradient} {Algorithms}},
	url = {https://arxiv.org/abs/2309.06921},
	doi = {10.48550/arxiv.2309.06921},
	abstract = {In reinforcement learning, the choice of action representation is a crucial design decision that can significantly impact the performance of an agent. While many studies focus on state representations, the impact of action representations is less explored. In this work, we investigate how different action representations affect the performance of policy gradient algorithms. We evaluate several action representations on a set of continuous control tasks and find that the choice of action representation can lead to significant differences in performance. Our results suggest that action representations should be carefully considered when designing reinforcement learning agents.},
	language = {en},
	urldate = {2025-05-14},
	author = {Schneider, Jan and Schumacher, Pierre and Häufle, Daniel and Schölkopf, Bernhard and Büchler, Dieter},
	month = may,
	year = {2023},
	keywords = {Reinforcement learning, Benchmark (surveying), Computer science, Artificial intelligence, Action (physics), Representation (politics), Machine learning, Algorithm, ICRA},
}
