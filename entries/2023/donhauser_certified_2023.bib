@inproceedings{donhauser_certified_2023,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Certified private data release for sparse {Lipschitz} functions},
	shorttitle = {Certified private data release for sparse {Lipschitz} functions},
	url = {https://tpdp.journalprivacyconfidentiality.org/2023/},
	abstract = {We study the problem of releasing a dataset under differential privacy (DP) such that the released data is useful for a class of Lipschitz functions. We focus on the setting where the functions are sparse, meaning they only depend on a small subset of the features. We provide a new mechanism for this problem that achieves a better utility-privacy trade-off than existing methods. Our mechanism is based on a combination of the exponential mechanism and a new technique for sparse estimation. We also provide a certified privacy guarantee for our mechanism, which means that the privacy loss is bounded even if the data distribution is unknown.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {{TPDP} 2023 - {Theory} and {Practice} of {Differential} {Privacy}},
	publisher = {PMLR},
	author = {Donhauser, Kathrin and Lokna, Jonas and Sanyal, Aritra and Boedihardjo, Maheswari and Hönig, Robin and Yang, Fanny},
	month = sep,
	year = {2023},
	keywords = {AISTATS, TPDP},
}
