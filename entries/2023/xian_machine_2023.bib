@misc{xian_machine_2023,
	title = {A machine learning route between band mapping and band structure},
	shorttitle = {A machine learning route between band mapping and band structure},
	url = {https://doi.org/10.1038/s43588-022-00382-2},
	doi = {10.1038/s43588-022-00382-2},
	abstract = {Angle-resolved photoemission spectroscopy (ARPES) is the primary experimental technique for mapping the electronic band structure of solids. However, the extraction of band structure from raw photoemission data is often hindered by experimental artifacts, limited resolution and the complexity of the data. Here we present a machine learning framework that automates the extraction of band structure from ARPES data. Our approach, based on a deep neural network, learns to map raw photoemission intensity distributions to the underlying band structure. We demonstrate that our method is robust to experimental noise and artifacts, and can be applied to a wide range of materials. Our framework provides a scalable and objective route for the analysis of ARPES data, facilitating the high-throughput characterization of quantum materials.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Nature Portfolio},
	author = {Xian, R. P. and Stimper, V. and Zacharias, M. and Dendzik, M. and Dong, S. and Beaulieu, S. and Schölkopf, B. and Wolf, M. and Rettig, L. and Carbogno, C. and Bauer, S. and Ernstorfer, R.},
	month = jan,
	year = {2023},
	keywords = {Computer science, Artificial intelligence, Pipeline (software), Machine learning, Scalability, Database},
}
