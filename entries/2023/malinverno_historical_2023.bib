@article{malinverno_historical_2023,
	title = {A historical perspective of biomedical explainable {AI} research},
	issn = {2666-3899},
	shorttitle = {A historical perspective of biomedical explainable {AI} research},
	url = {https://doi.org/10.1016/j.patter.2023.100830},
	doi = {10.1016/j.patter.2023.100830},
	abstract = {Explainable AI (XAI) has become a central topic in the development of machine learning models for biomedical applications. While the field has grown rapidly in recent years, the underlying concepts and motivations have a long history. In this perspective, we provide a historical overview of XAI in the biomedical domain, tracing its evolution from early expert systems to modern deep learning approaches. We discuss the shifting focus from rule-based systems to black-box models and the subsequent emergence of post-hoc explanation methods. Finally, we highlight current challenges and future directions for the field, emphasizing the need for interdisciplinary collaboration and the development of evaluation frameworks that account for the specific requirements of biomedical stakeholders.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Patterns},
	publisher = {Elsevier},
	author = {Malinverno, L. and Barros, V. and Ghisoni, F. and Visonà, G. and Kern, R. and Nickel, P. J. and Ventura, B. E. and Šimić, I. and Stryeck, S. and Manni, F. and Ferri, C. and Jean-Quartier, C. and Genga, L. and Schweikert, G. and Lovrić, M. and Rosen-Zvi, M.},
	month = sep,
	year = {2023},
	keywords = {PATTERNS},
}
