@inproceedings{nguyen_bayesian_2023-1,
	title = {A {Bayesian} {Perspective} {On} {Training} {Data} {Attribution}},
	shorttitle = {A {Bayesian} {Perspective} {On} {Training} {Data} {Attribution}},
	url = {https://arxiv.org/abs/2305.19765},
	abstract = {Training data attribution (TDA) aims to quantify the influence of individual training examples on a model's prediction. Existing methods often rely on local linear approximations of the model, which can be inaccurate for deep neural networks. In this work, we propose a Bayesian perspective on TDA. We frame TDA as the problem of estimating the posterior predictive distribution under a leave-one-out training set. We show that this perspective naturally leads to a principled and computationally efficient approach to TDA. We demonstrate that our method, which we call Bayesian TDA, provides more accurate and robust attribution scores than existing methods on a variety of tasks and models.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {arXiv},
	author = {Nguyen, Elisa and Seo, Minjoon and Oh, Seong Joon},
	year = {2023},
	keywords = {NEURIPS},
}
