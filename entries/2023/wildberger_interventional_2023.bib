@misc{wildberger_interventional_2023,
	title = {On the {Interventional} {Kullback}-{Leibler} {Divergence}},
	url = {https://proceedings.mlr.press/v213/wildberger23a.html},
	doi = {10.48550/arxiv.2302.05380},
	abstract = {The Kullback-Leibler (KL) divergence is a fundamental measure of the difference between two probability distributions. In causal inference, we are often interested in how distributions change under interventions. We introduce the interventional KL divergence, which measures the difference between two causal models by comparing their interventional distributions. We show that this divergence satisfies a number of desirable properties, including a chain rule and a data processing inequality. We also show that it can be used to define a causal version of the information bottleneck, and we provide an algorithm for estimating it from observational and interventional data.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Wildberger, J. B. and Guo, S. and Bhattacharyya, A. and Schölkopf, B.},
	editor = {van der Schaar, Mihaela and Zhang, Cheng and Janzing, Dominik},
	month = apr,
	year = {2023},
	keywords = {Divergence (linguistics), Modularity (biology), Computer science, Kullback–Leibler divergence, Set (abstract data type), Ground truth, Task (project management), Machine learning, Causal structure, Artificial intelligence, Data set, CLEAR},
}
