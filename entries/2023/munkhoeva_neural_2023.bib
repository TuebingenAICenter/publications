@inproceedings{munkhoeva_neural_2023,
	title = {Neural {Harmonics}: {Bridging} {Spectral} {Embedding} and {Matrix} {Completion} in {Self}-{Supervised} {Learning}},
	shorttitle = {Neural {Harmonics}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2023/file/bede8c7d5ed2348494d2b0621d613592-Paper-Conference.pdf},
	abstract = {Self-supervised learning (SSL) methods often rely on contrastive loss functions to learn representations. While effective, these methods can be computationally expensive and sensitive to hyperparameters. In this paper, we propose Neural Harmonics, a novel framework that bridges spectral embedding and matrix completion for SSL. We show that many popular SSL methods can be interpreted as performing spectral embedding on a graph constructed from the data. By leveraging this connection, we formulate SSL as a matrix completion problem, which allows us to learn representations by solving a convex optimization problem. We demonstrate the effectiveness of our approach on several benchmark datasets, showing that it achieves competitive performance while being more computationally efficient and robust to hyperparameters than existing methods.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 36 ({NeurIPS} 2023)},
	publisher = {Curran Associates, Inc.},
	author = {Munkhoeva, Maria and Oseledets, Ivan},
	editor = {Oh, Alice and Neumann, Tobias and Globerson, Amir and Saenko, Kate and Hardt, Moritz and Levine, Sergey},
	month = dec,
	year = {2023},
	keywords = {NEURIPS},
}
