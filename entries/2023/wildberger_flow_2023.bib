@misc{wildberger_flow_2023,
	title = {Flow {Matching} for {Scalable} {Simulation}-{Based} {Inference}},
	shorttitle = {Flow {Matching} for {Scalable} {SBI}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2023/file/3663ae53ec078860bb0b9c6606e092a0-Paper-Conference.pdf},
	doi = {10.48550/arxiv.2305.17161},
	abstract = {Simulation-based inference (SBI) allows for Bayesian inference in models where the likelihood is intractable but simulation is possible. Recent advances in SBI have been driven by neural density estimation, particularly using normalizing flows. However, training these flows can be computationally expensive and unstable, especially in high-dimensional parameter spaces. In this work, we propose to use flow matching, a recently introduced framework for training continuous normalizing flows, for SBI. We show that flow matching provides a stable and efficient alternative to existing methods for simulation-based inference. We demonstrate that our approach, which we call Flow Matching for SBI (FM-SBI), achieves state-of-the-art performance on a range of benchmark problems, while being significantly faster to train than existing methods. We also show that FM-SBI scales well to high-dimensional parameter spaces, making it a promising tool for complex scientific models.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Wildberger, J. and Dax, M. and Buchholz, S. and Green, S. R. and Macke, J. H. and Schölkopf, B.},
	editor = {Oh, A. and Neumann, T. and Globerson, A. and Saenko, K. and Hardt, M. and Levine, S.},
	month = dec,
	year = {2023},
	keywords = {Computer science, Scalability, Inference, Benchmark (surveying), Matching (statistics), Estimator, Flexibility (engineering), Machine learning, Artificial intelligence, Algorithm, Data mining, Computer engineering, Mathematics, NEURIPS},
}
