@inproceedings{sukhija_optimistic_2023,
	title = {Optimistic {Active} {Exploration} of {Dynamical} {Systems}},
	shorttitle = {Optimistic {Active} {Exploration} of {Dynamical} {Systems}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2023/file/77b5aaf2826c95c98e5eb4ab830073de-Paper-Conference.pdf},
	abstract = {Active exploration is a fundamental challenge in reinforcement learning and control, where an agent must interact with an unknown environment to learn its dynamics efficiently. While many existing methods rely on uncertainty-based exploration, they often struggle with the exploration-exploitation trade-off in complex, high-dimensional dynamical systems. In this work, we propose a novel framework for optimistic active exploration of dynamical systems. Our approach leverages the principle of optimism in the face of uncertainty by constructing a set of plausible dynamics models and selecting actions that maximize the potential for information gain or task performance. We demonstrate the effectiveness of our method on a range of challenging control tasks, showing that it outperforms existing state-of-the-art exploration strategies in terms of sample efficiency and final performance.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 36 ({NeurIPS} 2023)},
	publisher = {Curran Associates Inc.},
	author = {Sukhija, Bhavya and Treven, Lenart and Sancaktar, Cansu and Blaes, Sebastian and Coros, Stelian and Krause, Andreas},
	month = dec,
	year = {2023},
	keywords = {NEURIPS},
}
