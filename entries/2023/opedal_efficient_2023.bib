@inproceedings{opedal_efficient_2023,
	title = {Efficient {Semiring}-{Weighted} {Earley} {Parsing}},
	url = {https://aclanthology.org/2023.acl-long.204},
	doi = {10.18653/v1/2023.acl-long.204},
	abstract = {We present a new algorithm for parsing with semiring-weighted context-free grammars. Our algorithm is a generalization of the Earley parser that computes the sum of the weights of all derivations of a string. Like the original Earley parser, it runs in O(nˆ3) time for general context-free grammars and O(nˆ2) time for unambiguous grammars. We show that our algorithm is more efficient than the standard approach of converting the grammar to Chomsky Normal Form and using the CKY algorithm, as it avoids the overhead of binarization. We also provide a formal proof of correctness and demonstrate the efficiency of our algorithm on a range of tasks.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {Proceedings of the 61st {Annual} {Meeting} of the {Association} for {Computational} {Linguistics} ({ACL})},
	publisher = {Association for Computational Linguistics},
	author = {Opedal, Andreas and Zmigrod, Ryan and Vieira, Tim and Cotterell, Ryan and Eisner, Jason},
	editor = {Rogers, Anna and Boyd-Graber, Jordan L. and Okazaki, Naoaki},
	month = jul,
	year = {2023},
	keywords = {ACL},
}
