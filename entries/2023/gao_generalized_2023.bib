@inproceedings{gao_generalized_2023,
	title = {Generalized {Bayesian} {Inference} for {Scientific} {Simulators} via {Amortized} {Cost} {Estimation}},
	shorttitle = {Generalized {Bayesian} {Inference} for {Scientific} {Simulators}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2023/file/fdd565f63f49776bef620e0ce368a492-Paper-Conference.pdf},
	doi = {10.48550/arxiv.2305.15208},
	abstract = {Simulation-based inference (SBI) has become a powerful tool for performing Bayesian inference in scientific models where the likelihood is intractable but simulation is possible. However, standard SBI methods typically target the posterior distribution under a specific loss function (e.g., the log-likelihood). In many scientific applications, we are interested in generalized Bayesian inference (GBI), where the goal is to minimize a more general loss function, such as a robust loss or a loss that accounts for model misspecification. In this paper, we introduce a novel framework for amortized GBI that allows for flexible loss functions. Our approach, which we call Amortized Cost Estimation (ACE), learns to estimate the cost function associated with a given observation and parameter, allowing for efficient inference. We demonstrate the effectiveness of our approach on several scientific benchmarks, showing that it outperforms existing methods in terms of accuracy and robustness.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 36 ({NeurIPS} 2023)},
	publisher = {Curran Associates, Inc.},
	author = {Gao, R. and Deistler, M. and Macke, J. H.},
	editor = {Oh, A. and Neumann, T. and Globerson, A. and Saenko, K. and Hardt, M. and Levine, S.},
	month = dec,
	year = {2023},
	keywords = {Inference, Computer science, Benchmark (surveying), Bayesian inference, Markov chain Monte Carlo, Bayesian probability, Uncertainty quantification, Frequentist inference, Function (biology), Machine learning, Predictive inference, Algorithm, Artificial intelligence, NEURIPS},
}
