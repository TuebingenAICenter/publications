@article{shao_information_2023,
	title = {Information theoretic measures of causal influences during transient neural events},
	copyright = {CC BY 4.0},
	issn = {2674-0362},
	shorttitle = {Information theoretic measures of causal influences},
	url = {https://www.frontiersin.org/articles/10.3389/fnetp.2023.1085347},
	doi = {10.3389/fnetp.2023.1085347},
	abstract = {The study of causal interactions in neural systems is central to understanding brain function. While many methods exist to infer directed connectivity, they often rely on assumptions of stationarity or linear dynamics, which may not hold for transient neural events such as spikes, bursts, or evoked potentials. Here, we propose a framework based on information theory to quantify causal influences during transient events. We define a measure of causal influence based on the transfer entropy, adapted to the non-stationary nature of transient events. We validate our approach using synthetic data and demonstrate its application to electrophysiological recordings from the macaque visual cortex. Our results show that the proposed measure can effectively capture the dynamics of causal influences during transient events and reveal directed interactions that are missed by standard methods.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Frontiers in Network Physiology},
	publisher = {Frontiers Media S.A.},
	author = {Shao, K. and Logothetis, N. K. and Besserve, M.},
	year = {2023},
	keywords = {FNETP},
}
