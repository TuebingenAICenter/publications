@article{visona_machine-learning-aided_2023,
	title = {Machine-{Learning}-{Aided} {Prediction} of {Brain} {Metastases} {Development} in {Non}-{Small}-{Cell} {Lung} {Cancers}},
	issn = {1525-7304},
	shorttitle = {Machine-{Learning}-{Aided} {Prediction} of {Brain} {Metastases} {Development}},
	url = {https://is.mpg.de/ei/publications/visonaetal23b},
	doi = {10.1016/j.cllc.2023.08.002},
	abstract = {Background: Brain metastases (BM) are a frequent and severe complication in patients with non-small-cell lung cancer (NSCLC). Early identification of patients at high risk for BM development could improve clinical management. We aimed to develop a machine-learning (ML) model to predict the development of BM in patients with NSCLC. Patients and Methods: We retrospectively analyzed 248 patients with NSCLC treated at our institution between 2010 and 2019. Clinical, radiological, and histopathological data were collected. We developed an ML model using a random forest classifier to predict the development of BM. The model was trained and validated using a 5-fold cross-validation approach. Results: The final model achieved an area under the receiver operating characteristic curve (AUC) of 0.78 (95\% CI, 0.71-0.85) for predicting BM development. The most important predictors were the presence of lymph node metastases, tumor size, and the histological subtype. Conclusion: Our ML model shows promising performance in predicting the development of BM in patients with NSCLC. This tool could potentially assist clinicians in identifying high-risk patients who might benefit from closer surveillance or prophylactic interventions.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Clinical lung cancer},
	publisher = {Elsevier},
	author = {Visonà, G. and Spiller, L. M. and Hahn, S. and Hattingen, E. and Vogl, T. J. and Schweikert, G. and Bankov, K. and Demes, M. and Reis, H. and Wild, P. and Zeiner, P. S. and Acker, F. and Sebastian, M. and Wenger, K. J.},
	month = dec,
	year = {2023},
}
