@misc{klepper_relating_2023,
	title = {Relating graph auto-encoders to linear models},
	url = {https://openreview.net/forum?id=Y1eYplvxrE},
	doi = {10.48550/arxiv.2211.01858},
	abstract = {Graph auto-encoders (GAEs) are a popular class of models for graph representation learning. Despite their empirical success, their theoretical properties are not yet well understood. In this paper, we analyze the behavior of GAEs by relating them to linear models. We show that for a specific choice of the decoder, the GAE objective is equivalent to a linear model that performs a form of graph smoothing. This allows us to interpret the GAE as a method that learns a representation by balancing the reconstruction of the input features and the smoothness of the representation with respect to the graph structure. We further show that this interpretation holds for both the standard GAE and the Variational Graph Auto-Encoder (VGAE). Our theoretical findings are supported by empirical experiments on several benchmark datasets.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Transactions on Machine Learning Research},
	author = {Klepper, Solveig and von Luxburg, Ulrike},
	year = {2023},
	keywords = {Encoder, Graph, Inductive bias, Computer science, Theoretical computer science, Algorithm, TMLR},
}
