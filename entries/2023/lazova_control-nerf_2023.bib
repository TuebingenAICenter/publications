@article{lazova_control-nerf_2023,
	title = {Control-{NeRF}: {Editable} {Feature} {Volumes} for {Scene} {Rendering} and {Manipulation}},
	shorttitle = {Control-{NeRF}},
	url = {https://arxiv.org/abs/2204.10850},
	doi = {10.1109/WACV56688.2023.00432},
	abstract = {Neural Radiance Fields (NeRF) have shown impressive results in synthesizing novel views of static scenes. However, they are typically static and difficult to edit. In this paper, we propose Control-NeRF, a method that enables intuitive control and manipulation of NeRF-based scenes. We achieve this by learning a feature volume that is conditioned on a set of control parameters. Specifically, we represent the scene as a set of feature volumes that are warped and blended based on the input control parameters. This allows us to manipulate the scene by simply changing the control parameters, such as the pose of an object or the camera view. We demonstrate the effectiveness of our method on a variety of scenes and show that it outperforms existing methods in terms of both rendering quality and editability.},
	language = {en},
	urldate = {2025-05-14},
	journal = {2023 IEEE/CVF Winter Conference on Applications of Computer Vision (WACV)},
	publisher = {IEEE},
	author = {Lazova, Verica and Guzov, Vladimir and Olszewski, Kyle and Tulyakov, Sergey and Pons-Moll, Gerard},
	year = {2023},
	keywords = {Computer science, Rendering (computer graphics), Artificial intelligence, Computer vision, Voxel, Feature (linguistics), View synthesis, Volume rendering, Computer graphics (images), WACV},
}
