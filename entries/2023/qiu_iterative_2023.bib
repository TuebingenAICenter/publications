@misc{qiu_iterative_2023,
	title = {Iterative {Teaching} by {Data} {Hallucination}},
	url = {https://proceedings.mlr.press/v206/qiu23a.html},
	doi = {10.48550/arxiv.2210.17467},
	abstract = {Machine teaching aims to find a minimal set of training examples to guide a learner to a target model. Existing methods often assume that the teacher has full access to the learner's training process or that the learner is a simple model. In this paper, we propose a novel framework, Iterative Teaching by Data Hallucination (ITDH), which enables a teacher to guide a black-box learner to a target model by iteratively hallucinating training data. Specifically, the teacher generates synthetic data to influence the learner's update, and the learner updates its model based on the combined real and synthetic data. We show that ITDH can effectively guide various learners, including deep neural networks, to target models with high accuracy. We also provide theoretical analysis to understand the convergence and optimality of the proposed framework.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Qiu, Zeju and Liu, Weiyang and Xiao, Tim and Liu, Zhen and Bhatt, Umang and Luo, Yucen and Weller, Adrian and Schölkopf, Bernhard},
	editor = {Ruiz, Francisco and Dy, Jennifer and van de Meent, Jan-Willem},
	year = {2023},
	keywords = {Computer science, Space (punctuation), Black box, Iterative method, Image (mathematics), Artificial intelligence, Distribution (mathematics), Mathematics education, Algorithm, Machine learning, Mathematics, AISTATS},
}
