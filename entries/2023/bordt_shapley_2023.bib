@misc{bordt_shapley_2023,
	title = {From {Shapley} {Values} to {Generalized} {Additive} {Models} and back},
	url = {http://tml.cs.uni-tuebingen.de/team/luxburg/publications/BordtLuxburg2023.pdf},
	doi = {10.48550/arxiv.2209.04012},
	abstract = {Shapley values are a popular tool for explaining machine learning models. However, their theoretical properties are often misunderstood. In this paper, we show that for any model, the Shapley value explanation is the unique additive approximation that minimizes a specific weighted least squares loss. This result allows us to bridge the gap between Shapley values and Generalized Additive Models (GAMs). We show that Shapley values can be interpreted as a specific type of GAM, and that many properties of Shapley values can be derived from this connection. We also show that this connection allows us to define new types of Shapley values, and to better understand the behavior of existing ones.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Bordt, Sebastian and von Luxburg, Ulrike},
	year = {2023},
	keywords = {Shapley value, Characterization (materials science), Interpretation (philosophy), Decomposition, Sequence (biology), Function (biology), Parametric statistics, Variable (mathematics), Computer science, Mathematics, Mathematical economics, Statistics, Game theory, AISTATS},
}
