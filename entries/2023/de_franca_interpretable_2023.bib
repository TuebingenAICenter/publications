@misc{de_franca_interpretable_2023,
	title = {Interpretable {Symbolic} {Regression} for {Data} {Science}: {Analysis} of the 2022 {Competition}},
	shorttitle = {Interpretable {Symbolic} {Regression} for {Data} {Science}},
	url = {https://arxiv.org/abs/2304.01117},
	abstract = {Symbolic regression (SR) is a type of regression analysis that searches the space of mathematical expressions to find a model that best fits a given dataset. Unlike traditional regression methods, SR does not assume a functional form for the model, but rather discovers it from the data. This makes SR a powerful tool for scientific discovery, as it can produce interpretable models that are often more accurate than those produced by traditional methods. In 2022, we organized the first competition on interpretable symbolic regression for data science at the Genetic and Evolutionary Computation Conference (GECCO). The competition aimed to evaluate the state-of-the-art in SR algorithms on a set of diverse and challenging datasets. This paper provides an analysis of the competition, including the datasets, the participating algorithms, and the results. We also discuss the lessons learned and provide recommendations for future competitions.},
	language = {en},
	urldate = {2024-05-22},
	publisher = {arXiv},
	author = {de Franca, FO and Virgolin, M and Kommenda, M and Majumder, MS and Cranmer, M and Espada, G and Ingelse, L and Fonseca, A and Landajuela, M and Petersen, B and Glatt, R and Mundhenk, N and Lee, CS and Hochhalter, JD and Randall, DL and Kamienny, P and Zhang, H and Dick, G and Simon, A and Burlacu, B and Kasak, Jaan and Machado, Meera and Wilstrup, Casper and Cava, WG La},
	year = {2023},
	keywords = {GECCO},
}
