@misc{bitterwolf_or_2023,
	title = {In or {Out}? {Fixing} {ImageNet} {Out}-of-{Distribution} {Detection} {Evaluation}},
	shorttitle = {In or {Out}?},
	url = {https://openreview.net/pdf?id=8K6FMDyBs2},
	doi = {10.48550/arxiv.2306.00826},
	abstract = {Out-of-distribution (OOD) detection is a critical component for the safe deployment of machine learning models. While ImageNet is the standard benchmark for OOD detection, we show that the current evaluation practice is flawed: the OOD test sets contain a significant fraction of images that are semantically similar to ImageNet classes, leading to an overestimation of OOD detection performance. We introduce NINCO (No ImageNet Classes Out-of-distribution), a new OOD benchmark that is carefully curated to exclude any images that are semantically similar to ImageNet classes. We show that on NINCO, the performance of state-of-the-art OOD detection methods is significantly lower than on existing benchmarks, and that the ranking of methods changes. Our results suggest that the current OOD detection evaluation on ImageNet is not representative of the true performance of OOD detection methods in the wild.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {ICML},
	author = {Bitterwolf, Julian and Müller, Maximilian and Hein, Matthias},
	year = {2023},
	keywords = {Computer science, Range (aeronautics), Set (abstract data type), Detector, Unit testing, Code (set theory), Artificial intelligence, Task (project management), Machine learning, Data mining, Pattern recognition (psychology), Engineering, Software, ICML},
}
