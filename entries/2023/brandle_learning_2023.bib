@article{brandle_learning_2023,
	title = {Learning progress and uncompensated rewards as motivational drivers of engagement},
	url = {https://charleywu.github.io/downloads/braendle2023learning.pdf},
	doi = {10.32470/ccn.2023.1286-0},
	abstract = {Why do humans engage with tasks even in the absence of external rewards? Here, we investigate the drivers of engagement in a multi-armed bandit task where participants can choose to explore or exploit, but also have the option to quit the task at any time. We find that both learning progress (the reduction of uncertainty) and uncompensated rewards (rewards that do not affect the task's outcome) are strong predictors of engagement. We propose a computational model that accounts for these factors and show that it outperforms alternative models in predicting human behavior. Our results suggest that engagement is driven by a combination of intrinsic and extrinsic motivations, and that these motivations are integrated into a common currency for decision-making.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 2023 Conference on Cognitive Computational Neuroscience},
	publisher = {Cognitive Computational Neuroscience},
	author = {Brändle, Franziska and Wu, Charley M. and Schulz, Eric},
	editor = {Hunt, L. and Summerfield, C. and Konkle, T. and Fedorenko, E. and Naselaris, T.},
	year = {2023},
	keywords = {Computer science, Psychology, Human–computer interaction, CCN},
}
