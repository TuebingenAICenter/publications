@article{uchiyama_model-based_2023,
	title = {Model-{Based} {Assimilation} {Transmits} and {Recombines} {World} {Models}},
	url = {https://doi.org/10.31234/osf.io/v69jy},
	doi = {10.31234/osf.io/v69jy},
	abstract = {Cultural evolution is often described as a process of cumulative change, where information is transmitted and refined over generations. However, the cognitive mechanisms that enable this process remain debated. We propose that model-based assimilation—the process of integrating new information into an existing internal model of the world—is a key mechanism for cultural evolution. We formalize this process using a Bayesian framework, where agents update their world models based on observed behavior. We show that this mechanism allows for the transmission of complex world models, and that it can lead to the recombination of different models, resulting in novel cultural traits. We test our model in a series of simulations and show that it can account for key features of cultural evolution, including the emergence of cumulative culture and the recombination of cultural traits.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 2023 Conference on Cognitive Computational Neuroscience},
	publisher = {OSF Preprints},
	author = {Uchiyama, Ryutaro and Tennie, Claudio and Wu, Charley M.},
	editor = {Hunt, L. and Summerfield, C. and Konkle, T. and Fedorenko, E. and Naselaris, T.},
	year = {2023},
	keywords = {Computer science, Atmospheric model, Data assimilation, Assimilation (phonology), Meteorology, Physics, CCN},
}
