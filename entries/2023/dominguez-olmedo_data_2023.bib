@article{dominguez-olmedo_data_2023,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {On {Data} {Manifolds} {Entailed} by {Structural} {Causal} {Models}},
	url = {https://proceedings.mlr.press/v202/dominguez-olmedo23a.html},
	abstract = {Structural Causal Models (SCMs) are a powerful framework for modeling causal relationships. While they are often used to reason about interventions and counterfactuals, they also implicitly define the geometry of the data distribution. In this work, we study the data manifolds entailed by SCMs. We show that under mild conditions, the data generated by an SCM lies on a low-dimensional manifold. We characterize the tangent space of this manifold and show that it is determined by the causal structure and the noise variables. We further show that this geometric perspective allows us to derive new insights into causal representation learning and provides a principled way to perform causal inference in high-dimensional spaces.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 40th International Conference on Machine Learning},
	publisher = {PMLR},
	author = {Dominguez-Olmedo, Ricardo and Karimi, Amir-Hossein and Arvanitidis, Georgios and Schölkopf, Bernhard},
	editor = {Krause, A. and Brunskill, E. and Cho, K. and Engelhardt, B. and Sabato, S. and Scarlett, J.},
	month = jul,
	year = {2023},
	keywords = {Mathematics, Econometrics, ICML},
}
