@misc{auzina_modulated_2023,
	title = {Modulated {Neural} {ODEs}},
	shorttitle = {{MoNODEs}},
	url = {https://bethgelab.org/publication/2023_12_auzina_yildiz/},
	doi = {10.48550/arxiv.2302.13262},
	abstract = {Neural Ordinary Differential Equations (Neural ODEs) have emerged as a powerful framework for modeling continuous-time dynamical systems. However, they often struggle to capture complex, non-stationary dynamics where the underlying system behavior changes over time. To address this, we introduce Modulated Neural ODEs (MoNODEs), a novel architecture that incorporates a modulation mechanism to adapt the vector field of the ODE based on time-varying context. By conditioning the dynamics on a latent representation of the system's state, MoNODEs can effectively model non-stationary processes and exhibit improved generalization capabilities. We demonstrate the effectiveness of our approach on a range of synthetic and real-world datasets, showing that MoNODEs outperform standard Neural ODEs and other baselines in terms of predictive accuracy and computational efficiency.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Auzina, Ilze Amanda and Yıldız, Çağatay and Magliacane, Sara and Bethge, Matthias and Gavves, Efstratios},
	year = {2023},
	keywords = {Ode, Ordinary differential equation, Trajectory, Node (physics), Computer science, Encoder, Artificial neural network, Invariant (physics), Variation (astronomy), Control theory (sociology), Mathematics, Artificial intelligence, Differential equation, Applied mathematics, Control (management), NEURIPS},
}
