@inproceedings{daunhawer_identifiability_2023,
	title = {Identifiability {Results} for {Multimodal} {Contrastive} {Learning}},
	url = {https://openreview.net/pdf?id=U_2kuqoTcB},
	abstract = {Multimodal contrastive learning has emerged as a powerful framework for learning representations from multiple data modalities. Despite its empirical success, the theoretical foundations of why and when these models learn identifiable representations remain largely unexplored. In this work, we provide a theoretical analysis of identifiability in multimodal contrastive learning. We show that under a generative model where modalities are conditionally independent given a shared latent factor, multimodal contrastive learning can identify the latent factors up to a group of transformations. We further characterize the conditions under which this identifiability holds, and provide a framework for analyzing the identifiability of multimodal contrastive learning models. Our results provide a theoretical justification for the success of multimodal contrastive learning and offer insights into the design of more effective multimodal representation learning algorithms.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {The {Eleventh} {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Daunhawer, Imant and Bizeul, Alice and Palumbo, Emmanuele and Marx, Alexander and Vogt, Julia E.},
	month = may,
	year = {2023},
	keywords = {ICLR},
}
