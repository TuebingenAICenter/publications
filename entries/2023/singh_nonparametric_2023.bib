@inproceedings{singh_nonparametric_2023,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Nonparametric {Indirect} {Active} {Learning}},
	url = {https://proceedings.mlr.press/v206/singh23a.html},
	abstract = {We consider the problem of active learning where the learner does not have direct access to the labels of the data points. Instead, the learner can only query a noisy, indirect signal related to the labels. This setting is motivated by applications where obtaining direct labels is expensive or impossible, but indirect feedback is available. We propose a nonparametric approach to this problem, which we call Nonparametric Indirect Active Learning (NIAL). NIAL uses a kernel-based approach to estimate the relationship between the indirect signal and the labels, and then uses this estimate to guide the active learning process. We provide theoretical guarantees for the convergence of NIAL and demonstrate its effectiveness on several synthetic and real-world datasets.},
	language = {en},
	booktitle = {Proceedings of the 26th {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Singh, S.},
	editor = {Ruiz, Francisco and Dy, Jennifer and van de Meent, Jan-Willem},
	month = apr,
	year = {2023},
	keywords = {AISTATS},
}
