@article{dangel_vivit_2023,
	title = {{ViViT}: {Curvature} {Access} {Through} {The} {Generalized} {Gauss}-{Newton}'s {Low}-{Rank} {Structure}},
	shorttitle = {{ViViT}},
	url = {https://openreview.net/forum?id=DzJ7JfPXkE},
	doi = {10.48550/arxiv.2106.02624},
	abstract = {The Generalized Gauss-Newton (GGN) matrix is a central object in deep learning, as it approximates the Hessian and is used in second-order optimization, curvature-based pruning, and uncertainty estimation. However, the GGN is often too large to be computed or stored explicitly. We present ViViT, a library that provides efficient access to the GGN's low-rank structure. ViViT enables the computation of GGN-vector products, the GGN's diagonal, and the GGN's trace without ever forming the full matrix. We demonstrate the utility of ViViT by applying it to second-order optimization, curvature-based pruning, and uncertainty estimation in deep learning.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Transactions on Machine Learning Research},
	author = {Dangel, Felix and Tatzel, Lukas and Hennig, Philipp},
	month = feb,
	year = {2023},
	keywords = {Hessian matrix, Curvature, Computation, Eigenvalues and eigenvectors, Noise (video), Algorithm, Diagonal, Rank (graph theory), Computer science, Representation (politics), Kronecker delta, Applied mathematics, Mathematics, Artificial intelligence, Geometry, Combinatorics, ICLR, TMLR},
}
