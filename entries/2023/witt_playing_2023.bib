@article{witt_playing_2023,
	title = {Playing to win or playing to learn? {Human} performance in a social card game task},
	shorttitle = {Playing to win or playing to learn?},
	url = {https://charleywu.github.io/downloads/witt2023playing.pdf},
	doi = {10.32470/ccn.2023.1415-0},
	abstract = {Social interaction often requires balancing the goal of maximizing immediate rewards with the goal of learning about others' intentions. In this paper, we investigate how humans navigate this exploration-exploitation trade-off in a social card game. We introduce a novel task where participants play against a partner whose strategy is unknown and changes over time. We find that participants' behavior is well-described by a model that balances reward maximization with information gain, and that this balance is sensitive to the social context. Our results suggest that humans are sophisticated social learners who adapt their exploration strategies to the demands of the social environment.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 2023 Conference on Cognitive Computational Neuroscience},
	publisher = {Cognitive Computational Neuroscience},
	author = {Witt, Alexandra and Vasama, Joel and Vélez, Natalia and Wu, Charley M.},
	year = {2023},
	keywords = {Task (project management), Computer science, Human–computer interaction, Multimedia, Engineering, CCN},
}
