@article{orvieto_explicit_2023,
	title = {Explicit {Regularization} in {Overparametrized} {Models} via {Noise} {Injection}},
	shorttitle = {Explicit {Regularization} in {Overparametrized} {Models}},
	url = {https://arxiv.org/abs/2206.04613},
	doi = {10.48550/arXiv.2206.04613},
	abstract = {We study the effect of noise injection in the training of overparametrized models. We show that, in the limit of small noise, the training dynamics of stochastic gradient descent (SGD) with noise injection can be described by a stochastic differential equation (SDE). We prove that this SDE is equivalent to a gradient flow on a regularized objective function, where the regularization term is explicitly given by the Fisher information matrix of the noise distribution. We further show that this regularization term can be interpreted as a form of implicit regularization that favors flat minima. We provide theoretical guarantees for the convergence of the training dynamics and demonstrate the effectiveness of our approach on a variety of tasks, including image classification and language modeling.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 26th International Conference on Artificial Intelligence and Statistics},
	publisher = {PMLR},
	author = {Orvieto, Antonio and Raj, Anant and Kersting, Hans and Bach, Francis},
	year = {2023},
	keywords = {AISTATS},
}
