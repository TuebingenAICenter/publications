@inproceedings{sun_right_2023,
	series = {Lecture {Notes} in {Computer} {Science}},
	title = {Right for the {Wrong} {Reason}: {Can} {Interpretable} {ML} {Techniques} {Detect} {Spurious} {Correlations}?},
	isbn = {978-3-031-43895-0},
	shorttitle = {Right for the {Wrong} {Reason}},
	url = {https://link.springer.com/chapter/10.1007/978-3-031-43895-0_40},
	doi = {10.1007/978-3-031-43895-0_40},
	abstract = {Deep learning models are known to be prone to learning spurious correlations, i.e., relying on features that are predictive in the training set but not causally related to the target. Interpretable machine learning (IML) techniques are often proposed as a solution to detect such behavior. However, it remains unclear whether these techniques are actually capable of identifying when a model relies on spurious correlations. In this work, we systematically evaluate the ability of several popular IML methods to detect spurious correlations in a controlled medical imaging setting. We find that most IML methods fail to reliably indicate whether a model is relying on spurious features, and in some cases, even provide misleading explanations. Our results suggest that IML methods should be used with caution for the purpose of detecting spurious correlations and that further research is needed to develop more robust interpretability tools.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Medical {Image} {Computing} and {Computer}-{Assisted} {Intervention} – {MICCAI} 2023},
	publisher = {Springer Nature Switzerland},
	author = {Sun, Shiyu and Koch, Laura M. and Baumgartner, Christian F.},
	month = oct,
	year = {2023},
	keywords = {MICCAI},
}
