@article{xie_visibility_2023,
	title = {Visibility {Aware} {Human}-{Object} {Interaction} {Tracking} from {Single} {RGB} {Camera}},
	shorttitle = {Visibility {Aware} {Human}-{Object} {Interaction} {Tracking}},
	url = {https://arxiv.org/abs/2303.16479},
	doi = {10.1109/CVPR52729.2023.00461},
	abstract = {Tracking human-object interactions (HOI) from a single RGB camera is a challenging task due to frequent occlusions, complex contact patterns, and the lack of depth information. Existing methods often struggle to maintain consistent tracking when the object is occluded by the human or vice versa. In this paper, we propose a novel visibility-aware approach for HOI tracking. We introduce a visibility-aware representation that explicitly models the visibility of both the human and the object over time. Our method leverages this visibility information to guide the tracking process, effectively handling occlusions and improving the robustness of the interaction estimation. We demonstrate the effectiveness of our approach on challenging datasets, showing significant improvements over state-of-the-art methods in both tracking accuracy and interaction fidelity.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
	publisher = {IEEE},
	author = {Xie, Xianghui and Bhatnagar, Bharat Lal and Pons-Moll, Gerard},
	year = {2023},
	keywords = {Artificial intelligence, Computer vision, Computer science, RGB color model, Leverage (statistics), Object (grammar), Computer graphics (images), CVPR},
}
