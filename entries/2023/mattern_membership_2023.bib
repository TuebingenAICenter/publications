@misc{mattern_membership_2023,
	title = {Membership {Inference} {Attacks} against {Language} {Models} via {Neighbourhood} {Comparison}},
	url = {https://doi.org/10.18653/V1/2023.FINDINGS-ACL.719},
	doi = {10.18653/V1/2023.FINDINGS-ACL.719},
	abstract = {Membership inference attacks (MIAs) aim to determine whether a specific data point was used to train a machine learning model. While MIAs have been extensively studied for classification models, their application to large language models (LLMs) remains under-explored. In this work, we propose a novel MIA for LLMs based on the intuition that a model's loss on a training sample is lower than on its neighbours in the data space. We introduce a neighbourhood comparison attack that compares the loss of a target sample to the loss of its perturbed versions. Our method is model-agnostic, requires no access to the training process, and does not require a reference model trained on a similar distribution. We evaluate our attack on a variety of LLMs and datasets, demonstrating that it consistently outperforms existing baselines, especially in the low-false-positive regime.},
	language = {en},
	publisher = {Association for Computational Linguistics},
	author = {Mattern, Justus and Mireshghallah, Fatemehsadat and Jin, Zhijing and Schölkopf, Bernhard and Sachan, Mrinmaya and Berg-Kirkpatrick, Taylor},
	editor = {Rogers, Anna and Boyd-Graber, Jordan L. and Okazaki, Naoaki},
	month = jul,
	year = {2023},
	keywords = {Computer science, Inference, Adversary, Sample (material), Imperfect, Artificial intelligence, Machine learning, Neighbourhood (mathematics), Data mining, Computer security, Mathematics, ACL},
}
