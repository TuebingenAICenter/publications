@article{wellnitz_network_2023,
	title = {A network approach to atomic spectra},
	issn = {2632-072X},
	url = {https://doi.org/10.1088/2632-072X/ace1c3},
	doi = {10.1088/2632-072X/ace1c3},
	abstract = {Atomic spectra are complex structures that encode the quantum mechanical properties of atoms. While the analysis of individual transitions is well-established, the global structure of these spectra remains less explored. Here, we propose a network-based approach to represent atomic spectra, where energy levels are nodes and transitions are edges. We apply this framework to the spectra of several atoms and ions, demonstrating that the resulting networks exhibit non-trivial topological features, such as community structure and small-world properties. We further show that these features are robust across different elements and can be used to identify groups of transitions that share common physical origins. Our approach provides a new perspective on the complexity of atomic spectra and offers a powerful tool for their systematic analysis and classification.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Journal of Physics: Complexity},
	publisher = {IOP Publishing},
	author = {Wellnitz, D. and Kekić, A. and Heiss, J. and Gertz, M. and Weidemüller, M. and Spitz, A.},
	month = jul,
	year = {2023},
	keywords = {JPHYSCOMPLEX},
}
