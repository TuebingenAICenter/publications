@article{nam_scratching_2023,
	title = {Scratching {Visual} {Transformer}'s {Back} with {Uniform} {Attention}},
	shorttitle = {Scratching {Visual} {Transformer}'s {Back}},
	url = {https://arxiv.org/abs/2210.08457},
	doi = {10.1109/ICCV51078.2023.00125},
	abstract = {Vision Transformers (ViTs) have shown remarkable performance in various computer vision tasks. However, the self-attention mechanism, the core component of ViTs, has a quadratic computational complexity with respect to the number of tokens, which limits its application to high-resolution images. To address this, we propose Uniform Attention, a simple yet effective attention mechanism that reduces the computational complexity to linear. Uniform Attention replaces the standard self-attention with a uniform distribution of attention weights, which can be computed efficiently. We demonstrate that Uniform Attention achieves competitive performance on various vision tasks, including image classification, object detection, and semantic segmentation, while significantly reducing the computational cost.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the IEEE/CVF International Conference on Computer Vision (ICCV)},
	publisher = {IEEE},
	author = {Nam, Hyeon-Woo and Kim, Yu-Ji and Heo, Byeongho and Han, Dongyoon and Oh, Seong Joon and Oh, Tae-Hyun},
	year = {2023},
	keywords = {ICCV},
}
