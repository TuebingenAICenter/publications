@misc{singh_revisiting_2023,
	title = {Revisiting {Adversarial} {Training} for {ImageNet}: {Architectures}, {Training} and {Generalization} across {Threat} {Models}},
	shorttitle = {Revisiting {Adversarial} {Training} for {ImageNet}},
	url = {https://arxiv.org/abs/2303.01870},
	doi = {10.48550/arxiv.2303.01870},
	abstract = {Adversarial training (AT) is the standard defense against adversarial attacks. While AT has been extensively studied on small-scale datasets like CIFAR-10, its application to ImageNet remains challenging due to the high computational cost and the difficulty of achieving high robust accuracy. In this paper, we revisit adversarial training for ImageNet. We first show that the choice of architecture is crucial: we demonstrate that modern architectures like ConvNeXt and Swin Transformer significantly outperform the standard ResNet-50 in terms of robust accuracy. Second, we investigate the impact of training recipes and show that simple modifications to the training procedure, such as using larger batch sizes and longer training schedules, can lead to substantial improvements. Finally, we analyze the generalization of these models across different threat models and show that models trained with a specific threat model can exhibit surprising robustness to others. Our results provide a new state-of-the-art for adversarial training on ImageNet and offer insights into the factors that contribute to robust generalization.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Singh, Naman D. and Croce, Francesco and Hein, Matthias},
	year = {2023},
	keywords = {Adversarial system, Robustness (evolution), Generalization, FLOPS, Computer science, Artificial intelligence, Machine learning, Training (meteorology), Training set, Deep neural networks, Generalization error, Mathematics, Artificial neural network, Geography, Parallel computing, CVPR},
}
