@article{liu_sphereface_2023,
	title = {{SphereFace} {Revived}: {Unifying} {Hyperspherical} {Face} {Recognition}},
	shorttitle = {{SphereFace} {Revived}},
	url = {https://is.mpg.de/ei/publications/liuetal23-bfae3282-b0e1-4537-b737-b223abd557a9},
	doi = {10.1109/TPAMI.2022.3159732},
	abstract = {Hyperspherical face recognition has achieved great success in recent years. Among various methods, SphereFace is a pioneer that introduces angular margin to deep face recognition. However, the original SphereFace formulation is not strictly hyperspherical, which leads to optimization difficulties and suboptimal performance. In this paper, we revisit SphereFace and propose a unified hyperspherical face recognition framework. We show that the original SphereFace can be interpreted as a specific case of our proposed framework. We further provide a theoretical analysis of the proposed framework and show that it can be optimized more effectively. Extensive experiments on standard benchmarks demonstrate that our proposed method achieves state-of-the-art performance.},
	language = {en},
	journal = {IEEE Transactions on Pattern Analysis and Machine Intelligence},
	publisher = {IEEE},
	author = {Liu, Weiyang and Wen, Yandong and Raj, Bhiksha and Singh, Rita and Weller, Adrian},
	month = feb,
	year = {2023},
	keywords = {TPAMI},
}
