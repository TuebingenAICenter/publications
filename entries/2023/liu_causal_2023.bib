@misc{liu_causal_2023,
	title = {Causal {Triplet}: {An} {Open} {Challenge} for {Intervention}-centric {Causal} {Representation} {Learning}},
	url = {https://proceedings.mlr.press/v213/liu23a.html},
	doi = {10.48550/arxiv.2301.05169},
	abstract = {Causal representation learning aims to recover the underlying causal variables and their causal relationships from raw observations. While recent works have made significant progress in identifying causal variables, they often rely on strong assumptions about the data-generating process or the availability of specific interventions. In this work, we introduce the Causal Triplet, a new benchmark for intervention-centric causal representation learning. The Causal Triplet consists of three components: a set of causal variables, a set of interventions, and a set of observations. We evaluate several state-of-the-art causal representation learning methods on the Causal Triplet and find that they struggle to recover the underlying causal structure in the presence of complex interventions. We hope that the Causal Triplet will serve as a challenging testbed for future research in causal representation learning.},
	language = {en},
	publisher = {PMLR},
	author = {Liu, Y. and Alahi, A. and Russell, C. and Horn, M. and Zietlow, D. and Schölkopf, B. and Locatello, F.},
	editor = {van der Schaar, Mihaela and Zhang, Cheng and Janzing, Dominik},
	month = apr,
	year = {2023},
	keywords = {Counterfactual thinking, Causal structure, Computer science, Robustness (evolution), Representation (politics), Artificial intelligence, Feature learning, Causal chain, Machine learning, Causal model, Data science, Cognitive psychology, Psychology, Social psychology, Epistemology, Mathematics, Political science, CLEAR},
}
