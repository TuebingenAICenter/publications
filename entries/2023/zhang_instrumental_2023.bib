@misc{zhang_instrumental_2023,
	title = {Instrumental variable regression via kernel maximum moment loss},
	url = {https://is.mpg.de/ei/publications/zhaimaschmua23},
	doi = {10.1515/jci-2022-0073},
	abstract = {Instrumental variable (IV) regression is a fundamental tool for estimating causal effects in the presence of unobserved confounders. In this paper, we propose a novel nonparametric IV regression method based on the kernel maximum moment loss (KMM loss). The KMM loss is derived from the conditional moment restriction, which characterizes the IV model, and it is defined as the maximum mean discrepancy between the joint distribution of the instruments and the treatment, and the distribution of the instruments and the outcome. We show that the proposed estimator is consistent and achieves the minimax optimal convergence rate under certain conditions. Furthermore, we provide a practical algorithm for computing the estimator and demonstrate its effectiveness through extensive experiments on both synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {De Gruyter},
	author = {Zhang, Rui and Imaizumi, Masaaki and Schölkopf, Bernhard and Muandet, Krikamol},
	month = apr,
	year = {2023},
	keywords = {Mathematics, Kernel (algebra), Kernel regression, Moment (physics), Reproducing kernel Hilbert space, Kernel method, Statistic, Consistency (knowledge bases), Nonparametric regression, Applied mathematics, Mathematical optimization, Nonparametric statistics, Statistics, Computer science, Hilbert space, Artificial intelligence, Support vector machine, Combinatorics, Discrete mathematics, Mathematical analysis},
}
