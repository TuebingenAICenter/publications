@misc{yatsura_certified_2023,
	title = {Certified {Defences} {Against} {Adversarial} {Patch} {Attacks} on {Semantic} {Segmentation}},
	url = {https://openreview.net/forum?id=VFGgG8XpFLu},
	doi = {10.48550/arxiv.2209.05980},
	abstract = {Adversarial patch attacks are a severe threat to deep learning models in computer vision, as they can be easily realized in the physical world. While certified defenses against such attacks have been developed for image classification, they are largely missing for semantic segmentation. In this work, we propose the first certified defense against adversarial patch attacks for semantic segmentation. Our approach is based on randomized smoothing and provides a certified guarantee that the prediction for a pixel remains unchanged if the patch is restricted to a certain size. We evaluate our method on the Cityscapes and Pascal VOC datasets and show that it provides meaningful robustness guarantees while maintaining competitive performance.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {OpenReview},
	author = {Yatsura, Maksym and Sakmann, Kaspar and Hua, N. Grace and Hein, Matthias and Metzen, Jan Hendrik},
	year = {2023},
	keywords = {Smoothing, Computer science, Segmentation, Adversarial system, Artificial intelligence, Robustness (evolution), Task (project management), Certification, Machine learning, Architecture, Computer vision, Engineering, ICLR},
}
