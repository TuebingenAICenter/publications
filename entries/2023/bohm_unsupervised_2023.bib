@misc{bohm_unsupervised_2023,
	title = {Unsupervised visualization of image datasets using contrastive learning},
	url = {https://openreview.net/forum?id=nI2HmVA0hvt},
	doi = {10.48550/arxiv.2210.09879},
	abstract = {Visualization of high-dimensional data is a key tool for exploratory data analysis. For image datasets, standard approaches like t-SNE or UMAP are often applied to raw pixels or to features from a pre-trained neural network. However, raw pixels do not capture semantic similarity, and pre-trained features are biased by the training task. Here, we propose to use self-supervised contrastive learning to learn a representation specifically for visualization. We show that this approach produces visualizations that are more faithful to the semantic structure of the data than those based on raw pixels or standard pre-trained features, and that it is robust to the choice of the contrastive learning objective. We demonstrate the utility of our approach on several image datasets, including CIFAR-10, CIFAR-100, and ImageNet, and show that it can be used to identify clusters, outliers, and other structures in the data.},
	language = {en},
	urldate = {2025-02-07},
	publisher = {International Conference on Learning Representations},
	author = {Böhm, Jan Niklas and Berens, Philipp and Kobak, Dmitry},
	month = may,
	year = {2023},
	keywords = {Computer science, Visualization, Artificial intelligence, Pattern recognition (psychology), Pixel, Graph, Similarity (geometry), k-nearest neighbors algorithm, Outlier, Unsupervised learning, Image (mathematics), Theoretical computer science, ICLR},
}
