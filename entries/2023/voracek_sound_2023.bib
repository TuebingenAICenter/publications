@misc{voracek_sound_2023,
	title = {Sound {Randomized} {Smoothing} in {Floating}-{Point} {Arithmetics}},
	url = {https://openreview.net/forum?id=HaHCoGcpV9},
	doi = {10.48550/arxiv.2207.07209},
	abstract = {Randomized smoothing is a popular technique to provide certified robustness guarantees for deep learning models. However, existing methods typically assume that the underlying computations are performed in exact real arithmetic. In this paper, we show that this assumption is violated in practice due to floating-point arithmetic, which can lead to invalid certificates. We propose a sound randomized smoothing framework that accounts for floating-point errors and provides rigorous robustness guarantees. Our approach is based on interval arithmetic and provides a way to compute certified radii that are valid even in the presence of floating-point inaccuracies. We demonstrate the effectiveness of our method on several benchmarks and show that it provides sound certificates with minimal loss in robustness.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {OpenReview},
	author = {Voráček, Václav and Hein, Matthias},
	year = {2023},
	keywords = {Smoothing, Point (geometry), Matching (statistics), Computer science, Randomized experiment, Floating point, Algorithm, Mathematics, Computer vision, Statistics, ICLR},
}
