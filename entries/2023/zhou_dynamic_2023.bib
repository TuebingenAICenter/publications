@article{zhou_dynamic_2023,
	title = {The {Dynamic} and {Structured} {Nature} of {Learning} and {Memory}},
	shorttitle = {The {Dynamic} and {Structured} {Nature} of {Learning} and {Memory}},
	url = {https://charleywu.github.io/downloads/zhou2023dynamic.pdf},
	doi = {10.32470/ccn.2023.1331-0},
	abstract = {How do humans learn and remember in a world that is both dynamic and structured? While traditional models of learning and memory often treat these processes as separate, recent work suggests they are deeply intertwined. Here, we propose a framework that integrates these two perspectives, suggesting that learning and memory are dynamic processes that rely on the structure of the environment. We test this framework using a series of behavioral experiments and computational models, showing that it can account for a wide range of phenomena in human learning and memory.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 2023 Conference on Cognitive Computational Neuroscience},
	publisher = {Cognitive Computational Neuroscience},
	author = {Zhou, Hanqi and Tejero-Cantero, Álvaro and Wu, Charley M.},
	editor = {Hunt, L. and Summerfield, C. and Konkle, T. and Fedorenko, E. and Naselaris, T.},
	year = {2023},
	keywords = {Computer science, Dynamic random-access memory, Semiconductor memory, Operating system, CCN},
}
