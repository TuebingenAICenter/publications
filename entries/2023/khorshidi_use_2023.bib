@inproceedings{khorshidi_use_2023,
	title = {On the {Use} of {Torque} {Measurement} in {Centroidal} {State} {Estimation}},
	shorttitle = {On the {Use} of {Torque} {Measurement} in {Centroidal} {State} {Estimation}},
	url = {https://is.mpg.de/ei/publications/khorshidietal23},
	doi = {10.1109/ICRA48891.2023.10160823},
	abstract = {Centroidal state estimation is a fundamental component for the control of legged robots. Most existing approaches rely on kinematic measurements and contact information to estimate the robot's base state. However, these methods are prone to drift and are sensitive to contact detection errors. In this paper, we investigate the use of joint torque measurements to improve centroidal state estimation. We propose a novel estimator that incorporates torque measurements into a centroidal dynamics model. We evaluate our approach on a quadruped robot and show that it significantly improves the estimation accuracy compared to a standard kinematic-based estimator, especially in the presence of contact uncertainties.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {{IEEE} {International} {Conference} on {Robotics} and {Automation} ({ICRA})},
	publisher = {IEEE},
	author = {Khorshidi, S. and Gazar, A. and Rotella, N. and Naveau, M. and Righetti, L. and Bennewitz, M. and Khadiv, M.},
	month = may,
	year = {2023},
	keywords = {ICRA},
}
