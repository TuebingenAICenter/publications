@misc{ilanchezian_generating_2023,
	title = {Generating {Realistic} {Counterfactuals} for {Retinal} {Fundus} and {OCT} {Images} using {Diffusion} {Models}},
	shorttitle = {Generating {Realistic} {Counterfactuals}},
	url = {https://arxiv.org/abs/2311.11629},
	doi = {10.48550/arXiv.2311.11629},
	abstract = {Counterfactual explanations are a promising approach to provide interpretable insights into the decision-making process of deep learning models in medical imaging. However, generating realistic counterfactuals for high-dimensional medical images remains challenging. In this work, we propose a method to generate counterfactuals for retinal fundus and optical coherence tomography (OCT) images using diffusion models. We leverage the latent space of a pre-trained diffusion model to perform counterfactual edits by optimizing the latent representation to change the model's prediction while preserving the identity of the original image. We demonstrate that our method generates realistic and clinically plausible counterfactuals for both fundus and OCT images, and that these counterfactuals can be used to gain insights into the features that drive the model's predictions.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Ilanchezian, Indu and Boreiko, Valentyn and Kühlewein, Laura and Huang, Ziwei and Ayhan, Murat Seçkin and Hein, Matthias and Koch, Lisa M. and Berens, Philipp},
	year = {2023},
	keywords = {Counterfactual conditional, Counterfactual thinking, Computer science, Optical coherence tomography, Artificial intelligence, Fundus (uterus), Computer vision, Optometry, Medicine, Ophthalmology, Psychology},
}
