@misc{kekic_evaluating_2023,
	title = {Evaluating vaccine allocation strategies using simulation-assisted causal modeling},
	shorttitle = {Evaluating vaccine allocation strategies},
	url = {https://www.sciencedirect.com/science/article/pii/S266638992300079X},
	doi = {10.1016/j.patter.2023.100739},
	abstract = {The COVID-19 pandemic has highlighted the need for robust decision-making tools to guide public health interventions. Vaccine allocation is a critical policy lever, yet its effectiveness depends on complex, non-linear dynamics and the underlying causal structure of the epidemic. We propose a simulation-assisted causal modeling framework to evaluate vaccine allocation strategies. By combining mechanistic epidemiological models with causal inference, we can estimate the counterfactual outcomes of different allocation policies. We demonstrate our approach by evaluating age-stratified vaccination strategies in a simulated population, showing that our framework can identify optimal allocation policies that are robust to uncertainties in model parameters and population structure.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Elsevier},
	author = {Kekić, A. and Dehning, J. and Gresele, L. and von Kügelgen, J. and Priesemann, V. and Schölkopf, B.},
	month = jun,
	year = {2023},
	keywords = {Counterfactual thinking, Pandemic, Vaccination, Flexibility (engineering), Population, Computer science, Herd immunity, Incidence (geometry), Medicine, Demography, Coronavirus disease 2019 (COVID-19), Immunology, Environmental health, Psychology, Statistics, Disease, Mathematics, Social psychology, Infectious disease (medical specialty)},
}
