@inproceedings{kim_bridging_2023,
	title = {Bridging the {Gap} between {Model} {Explanations} in {Partially} {Annotated} {Multi}-label {Classification}},
	shorttitle = {Bridging the {Gap} between {Model} {Explanations}},
	url = {https://ieeexplore.ieee.org/document/10203674},
	doi = {10.1109/CVPR52729.2023.00332},
	abstract = {Multi-label classification (MLC) models are often trained on partially annotated datasets where only a subset of labels is provided for each image. While recent methods have shown success in handling missing labels, they often struggle to provide reliable explanations for their predictions. In this paper, we propose a novel framework to bridge the gap between model explanations and partially annotated MLC. Our approach leverages the available labels to guide the model's attention towards relevant image regions, while simultaneously learning to predict the missing labels. We demonstrate the effectiveness of our method on several benchmark datasets, showing that it not only improves classification performance but also produces more faithful and interpretable explanations compared to existing methods.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {Proceedings of the {IEEE}/{CVF} {Conference} on {Computer} {Vision} and {Pattern} {Recognition} ({CVPR})},
	publisher = {IEEE},
	author = {Kim, Y. and Kim, J. M. and Jeong, J. and Schmid, C. and Akata, Z. and Lee, J.},
	month = jun,
	year = {2023},
	keywords = {Computer science, Artificial intelligence, Multi-label classification, Bridging (networking), Margin (machine learning), Discriminative model, Attribution, Machine learning, Task (project management), Field (mathematics), Code (set theory), Noise (video), Pattern recognition (psychology), Psychology, Mathematics, Social psychology, Set (abstract data type), Image (mathematics), CVPR},
}
