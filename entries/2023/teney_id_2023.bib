@article{teney_id_2023,
	title = {{ID} and {OOD} {Performance} {Are} {Sometimes} {Inversely} {Correlated} on {Real}-world {Datasets}},
	shorttitle = {{ID} and {OOD} {Performance} {Are} {Sometimes} {Inversely} {Correlated}},
	url = {https://arxiv.org/abs/2209.00613},
	doi = {10.48550/arXiv.2209.00613},
	abstract = {The performance of machine learning models on out-of-distribution (OOD) data is often assumed to be positively correlated with their performance on in-distribution (ID) data. This assumption is a cornerstone of model selection and evaluation, where ID validation performance is used as a proxy for OOD generalization. In this paper, we challenge this assumption. We show that ID and OOD performance are sometimes inversely correlated on real-world datasets. We demonstrate this phenomenon on a variety of tasks, including image classification, object detection, and semantic segmentation. We analyze the causes of this inverse correlation and show that it is linked to the model's reliance on spurious correlations. We conclude by discussing the implications of our findings for model selection and evaluation.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Advances in Neural Information Processing Systems},
	publisher = {Curran Associates, Inc.},
	author = {Teney, Damien and Yong, Lin and Oh, Seong Joon and Abbasnejad, Ehsan},
	year = {2023},
	keywords = {NEURIPS},
}
