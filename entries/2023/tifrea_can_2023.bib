@inproceedings{tifrea_can_2023,
	title = {Can semi-supervised learning use all the data effectively? {A} lower bound perspective},
	shorttitle = {Can semi-supervised learning use all the data effectively?},
	url = {https://proceedings.neurips.cc/paper_files/paper/2023/file/458fa8ee331566383d8e74bdb647f829-Paper-Conference.pdf},
	abstract = {Semi-supervised learning (SSL) aims to improve the performance of a model by leveraging a large amount of unlabeled data in addition to a small amount of labeled data. While many empirical successes have been reported, the theoretical understanding of when and how much unlabeled data can improve the performance remains limited. In this paper, we study the sample complexity of SSL in the agnostic PAC learning framework. We provide a general lower bound on the excess risk of any SSL algorithm, which depends on the relationship between the hypothesis class and the data distribution. Our results show that for many common hypothesis classes, the unlabeled data can only provide a limited improvement in the sample complexity, and in some cases, no improvement at all. We also provide matching upper bounds for several cases, demonstrating the tightness of our lower bounds. Our findings suggest that the effectiveness of SSL is highly dependent on the alignment between the hypothesis class and the underlying data distribution, and provide a theoretical foundation for understanding the limitations of SSL.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 36},
	publisher = {Curran Associates, Inc.},
	author = {Tifrea, Alexandru and Yüce, Gökberk and Sanyal, Amartya and Yang, Fan},
	editor = {Oh, A. and Neumann, T. and Globerson, A. and Saenko, K. and Hardt, M. and Levine, S.},
	month = dec,
	year = {2023},
	keywords = {NEURIPS},
}
