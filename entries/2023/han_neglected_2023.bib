@article{han_neglected_2023,
	title = {Neglected {Free} {Lunch}: {Learning} {Image} {Classifiers} {Using} {Annotation} {Byproducts}},
	shorttitle = {Neglected {Free} {Lunch}},
	url = {https://arxiv.org/abs/2303.17595},
	doi = {10.48550/arXiv.2303.17595},
	abstract = {Modern computer vision models are typically trained on datasets where each image is associated with a single label or a set of labels. However, the process of creating such datasets often involves intermediate steps that produce valuable information, which we call annotation byproducts. For example, when annotators draw bounding boxes or segment objects, they often look at multiple parts of an object or even multiple objects in an image. In this paper, we show that these annotation byproducts, which are often discarded, can be used to significantly improve the performance of image classifiers. We propose a simple yet effective framework to leverage these byproducts for training image classifiers. Our method, which we call Annotation Byproduct Learning (ABL), consistently improves the performance of various image classification models on multiple datasets, including ImageNet and COCO. We also show that ABL can be used to improve the performance of models trained with noisy labels.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the IEEE/CVF International Conference on Computer Vision (ICCV)},
	publisher = {IEEE},
	author = {Han, Dongyoon and Choe, Junsuk and Chun, Seonghyeok and Chung, John Joon Young and Chang, Minsuk and Yun, Sangdoo and Song, Jean Y. and Oh, Seong Joon},
	year = {2023},
	keywords = {ICCV},
}
