@misc{ramesh_indistinguishable_2023,
	title = {Indistinguishable network dynamics can emerge from unalike plasticity rules},
	copyright = {© 2023, Posted by the authors. This article is a preprint and has not been certified by peer review.},
	shorttitle = {Indistinguishable network dynamics},
	url = {https://www.biorxiv.org/content/10.1101/2023.11.01.565168v1},
	doi = {10.1101/2023.11.01.565168},
	abstract = {Synaptic plasticity rules are often inferred from experimental data by assuming a specific functional form. However, it is unclear whether different plasticity rules can lead to the same network-level dynamics. Here, we show that indistinguishable network dynamics can emerge from unalike plasticity rules. We use a simulation-based inference framework to identify the space of plasticity rules that give rise to the same network-level dynamics. We find that a wide range of plasticity rules can produce the same network-level dynamics, suggesting that inferring plasticity rules from network-level observations is an ill-posed problem. Our results highlight the importance of considering the non-uniqueness of plasticity rules when interpreting experimental data and designing artificial neural networks.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {bioRxiv},
	author = {Ramesh, Poornima and Confavreux, Basile and Gonçalves, Pedro J. and Vogels, Tim P. and Macke, Jakob H.},
	month = nov,
	year = {2023},
	keywords = {Plasticity, Computer science, Synaptic plasticity, Intuition, Artificial intelligence, Neuroscience, Cognitive science, Psychology, Biology, Physics},
}
