@inproceedings{petrov_certifying_2023,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Certifying {Ensembles}: {A} {General} {Certification} {Theory} with {S}-{Lipschitzness}},
	shorttitle = {Certifying {Ensembles}},
	url = {https://proceedings.mlr.press/v202/petrov23a.html},
	abstract = {Ensemble methods are a cornerstone of modern machine learning, yet their robustness properties remain poorly understood. In this work, we propose a general certification theory for ensembles based on the notion of S-Lipschitzness, which allows us to derive certified robustness guarantees for a wide range of ensemble architectures and aggregation functions. Our theory encompasses both randomized and deterministic ensembles, and provides a unified framework for analyzing their robustness. We demonstrate the effectiveness of our approach by certifying several state-of-the-art ensemble models on standard benchmarks, showing that our bounds are significantly tighter than existing methods.},
	language = {en},
	booktitle = {Proceedings of the 40th {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Petrov, A. and Eiras, F. and Sanyal, A. and Torr, P. and Bibi, A.},
	editor = {Krause, A. and Brunskill, E. and Cho, K. and Engelhardt, B. and Sabato, S. and Scarlett, J.},
	month = jul,
	year = {2023},
	keywords = {ICML},
}
