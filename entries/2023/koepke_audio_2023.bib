@article{koepke_audio_2023,
	title = {Audio {Retrieval} {With} {Natural} {Language} {Queries}: {A} {Benchmark} {Study}},
	shorttitle = {Audio {Retrieval} {With} {Natural} {Language} {Queries}},
	url = {https://is.mpg.de/ei/publications/koepkeetal23},
	doi = {10.1109/TMM.2022.3149712},
	abstract = {The task of retrieving audio clips using natural language queries has recently gained attention due to its potential for enabling intuitive search in large-scale audio databases. However, progress in this field is hindered by the lack of a unified evaluation framework, with different works using disparate datasets and metrics. In this paper, we present a comprehensive benchmark study for audio retrieval with natural language queries. We first curate a large-scale dataset, AudioCaps-Eval, which provides high-quality, human-annotated captions for audio clips. We then evaluate several state-of-the-art cross-modal retrieval models on this dataset, as well as on existing benchmarks. Our results reveal that current models struggle to capture the fine-grained semantic relationships between audio and text, and that there is a significant performance gap between different architectures. We also propose a new evaluation metric, the Audio-Text Alignment Score, which better captures the semantic consistency between retrieved audio and query captions. We hope that this benchmark will facilitate future research in this area and provide a clear path for evaluating progress.},
	language = {en},
	urldate = {2024-05-22},
	journal = {IEEE Transactions on Multimedia},
	publisher = {IEEE},
	author = {Koepke, A. S. and Oncescu, A.-M. and Henriques, J. F. and Akata, Z. and Albanie, S.},
	month = jan,
	year = {2023},
	keywords = {Computer science, Benchmark (surveying), Information retrieval, Audio mining, Natural language, Construct (python library), Natural language processing, Closed captioning, Speech recognition, Artificial intelligence, Acoustic model, Speech processing, Task (project management), Modal, Natural (archaeology), TMM},
}
