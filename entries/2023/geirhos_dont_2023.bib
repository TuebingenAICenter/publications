@inproceedings{geirhos_dont_2023,
	title = {Don't trust your eyes: on the (un)reliability of feature visualizations},
	shorttitle = {Don't trust your eyes},
	url = {https://arxiv.org/abs/2306.04719},
	doi = {10.48550/arxiv.2306.04719},
	abstract = {Feature visualization is a popular technique for interpreting deep neural networks. It aims to provide human-understandable insights into what a network has learned by generating images that maximally activate specific neurons or layers. However, we show that feature visualizations can be highly unreliable. We demonstrate that for a wide range of standard visualization methods, the generated images can be manipulated to look like almost anything while still producing the same activation, or conversely, that very different activations can produce visually similar images. We argue that these findings call into question the reliability of feature visualizations as a tool for interpreting deep neural networks and suggest that they should be used with caution.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Forty-first {International} {Conference} on {Machine} {Learning}, {ICML} 2024, {Vienna}, {Austria}, {July} 21-27, 2024},
	publisher = {arXiv},
	author = {Geirhos, Robert and Zimmermann, Roland S. and Bilodeau, Blair and Brendel, Wieland and Kim, Been},
	year = {2023},
	keywords = {Interpretability, Computer science, Visualization, Feature (linguistics), Artificial neural network, Artificial intelligence, Set (abstract data type), Process (computing), Data visualization, Black box, Data mining, Machine learning, Human–computer interaction, Programming language, processed, MPI-IS, ELLIS Institute Tübingen, ICML},
}
