@inproceedings{opedal_world_2023,
	title = {World {Models} for {Math} {Story} {Problems}},
	shorttitle = {World {Models} for {Math} {Story} {Problems}},
	url = {https://aclanthology.org/2023.findings-acl.579},
	abstract = {Math story problems require models to perform multi-step reasoning over a narrative. While large language models (LLMs) have shown impressive performance on these tasks, they often struggle with consistency and interpretability. In this work, we propose a framework for solving math story problems by explicitly modeling the world state. We define a world model as a state-transition system that tracks the entities and their properties as described in the problem. We show that by training models to predict the state transitions, we can improve performance and provide interpretable traces of the reasoning process. Our approach achieves state-of-the-art results on several math story problem datasets.},
	language = {en},
	booktitle = {Findings of the {Association} for {Computational} {Linguistics} ({ACL})},
	publisher = {Association for Computational Linguistics},
	author = {Opedal, A. and Stoehr, N. and Saparov, A. and Sachan, M.},
	editor = {Rogers, Anna and Boyd-Graber, Jordan L. and Okazaki, Naoaki},
	month = jul,
	year = {2023},
	keywords = {ACL},
}
