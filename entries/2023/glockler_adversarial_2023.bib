@inproceedings{glockler_adversarial_2023,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Adversarial robustness of amortized {Bayesian} inference},
	url = {https://proceedings.mlr.press/v202/gloeckler23a.html},
	doi = {10.48550/arxiv.2305.14984},
	abstract = {Amortized Bayesian inference (ABI) has become a popular tool for performing inference in complex simulation-based models. However, ABI methods are typically trained to minimize the average error over a prior distribution, which does not guarantee robustness to adversarial perturbations of the observations. In this paper, we investigate the adversarial robustness of ABI. We show that standard ABI methods are vulnerable to adversarial attacks, where small, imperceptible perturbations to the observation can lead to drastically incorrect posterior estimates. We propose a robust training framework for ABI based on adversarial training, which significantly improves the robustness of the posterior estimates to adversarial attacks. We demonstrate the effectiveness of our approach on several benchmark problems, including a high-dimensional simulation-based model.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {Proceedings of {Machine} {Learning} {Research}},
	publisher = {PMLR},
	author = {Glöckler, M. and Deistler, M. and Macke, J. H.},
	editor = {Krause, A. and Brunskill, E. and Cho, K. and Engelhardt, B. and Sabato, S. and Scarlett, J.},
	month = jul,
	year = {2023},
	keywords = {Inference, Robustness (evolution), Bayesian inference, Computer science, Machine learning, Bayesian probability, Artificial intelligence, Frequentist inference, Estimator, Posterior probability, Algorithm, Mathematics, Statistics, ICML},
}
