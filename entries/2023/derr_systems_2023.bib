@misc{derr_systems_2023,
	title = {Systems of {Precision}: {Coherent} {Probabilities} on {Pre}-{Dynkin} {Systems} and {Coherent} {Previsions} on {Linear} {Subspaces}},
	copyright = {CC BY 4.0},
	shorttitle = {Systems of {Precision}},
	url = {https://doi.org/10.3390/e25091283},
	doi = {10.3390/e25091283},
	abstract = {We study the relationship between coherent probabilities defined on pre-Dynkin systems and coherent previsions defined on linear subspaces of bounded functions. We show that the former can be viewed as a special case of the latter. We provide a general duality result that characterises coherent previsions in terms of the set of linear extensions to the space of all bounded functions. We also show that the set of coherent previsions on a linear subspace is a convex set, and we provide a characterisation of its extreme points. Finally, we discuss the implications of our results for the theory of imprecise probability.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {MDPI},
	author = {Derr, Rabanus and Williamson, Robert C.},
	year = {2023},
	keywords = {Mathematics, Linear subspace, Coherence (philosophical gambling strategy), Duality (order theory), Lattice (music), Generalization, Bounded function, Imprecise probability, Dynkin diagram, Basis (linear algebra), Discrete mathematics, Probability measure, Pure mathematics, Statistics, Mathematical analysis, Lie algebra},
}
