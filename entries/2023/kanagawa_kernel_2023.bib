@article{kanagawa_kernel_2023,
	title = {A {Kernel} {Stein} {Test} for {Comparing} {Latent} {Variable} {Models}},
	issn = {1369-7412},
	shorttitle = {A {Kernel} {Stein} {Test}},
	url = {https://doi.org/10.1093/jrsssb/qkad050},
	doi = {10.1093/jrsssb/qkad050},
	abstract = {We propose a kernel-based test for comparing two latent variable models, where the likelihood is intractable but samples can be drawn from the models. Our test is based on the kernel Stein discrepancy, which measures the distance between a model and a target distribution using a Stein operator. We show that the test is consistent and has a well-behaved asymptotic distribution under the null hypothesis. We demonstrate the performance of our test on a variety of latent variable models, including Gaussian mixture models, hidden Markov models, and deep generative models.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Journal of the Royal Statistical Society Series B: Statistical Methodology},
	publisher = {Oxford University Press},
	author = {Kanagawa, Motonobu and Jitkrittum, Wittawat and Mackey, Lester and Fukumizu, Kenji and Gretton, Arthur},
	month = may,
	year = {2023},
	keywords = {JRSSB},
}
