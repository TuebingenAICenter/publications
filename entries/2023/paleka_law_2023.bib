@inproceedings{paleka_law_2023,
	title = {A law of adversarial risk, interpolation, and label noise},
	shorttitle = {A law of adversarial risk, interpolation, and label noise},
	url = {https://openreview.net/pdf?id=0_TxFpAsEI},
	abstract = {We study the adversarial risk of interpolating classifiers in the presence of label noise. We show that for a wide class of models, including linear models and neural networks in the neural tangent kernel regime, the adversarial risk is governed by a simple law: it is the sum of the standard risk and a term that depends on the label noise and the geometry of the data. This law allows us to quantify the trade-off between standard and adversarial risk, and to explain why adversarial training can lead to a decrease in standard accuracy. We validate our theoretical findings with experiments on synthetic and real-world datasets.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {The {Eleventh} {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Paleka, D. and Sanyal, A.},
	month = may,
	year = {2023},
	keywords = {ICLR},
}
