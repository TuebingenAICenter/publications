@article{fay_avoiding_2023,
	title = {Avoiding {Shortcut}-{Learning} by {Mutual} {Information} {Minimization} in {Deep} {Learning}-{Based} {Image} {Processing}},
	issn = {2169-3536},
	shorttitle = {Avoiding {Shortcut}-{Learning} by {Mutual} {Information} {Minimization}},
	url = {https://is.mpg.de/ei/publications/fayetal23},
	doi = {10.1109/ACCESS.2023.3289397},
	abstract = {Deep learning-based image processing models often suffer from shortcut-learning, where the model relies on unintended features or artifacts in the data rather than the intended task-relevant features. This phenomenon leads to poor generalization performance on unseen data. In this paper, we propose a novel approach to mitigate shortcut-learning by minimizing the mutual information between the model's latent representations and the shortcut-related features. We demonstrate the effectiveness of our method on several image processing tasks, showing that it significantly improves generalization performance and robustness against distribution shifts.},
	language = {en},
	urldate = {2024-05-23},
	journal = {IEEE Access},
	publisher = {IEEE},
	author = {Fay, L. and Cobos, E. and Yang, B. and Gatidis, S. and Küstner, T.},
	year = {2023},
	keywords = {IEEE ACCESS},
}
