@article{hamidi_one_2023,
	title = {One bottleneck is not enough},
	url = {https://charleywu.github.io/downloads/hamidi2023one.pdf},
	doi = {10.32470/ccn.2023.1729-0},
	abstract = {The information bottleneck (IB) principle has been a popular framework for understanding representation learning in deep neural networks. However, recent work has questioned the necessity of the IB principle for explaining the emergence of invariant representations. Here, we investigate the role of the bottleneck in a simple task of learning to represent and categorize stimuli. We show that a single bottleneck is insufficient to capture the complexity of the task, and that multiple bottlenecks are required to learn a hierarchical representation. We propose a multi-bottleneck architecture and show that it outperforms a single-bottleneck model in both representation learning and categorization performance.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 2023 Conference on Cognitive Computational Neuroscience},
	publisher = {Cognitive Computational Neuroscience},
	author = {Hamidi, Mani and Bányai, Mihály and Wu, Charley M.},
	year = {2023},
	keywords = {Bottleneck, Computer science, Embedded system, CCN},
}
