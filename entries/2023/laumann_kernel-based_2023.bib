@misc{laumann_kernel-based_2023,
	title = {Kernel-{Based} {Independence} {Tests} for {Causal} {Structure} {Learning} on {Functional} {Data}},
	copyright = {© 2023 by the authors. Licensee MDPI, Basel, Switzerland. This article is an open access article distributed under the terms and conditions of the Creative Commons Attribution (CC BY) license.},
	shorttitle = {Kernel-{Based} {Independence} {Tests}},
	url = {https://doi.org/10.3390/e25121597},
	doi = {10.3390/e25121597},
	abstract = {Causal structure learning from observational data often relies on conditional independence (CI) testing. While many CI tests exist for multivariate data, they are not directly applicable to functional data, which are infinite-dimensional objects. In this paper, we propose a framework for kernel-based CI testing for functional data. We define a kernel-based test statistic for functional data by extending the Hilbert-Schmidt Independence Criterion (HSIC) and the Kernel Conditional Independence Test (KCIT) to the functional setting. We prove the consistency of our proposed tests and demonstrate their performance on synthetic and real-world datasets. Our results show that our proposed tests are more powerful than existing methods for functional data and are competitive with state-of-the-art methods for multivariate data.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {MDPI},
	author = {Laumann, Felix and von Kügelgen, Julius and Park, Junhyung and Schölkopf, Bernhard and Barahona, Mauricio},
	month = nov,
	year = {2023},
	keywords = {Conditional independence, Independence (probability theory), Bivariate analysis, Statistic, Computer science, Machine learning, Dimension (graph theory), Test statistic, Artificial intelligence, Functional data analysis, Statistical hypothesis testing, Econometrics, Mathematics, Statistics},
}
