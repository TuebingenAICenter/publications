@inproceedings{pinto_how_2023,
	title = {How to make semi-private learning more effective},
	shorttitle = {{PILLAR}},
	url = {https://tpdp.journalprivacyconfidentiality.org/2023/},
	doi = {10.1109/SaTML59370.2024.00014},
	abstract = {Semi-private learning is a framework where a learner has access to a small amount of private data and a large amount of public data. While this setting is well-motivated, existing algorithms for semi-private learning often fail to fully leverage the public data, leading to suboptimal performance. In this work, we propose a new approach to semi-private learning that effectively utilizes public data to improve the privacy-utility trade-off. Our method is based on a novel combination of private empirical risk minimization and public data-driven regularization. We provide theoretical guarantees for our approach and demonstrate its effectiveness through extensive experiments on various datasets.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {{TPDP} 2023 - {Theory} and {Practice} of {Differential} {Privacy}},
	publisher = {IEEE},
	author = {Pinto, F. and Hu, Y. and Yang, F. and Sanyal, A.},
	month = sep,
	year = {2023},
	keywords = {SATML, TPDP},
}
