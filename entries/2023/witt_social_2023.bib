@inproceedings{witt_social_2023,
	title = {Social learning with a grain of salt},
	shorttitle = {Social learning with a grain of salt},
	url = {https://doi.org/10.31234/osf.io/c3fuq},
	doi = {10.31234/osf.io/c3fuq},
	abstract = {Social learning is a powerful tool for navigating uncertain environments, but it is also prone to biases. One such bias is the tendency to over-rely on social information, even when it is unreliable. In this paper, we investigate whether people can learn to discount unreliable social information. We present a behavioral experiment where participants perform a multi-armed bandit task and can choose to observe the choices of others. We find that participants are sensitive to the reliability of social information and adjust their reliance on it accordingly. We model this behavior using a Bayesian framework, which suggests that people treat social information as a noisy signal and update their beliefs about its reliability over time. Our results provide a mechanistic account of how people navigate the trade-off between social and individual learning.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {Proceedings of the 45th {Annual} {Conference} of the {Cognitive} {Science} {Society}},
	publisher = {Cognitive Science Society},
	author = {Witt, Andreas and Toyokawa, Wataru and Lala, K. and Gaissmaier, Wolfgang and Wu, Charley M.},
	editor = {Goldwater, Micah and Anggoro, F. K. and Hayes, B. K. and Ong, D. C.},
	year = {2023},
	keywords = {COGSCI},
}
