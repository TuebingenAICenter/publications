@article{keurti_desiderata_2023,
	title = {Desiderata for {Representation} {Learning} from {Identifiability}, {Disentanglement}, and {Group}-{Structuredness}},
	shorttitle = {Desiderata for {Representation} {Learning}},
	url = {https://openreview.net/pdf?id=r6C86JjuiW},
	abstract = {Representation learning aims to extract meaningful features from data. While identifiability and disentanglement have been proposed as desirable properties for learned representations, their definitions and relationships remain debated. In this work, we revisit these concepts through the lens of group theory. We argue that group-structuredness is a fundamental property that underlies both identifiability and disentanglement. We formalize this connection and show that group-structuredness provides a unifying framework for understanding and evaluating representation learning methods. We further propose a set of desiderata for representation learning based on these insights.},
	language = {en},
	urldate = {2025-05-14},
	journal = {2nd Annual Topology, Algebra, and Geometry in Machine Learning (TAG) at ICML 2023},
	author = {Keurti, H. and Reizinger, P. and Schölkopf, B. and Brendel, W.},
	month = jul,
	year = {2023},
	keywords = {ICML},
}
