@article{suhr_personality_2023,
	title = {Do personality tests generalize to {Large} {Language} {Models}?},
	shorttitle = {Do personality tests generalize to {Large} {Language} {Models}?},
	url = {https://openreview.net/pdf?id=zKDSfGhCoK},
	abstract = {Large Language Models (LLMs) are increasingly used in social science research to simulate human behavior. A common approach is to administer psychological questionnaires to LLMs to assess their 'personality'. However, it remains unclear whether these tests, originally developed for humans, are valid for LLMs. In this paper, we investigate the psychometric properties of personality tests when applied to LLMs. We find that while LLMs can produce consistent responses, the underlying factor structure of personality tests often fails to replicate in LLMs. Our results suggest that caution is warranted when using personality tests to characterize LLMs and that new evaluation frameworks are needed.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the Thirty-Seventh Annual Conference on Neural Information Processing Systems},
	author = {Sühr, Tom and Dorner, Florian and Samadi, Samira and Kelava, Augustin},
	year = {2023},
	keywords = {SOLAR, NeurIPS},
}
