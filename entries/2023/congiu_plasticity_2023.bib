@article{congiu_plasticity_2023,
	title = {Plasticity of neuronal dynamics in the lateral habenula for cue-punishment associative learning},
	copyright = {© 2023 The Author(s)},
	issn = {1476-5578},
	shorttitle = {Plasticity of neuronal dynamics in the lateral habenula},
	url = {https://www.nature.com/articles/s41380-023-02155-3},
	doi = {10.1038/s41380-023-02155-3},
	abstract = {The lateral habenula (LHb) is a key node in the brain's reward system, encoding negative motivational value. While LHb neurons are known to respond to aversive stimuli, the circuit mechanisms underlying the acquisition of cue-punishment associations remain poorly understood. Here, we show that mice learn to associate a neutral cue with a foot-shock, a process accompanied by a progressive increase in the firing rate of LHb neurons in response to the cue. This plasticity is specific to the cue-punishment association and is not observed in control animals. Using fiber photometry and in vivo electrophysiology, we demonstrate that this increase in cue-evoked activity is driven by a potentiation of excitatory inputs to the LHb. Furthermore, we show that this plasticity is dependent on N-methyl-D-aspartate receptor (NMDAR) signaling within the LHb. Our findings identify a circuit-level mechanism for the encoding of aversive cue-punishment associations in the LHb, providing a framework for understanding how negative motivational values are learned and represented in the brain.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Molecular Psychiatry},
	publisher = {Nature Portfolio},
	author = {Congiu, Mauro and Mondoloni, Sarah and Zouridis, Ioannis S. and Schmors, Lisa and Lecca, Salvatore and Lalive, Arnaud L. and Ginggen, Kyllian and Deng, Fei and Berens, Philipp and Paolicelli, Rosa Chiara and Li, Yulong and Burgalossi, Andrea and Mameli, Manuel},
	month = jul,
	year = {2023},
	keywords = {Neuroscience, Associative learning, Psychology, Excitatory postsynaptic potential, Postsynaptic potential, Population, Inhibitory postsynaptic potential, Biology, Receptor},
}
