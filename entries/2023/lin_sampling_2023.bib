@inproceedings{lin_sampling_2023,
	title = {Sampling from {Gaussian} {Process} {Posteriors} using {Stochastic} {Gradient} {Descent}},
	shorttitle = {Sampling from {Gaussian} {Process} {Posteriors} using {Stochastic} {Gradient} {Descent}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2023/file/7482e8ce4139df1a2d8195a0746fa713-Paper-Conference.pdf},
	abstract = {Gaussian processes (GPs) are powerful tools for uncertainty quantification, but their computational cost scales cubically with the number of data points. While sparse approximations reduce this to linear complexity, they often struggle to capture the full posterior distribution, especially in high-dimensional settings. In this paper, we propose a new approach to sample from GP posteriors using stochastic gradient descent (SGD). Our method, which we call Stochastic Gradient Langevin Dynamics for Gaussian Processes (SGLD-GP), leverages the fact that the GP posterior can be expressed as a sum of independent contributions from each data point. We show that SGLD-GP is unbiased, computationally efficient, and can be easily implemented using standard deep learning frameworks. We demonstrate the effectiveness of our approach on a range of synthetic and real-world datasets, showing that it outperforms existing sparse GP methods in terms of both predictive accuracy and uncertainty quantification.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 36 ({NeurIPS} 2023)},
	publisher = {Curran Associates, Inc.},
	author = {Lin, J. A. and Antorán, J. and Padhy, S. and Janz, D. and Hernández-Lobato, J. M. and Terenin, A.},
	editor = {Oh, A. and Neumann, T. and Globerson, A. and Saenko, K. and Hardt, M. and Levine, S.},
	month = dec,
	year = {2023},
	keywords = {NEURIPS},
}
