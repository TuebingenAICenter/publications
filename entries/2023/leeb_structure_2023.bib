@misc{leeb_structure_2023,
	title = {Structure by {Architecture}: {Structured} {Representations} without {Regularization}},
	shorttitle = {Structure by {Architecture}},
	url = {https://openreview.net/pdf?id=O_lFCPaF48t},
	doi = {10.48550/arxiv.2006.07796},
	abstract = {Disentangled representation learning aims to recover the underlying factors of variation of a data generating process. Current approaches typically rely on explicit regularization terms in the objective function to encourage disentanglement. In this work, we show that such regularization is not strictly necessary. We propose a framework that achieves disentanglement by design, through the choice of the architecture of the generative model. Specifically, we introduce a novel architecture that incorporates a structural bias towards disentanglement, which we call the 'Structure by Architecture' (SbA) framework. We demonstrate that our approach achieves state-of-the-art performance on several benchmark datasets, while being more robust and easier to train than existing methods.},
	language = {en},
	urldate = {2025-05-14},
	author = {Leeb, Felix and Lanzillotta, Guilia and Annadani, Yashas and Besserve, Michel and Bauer, Stefan and Schölkopf, Bernhard},
	month = may,
	year = {2023},
	keywords = {Autoencoder, Computer science, Feature learning, Generative grammar, Regularization (linguistics), Artificial intelligence, Latent variable, Machine learning, Generative model, Representation (politics), Matching (statistics), Extrapolation, Sampling (signal processing), Pattern recognition (psychology), Deep learning, Mathematics, Computer vision, ICLR},
}
