@article{keurti_homomorphism_2023,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Homomorphism {Autoencoder} — {Learning} {Group} {Structured} {Representations} from {Observed} {Transitions}},
	shorttitle = {Homomorphism {Autoencoder}},
	url = {https://proceedings.mlr.press/v202/keurti23a.html},
	doi = {10.48550/arxiv.2207.12067},
	abstract = {We propose the Homomorphism Autoencoder (HAE), a framework for learning group-structured representations of dynamical systems from observed transitions. By leveraging the concept of group homomorphisms, our model learns to map the state space of a system to a latent space where the dynamics are governed by a group action. This allows the model to capture the underlying symmetries and structural properties of the system, leading to more interpretable and robust representations. We demonstrate the effectiveness of our approach on various tasks, including learning representations of physical systems and grid-world environments, showing that HAE outperforms existing methods in terms of both reconstruction accuracy and the ability to recover the underlying group structure.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 40th International Conference on Machine Learning},
	publisher = {PMLR},
	author = {Keurti, H. and Pan, H.-R. and Besserve, M. and Grewe, B. F. and Schölkopf, B.},
	editor = {Krause, A. and Brunskill, E. and Cho, K. and Engelhardt, B. and Sabato, S. and Scarlett, J.},
	month = jul,
	year = {2023},
	keywords = {Autoencoder, Representation (politics), Group (periodic table), Computer science, Feature learning, Set (abstract data type), Homomorphism, Artificial intelligence, Contrast (vision), Property (philosophy), Space (punctuation), Group representation, Machine learning, Order (exchange), Theoretical computer science, Mathematics, Artificial neural network, Epistemology, ICML},
