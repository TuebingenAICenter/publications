@misc{immer_identifiability_2023,
	title = {On the {Identifiability} and {Estimation} of {Causal} {Location}-{Scale} {Noise} {Models}},
	url = {https://proceedings.mlr.press/v202/immer23a.html},
	doi = {10.48550/arxiv.2210.09054},
	abstract = {We study the identifiability of causal models with location-scale noise, i.e., models of the form Y = f(X) + g(X)E, where E is independent of X. Such models are widely used in practice, for instance, to account for heteroscedasticity. We show that if the noise E is non-Gaussian, the causal direction is identifiable from observational data alone, provided that the functions f and g are sufficiently flexible. We further propose a practical estimation procedure based on neural networks and demonstrate its effectiveness on synthetic and real-world data.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Immer, Alexander and Schultheiss, Christoph and Vogt, Julia E. and Schölkopf, Bernhard and Bühlmann, Peter and Marx, Alexander},
	editor = {Krause, A. and Brunskill, E. and Cho, K. and Engelhardt, B. and Sabato, S. and Scarlett, J.},
	year = {2023},
	keywords = {Identifiability, Estimator, Heteroscedasticity, Noise (video), Artificial neural network, Mathematics, Feature (linguistics), Function (biology), Computer science, Scale (ratio), Generality, Class (philosophy), Artificial intelligence, Pattern recognition (psychology), Algorithm, Statistics, ICML},
}
