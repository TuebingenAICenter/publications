@misc{tangemann_unsupervised_2023,
	title = {Unsupervised {Object} {Learning} via {Common} {Fate}},
	shorttitle = {Unsupervised object learning via common fate},
	url = {https://proceedings.mlr.press/v213/tangemann23a.html},
	doi = {10.48550/arxiv.2110.06562},
	abstract = {The Gestalt principle of common fate states that visual elements that move together are perceived as belonging to the same object. We propose to leverage this principle for unsupervised object learning. We introduce a generative model that decomposes a scene into a set of objects, where each object is represented by a latent appearance and a latent trajectory. By enforcing that pixels belonging to the same object share the same motion, our model learns to segment objects from video without any supervision. We demonstrate that our model achieves state-of-the-art performance on unsupervised object segmentation benchmarks and that it can be used to learn object-centric representations that are useful for downstream tasks.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Tangemann, Matthias and Schneider, Steffen and von Kügelgen, Julius and Locatello, Francesco and Gehler, Peter and Brox, Thomas and Kümmerer, Matthias and Bethge, Matthias and Schölkopf, Bernhard},
	editor = {van der Schaar, Mihaela and Zhang, Cheng and Janzing, Dominik},
	year = {2023},
	keywords = {Artificial intelligence, Computer science, Gestalt psychology, Object (grammar), Generative model, Generative grammar, Computer vision, Set (abstract data type), Segmentation, Unsupervised learning, Motion (physics), Pattern recognition (psychology), Machine learning, CLEAR},
}
