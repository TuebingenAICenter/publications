@misc{klepper_clustering_2023,
	title = {Clustering with {Tangles}: {Algorithmic} {Framework} and {Theoretical} {Guarantees}},
	shorttitle = {Clustering with {Tangles}},
	url = {https://jmlr.org/papers/volume24/21-1160/21-1160.pdf},
	doi = {10.5555/3636555},
	abstract = {Tangles are a concept from graph theory that allow for a robust, multi-scale analysis of data. They have recently been proposed as a new paradigm for clustering. In this paper, we provide a comprehensive algorithmic framework for clustering with tangles. We show how to compute tangles efficiently, how to use them for clustering, and how to interpret the results. We also provide theoretical guarantees for our approach, showing that tangles can recover the ground-truth clustering in various settings. Finally, we demonstrate the effectiveness of our approach on several real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Journal of Machine Learning Research},
	author = {Klepper, Solveig and Elbracht, Christian and Fioravanti, Diego and Kneip, Jakob and Rendsburg, Luca and Teegen, Maximilian and von Luxburg, Ulrike},
	year = {2023},
	keywords = {Cluster analysis, Bottleneck, Computer science, Hierarchical clustering, Theoretical computer science, Simple (philosophy), Algorithm, Graph, Set (abstract data type), Mathematics, Artificial intelligence, JMLR},
}
