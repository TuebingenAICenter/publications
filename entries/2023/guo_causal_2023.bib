@misc{guo_causal_2023,
	title = {Causal de {Finetti}: {On} the {Identification} of {Invariant} {Causal} {Structure} in {Exchangeable} {Data}},
	shorttitle = {Causal de {Finetti}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2023/file/7279908471a7dd4898d2715f7c6a7413-Paper-Conference.pdf},
	doi = {10.48550/arxiv.2203.15756},
	abstract = {We study the problem of identifying causal structure from observational data that is exchangeable but not necessarily independent and identically distributed (i.i.d.). This setting is common in many real-world applications, such as multi-environment data, where the data points are conditionally i.i.d. given some latent context variable. We show that the de Finetti representation theorem provides a natural framework for this problem. We define a notion of invariant causal structure that is robust to changes in the latent context and show that it can be identified from exchangeable data under certain conditions. We provide a practical algorithm for learning such structures and demonstrate its effectiveness on synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Guo, Siyuan and Tóth, Viktor and Schölkopf, Bernhard and Huszár, Ferenc},
	editor = {Oh, A. and Neumann, T. and Globerson, A. and Saenko, K. and Hardt, M. and Levine, S.},
	year = {2023},
	keywords = {Conditional independence, Causal structure, Causal model, Causal inference, Computer science, Identification (biology), Representation (politics), Independent and identically distributed random variables, Set (abstract data type), Artificial intelligence, Mathematics, Econometrics, Random variable, Statistics, NEURIPS},
}
