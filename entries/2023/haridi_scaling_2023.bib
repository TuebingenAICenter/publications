@article{haridi_scaling_2023,
	title = {The scaling of mental computation in a sorting task},
	issn = {0010-0277},
	shorttitle = {The scaling of mental computation},
	url = {https://doi.org/10.1016/j.cognition.2023.105605},
	doi = {10.1016/j.cognition.2023.105605},
	abstract = {How do humans solve complex problems that require sequential planning? While computer science provides a rich toolkit of algorithms for such tasks, it remains unclear which of these algorithms, if any, describe human behavior. We investigate this question using a sorting task, which allows us to manipulate the computational complexity of the problem by varying the number of items to be sorted. We find that human performance is best described by a combination of simple, heuristic-based strategies rather than optimal sorting algorithms. Furthermore, we show that human mental computation scales sub-linearly with the number of items, suggesting that people adapt their computational effort to the difficulty of the task. Our results provide a new perspective on the constraints and strategies of human sequential planning.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Cognition},
	publisher = {Elsevier},
	author = {Haridi, Susanne and Wu, Charley M. and Dasgupta, Ishita and Schulz, Eric},
	year = {2023},
	keywords = {Computation, Task (project management), Sorting, Cognition, Scaling, sort, Sequence (biology), Computational model, Scale (ratio), Computer science, Psychology, Theoretical computer science, Artificial intelligence, Cognitive psychology, Algorithm, Mathematics, Information retrieval},
}
