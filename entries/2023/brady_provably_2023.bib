@misc{brady_provably_2023,
	title = {Provably {Learning} {Object}-{Centric} {Representations}},
	shorttitle = {Provably {Learning} {Object}-{Centric} {Representations}},
	url = {https://proceedings.mlr.press/v202/brady23a.html},
	doi = {10.48550/arxiv.2305.14229},
	abstract = {Object-centric representation learning aims to decompose complex scenes into sets of entities. While many heuristic approaches have been proposed, a theoretical understanding of when and why these models succeed remains elusive. In this work, we provide a formal framework for object-centric representation learning based on the principle of independent causal mechanisms. We prove that under certain conditions, object-centric representations are identifiable from observational data. We further show that these conditions are satisfied by a broad class of generative models, including those based on slot-based architectures. Finally, we demonstrate that our theoretical results provide a principled explanation for the success of existing object-centric models and suggest new directions for future research.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {JMLR},
	author = {Brady, Jack and Zimmermann, Roland S. and Sharma, Yash and Schölkopf, Bernhard and von Kügelen, Julius and Brendel, Wieland},
	month = jul,
	year = {2023},
	keywords = {Principle of compositionality, Computer science, Inference, Artificial intelligence, Object (grammar), Generalization, Representation (politics), Generative model, Generative grammar, Machine learning, Theoretical computer science, Process (computing), Natural language processing, Programming language, Mathematics, ICML},
}
