@article{somepalli_diffusion_2023,
	title = {Diffusion {Art} or {Digital} {Forgery}? {Investigating} {Data} {Replication} in {Diffusion} {Models}},
	shorttitle = {Diffusion {Art} or {Digital} {Forgery}?},
	url = {https://doi.org/10.1109/cvpr52729.2023.00586},
	doi = {10.1109/cvpr52729.2023.00586},
	abstract = {Diffusion models have recently demonstrated an unprecedented ability to generate high-quality images. However, these models are trained on massive datasets scraped from the internet, raising concerns about whether they simply memorize and replicate their training data. In this work, we investigate the extent to which diffusion models replicate training images. We find that diffusion models are indeed capable of generating near-identical copies of training images, and that this behavior is more common than previously thought. We characterize the conditions under which this occurs and propose a simple method to detect such replications. Our findings suggest that diffusion models can be used to perform digital forgery, and we discuss the implications for copyright and privacy.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition},
	publisher = {IEEE},
	author = {Somepalli, Gowthami and Singla, Vasu and Goldblum, Micah and Geiping, Jonas and Goldstein, Tom},
	year = {2023},
	keywords = {Computer science, Replication (statistics), Diffusion, Set (abstract data type), Enhanced Data Rates for GSM Evolution, Training set, Information retrieval, Artificial intelligence, CVPR},
}
