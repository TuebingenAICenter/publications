@article{grote_uncertainty_2023,
	title = {Uncertainty, {Evidence}, and the {Integration} of {Machine} {Learning} into {Medical} {Practice}},
	issn = {0360-5310},
	shorttitle = {Uncertainty, {Evidence}, and the {Integration} of {Machine} {Learning}},
	url = {https://academic.oup.com/jmp/article-abstract/48/1/84/6984888?login=false},
	doi = {10.1093/jmp/jhac034},
	abstract = {Machine learning (ML) is increasingly being integrated into medical practice. While its potential to improve diagnostic and prognostic accuracy is widely recognized, its integration also raises significant epistemic challenges. In this article, we focus on the challenge of uncertainty. We argue that the integration of ML into medical practice requires a nuanced understanding of the different types of uncertainty involved. We distinguish between aleatoric and epistemic uncertainty and show how they affect the evidence base for medical decisions. We then discuss how these uncertainties can be communicated to clinicians and patients and how they should be integrated into clinical decision-making processes. We conclude by arguing that the integration of ML into medical practice requires a shift from a focus on predictive accuracy to a focus on the epistemic quality of the evidence provided by ML models.},
	language = {en},
	urldate = {2025-05-14},
	journal = {The Journal of Medicine and Philosophy: A Forum for Bioethics and Philosophy of Medicine},
	publisher = {Oxford University Press},
	author = {Grote, Thomas and Berens, Philipp},
	month = jul,
	year = {2023},
	keywords = {Artificial intelligence, Machine learning, Computer science, Relevance (law), Deep learning, Trustworthiness, Quality (philosophy), Data science, Epistemology},
}
