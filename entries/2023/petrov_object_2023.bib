@misc{petrov_object_2023,
	title = {Object pop-up: {Can} we infer 3D objects and their poses from human interactions alone?},
	shorttitle = {Object pop-up},
	url = {https://arxiv.org/abs/2306.00777},
	doi = {10.48550/arXiv.2306.00777},
	abstract = {We present Object Pop-up, a method to infer 3D objects and their poses from human interactions alone. Given a sequence of a person interacting with an object, our method predicts the 3D shape and pose of the object. We leverage the fact that human-object interactions are highly constrained: the human body and the object must be in contact, and the object must be physically plausible. We propose a novel representation for objects that allows us to learn from large-scale human-object interaction datasets without 3D object annotations. Our method is self-supervised and learns to 'pop-up' 3D objects from 2D images by observing how humans interact with them. We demonstrate that our method can infer 3D objects and their poses from monocular video sequences, and that it generalizes to unseen objects and interactions.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {IEEE},
	author = {Petrov, Ilya A. and Marin, Riccardo and Chibane, Julian and Pons-Moll, Gerard},
	year = {2023},
	keywords = {Affordance, Computer science, Object (grammar), Human–computer interaction, Perspective (graphical), Artificial intelligence, Code (set theory), Point (geometry), Point cloud, Task (project management), Programming language, Mathematics, Human-computer interaction, CVPR},
}
