@misc{von_kugelgen_nonparametric_2023,
	title = {Nonparametric {Identifiability} of {Causal} {Representations} from {Unknown} {Interventions}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2023/file/97fe251c25b6f99a2a23b330a75b11d4-Paper-Conference.pdf},
	doi = {10.48550/arxiv.2306.00542},
	abstract = {We study the problem of identifying latent causal variables from observed data. Existing work on causal representation learning typically assumes that the causal variables are observed under known interventions or that the causal graph is known. We relax these assumptions and consider the setting where we have access to data from multiple environments, each corresponding to an unknown intervention on a subset of the latent variables. We provide the first nonparametric identifiability results for this setting. Specifically, we show that the latent causal variables and the causal mechanism are identifiable up to a permutation and component-wise transformations, provided that the interventions are sufficiently diverse. Our results rely on a novel connection between causal representation learning and independent component analysis, and we provide a constructive proof that leads to a practical algorithm for learning causal representations.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {von Kügelgen, Julius and Besserve, Michel and Liang, Wendong and Gresele, Luigi and Kekić, Armin and Bareinboim, Elias and Blei, David and Schölkopf, Bernhard},
	editor = {Oh, A. and Neumann, T. and Globerson, A. and Saenko, K. and Hardt, M. and Levine, S.},
	year = {2023},
	keywords = {Identifiability, Latent variable, Spurious relationship, Causal inference, Nonparametric statistics, Mathematics, Causal model, Causal structure, Econometrics, Computer science, Machine learning, Statistics, NEURIPS},
}
