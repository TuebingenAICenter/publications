@inproceedings{van_der_ouderaa_learning_2023,
	title = {Learning {Layer}-wise {Equivariances} {Automatically} using {Gradients}},
	shorttitle = {Learning {Layer}-wise {Equivariances} {Automatically} using {Gradients}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2023/file/5a33645b5c5b7a9882652526d30d0acc-Paper-Conference.pdf},
	abstract = {Equivariance is a powerful inductive bias for deep learning, but designing equivariant architectures requires expert knowledge and is often specific to the data domain. We propose a method to automatically learn layer-wise equivariances by optimising the parameters of a transformation group. We parameterise the group action as a linear transformation and use the gradient of the loss with respect to the group parameters to update the equivariance. This allows the model to learn the symmetries of the data during training. We demonstrate that our method can learn known symmetries, such as rotations and reflections, and discover new symmetries in synthetic and real-world datasets. Our approach is computationally efficient and can be applied to a wide range of architectures.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 36 ({NeurIPS} 2023)},
	publisher = {Curran Associates, Inc.},
	author = {van der Ouderaa, T. and Immer, A. and van der Wilk, M.},
	editor = {Oh, A. and Neumann, T. and Globerson, A. and Saenko, K. and Hardt, M. and Levine, S.},
	month = dec,
	year = {2023},
	keywords = {NEURIPS},
}
