@article{smith_constructing_2023,
	title = {Constructing and deconstructing bias: modeling privilege and mentorship in agent-based simulations},
	shorttitle = {Constructing and deconstructing bias},
	url = {https://doi.org/10.48550/arXiv.2304.02351},
	doi = {10.48550/arXiv.2304.02351},
	abstract = {Systemic biases in academic and professional environments are often self-reinforcing, where early advantages compound over time. While mentorship is frequently proposed as a solution to mitigate these biases, its effectiveness is often limited by the same structural factors it seeks to address. We present an agent-based model to simulate the dynamics of privilege and mentorship in a career progression environment. Our model demonstrates how mentorship can either alleviate or exacerbate existing biases depending on the structure of the mentorship network and the selection criteria for mentors. We find that while mentorship can improve outcomes for marginalized groups, it is insufficient to overcome structural biases without systemic interventions that address the underlying mechanisms of privilege.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 2023 Conference on Cognitive Computational Neuroscience},
	author = {Smith, Andria L. and Heuschkel, Simon and Keplinger, Ksenia and Wu, Charley M.},
	editor = {Hunt, L. and Summerfield, C. and Konkle, T. and Fedorenko, E. and Naselaris, T.},
	year = {2023},
	keywords = {Mentorship, Privilege (computing), Computer science, Computer security, Medicine, CCN},
}
