@article{moneta_reward_2023,
	title = {Reward morphs non-spatial cognitive maps in humans},
	url = {https://charleywu.github.io/downloads/moneta2023reward.pdf},
	doi = {10.32470/ccn.2023.1396-0},
	abstract = {Cognitive maps are thought to support flexible behavior by organizing knowledge about the world. While spatial navigation is the canonical example, cognitive maps are also used for non-spatial domains. Recent evidence suggests that these maps are not static representations but are dynamically updated based on task demands. Here, we investigate how reward influences the structure of non-spatial cognitive maps. Participants learned a two-dimensional non-spatial task space defined by two continuous features. We manipulated the reward distribution in this space, creating regions of high and low value. Using representational similarity analysis on fMRI data, we show that the cognitive map is warped in the presence of reward: the representational distance between states is compressed in high-reward regions and expanded in low-reward regions. This finding suggests that reward acts as a powerful force in shaping the geometry of cognitive maps, potentially facilitating efficient decision-making in valuable regions of the state space.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 2023 Conference on Cognitive Computational Neuroscience},
	publisher = {Cognitive Computational Neuroscience},
	author = {Moneta, Nir and Wu, Charley M. and Doeller, Christian F. and Schuck, Nicolas W.},
	editor = {Hunt, L. and Summerfield, C. and Konkle, T. and Fedorenko, E. and Naselaris, T.},
	year = {2023},
	keywords = {Computer science, Cognition, Spatial cognition, Cognitive map, Cognitive psychology, Artificial intelligence, Psychology, Neuroscience, CCN},
}
