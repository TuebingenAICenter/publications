@article{kummerer_predicting_2023,
	title = {Predicting {Visual} {Fixations}},
	issn = {2574-3171},
	url = {https://doi.org/10.1146/annurev-vision-120822-072528},
	doi = {10.1146/annurev-vision-120822-072528},
	abstract = {Predicting where humans look in natural scenes is a fundamental problem in vision science. Over the last two decades, the field has shifted from simple heuristic models to deep learning models that achieve high predictive performance. In this review, we provide a comprehensive overview of the state of the art in predicting visual fixations. We discuss the evolution of models, the datasets used for training and evaluation, and the metrics used to quantify performance. We also highlight the challenges that remain, such as the role of top-down factors, the influence of task, and the need for models that can generalize across different domains. Finally, we discuss the implications of these models for our understanding of the human visual system and their potential applications in computer vision and human-computer interaction.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Annual Review of Vision Science},
	publisher = {Annual Reviews},
	author = {Kümmerer, Matthias and Bethge, Matthias},
	year = {2023},
	keywords = {Computer science, Artificial intelligence, Probabilistic logic, Machine learning, Variety (cybernetics), Eye movement, Process (computing), Focus (optics), Fixation (population genetics), Measure (data warehouse), Data mining, ARVS},
}
