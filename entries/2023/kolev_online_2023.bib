@misc{kolev_online_2023,
	title = {Online {Learning} under {Adversarial} {Nonlinear} {Constraints}},
	url = {https://openreview.net/forum?id=N6YNe4KxDc},
	doi = {10.48550/arxiv.2306.03655},
	abstract = {We study online convex optimization with adversarial nonlinear constraints. In this setting, a learner aims to minimize a sequence of convex loss functions while satisfying a sequence of nonlinear constraints that are revealed sequentially. We propose a novel algorithm that achieves sublinear regret and sublinear constraint violation. Our algorithm is based on a primal-dual approach that uses a regularized Lagrangian. We provide a theoretical analysis of the regret and constraint violation bounds, and we demonstrate the effectiveness of our approach on several numerical examples.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Kolev, Pavel and Martius, Georg and Muehlebach, Michael},
	month = dec,
	year = {2023},
	keywords = {Regret, A priori and a posteriori, Constraint (computer-aided design), Set (abstract data type), Mathematical optimization, Nonlinear system, Mathematics, Computer science, Process (computing), Adversarial system, Feasible region, Algorithm, Artificial intelligence, Machine learning, NEURIPS},
}
