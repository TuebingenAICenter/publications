@article{katiyar_quantification_2023,
	title = {Quantification of intratumoural heterogeneity in mice and patients via machine-learning models trained on {PET}–{MRI} data},
	issn = {2157-846X},
	shorttitle = {Quantification of intratumoural heterogeneity},
	url = {https://doi.org/10.1038/s41551-023-01047-9},
	doi = {10.1038/s41551-023-01047-9},
	abstract = {Intratumoural heterogeneity is a major driver of cancer progression and therapy resistance, but its non-invasive quantification remains challenging. Here we show that machine-learning models trained on PET–MRI data can quantify intratumoural heterogeneity in mice and patients. We developed a deep-learning framework, termed PET–MRI-based heterogeneity quantification (PMHQ), which uses co-registered PET and MRI data to predict the spatial distribution of tumour-cell density and proliferation in colorectal cancer. PMHQ models trained on mouse models of colorectal cancer accurately predicted the spatial distribution of tumour-cell density and proliferation in human patients, as validated by histopathology. Our findings suggest that PMHQ can non-invasively quantify intratumoural heterogeneity and may facilitate the development of personalized cancer therapies.},
	language = {en},
	journal = {Nature Biomedical Engineering},
	publisher = {Nature Portfolio},
	author = {Katiyar, Prateek and Schwenck, Johannes and Frauenfeld, Leonie and Divine, Mathew R. and Agrawal, Vaibhav and Kohlhofer, Ursula and Gatidis, Sergios and Kontermann, Roland E. and Königsrainer, Alfred and Quintanilla-Martinez, Leticia and la Fougère, Christian and Schölkopf, Bernhard and Pichler, Bernd J. and Disselhorst, Jonathan A.},
	month = jun,
	year = {2023},
	keywords = {Tumour heterogeneity, Magnetic resonance imaging, Positron emission tomography, Colorectal cancer, Medicine, Phenotype, Pathology, Radiology, Cancer, Nuclear medicine, Internal medicine, Biology},
}
