@article{wiedemer_compositional_2023,
	title = {Compositional {Generalization} from {First} {Principles}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2023/hash/15f6a10899f557ce53fe39939af6f930-Abstract-Conference.html},
	doi = {10.48550/arXiv.2305.18434},
	abstract = {Compositional generalization—the ability to understand and produce new combinations of known components—is a hallmark of human intelligence. While deep learning models have achieved remarkable success in many tasks, they often struggle with compositional generalization. In this paper, we propose a new framework for compositional generalization based on the principle of compositionality. We show that by explicitly modeling the compositional structure of the data, we can improve the generalization performance of deep learning models on a variety of tasks. We demonstrate the effectiveness of our approach on several benchmarks and show that it outperforms existing methods.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Advances in Neural Information Processing Systems},
	publisher = {Curran Associates, Inc.},
	author = {Wiedemer, Thaddäus and Mayilvahanan, Prasanna and Bethge, Matthias and Brendel, Wieland},
	year = {2023},
	keywords = {Generalization, Principle of compositionality, Computer science, Property (philosophy), Representation (politics), Artificial intelligence, Prior probability, Set (abstract data type), Process (computing), Machine learning, Theoretical computer science, Mathematics, Programming language, Bayesian probability, NEURIPS},
}
