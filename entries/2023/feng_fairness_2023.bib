@article{feng_fairness_2023,
	title = {On {Fairness} in {Face} {Albedo} {Estimation}},
	url = {https://dl.acm.org/doi/abs/10.1145/3532836.3536281},
	doi = {10.1145/3532836.3536281},
	abstract = {Face albedo estimation is a fundamental task in computer vision with applications in face reconstruction, relighting, and editing. While recent methods have achieved impressive results, they often exhibit biases, performing better on lighter skin tones than on darker ones. In this work, we investigate the sources of these biases and propose a simple yet effective approach to mitigate them. We show that by balancing the training data and using a fairness-aware loss function, we can significantly improve the fairness of face albedo estimation without sacrificing overall performance.},
	language = {en},
	urldate = {2025-05-14},
	journal = {PROCEEDINGS SIGGRAPH 2022 TALKS},
	publisher = {ACM},
	author = {Feng, Haiwen and Bolkart, Timo and Tesch, Joachim and Black, Michael J. and Abrevaya, Victoria},
	year = {2023},
	keywords = {Ambiguity, Albedo (alchemy), Computer science, Face (sociological concept), Estimation, Artificial intelligence, Computer vision, Engineering, Sociology, SIGGRAPH},
}
