@inproceedings{confavreux_meta-learning_2023,
	title = {Meta-learning families of plasticity rules in recurrent spiking networks using simulation-based inference},
	url = {https://proceedings.neurips.cc/paper_files/paper/2023/file/2bdc2267c3d7d01523e2e17ac0a754f3-Paper-Conference.pdf},
	abstract = {Synaptic plasticity is a fundamental mechanism for learning and memory in the brain. While many plasticity rules have been proposed, it remains unclear how these rules are shaped by evolutionary or developmental pressures to support specific computational goals. Here, we propose a framework to meta-learn families of plasticity rules in recurrent spiking networks using simulation-based inference (SBI). Our approach allows us to infer the parameters of a flexible, parameterized plasticity rule that enables a network to solve a given task, without requiring the task to be differentiable. We demonstrate that our framework can recover known plasticity rules in simple settings and discover novel, effective rules in more complex, non-differentiable tasks. Furthermore, we show that the meta-learned rules are robust to variations in network architecture and task statistics, suggesting that our approach can uncover general principles of synaptic plasticity.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 36 ({NeurIPS} 2023)},
	publisher = {Curran Associates, Inc.},
	author = {Confavreux, B. and Ramesh, P. and Goncalves, P. J. and Macke, J. H. and Vogels, T. P.},
	editor = {Oh, A. and Neumann, T. and Globerson, A. and Saenko, K. and Hardt, M. and Levine, S.},
	month = dec,
	year = {2023},
	keywords = {NEURIPS},
}
