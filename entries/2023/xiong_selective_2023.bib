@article{xiong_selective_2023,
	title = {Selective memory for reward-relevant features is modulated by expertise during reward learning},
	shorttitle = {Selective memory for reward-relevant features},
	url = {https://charleywu.github.io/downloads/xiong2023selective.pdf},
	doi = {10.32470/ccn.2023.1504-0},
	abstract = {How do we learn to prioritize relevant information in complex environments? While reinforcement learning models often assume that agents learn to represent all features of the environment, human learners are known to be selective, focusing on features that are predictive of reward. Here, we investigate how expertise—defined as prior experience with a task—modulates this selective memory. We conducted a behavioral experiment where participants learned to predict rewards based on a subset of features, while other features were irrelevant. We found that experts, compared to novices, showed enhanced memory for reward-relevant features, but not for irrelevant features. This suggests that expertise facilitates the selective encoding of reward-relevant information, potentially through a mechanism that gates information based on its predicted utility.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 2023 Conference on Cognitive Computational Neuroscience},
	publisher = {Cognitive Computational Neuroscience},
	author = {Xiong, Yirong and Moneta, Nir and Bányai, Mihály and Wu, Charley M.},
	year = {2023},
	keywords = {Computer science, Cognitive psychology, Reward system, Psychology, Neuroscience, CCN},
}
