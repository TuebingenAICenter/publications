@misc{schlarmann_adversarial_2023,
	title = {On the {Adversarial} {Robustness} of {Multi}-{Modal} {Foundation} {Models}},
	shorttitle = {On the {Adversarial} {Robustness} of {Multi}-{Modal} {Foundation} {Models}},
	url = {https://arxiv.org/abs/2308.10741},
	doi = {10.48550/arXiv.2308.10741},
	abstract = {Multi-modal foundation models like CLIP have shown impressive zero-shot performance on a variety of tasks. However, their robustness to adversarial attacks remains largely unexplored. In this paper, we perform a systematic study of the adversarial robustness of CLIP-like models. We find that these models are highly vulnerable to adversarial perturbations, even when the perturbations are small. We show that the robustness of these models is significantly lower than that of unimodal models trained on the same data. Furthermore, we investigate the transferability of adversarial examples between modalities and find that adversarial examples generated for one modality can often be transferred to the other, highlighting the shared vulnerability of these models.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Schlarmann, Christian and Hein, Matthias},
	year = {2023},
	keywords = {Foundation (evidence), Adversarial system, Modal, Robustness (evolution), Harm, Computer science, Computer security, Internet privacy, Artificial intelligence, Political science, ICCV},
}
