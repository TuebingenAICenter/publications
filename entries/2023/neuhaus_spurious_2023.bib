@misc{neuhaus_spurious_2023,
	title = {Spurious {Features} {Everywhere} - {Large}-{Scale} {Detection} of {Harmful} {Spurious} {Features} in {ImageNet}},
	shorttitle = {Spurious {Features} {Everywhere}},
	url = {https://arxiv.org/abs/2212.04871},
	doi = {10.48550/arXiv.2212.04871},
	abstract = {Deep neural networks are known to rely on spurious features, which are features that are predictive of the label in the training set but do not generalize to other distributions. While previous work has focused on specific, manually curated spurious features, we propose a method to detect harmful spurious features at scale. We introduce a novel approach to identify spurious features by analyzing the internal representations of deep neural networks. Our method allows us to detect thousands of spurious features in ImageNet-trained models. We show that these features are indeed harmful, as they lead to a significant drop in performance on out-of-distribution data. Furthermore, we demonstrate that our method can be used to improve the robustness of models by suppressing these spurious features.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {IEEE},
	author = {Neuhaus, Yannic and Augustin, Maximilian and Boreiko, Valentyn and Hein, Matthias},
	year = {2023},
	keywords = {Spurious relationship, Computer science, Classifier (UML), Artificial intelligence, Machine learning, Feature (linguistics), Pattern recognition (psychology), Benchmark (surveying), Visualization, Source code, Deep neural networks, Artificial neural network, ICCV},
}
