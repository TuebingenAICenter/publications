@misc{ayhan_multitask_2023,
	title = {Multitask {Learning} for {Activity} {Detection} in {Neovascular} {Age}-{Related} {Macular} {Degeneration}},
	shorttitle = {Multitask {Learning} for {Activity} {Detection} in {nAMD}},
	url = {https://tvst.arvojournals.org/article.aspx?articleid=2785531},
	doi = {10.1167/tvst.12.7.12},
	abstract = {Purpose: To develop and evaluate a multitask deep learning model for the detection of disease activity in neovascular age-related macular degeneration (nAMD) on optical coherence tomography (OCT) B-scans. Methods: We retrospectively included 10,560 OCT B-scans from 1056 patients with nAMD. We trained a multitask convolutional neural network (CNN) to simultaneously predict the presence of intraretinal fluid (IRF), subretinal fluid (SRF), and pigment epithelial detachment (PED), as well as the overall disease activity status. We compared the performance of the multitask model to single-task models and evaluated the model's performance on an external test set. Results: The multitask model achieved an area under the receiver operating characteristic curve (AUROC) of 0.94 for the detection of disease activity. The multitask approach outperformed single-task models for the detection of IRF and SRF. The model showed good generalization performance on the external test set. Conclusions: Multitask learning is a promising approach for the automated detection of disease activity in nAMD on OCT B-scans. The simultaneous prediction of fluid types and activity status improves the model's performance and provides a more comprehensive assessment of the disease state.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Association for Research in Vision and Ophthalmology},
	author = {Ayhan, Murat Seckin and Faber, Hanna and Kuhlewein, Laura and Inhoffen, W. and Aliyeva, Gulnar and Ziemssen, Focke and Berens, Philipp},
	month = jul,
	year = {2023},
	keywords = {Macular degeneration, Computer science, Task (project management), Artificial intelligence, Deep learning, Machine learning, Medicine, Ophthalmology, TVST},
}
