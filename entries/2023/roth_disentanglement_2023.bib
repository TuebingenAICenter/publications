@inproceedings{roth_disentanglement_2023,
	title = {Disentanglement of {Correlated} {Factors} via {Hausdorff} {Factorized} {Support}},
	shorttitle = {Disentanglement of {Correlated} {Factors} via {Hausdorff} {Factorized} {Support}},
	url = {https://openreview.net/pdf?id=OKcJhpQiGiX},
	doi = {10.48550/arxiv.2210.07347},
	abstract = {Learning disentangled representations of data is a fundamental problem in machine learning. Most existing approaches rely on the assumption that the underlying factors of variation are independent. However, in many real-world scenarios, factors are correlated. In this work, we propose a novel framework for disentanglement that explicitly accounts for correlations between factors. We introduce the Hausdorff Factorized Support (HFS) loss, which encourages the model to learn a representation where the support of the joint distribution of factors is factorized. We demonstrate that our approach effectively disentangles correlated factors on several synthetic and real-world datasets, outperforming existing state-of-the-art methods.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {The {Eleventh} {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Roth, Karsten and Ibrahim, Mark and Akata, Zeynep and Vincent, Pascal and Bouchacourt, Diane},
	month = may,
	year = {2023},
	keywords = {Pairwise comparison, Generalization, Representation (politics), Computer science, Hausdorff space, Hausdorff distance, Variety (cybernetics), Object (grammar), Distribution (mathematics), Correlation, Mathematics, Artificial intelligence, Discrete mathematics, ICLR},
}
