@article{boelts_simulation-based_2023,
	title = {Simulation-based inference for efficient identification of generative models in computational connectomics},
	copyright = {CC BY 4.0},
	issn = {1553-7358},
	shorttitle = {Simulation-based inference for efficient identification},
	url = {https://doi.org/10.1371/journal.pcbi.1011406},
	doi = {10.1371/journal.pcbi.1011406},
	abstract = {Generative models are essential for understanding the principles of neural circuit organization. However, identifying the parameters of these models is challenging because the likelihood function is often intractable. Simulation-based inference (SBI) has emerged as a powerful framework for parameter inference in such cases. Here, we demonstrate the utility of SBI for identifying generative models of neuronal connectivity. We apply SBI to a model of the rat vibrissal cortex, where we infer the parameters of a generative model of axonal and dendritic morphology and synaptic connectivity. We show that SBI can efficiently identify the parameters of this model, even when the model is computationally expensive to simulate. Our results suggest that SBI is a promising approach for identifying generative models in computational connectomics and beyond.},
	language = {en},
	urldate = {2024-05-23},
	journal = {PLOS Computational Biology},
	publisher = {Public Library of Science},
	author = {Boelts, Jan-Matthis and Harth, Pia and Gao, Rui and Udvary, Dániel and Yáñez, Felipe and Baum, Dorothea and Hege, Hans-Christian and Oberlaender, Marcel and Macke, Jakob H.},
	month = sep,
	year = {2023},
	keywords = {Connectomics, Computer science, Inference, Generative model, Bayesian inference, Artificial intelligence, Bayes' theorem, Machine learning, Prior probability, Data mining, Bayesian probability, Approximate Bayesian computation, Synthetic data, Generative grammar, Connectome, PLOSCB},
}
