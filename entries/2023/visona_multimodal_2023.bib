@article{visona_multimodal_2023,
	title = {Multimodal learning in clinical proteomics: enhancing antimicrobial resistance prediction models with chemical information},
	shorttitle = {Multimodal learning in clinical proteomics},
	url = {https://doi.org/10.1093/bioinformatics/btad717},
	doi = {10.1093/bioinformatics/btad717},
	abstract = {Motivation: Antimicrobial resistance (AMR) is a major global health threat. Clinical proteomics, specifically mass spectrometry-based identification of bacteria, has emerged as a rapid diagnostic tool. However, current methods often rely on single-modality data, potentially missing valuable information. Multimodal learning, which integrates diverse data sources, has shown promise in various domains but remains under-explored in clinical proteomics for AMR prediction. Results: We propose a multimodal learning framework that integrates clinical proteomics data with chemical information about antibiotics. We demonstrate that incorporating chemical information significantly improves the performance of AMR prediction models compared to unimodal baselines. Our approach achieves state-of-the-art results on a large-scale clinical proteomics dataset, highlighting the potential of multimodal learning to enhance diagnostic accuracy in clinical settings.},
	language = {en},
	journal = {Bioinformatics},
	publisher = {Oxford University Press},
	author = {Visonà, G. and Duroux, D. and Miranda, L. and Sükei, E. and Li, Y. and Borgwardt, K. and Oliver, C.},
	month = dec,
	year = {2023},
	keywords = {BIOINFORMATICS},
}
