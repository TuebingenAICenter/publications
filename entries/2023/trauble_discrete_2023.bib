@misc{trauble_discrete_2023,
	title = {Discrete {Key}-{Value} {Bottleneck}},
	shorttitle = {{DKVB}},
	url = {https://proceedings.mlr.press/v202/trauble23a.html},
	doi = {10.48550/arxiv.2207.11240},
	abstract = {We introduce the Discrete Key-Value Bottleneck (DKVB), a representation learning framework that learns to store information in a discrete, structured memory. DKVB decomposes the input into a set of keys and values, where the keys act as pointers to a learned codebook of values. This bottleneck encourages the model to learn a compact, interpretable, and reusable representation of the data. We demonstrate that DKVB achieves competitive performance on a variety of tasks, including image classification, reinforcement learning, and language modeling, while providing insights into the learned representations.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Träuble, Frederik and Goyal, Anirudh and Rahaman, Nasim and Mozer, Michael C. and Kawaguchi, Kenji and Bengio, Yoshua and Schölkopf, Bernhard},
	month = jul,
	year = {2023},
	keywords = {Bottleneck, Computer science, Forgetting, Encoder, Key (lock), Inference, Context (archaeology), Task (project management), Information bottleneck method, Data stream mining, Encoding (memory), Artificial intelligence, Machine learning, ENCODE, Process (computing), Cluster analysis, ICML},
}
