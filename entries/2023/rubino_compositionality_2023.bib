@misc{rubino_compositionality_2023,
	title = {Compositionality under time pressure},
	shorttitle = {Compositionality under time pressure},
	url = {https://doi.org/10.31234/osf.io/z2648},
	doi = {10.31234/osf.io/z2648},
	abstract = {Compositionality—the ability to combine known components to represent novel concepts—is a hallmark of human cognition. However, the computational costs of compositional processing are often overlooked. We investigate how time pressure affects the use of compositional strategies in a function learning task. Participants learned to predict outcomes based on combinations of features, where the underlying function was either compositional (additive) or non-compositional (configural). We find that under high time pressure, participants rely more on simple, non-compositional heuristics, whereas under low time pressure, they are more likely to employ compositional strategies. These results suggest that compositionality is a flexible, resource-dependent strategy that is modulated by the availability of cognitive resources.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Cognitive Science Society},
	author = {Rubino, Valerio and Hamidi, Mani and Dayan, Peter and Wu, Charley M.},
	editor = {Goldwater, Micah and Anggoro, F. X. and Hayes, B. K. and Ong, D. C.},
	year = {2023},
	keywords = {Principle of compositionality, Computer science, Reuse, Flexibility (engineering), Computation, Robustness (evolution), Generalization, Artificial intelligence, Theoretical computer science, Algorithm, Mathematics, COGSCI},
}
