@inproceedings{kuznetsova_importance_2023,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {On the {Importance} of {Step}-wise {Embeddings} for {Heterogeneous} {Clinical} {Time}-{Series}},
	shorttitle = {On the {Importance} of {Step}-wise {Embeddings}},
	url = {https://proceedings.mlr.press/v225/kuznetsova23a.html},
	abstract = {Clinical time-series data are often heterogeneous, containing both irregularly sampled continuous measurements and categorical events. Existing approaches typically handle this by either imputing missing values or using specialized architectures to process the raw data directly. In this work, we argue that the representation of individual time-steps is a critical, yet often overlooked, component of clinical time-series modeling. We propose a step-wise embedding framework that learns a unified representation for heterogeneous clinical data at each time-step. We demonstrate that this approach consistently improves performance across various clinical tasks and architectures, highlighting the importance of step-wise embeddings for modeling heterogeneous clinical time-series.},
	language = {en},
	booktitle = {Proceedings of the 3rd {Machine} {Learning} for {Health} {Symposium}},
	publisher = {PMLR},
	author = {Kuznetsova, R. and Pace, A. and Burger, M. and Yèche, H. and Rätsch, G.},
	editor = {Hegselmann, S. and Parziale, A. and Shanmugam, D. and Tang, S. and Asiedu, M. N. and Chang, S. and Hartvigsen, T. and Singh, H.},
	month = dec,
	year = {2023},
	keywords = {ML4H},
}
