@misc{andriushchenko_modern_2023,
	title = {A {Modern} {Look} at the {Relationship} between {Sharpness} and {Generalization}},
	shorttitle = {A modern look at the relationship between sharpness and generalization},
	url = {https://arxiv.org/abs/2302.07011},
	doi = {10.48550/arXiv.2302.07011},
	abstract = {The relationship between the sharpness of the loss landscape and the generalization performance of deep neural networks has been a subject of intense study. Several works have proposed sharpness-based measures that correlate with generalization, and algorithms like Sharpness-Aware Minimization (SAM) have been developed to explicitly minimize these measures. However, the empirical evidence supporting the claim that sharpness causes better generalization remains mixed. In this paper, we perform a large-scale study of the relationship between sharpness and generalization. We evaluate a wide range of sharpness measures and training methods on various architectures and datasets. Our results show that while some sharpness measures correlate with generalization, this correlation is often weak or non-existent when controlling for other factors. We further show that SAM does not consistently improve generalization, and its performance is highly sensitive to hyperparameters. Our findings suggest that the link between sharpness and generalization is more complex than previously thought and that current sharpness-based measures are not sufficient to explain the generalization performance of deep neural networks.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Andriushchenko, Maksym and Croce, Francesco and Müller, Maximilian and Hein, Matthias and Flammarion, Nicolas},
	year = {2023},
	keywords = {Generalization, Maxima and minima, Computer science, Artificial neural network, Artificial intelligence, Invariant (physics), Code (set theory), Algorithm, Pattern recognition (psychology), Mathematics, Set (abstract data type), Mathematical analysis, ICML},
}
