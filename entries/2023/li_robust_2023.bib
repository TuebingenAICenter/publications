@misc{li_robust_2023,
	title = {Robust deep learning object recognition models rely on low frequency information in natural images},
	copyright = {© 2023 Li et al.},
	shorttitle = {Robust deep learning object recognition models},
	url = {https://journals.plos.org/ploscompbiol/article?id=10.1371/journal.pcbi.1010932},
	doi = {10.1371/journal.pcbi.1010932},
	abstract = {Deep neural networks (DNNs) have achieved human-level performance on object recognition tasks, but they remain vulnerable to adversarial attacks and distribution shifts. Recent work suggests that robust models, which are trained to be invariant to such perturbations, rely more on shape-like features than standard models. However, it remains unclear what specific image features these robust models use. Here, we investigate the frequency dependence of robust models. We find that robust models rely significantly more on low-frequency information than standard models. This reliance on low-frequency information is a key factor in their robustness. We further show that this reliance is not merely a byproduct of the training process but is a fundamental property of robust representations. Our results provide new insights into the nature of robust representations and suggest that low-frequency information is a critical component of robust object recognition.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Public Library of Science},
	author = {Li, Zhe and Ortega Caro, Josue and Rusak, Evgenia and Brendel, Wieland and Bethge, Matthias and Anselmi, Fabio and Patel, Ankit B. and Tolias, Andreas S. and Pitkow, Xaq},
	year = {2023},
	keywords = {Robustness (evolution), Artificial intelligence, Computer science, Preprocessor, Adversarial system, Spatial frequency, Machine learning, Pattern recognition (psychology), Cognitive neuroscience of visual object recognition, Representation (politics), Deep neural networks, Deep learning, Object (grammar), PLOSCB},
}
