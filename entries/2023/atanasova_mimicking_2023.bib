@article{atanasova_mimicking_2023,
	title = {Mimicking {Tumor} {Cell} {Heterogeneity} of {Colorectal} {Cancer} in a {Patient}-derived {Organoid}-{Fibroblast} {Model}},
	issn = {2352-345X},
	shorttitle = {Mimicking {Tumor} {Cell} {Heterogeneity} of {Colorectal} {Cancer}},
	url = {https://doi.org/10.1016/j.jcmgh.2023.02.014},
	doi = {10.1016/j.jcmgh.2023.02.014},
	abstract = {Colorectal cancer (CRC) is characterized by high inter- and intratumoral heterogeneity, which poses a major challenge for personalized therapy. Patient-derived organoids (PDOs) are powerful models to study CRC, but they often lack the complex tumor microenvironment (TME). Here, we established a co-culture system of patient-derived CRC organoids and cancer-associated fibroblasts (CAFs) to mimic the TME. We show that this model recapitulates key features of the original tumors, including the maintenance of tumor cell heterogeneity and the activation of CAFs. Furthermore, we demonstrate that the presence of CAFs significantly alters the drug response of the organoids, highlighting the importance of the TME in therapeutic studies. Our model provides a robust platform for studying CRC biology and for testing personalized treatment strategies.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Cellular and Molecular Gastroenterology and Hepatology},
	publisher = {Elsevier},
	author = {Atanasova, V. S. and de Jesus Cardona, C. and Hejret, V. and Tiefenbacher, A. and Mair, T. and Tran, L. and Pfneissl, J. and Draganić, K. and Binder, C. and Kabiljo, J. and Clement, J. and Woeran, K. and Neudert, B. and Wohlhaupter, S. and Haase, A. and Domazet, S. and Hengstschläger, M. and Mitterhauser, M. and Müllauer, L. and Tichý, B. and Bermann, M. and Schweikert, G. and Hartl, M. and Dolznig, H. and Egger, G.},
	year = {2023},
	keywords = {CMGH},
}
