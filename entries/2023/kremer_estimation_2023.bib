@misc{kremer_estimation_2023,
	title = {Estimation {Beyond} {Data} {Reweighting}: {Kernel} {Method} of {Moments}},
	shorttitle = {Kernel {Method} of {Moments}},
	url = {https://proceedings.mlr.press/v202/kremer23a.html},
	doi = {10.48550/arxiv.2305.10898},
	abstract = {We propose the Kernel Method of Moments (KMM), a framework for estimation and inference in models defined by conditional moment restrictions. KMM generalizes the Generalized Method of Moments (GMM) by using a continuum of moment conditions indexed by a reproducing kernel Hilbert space. This allows for the use of non-parametric instruments and provides a flexible way to incorporate prior knowledge. We show that KMM is consistent and asymptotically normal, and we provide a computationally efficient implementation. We demonstrate the effectiveness of KMM on a variety of tasks, including causal inference, instrumental variable regression, and density ratio estimation.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Kremer, Heiner and Nemmour, Yassine and Schölkopf, Bernhard and Zhu, Jia-Jie},
	editor = {Krause, Andreas and Brunskill, Emma and Cho, Kyunghyun and Engelhardt, Barbara and Sabato, Sivan and Scarlett, Jonathan},
	month = jul,
	year = {2023},
	keywords = {Estimator, Generalized method of moments, Moment (physics), Mathematics, Kernel (algebra), Empirical likelihood, Inference, Asymptotic distribution, Causal inference, Divergence (linguistics), Applied mathematics, Lift (data mining), Conditional probability distribution, Kernel density estimation, Computer science, Econometrics, Statistics, Artificial intelligence, Machine learning, ICML},
}
