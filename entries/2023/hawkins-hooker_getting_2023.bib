@article{hawkins-hooker_getting_2023,
	title = {Getting personal with epigenetics: towards individual-specific epigenomic imputation with machine learning},
	copyright = {© 2023 The Author(s)},
	issn = {2041-1723},
	shorttitle = {Getting personal with epigenetics},
	url = {https://doi.org/10.1038/s41467-023-40211-2},
	doi = {10.1038/s41467-023-40211-2},
	abstract = {Epigenomic data are essential for understanding gene regulation and disease, yet they are often incomplete due to experimental limitations or cost. While imputation methods exist, they typically rely on population-level data, ignoring individual-specific variation. Here we introduce a framework for individual-specific epigenomic imputation that leverages both population-level and individual-specific information. We demonstrate that our approach outperforms existing methods in imputing DNA methylation and histone modification profiles, particularly in regions with high inter-individual variability. Our results suggest that incorporating individual-specific information is crucial for accurate epigenomic imputation and has the potential to improve our understanding of the epigenomic basis of complex diseases.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Nature Communications},
	publisher = {Nature Portfolio},
	author = {Hawkins-Hooker, Alex and Visonà, Giovanni and Narendra, Tanmayee and Rojas-Carulla, Mateo and Schölkopf, Bernhard and Schweikert, Gabriele},
	month = aug,
	year = {2023},
	keywords = {Epigenomics, Epigenetics, Epigenome, Computational biology, DNA methylation, Epigenesis, Imputation (statistics), Computer science, Personalized medicine, Biology, Artificial intelligence, Bioinformatics, Genetics, Machine learning, Gene expression, Gene, Missing data},
}
