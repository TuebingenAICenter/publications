@inproceedings{rangnekar_usim-dal_2023,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {{USIM}-{DAL}: {Uncertainty}-aware {Statistical} {Image} {Modeling}-based {Dense} {Active} {Learning} for {Super}-resolution},
	shorttitle = {{USIM}-{DAL}},
	url = {https://proceedings.mlr.press/v216/rangnekar23a.html},
	doi = {10.48550/arxiv.2305.17520},
	abstract = {Deep learning-based super-resolution (SR) models are data-hungry and require large-scale high-resolution (HR) datasets for training. However, acquiring HR images is expensive and time-consuming. Active learning (AL) is a promising paradigm to reduce the annotation burden by selecting the most informative samples for training. Existing AL methods for SR are typically image-level, selecting entire images for annotation. In this work, we propose a novel dense active learning framework for SR, termed USIM-DAL, which selects informative patches within images for annotation. We introduce a novel uncertainty estimation technique based on statistical image modeling (SIM) that captures the local image statistics to identify regions where the model is uncertain. Our method is model-agnostic and can be integrated with any SR architecture. We demonstrate the effectiveness of our approach on several benchmark datasets, showing that USIM-DAL achieves competitive performance with significantly fewer training samples compared to state-of-the-art AL methods.},
	language = {en},
	booktitle = {Proceedings of the {Thirty}-{Ninth} {Conference} on {Uncertainty} in {Artificial} {Intelligence}},
	publisher = {PMLR},
	author = {Rangnekar, V. and Upadhyay, U. and Akata, Z. and Banerjee, B.},
	editor = {Evans, Robin J. and Shpitser, Ilya},
	month = aug,
	year = {2023},
	keywords = {Artificial intelligence, Computer science, Probabilistic logic, Machine learning, Deep learning, Convolutional neural network, Prior probability, Regression, Statistical model, Pattern recognition (psychology), Random forest, Bayesian probability, Mathematics, UAI},
}
