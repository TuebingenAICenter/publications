@inproceedings{jiang_instantavatar_2023,
	title = {{InstantAvatar}: {Learning} {Avatars} from {Monocular} {Video} in 60 {Seconds}},
	shorttitle = {{InstantAvatar}},
	url = {https://ieeexplore.ieee.org/document/10203382},
	doi = {10.1109/CVPR52729.2023.01623},
	abstract = {We present InstantAvatar, a method that learns a high-fidelity animatable human avatar from a short monocular video in about a minute. Existing methods for learning human avatars from monocular video typically require long optimization times, often ranging from tens of minutes to hours, which hinders their practical application. To address this, we propose a novel approach that leverages a dynamic neural radiance field (NeRF) representation and a fast optimization strategy. Specifically, we introduce a canonical space deformation field that is conditioned on the human pose, and we use a sparse set of control points to guide the deformation. We further propose a coarse-to-fine optimization scheme that allows for rapid convergence. Our experiments demonstrate that InstantAvatar achieves state-of-the-art performance in terms of both visual quality and animation fidelity, while being significantly faster than existing methods.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {Proceedings 2023 {IEEE}/{CVF} {Conference} on {Computer} {Vision} and {Pattern} {Recognition} ({CVPR})},
	publisher = {IEEE},
	author = {Jiang, Tianjian and Chen, Xu and Song, Jie and Hilliges, Otmar},
	year = {2023},
	keywords = {CVPR},
}
