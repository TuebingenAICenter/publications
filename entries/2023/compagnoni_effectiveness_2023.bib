@article{compagnoni_effectiveness_2023,
	title = {On the {Effectiveness} of {Randomized} {Signatures} as {Reservoir} for {Learning} {Rough} {Dynamics}},
	shorttitle = {On the {Effectiveness} of {Randomized} {Signatures}},
	url = {https://arxiv.org/abs/2201.00384},
	doi = {10.1109/ijcnn54540.2023.10191624},
	abstract = {We study the approximation properties of randomized signatures as reservoir systems for learning rough dynamics. Randomized signatures are a computationally efficient alternative to the classical signature transform, which is a powerful tool for feature extraction from time series. We prove that randomized signatures are universal approximators for continuous functions on compact sets of paths, and we provide a quantitative bound on the approximation error. We further demonstrate the effectiveness of the proposed approach on several synthetic and real-world datasets, showing that randomized signatures can achieve competitive performance with significantly lower computational cost than classical signatures.},
	language = {en},
	urldate = {2025-05-14},
	journal = {2023 International Joint Conference on Neural Networks (IJCNN)},
	publisher = {IEEE},
	author = {Compagnoni, Enea Monzio and Scampicchio, Anna and Biggio, Luca and Orvieto, Antonio and Hofmann, Thomas and Teichmann, Josef},
	year = {2023},
	keywords = {Robustness (evolution), Computer science, Signature (topology), Random projection, Context (archaeology), Lemma (botany), Randomized algorithm, Artificial intelligence, Data mining, Algorithm, Theoretical computer science, Machine learning, Mathematics, IJCNN},
}
