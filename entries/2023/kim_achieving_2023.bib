@misc{kim_achieving_2023,
	title = {Achieving a {Better} {Stability}-{Plasticity} {Trade}-off via {Auxiliary} {Networks} in {Continual} {Learning}},
	shorttitle = {Achieving a {Better} {Stability}-{Plasticity} {Trade}-off},
	url = {https://arxiv.org/pdf/2303.09483.pdf},
	doi = {10.48550/arxiv.2303.09483},
	abstract = {Continual learning aims to learn a sequence of tasks without forgetting previously acquired knowledge. A central challenge is the stability-plasticity trade-off: the model must be stable enough to retain old knowledge while being plastic enough to learn new tasks. In this paper, we propose a novel approach to address this trade-off by introducing auxiliary networks. Our method leverages these auxiliary networks to selectively update the main model's parameters, effectively balancing stability and plasticity. We demonstrate the effectiveness of our approach through extensive experiments on standard continual learning benchmarks, showing that it consistently outperforms existing methods.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {IEEE},
	author = {Kim, Sanghwan and Noci, Lorenzo and Orvieto, Antonio and Hofmann, Thomas},
	year = {2023},
	keywords = {Forgetting, Computer science, Stability (learning theory), Task (project management), Plasticity, Artificial intelligence, Artificial neural network, Mechanism (biology), Machine learning, Cognitive psychology, Psychology, Engineering, CVPR},
}
