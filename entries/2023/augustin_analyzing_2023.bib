@article{augustin_analyzing_2023,
	title = {Analyzing and explaining image classifiers via diffusion guidance},
	shorttitle = {Analyzing and explaining image classifiers via diffusion guidance},
	url = {https://arxiv.org/abs/2311.17833},
	abstract = {We propose a novel framework for explaining image classifiers by leveraging the generative power of diffusion models. Instead of relying on gradients or perturbations, we use the diffusion model as a prior to guide the generation of images that are prototypical for a specific class or that explain a classifier's decision. Our method, Diffusion Guidance for Explanation (DGE), allows for the generation of high-quality, diverse, and class-specific explanations. We demonstrate that DGE can be used to visualize the features that a classifier relies on, to identify potential biases, and to generate counterfactual explanations. We show that our approach outperforms existing methods in terms of visual quality and faithfulness to the classifier's decision-making process.},
	language = {en},
	urldate = {2025-05-14},
	journal = {arXiv preprint arXiv:2311.17833},
	publisher = {arXiv},
	author = {Augustin, Matthias and Neuhaus, Yannic and Hein, Matthias},
	year = {2023},
	keywords = {ARXIV},
}
