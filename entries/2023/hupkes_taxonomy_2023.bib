@article{hupkes_taxonomy_2023,
	title = {A taxonomy and review of generalization research in {NLP}},
	issn = {2522-5839},
	shorttitle = {A taxonomy and review of generalization research in {NLP}},
	url = {https://www.nature.com/articles/s42256-023-00729-y},
	doi = {10.1038/s42256-023-00729-y},
	abstract = {Generalization—the ability of a model to perform well on data that it has not encountered during training—is a central challenge in natural language processing (NLP). Despite its importance, the field lacks a unified framework for discussing generalization, leading to fragmented research and inconsistent terminology. In this Review, we propose a taxonomy of generalization in NLP that categorizes research based on the relationship between the training and test distributions. We use this taxonomy to survey the state of the art, identifying key trends, challenges and open questions. We hope that this framework will provide a common language for the community, facilitate the comparison of different approaches and guide future research in this critical area.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Nature Machine Intelligence},
	publisher = {Nature Portfolio},
	author = {Hupkes, Dieuwke and Giulianelli, Mario and Dankers, Verna and Artetxe, Mikel and Elazar, Yanai and Pimentel, Tiago and Christodoulopoulos, Christos and Lasri, Karim and Saphra, Naomi and Sinclair, Arabella and Ulmer, Dennis and Schottmann, Florian and Batsuren, Khuyagbaatar and Sun, Kaisheng and Sinha, Koustuv and Khalatbari, Leila and Ryskina, Maria and Frieske, Robert and Cotterell, Ryan and Jin, Zhijing},
	month = oct,
	year = {2023},
	keywords = {Generalization, NLP},
}
