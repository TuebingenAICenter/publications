@article{sarnthein_escaping_2023,
	title = {Escaping {Random} {Teacher} {Initialization} {Enhances} {Signal} {Propagation} and {Representations}},
	shorttitle = {Escaping {Random} {Teacher} {Initialization}},
	url = {https://openreview.net/forum?id=ClCrg213JS},
	abstract = {In the context of knowledge distillation, the teacher model is typically assumed to be a fixed, pre-trained network. However, in many practical scenarios, the teacher is trained concurrently with the student. In this work, we investigate the dynamics of such co-training setups. We find that standard random initialization of the teacher leads to poor signal propagation and suboptimal representations, as the teacher's initial lack of structure hinders the student's learning process. We propose a simple yet effective strategy to overcome this: initializing the teacher with a structured, non-random initialization. We demonstrate that this approach significantly enhances signal propagation, leads to better representations, and improves the final performance of the student model across various architectures and datasets.},
	language = {en},
	urldate = {2024-05-22},
	journal = {NeurIPS 2023 Workshop on Mathematics of Modern Machine Learning},
	publisher = {OpenReview},
	author = {Sarnthein, Felix and Singh, Sandeep Pal and Orvieto, Antonio and Hofmann, Thomas},
	year = {2023},
	keywords = {NEURIPS},
}
