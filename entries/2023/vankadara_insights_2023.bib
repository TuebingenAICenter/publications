@article{vankadara_insights_2023,
	title = {Insights into {Ordinal} {Embedding} {Algorithms}: {A} {Systematic} {Evaluation}},
	issn = {1532-4435},
	shorttitle = {Insights into {Ordinal} {Embedding} {Algorithms}},
	url = {https://jmlr.org/papers/v24/21-0566.html},
	doi = {10.48550/arxiv.1912.01666},
	abstract = {Ordinal embedding is the problem of learning a representation of objects in a low-dimensional Euclidean space given only ordinal information about the objects (e.g., 'object i is closer to object j than to object k'). While many algorithms have been proposed for this task, they are often evaluated on different datasets, using different evaluation metrics, and under different experimental settings. This makes it difficult to compare the performance of different algorithms. In this paper, we perform a systematic evaluation of several state-of-the-art ordinal embedding algorithms. We evaluate them on a variety of synthetic and real-world datasets, using a consistent set of evaluation metrics. We find that no single algorithm performs best across all datasets. Instead, the performance of an algorithm depends on the structure of the underlying data and the type of ordinal information available. We also provide insights into the strengths and weaknesses of each algorithm, which can help practitioners choose the right algorithm for their specific application.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Machine Learning Research},
	publisher = {Journal of Machine Learning Research},
	author = {Vankadara, Leena Chennuru and Haghiri, Siavash and Lohaus, Michael and Wahab, Faiz Ul and von Luxburg, Ulrike},
	year = {2023},
	keywords = {Embedding, Computer science, Dimension (graph theory), Set (abstract data type), Key (lock), Representation (politics), Simple (philosophy), Artificial neural network, Algorithm, Regular polygon, Theoretical computer science, Euclidean geometry, Pairwise comparison, Artificial intelligence, Machine learning, Mathematics, JMLR},
}
