@article{janschewski_school_2023,
	title = {School predictors of mental health problems in children and adolescents based on a survey of students in hospital and regular schools},
	issn = {1010-0652},
	shorttitle = {School predictors of mental health problems},
	url = {https://econtent.hogrefe.com/doi/full/10.1024/1010-0652/a000339},
	doi = {10.1024/1010-0652/a000339},
	abstract = {Mental health problems are highly prevalent in children and adolescents. Schools are important settings for mental health promotion and prevention. However, little is known about school-related predictors of mental health problems in students in hospital schools compared to regular schools. In this cross-sectional study, we surveyed 1,056 students (Mage = 13.6 years, SD = 2.3) from hospital schools (n = 156) and regular schools (n = 900) in Germany. We assessed mental health problems (SDQ), school climate, teacher-student relationship, and school-related stress. Students in hospital schools reported significantly higher levels of mental health problems than students in regular schools. In both groups, a positive teacher-student relationship and a positive school climate were associated with fewer mental health problems, while school-related stress was associated with more mental health problems. The results highlight the importance of school-related factors for the mental health of students in both settings and suggest that interventions should focus on improving the school climate and teacher-student relationships.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Zeitschrift für Pädagogische Psychologie},
	publisher = {Hogrefe Publishing},
	author = {Janschewski, J. and Käppler, C. and Berens, P.},
	month = jan,
	year = {2023},
}
