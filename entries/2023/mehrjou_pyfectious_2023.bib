@misc{mehrjou_pyfectious_2023,
	title = {Pyfectious: {An} individual-level simulator to discover optimal containment policies for epidemic diseases},
	shorttitle = {Pyfectious},
	url = {https://doi.org/10.1371/journal.pcbi.1010799},
	doi = {10.1371/journal.pcbi.1010799},
	abstract = {The COVID-19 pandemic has highlighted the need for robust tools to evaluate the impact of non-pharmaceutical interventions (NPIs) on the spread of infectious diseases. While many models exist, they often rely on simplifying assumptions that may not capture the complexity of human behavior and social interactions. We introduce Pyfectious, an individual-level simulator designed to model the spread of infectious diseases in a population with realistic social structures. Pyfectious allows for the simulation of various NPIs, such as social distancing, school closures, and contact tracing, and provides a framework for discovering optimal containment policies using reinforcement learning. We demonstrate the utility of Pyfectious by applying it to a synthetic population and showing that it can identify effective intervention strategies that balance disease control with social and economic costs.},
	language = {en},
	publisher = {Public Library of Science},
	author = {Mehrjou, Arash and Soleymani, Ashkan and Abyaneh, Amin and Bhatt, Samir and Schölkopf, Bernhard and Bauer, Stefan},
	month = jan,
	year = {2023},
	keywords = {Computer science, Probabilistic logic, Population, Reinforcement learning, Missile, Rotation formalisms in three dimensions, Range (aeronautics), Set (abstract data type), Software, Simulation, Pandemic, Machine learning, Artificial intelligence, Coronavirus disease 2019 (COVID-19), Engineering, Infectious disease (medical specialty), Mathematics},
}
