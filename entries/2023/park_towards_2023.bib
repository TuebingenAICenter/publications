@inproceedings{park_towards_2023,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Towards {Empirical} {Process} {Theory} for {Vector}-{Valued} {Functions}: {Metric} {Entropy} of {Smooth} {Function} {Classes}},
	shorttitle = {Towards {Empirical} {Process} {Theory} for {Vector}-{Valued} {Functions}},
	url = {https://proceedings.mlr.press/v201/park23a.html},
	abstract = {Empirical process theory for scalar-valued functions is a cornerstone of modern statistical learning theory. However, many contemporary machine learning tasks, such as multi-task learning, structured prediction, and kernel methods, involve vector-valued functions. In this paper, we develop an empirical process theory for vector-valued functions by extending the notion of metric entropy to this setting. Specifically, we provide upper bounds on the metric entropy of H{\textbackslash}"older and Sobolev spaces of vector-valued functions. Our results are based on a novel covering number analysis that leverages the geometry of the output space. We demonstrate the utility of our results by providing generalization error bounds for vector-valued kernel ridge regression and multi-task learning.},
	language = {en},
	booktitle = {Proceedings of the 34th {International} {Conference} on {Algorithmic} {Learning} {Theory}},
	publisher = {PMLR},
	author = {Park, J. and Muandet, K.},
	editor = {Agrawal, Shipra and Orabona, Francesco},
	month = feb,
	year = {2023},
	keywords = {ALT},
}
