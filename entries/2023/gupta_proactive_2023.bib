@article{gupta_proactive_2023,
	title = {Proactive {Contact} {Tracing}},
	copyright = {CC BY 4.0},
	issn = {2767-3170},
	shorttitle = {Proactive {Contact} {Tracing}},
	url = {https://doi.org/10.1371/journal.pdig.0000199},
	doi = {10.1371/journal.pdig.0000199},
	abstract = {Contact tracing is a critical tool for controlling the spread of infectious diseases. Traditional contact tracing relies on manual interviews to identify and notify individuals who have been in contact with an infected person. However, this process is often slow and labor-intensive, limiting its effectiveness during rapid outbreaks. In this paper, we propose a proactive contact tracing framework that leverages machine learning to predict the infectiousness of individuals and prioritize contact tracing efforts. Our approach uses a combination of epidemiological modeling and deep learning to estimate the probability that an individual is infectious based on their recent history and contact patterns. We demonstrate the effectiveness of our approach through simulations on real-world contact networks, showing that proactive contact tracing can significantly reduce the spread of disease compared to traditional methods while maintaining privacy and minimizing the burden on public health resources.},
	language = {en},
	urldate = {2025-05-14},
	journal = {PLOS Digital Health},
	publisher = {Public Library of Science},
	author = {Gupta, Prateek and Maharaj, Tegan and Weiss, Martin and Rahaman, Nasim and Alsdurf, Hannah and Minoyan, Nanor and Harnois-Leblanc, Soren and Merckx, Joanna and Williams, Andrew and Schmidt, Victor and St-Charles, Pierre-Luc and Patel, Akshay and Zhang, Yang and Buckeridge, David L. and Pal, Christopher and Schölkopf, Bernhard and Bengio, Yoshua},
	month = mar,
	year = {2023},
	keywords = {Contact tracing, Computer science, Psychological intervention, Negotiation, Coronavirus disease 2019 (COVID-19), Pandemic, Test (biology), Internet privacy, Computer security, Psychology, Infectious disease (medical specialty), Medicine, Disease, Psychiatry},
}
