@article{reizinger_jacobian-based_2023,
	title = {Jacobian-based {Causal} {Discovery} with {Nonlinear} {ICA}},
	shorttitle = {Jacobian-based {Causal} {Discovery}},
	url = {https://openreview.net/forum?id=2Yo9xqR6Ab},
	abstract = {We propose a novel method for causal discovery from observational data. Our approach leverages the connection between nonlinear independent component analysis (ICA) and causal discovery. Specifically, we show that the Jacobian of the transformation from the observed variables to the latent independent components contains information about the causal structure. We propose a practical algorithm, JICA, that estimates the causal structure by first learning a nonlinear ICA model and then analyzing the Jacobian of the learned transformation. We demonstrate the effectiveness of our method on synthetic and real-world data, showing that it outperforms existing methods in several settings.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Transactions on Machine Learning Research},
	publisher = {Transactions on Machine Learning Research},
	author = {Reizinger, P. and Sharma, Y. and Bethge, M. and Schölkopf, B. and Huszár, F. and Brendel, W.},
	month = apr,
	year = {2023},
	keywords = {TMLR},
}
