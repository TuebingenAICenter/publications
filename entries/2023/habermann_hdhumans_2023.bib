@article{habermann_hdhumans_2023,
	title = {{HDHumans}: {A} {Hybrid} {Approach} for {High}-fidelity {Digital} {Humans}},
	issn = {2577-6193},
	shorttitle = {{HDHumans}},
	url = {https://arxiv.org/pdf/2210.12003.pdf},
	doi = {10.1145/3606915.3616036},
	abstract = {We present HDHumans, a novel hybrid approach for high-fidelity digital human synthesis. Our method combines the benefits of explicit geometry representations with the expressive power of neural rendering. Specifically, we propose a hybrid representation that consists of a coarse mesh proxy and a learned neural texture field. The mesh proxy provides a strong geometric prior, while the neural texture field captures fine-scale details and view-dependent effects. We demonstrate that our approach can synthesize high-fidelity digital humans from sparse multi-view input, and that it generalizes well to novel poses and viewpoints. Our method outperforms state-of-the-art approaches in terms of visual quality and geometric accuracy.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the ACM on Computer Graphics and Interactive Techniques},
	publisher = {ACM},
	author = {Habermann, Marc and Liu, Lingjie and Xu, Weipeng and Pons-Moll, Gerard and Zollhoefer, Michael and Theobalt, Christian},
	year = {2023},
	keywords = {SCA},
}
