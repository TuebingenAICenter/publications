@article{melde_compact_2023,
	title = {Compact holographic sound fields enable rapid one-step assembly of matter in 3D},
	url = {https://www.science.org/doi/abs/10.1126/sciadv.adf6182},
	doi = {10.1126/sciadv.adf6182},
	abstract = {Acoustic manipulation is a powerful tool for the noncontact assembly of matter. However, current methods are often limited to simple geometries or require complex, multi-step processes. We present a method for the rapid, one-step assembly of matter in 3D using compact holographic sound fields. Our approach uses a single acoustic hologram to generate a complex 3D sound field that can trap and assemble particles into arbitrary 3D structures. We demonstrate the assembly of various materials, including hydrogels, cells, and microparticles, into complex 3D shapes with high precision and speed. This method opens new avenues for tissue engineering, micro-robotics, and materials science.},
	language = {en},
	journal = {Science Advances},
	publisher = {AAAS},
	author = {Melde, Kai and Kremer, Heiner and Shi, Minghui and Seneca, Senne and Frey, Christoph and Platzman, Ilia and Degel, Christian and Schmitt, Daniel and Schölkopf, Bernhard and Fischer, Peer},
	month = feb,
	year = {2023},
	keywords = {Holography, Biofabrication, Computer science, 3d printed, Nanotechnology, Acoustic wave, Acoustics, Materials science, Physics, Optics, Tissue engineering, Biomedical engineering, Engineering},
}
