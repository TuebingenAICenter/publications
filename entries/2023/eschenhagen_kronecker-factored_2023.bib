@inproceedings{eschenhagen_kronecker-factored_2023,
	title = {Kronecker-{Factored} {Approximate} {Curvature} for {Modern} {Neural} {Network} {Architectures}},
	shorttitle = {Kronecker-{Factored} {Approximate} {Curvature} for {Modern} {Neural} {Network} {Architectures}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2023/file/6a6679e3d5b9f7d5f09cdb79a5fc3fd8-Paper-Conference.pdf},
	doi = {10.48550/arXiv.2306.00955},
	abstract = {Kronecker-factored approximate curvature (K-FAC) is a popular second-order optimization method for neural networks. However, its original formulation is restricted to simple feed-forward architectures. While extensions to more complex layers exist, they are often heuristic or lack a unified theoretical framework. In this work, we provide a general framework for K-FAC that covers a wide range of modern neural network architectures, including residual connections, normalization layers, and attention mechanisms. We achieve this by deriving the K-FAC approximation for general computational graphs. Our approach is modular, easy to implement, and recovers existing K-FAC variants as special cases. We demonstrate the effectiveness of our method on various architectures, including ResNets and Transformers, where it achieves competitive performance compared to first-order methods while requiring significantly fewer iterations.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 36 ({NeurIPS} 2023)},
	publisher = {Curran Associates, Inc.},
	author = {Eschenhagen, R. and Immer, A. and Turner, R. and Schneider, F. and Hennig, P.},
	month = dec,
	year = {2023},
	keywords = {Artificial neural network, Curvature, Feature (linguistics), Generalization, Key (lock), NEURIPS},
}
