@misc{wildberger_adapting_2023,
	title = {Adapting to noise distribution shifts in flow-based gravitational-wave inference},
	shorttitle = {Adapting to noise distribution shifts},
	url = {https://doi.org/10.1103/PhysRevD.107.084046},
	doi = {10.1103/PhysRevD.107.084046},
	abstract = {Flow-based inference has recently emerged as a powerful tool for gravitational-wave parameter estimation, enabling fast and accurate posterior estimation. However, these models are typically trained on a fixed noise distribution, and their performance can degrade significantly when the noise properties of the detector change. In this work, we propose a method to adapt flow-based inference models to shifts in the noise distribution. We introduce a conditioning mechanism that allows the model to take the noise power spectral density as input, enabling it to generalize to different noise conditions. We demonstrate the effectiveness of our approach on simulated gravitational-wave signals, showing that it maintains high accuracy even when the noise distribution deviates from the training distribution.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {American Physical Society},
	author = {Wildberger, J. and Dax, M. and Green, S. R. and Gair, J. and Pürrer, M. and Macke, J. H. and Buonanno, A. and Schölkopf, B.},
	month = apr,
	year = {2023},
	keywords = {Computer science, Inference, Gravitational wave, Noise (video), Machine learning, Artificial intelligence, Physics, Astrophysics, PRD},
}
