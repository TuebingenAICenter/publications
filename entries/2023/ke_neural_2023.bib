@article{ke_neural_2023,
	title = {Neural {Causal} {Structure} {Discovery} from {Interventions}},
	shorttitle = {Neural {Causal} {Structure} {Discovery} from {Interventions}},
	url = {https://openreview.net/forum?id=rdHVPPVuXa},
	abstract = {Causal structure discovery is a fundamental problem in science. While observational data can only identify causal structures up to a Markov equivalence class, interventional data can often identify the full causal graph. In this work, we propose a novel framework for causal structure discovery from interventional data. Our approach leverages the power of neural networks to learn a mapping from interventional data to the underlying causal graph. We demonstrate that our method can recover the causal structure of complex systems from a small number of interventions, and that it is robust to noise and missing data. We also show that our method can be used to discover causal relationships in real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Transactions on Machine Learning Research},
	publisher = {Transactions on Machine Learning Research},
	author = {Ke, Nan Rosemary and Bilaniuk, Olexa and Goyal, Anirudh and Bauer, Stefan and Larochelle, Hugo and Schölkopf, Bernhard and Mozer, Michael C. and Pal, Christopher and Bengio, Yoshua},
	month = sep,
	year = {2023},
	keywords = {Computer science, Observational study, Identifiability, Machine learning, Bayesian network, Data mining, Artificial intelligence, Mathematics, TMLR},
}
