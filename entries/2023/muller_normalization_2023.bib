@misc{muller_normalization_2023,
	title = {Normalization {Layers} {Are} {All} {That} {Sharpness}-{Aware} {Minimization} {Needs}},
	shorttitle = {Normalization {Layers} {Are} {All} {That} {SAM} {Needs}},
	url = {https://arxiv.org/abs/2306.04226},
	doi = {10.48550/arxiv.2306.04226},
	abstract = {Sharpness-Aware Minimization (SAM) has been shown to improve generalization in deep learning by simultaneously minimizing loss value and loss sharpness. However, SAM is computationally expensive as it requires two forward and backward passes per parameter update. In this paper, we show that the performance gains of SAM are largely due to the normalization layers in the network. We propose SAM-ON (SAM with Only Normalization), a method that applies the sharpness-aware update only to the parameters of normalization layers. SAM-ON achieves performance comparable to SAM while reducing the computational overhead of the sharpness-aware update by orders of magnitude. We provide theoretical and empirical evidence that the sharpness of the loss landscape is primarily determined by the normalization layers, and that SAM-ON effectively captures this sharpness.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Müller, Maximilian and Vlaar, Tiffany J. and Rolnick, David and Hein, Matthias},
	year = {2023},
	keywords = {Normalization (sociology), Maxima and minima, Affine transformation, Computer science, Adversarial system, Minification, Algorithm, Artificial intelligence, Mathematics, Geometry, NEURIPS},
}
