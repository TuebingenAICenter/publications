@inproceedings{paulus_lpgd_2024,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {{LPGD}: {A} {General} {Framework} for {Backpropagation} through {Embedded} {Optimization} {Layers}},
	shorttitle = {{LPGD}},
	url = {https://proceedings.mlr.press/v235/paulus24a.html},
	doi = {10.48550/arxiv.2407.05920},
	abstract = {Differentiating through optimization layers is a key component of modern machine learning, enabling the integration of structured constraints and physical models into neural networks. Existing approaches often rely on implicit differentiation, which requires solving a linear system at each backward pass, or unrolling, which is memory-intensive. We propose Lagrangian Proximal Gradient Descent (LPGD), a general framework for backpropagation through embedded optimization layers. LPGD treats the optimization process as a sequence of proximal gradient steps and derives the gradient of the solution with respect to the parameters by differentiating through the proximal operator. This approach is memory-efficient, avoids solving linear systems, and is applicable to a wide range of optimization problems, including those with non-smooth objectives and constraints. We demonstrate the effectiveness of LPGD on several tasks, including constrained optimization, model predictive control, and bilevel optimization, showing that it achieves competitive performance with state-of-the-art methods while being more memory-efficient and easier to implement.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 41st {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Paulus, Anselm and Martius, Georg and Musil, Vít},
	editor = {Salakhutdinov, Ruslan and Kolter, Zico and Heller, Katherine and Weller, Adrian and Oliver, Nuria and Scarlett, Jonathan and Berkenkamp, Felix},
	month = jul,
	year = {2024},
	keywords = {Backpropagation, Computer science, Artificial intelligence, Artificial neural network, processed, University of Tübingen, MPI-IS, ICML},
}
