@misc{dhedin_diffusion-based_2024,
	title = {Diffusion-based learning of contact plans for agile locomotion},
	url = {https://ieeexplore.ieee.org/document/10769875},
	doi = {10.1109/Humanoids58906.2024.10769875},
	abstract = {Contact planning is a fundamental challenge in legged locomotion, requiring the selection of contact locations and timings that ensure stability and feasibility. Traditional methods often rely on simplified models or heuristic-based approaches, which can limit the agility of the robot. In this work, we propose a novel approach to contact planning using diffusion models. We learn a generative model that can sample diverse and feasible contact plans for a given task. Our method is able to generate contact plans that are consistent with the robot's dynamics and the environment, enabling agile locomotion in complex scenarios. We demonstrate the effectiveness of our approach on a quadruped robot, showing that it can generate contact plans that lead to successful locomotion in challenging environments.},
	language = {en},
	urldate = {2025-05-22},
	publisher = {IEEE},
	author = {Dh'Edin, V. and Ravi, A. K. C. and Jordana, A. and Zhu, H. and Meduri, A. and Righetti, L. and Schölkopf, B. and Khadiv, M.},
	month = nov,
	year = {2024},
	keywords = {Agile software development, Stepping stone, Computer science, Psychology, Economics, Software engineering, HUMANOIDS},
}
