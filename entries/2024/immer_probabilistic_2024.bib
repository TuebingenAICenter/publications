@article{immer_probabilistic_2024,
	title = {Probabilistic pathway-based multimodal factor analysis},
	shorttitle = {{PPMFA}},
	url = {https://academic.oup.com/bioinformatics/article/40/Supplement_1/i189/7700877},
	doi = {10.1093/bioinformatics/btae216},
	abstract = {Motivation: Multimodal data integration is essential for understanding complex biological systems. However, integrating diverse data types, such as transcriptomics and proteomics, remains challenging due to differences in data distribution, noise levels, and feature spaces. Existing methods often struggle to incorporate prior biological knowledge, leading to models that are difficult to interpret and prone to overfitting. Results: We introduce Probabilistic Pathway-based Multimodal Factor Analysis (PPMFA), a generative model that integrates multimodal data by leveraging pathway information. PPMFA decomposes the data into shared and modality-specific factors, where shared factors are constrained by biological pathways. This approach improves interpretability and predictive performance. We demonstrate the effectiveness of PPMFA on a multi-omics dataset from the Tumor Profiler Consortium, showing that it identifies biologically meaningful factors and outperforms existing methods in downstream tasks.},
	language = {en},
	journal = {Bioinformatics},
	publisher = {Oxford University Press},
	author = {Immer, Alexander and Stark, Sebastian G. and Jacob, Franziska and Bonilla, Ximena and Thomas, T. and Kahles, Andre and Goetze, Sandra and Milani, E. S. and Wollscheid, Bernd and Consortium, The Tumor Profiler and Rätsch, Gunnar and Lehmann, K.-V.},
	month = jul,
	year = {2024},
	keywords = {BIOINFORMATICS},
}
