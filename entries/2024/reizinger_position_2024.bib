	author = {Reizinger, P. and Ujváry, S. and Mészáros, A. and Kerekes, A. and Brendel, W. and Huszár, F.},
	editor = {Salakhutdinov, Ruslan and Kolter, Zico and Heller, Katherine and Weller, Adrian and Oliver, Nuria and Scarlett, Jonathan and Berkenkamp, Felix},
	month = jul,
	year = {2024},
	keywords = {Generalization, Econometrics, Mathematics, processed, MPI-IS, ELLIS Institute Tübingen, ICML},
}
