@inproceedings{reizinger_position_2024,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Position: {Understanding} {LLMs} {Requires} {More} {Than} {Statistical} {Generalization}},
	shorttitle = {Understanding {LLMs} {Requires} {More} {Than} {Statistical} {Generalization}},
	url = {https://proceedings.mlr.press/v235/reizinger24a.html},
	doi = {10.48550/arXiv.2405.01964},
	abstract = {Large Language Models (LLMs) are often described as statistical models of language, and their success is frequently attributed to their ability to generalize from the statistical patterns in their training data. In this position paper, we argue that this view is incomplete. We show that while statistical generalization is a necessary condition for language modeling, it is not sufficient for understanding the capabilities and limitations of LLMs. We propose a framework for understanding LLMs that goes beyond statistical generalization, incorporating elements of causal reasoning, world modeling, and objective-driven behavior. We discuss the implications of this framework for the development and evaluation of future LLMs.},
