@article{oncel_adaptation_2024,
	title = {Adaptation {Odyssey} in {LLMs}: {Why} {Does} {Additional} {Pretraining} {Sometimes} {Fail} to {Improve}?},
	shorttitle = {Adaptation {Odyssey} in {LLMs}},
	url = {https://bethgelab.org/publication/2024_11_oncel_yildiz/},
	doi = {10.18653/v1/2024.emnlp-main.1108},
	abstract = {Additional pretraining is a common practice to adapt Large Language Models (LLMs) to specific domains or tasks. However, the performance gains from this process are often inconsistent, and in some cases, additional pretraining can even lead to performance degradation. In this work, we investigate the factors that influence the success or failure of additional pretraining. We conduct a systematic study across various domains and model sizes, identifying key variables such as data quality, domain overlap, and training dynamics. Our findings provide insights into why additional pretraining sometimes fails to improve model performance and offer practical recommendations for practitioners to enhance the effectiveness of this adaptation strategy.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 2024 Conference on Empirical Methods in Natural Language Processing},
	publisher = {Association for Computational Linguistics},
	author = {Öncel, Fırat and Bethge, Matthias and Ermiş, Beyza and Ravanelli, Mirco and Subakan, Cem and Yıldız, Çağatay},
	year = {2024},
	keywords = {Adaptation (eye), Psychology, Cognitive psychology, Neuroscience, processed, University of Tübingen, EMNLP},
}
