@article{gonzalez-marquez_landscape_2024,
	title = {The landscape of biomedical research},
	copyright = {© 2024 The Author(s). Published by Elsevier Inc.},
	issn = {2666-3899},
	url = {https://www.cell.com/patterns/fulltext/S2666-3899(24)00076-X},
	doi = {10.1016/j.patter.2024.100968},
	abstract = {Biomedical research is a vast and rapidly evolving field. To understand its structure and dynamics, we analyzed 30 million papers from PubMed published between 1990 and 2022. We used a citation-based approach to map the landscape of biomedical research, identifying 1,200 research topics and their evolution over time. We found that the field is highly modular, with topics forming distinct clusters that correspond to biological systems, diseases, and methodologies. We also observed a trend toward increasing interdisciplinarity, with research topics becoming more connected over time. Our results provide a comprehensive overview of the biomedical research landscape and offer insights into the drivers of scientific progress.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Patterns},
	publisher = {Elsevier},
	author = {Gonz'alez-M'arquez, Rita and Schmidt, Luca and Schmidt, Benjamin M. and Berens, Philipp and Kobak, Dmitry},
	month = apr,
	year = {2024},
	keywords = {Biomedicine, Data science, Field (mathematics), Computer science, Atlas (anatomy), Coronavirus disease 2019 (COVID-19), Web of science, MEDLINE, Biology, Bioinformatics, Infectious disease (medical specialty), Medicine, processed, University of Tübingen, University of T'ubingen, PATTERNS},
}
