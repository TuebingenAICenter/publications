@article{bonse_use_2024,
	title = {Use the 4S ({Signal}-{Safe} {Speckle} {Subtraction}): {Explainable} {Machine} {Learning} reveals the {Giant} {Exoplanet} {AF} {Lep} b in {High}-{Contrast} {Imaging} {Data} from 2011},
	issn = {1538-3881},
	shorttitle = {Use the 4S},
	url = {https://arxiv.org/abs/2406.01809},
	doi = {10.3847/1538-3881/adab79},
	abstract = {High-contrast imaging (HCI) is a powerful technique for the direct detection of exoplanets. However, the sensitivity of HCI is limited by quasi-static speckles, which are diffraction artifacts that mimic the appearance of planets. To mitigate these, various post-processing algorithms have been developed, often relying on principal component analysis (PCA) or neural networks. While these methods are effective at removing speckles, they often suffer from over-subtraction, where the planetary signal is also attenuated or distorted. In this work, we introduce the Signal-Safe Speckle Subtraction (4S), a novel post-processing framework based on explainable machine learning. 4S is designed to identify and remove speckles while preserving the planetary signal. We demonstrate the effectiveness of 4S by re-analyzing archival VLT/NACO data of the AF Lep system from 2011. We show that 4S successfully recovers the giant exoplanet AF Lep b, which was previously undetected in this dataset. Our results highlight the potential of explainable machine learning to improve the sensitivity and reliability of HCI observations.},
	language = {en},
	urldate = {2025-05-14},
	journal = {The Astronomical Journal},
	publisher = {American Astronomical Society},
	author = {Bonse, M. J. and Gebhard, T. D. and Dannert, F. A. and Absil, O. and Cantalloube, F. and Christiaens, V. and Cugno, G. and Garvin, E. O. and Hayoz, J. and Kasper, M. and Matthews, E. and Schölkopf, B. and Quanz, S. P.},
	year = {2024},
	keywords = {Exoplanet, Planet, Speckle pattern, Speckle noise, Noise (video), Physics, SIGNAL (programming language), Contrast (vision), Stars, Artificial intelligence, Computer science, Remote sensing, Astronomy, Geology, processed, AJ},
}
