@inproceedings{basting_scale_2024,
	title = {Scale {Learning} in {Scale}-{Equivariant} {Convolutional} {Networks}},
	isbn = {978-989-758-679-8},
	shorttitle = {Scale {Learning} in {Scale}-{Equivariant} {CNNs}},
	url = {https://www.scitepress.org/Papers/2024/123798/123798.pdf},
	doi = {10.5220/0012379800003660},
	abstract = {Scale-equivariance is a desirable property for convolutional neural networks (CNNs) in computer vision tasks where the scale of objects varies. While scale-equivariant CNNs have been proposed, they often rely on a fixed set of scales or a predefined scale-space. In this paper, we propose a method to learn the scale-space representation directly from data. We introduce a scale-equivariant convolution layer that learns the optimal scale-space sampling, allowing the network to adapt to the scale distribution of the input data. We demonstrate the effectiveness of our approach on several benchmarks, showing that our learned scale-equivariant CNNs outperform fixed-scale counterparts and achieve competitive results with state-of-the-art methods.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 19th {International} {Joint} {Conference} on {Computer} {Vision}, {Imaging} and {Computer} {Graphics} {Theory} and {Applications}},
	publisher = {SCITEPRESS - Science and and Technology Publications},
	author = {Basting, Mark and Bruintjes, Robert-Jan and Wiedemer, Thaddäus and Kümmerer, Matthias and Bethge, Matthias and van Gemert, Jan},
	year = {2024},
	keywords = {Scale (ratio), Computer science, Artificial intelligence, Geography, Cartography, processed, University of Tübingen, VISAPP},
}
