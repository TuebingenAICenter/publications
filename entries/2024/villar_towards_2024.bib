@misc{villar_towards_2024,
	title = {Towards fully covariant machine learning},
	url = {https://openreview.net/forum?id=gllUnpYuXg},
	doi = {10.48550/arxiv.2301.13724},
	abstract = {We propose a framework for machine learning that is fully covariant with respect to the action of a group. In our framework, the input data, the output predictions, and the internal representations are all elements of vector spaces that carry representations of a group G. A model is then a G-equivariant map between these spaces. We show that this framework encompasses many existing approaches, such as convolutional neural networks and graph neural networks, and allows for the construction of new models that are covariant with respect to more general groups, such as the Lorentz group or the group of rigid motions. We also provide a general construction for such maps using the theory of group representations and the Peter-Weyl theorem.},
	language = {en},
	author = {Villar, Soledad and Hogg, David W. and Yao, Weichi and Kevrekidis, George A. and Schölkopf, Bernhard},
	month = jan,
	year = {2024},
	keywords = {Homogeneous space, Symmetry (geometry), Representation (politics), Covariant transformation, Computer science, Symmetry group, Artificial intelligence, Algebra over a field, Machine learning, Theoretical computer science, Theoretical physics, Mathematics, Pure mathematics, Physics, Quantum mechanics, Geometry, TMLR},
}
