@misc{hu_provable_2024,
	title = {Provable {Privacy} with {Non}-{Private} {Pre}-{Processing}},
	url = {https://proceedings.mlr.press/v235/hu24m.html},
	doi = {10.48550/arxiv.2403.13041},
	abstract = {Differential privacy (DP) is the gold standard for privacy-preserving data analysis. However, the utility of DP mechanisms often degrades significantly when the data is high-dimensional or complex. A common strategy to mitigate this is to perform non-private pre-processing on the data before applying a DP mechanism. While this approach is widely used in practice, its privacy implications are often poorly understood. In this work, we provide a theoretical framework to analyze the privacy guarantees of DP mechanisms when applied to non-privately pre-processed data. We show that if the pre-processing function satisfies certain stability properties, the composition of the pre-processing and the DP mechanism can still provide strong privacy guarantees. We demonstrate the utility of our framework by applying it to several common pre-processing techniques, including dimensionality reduction and feature selection, and show that it leads to improved privacy-utility trade-offs in practice.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Hu, Y. and Sanyal, A. and Schölkopf, B.},
	editor = {Salakhutdinov, Ruslan and Kolter, Zico and Heller, Katherine and Weller, Adrian and Oliver, Nuria and Scarlett, Jonathan and Berkenkamp, Felix},
	month = jul,
	year = {2024},
	keywords = {Computer science, Internet privacy, Computer security, Business, ICML},
}
