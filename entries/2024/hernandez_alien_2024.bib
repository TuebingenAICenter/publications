@misc{hernandez_alien_2024,
	title = {Alien {Recombination}: {Exploring} {Concept} {Blends} {Beyond} {Human} {Cognitive} {Availability} in {Visual} {Art}},
	shorttitle = {Alien {Recombination}},
	url = {https://arxiv.org/abs/2411.11494},
	doi = {10.48550/arxiv.2411.11494},
	abstract = {Conceptual blending is a fundamental cognitive process that allows humans to create new meanings by combining existing concepts. While human creativity is often constrained by cognitive biases and cultural availability, generative AI models offer the potential to explore a much larger space of concept combinations. In this work, we introduce 'Alien Recombination', a framework for exploring concept blends that lie beyond the scope of human cognitive availability. We leverage large-scale text-to-image models to generate visual art based on these 'alien' blends and evaluate them through a series of human-subject experiments. Our results demonstrate that AI-generated alien blends can elicit novel aesthetic experiences and challenge human conceptual boundaries, suggesting a new paradigm for human-AI collaborative creativity.},
	language = {en},
	urldate = {2025-05-22},
	author = {Hernández, Alejandro and Brinkmann, Levin and Serna, Ignacio and Rahaman, Nasim and Alhaija, Hassan Abu and Yakura, Hiromu and Solà, Mar Canet and Schölkopf, Bernhard and Rahwan, Iyad},
	month = dec,
	year = {2024},
	keywords = {Recombination, Alien, Cognition, Computer science, Cognitive science, Biology, Psychology, Neuroscience, Genetics, Political science, Politics, NEURIPS},
}
