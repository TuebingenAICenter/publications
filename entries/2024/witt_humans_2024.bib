@article{witt_humans_2024,
	title = {Humans flexibly integrate social information despite interindividual differences in reward},
	issn = {0027-8424},
	shorttitle = {Humans flexibly integrate social information},
	url = {https://doi.org/10.1073/pnas.2404928121},
	doi = {10.1073/pnas.2404928121},
	abstract = {Social learning is a cornerstone of human success, yet individuals vary significantly in how they weigh social information. While some individuals are highly conformist, others are more independent. Here, we investigate the computational mechanisms underlying these interindividual differences in social learning. We show that individuals flexibly integrate social information by dynamically adjusting their reliance on social cues based on the reliability of their own experience versus the social information. Using a large-scale online experiment (N = 1,000) and a computational model of social learning, we demonstrate that individuals who are more sensitive to reward uncertainty are also more likely to rely on social information. Our results suggest that social learning is not a fixed trait but a flexible strategy that is adaptively tuned to the environment and the individual's own learning history.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the National Academy of Sciences},
	publisher = {National Academy of Sciences},
	author = {Witt, Alexandra and Toyokawa, Wataru and Lala, Kevin N. and Gaissmaier, Wolfgang and Wu, Charley M.},
	year = {2024},
	keywords = {Psychology, Cognitive psychology, Data science, Knowledge management, Computer science, processed, University of Tübingen, Social Learning Stochastic game, PNAS},
}
