@misc{bizeul_probabilistic_2024,
	title = {A {Probabilistic} {Model} behind {Self}-{Supervised} {Learning}},
	url = {https://openreview.net/forum?id=QEwz7447tR},
	doi = {10.48550/arxiv.2402.01399},
	abstract = {Self-supervised learning (SSL) has achieved remarkable success in learning representations from unlabeled data. Despite this, a unified theoretical framework that explains the success of various SSL methods remains elusive. In this work, we propose a probabilistic model that underlies many popular SSL approaches. We show that these methods can be interpreted as performing maximum likelihood estimation of a latent variable model, where the latent variables are the representations. We demonstrate that our framework encompasses several prominent SSL algorithms, including contrastive learning and distillation-based methods. Furthermore, we provide theoretical insights into the role of data augmentation and the choice of architecture in SSL, and we validate our findings through empirical experiments.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Transactions on Machine Learning Research},
	author = {Bizeul, Alice and Schölkopf, Bernhard and Allen, Carl},
	month = oct,
	year = {2024},
	keywords = {Probabilistic logic, Representation (politics), Artificial intelligence, Computer science, Machine learning, Probabilistic relevance model, Self representation, Probabilistic analysis of algorithms, Political science, Politics, TMLR},
}
