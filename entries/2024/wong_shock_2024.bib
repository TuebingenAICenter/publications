@inproceedings{wong_shock_2024,
	title = {Shock to {Thrill}: {Linking} {Sensation} and {Information} {Seeking}},
	shorttitle = {Shock to {Thrill}},
	url = {https://charleywu.github.io/downloads/wong2024shock.pdf},
	doi = {10.31234/osf.io/xa6yk},
	abstract = {Why do people seek out negative information? While sensation seeking is often associated with thrill-seeking and risky behavior, its relationship with information seeking remains underexplored. We propose that sensation seeking is a domain-general trait that drives the pursuit of high-arousal information, even when that information is negative. Across two experiments (N=600), we show that sensation seekers are more likely to choose to view negative, high-arousal images (e.g., car crashes, violence) over neutral ones, and that this preference is mediated by the expected arousal of the information. Our findings suggest that sensation seeking is a key driver of the 'curiosity gap' for negative information, providing a novel framework for understanding why people engage with distressing content.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 46th {Annual} {Conference} of the {Cognitive} {Science} {Society}},
	publisher = {Cognitive Science Society},
	author = {Wong, Ern and Hauser, Tobias U. and Pietrini, Pietro and Wu, Charley M.},
	year = {2024},
	keywords = {Shock (circulatory), Sensation, Sensation seeking, Psychology, Negative information, Social psychology, Internet privacy, Cognitive psychology, Computer science, Medicine, Internal medicine, processed, University of Tübingen, Sensation Sensation Seeking Negative information, COGSCI},
}
