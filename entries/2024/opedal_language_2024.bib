@misc{opedal_language_2024,
	title = {Do {Language} {Models} {Exhibit} the {Same} {Cognitive} {Biases} in {Problem} {Solving} as {Human} {Learners}?},
	url = {https://proceedings.mlr.press/v235/opedal24a.html},
	doi = {10.48550/arxiv.2401.18070},
	abstract = {We investigate whether large language models (LLMs) exhibit the same cognitive biases as human learners when solving problems. We focus on the domain of causal induction, where humans are known to exhibit systematic biases, such as the tendency to over-rely on prior knowledge or to ignore base rates. We evaluate a range of LLMs on a suite of causal induction tasks and find that they exhibit many of the same biases as humans. However, we also find that the extent of these biases varies across models and that some models are more susceptible to certain biases than others. Our results suggest that LLMs can serve as useful models of human cognitive biases, but that they also exhibit unique patterns of behavior that warrant further investigation.},
	language = {en},
	publisher = {PMLR},
	author = {Opedal, A. and Stolfo, A. and Shirakami, H. and Jiao, Y. and Cotterell, R. and Schölkopf, B. and Saparov, A. and Sachan, M.},
	editor = {Salakhutdinov, Ruslan and Kolter, Zico and Heller, Katherine and Weller, Adrian and Oliver, Nuria and Scarlett, Jonathan and Berkenkamp, Felix},
	month = jul,
	year = {2024},
	keywords = {Cognition, Cognitive psychology, Psychology, Computer science, Cognitive science, Linguistics, Philosophy, Neuroscience, ICML},
}
