@inproceedings{gumbsch_learning_2024,
	series = {{ICLR} 2024},
	title = {Learning {Hierarchical} {World} {Models} with {Adaptive} {Temporal} {Abstractions} from {Discrete} {Latent} {Dynamics}},
	url = {https://openreview.net/forum?id=TjCDNssXKU},
	abstract = {World models are essential for intelligent agents to predict, plan, and reason. While hierarchical world models promise to capture long-term dependencies by operating at different temporal scales, they often struggle with the trade-off between temporal abstraction and predictive accuracy. We propose Thick World Models (TWM), a hierarchical world model that learns adaptive temporal abstractions from discrete latent dynamics. TWM employs a hierarchy of discrete latent spaces, where higher levels operate at slower temporal resolutions. We introduce a novel objective that encourages the model to learn temporal abstractions by predicting future states at multiple time scales simultaneously. Our experiments demonstrate that TWM outperforms state-of-the-art hierarchical world models on complex control tasks, showing improved sample efficiency and the ability to learn meaningful temporal abstractions.},
	language = {en},
	urldate = {2025-05-22},
	booktitle = {The {Twelfth} {International} {Conference} on {Learning} {Representations}},
	publisher = {OpenReview.net},
	author = {Gumbsch, Christian and Sajid, Noor and Martius, Georg and Butz, Martin V.},
	month = may,
	year = {2024},
	keywords = {processed, University of Tübingen, MPI-IS, ICLR},
}
