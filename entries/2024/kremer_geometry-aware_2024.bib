@misc{kremer_geometry-aware_2024,
	title = {Geometry-{Aware} {Instrumental} {Variable} {Regression}},
	url = {https://proceedings.mlr.press/v235/kremer24a.html},
	doi = {10.48550/arxiv.2405.11633},
	abstract = {Instrumental variable (IV) regression is a standard tool for causal inference in the presence of unobserved confounders. Most existing methods rely on linear assumptions or require strong parametric models. We propose a novel approach to IV regression that leverages the geometry of the data to learn the structural relationship between variables. By incorporating geometric constraints, our method is more robust to misspecification and performs well in high-dimensional settings. We provide theoretical guarantees for our estimator and demonstrate its effectiveness on synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Kremer, H. and Schölkopf, B.},
	month = jul,
	year = {2024},
	keywords = {Instrumental variable, Variable (mathematics), Regression, Regression analysis, Linear regression, Geometry, Computer science, Mathematics, Statistics, Econometrics, Mathematical analysis, ICML},
}
