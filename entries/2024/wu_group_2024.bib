@article{wu_group_2024,
	title = {Group coordination catalyzes individual and cultural intelligence},
	issn = {2470-2986},
	url = {https://doi.org/10.1162/opmi_a_00155},
	doi = {10.1162/opmi_a_00155},
	abstract = {How do groups become smarter than the individuals who compose them? While collective intelligence is often attributed to the aggregation of individual abilities, we propose that the process of coordination itself—the ability to align actions with others—is a fundamental driver of both individual and cultural intelligence. We test this hypothesis using a large-scale online experiment (N = 1,000) where participants played a collaborative game requiring coordination. We find that individuals who are better at coordinating with others also exhibit higher individual intelligence and are more effective at transmitting knowledge to others, thereby fostering cultural intelligence. Furthermore, we show that groups that coordinate more effectively achieve higher collective performance, even when controlling for individual ability. These results suggest that coordination is not merely a byproduct of intelligence, but a catalyst that enables the emergence of smarter groups and more sophisticated cultures.},
	language = {en},
	journal = {Open Mind},
	publisher = {MIT Press},
	author = {Wu, Charley M. and Dale, Rick and Hawkins, Robert D.},
	year = {2024},
	keywords = {Group (periodic table), Cultural intelligence, Psychology, Social psychology, Chemistry, processed, University of Tübingen, OPEN MIND},
}
