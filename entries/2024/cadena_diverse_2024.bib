@article{cadena_diverse_2024,
	title = {Diverse task-driven modeling of macaque {V4} reveals functional specialization towards semantic tasks},
	copyright = {CC BY 4.0},
	issn = {1553-7358},
	shorttitle = {Diverse task-driven modeling of macaque {V4}},
	url = {https://journals.plos.org/ploscompbiol/article?id=10.1371/journal.pcbi.1012056},
	doi = {10.1371/journal.pcbi.1012056},
	abstract = {The ventral visual stream is thought to be organized hierarchically, with neurons in higher areas representing increasingly complex features. However, the computational principles that give rise to these representations remain debated. A prominent hypothesis is that the visual system is optimized for object recognition. Yet, it is unclear whether this is the only, or even the primary, objective. Here, we test this hypothesis by comparing the ability of deep neural networks trained on a diverse set of 23 different tasks to predict the responses of neurons in macaque area V4. We find that models trained on tasks involving semantic information, such as object classification and scene recognition, are better at predicting V4 responses than models trained on low-level tasks. Furthermore, we show that V4 neurons are not a monolithic population but rather exhibit functional specialization: different neurons are better predicted by different tasks. Our results suggest that V4 representations are shaped by a variety of task demands, with a strong emphasis on semantic information, and that this functional specialization is a key feature of the ventral visual stream.},
	language = {en},
	urldate = {2025-05-14},
	journal = {PLoS Computational Biology},
	publisher = {Public Library of Science},
	author = {Cadena, Santiago A. and Willeke, Konstantin F. and Restivo, Kelli and Denfield, George H. and Sinz, Fabian H. and Bethge, Matthias and Tolias, Andreas S. and Ecker, Alexander S.},
	year = {2024},
	keywords = {Computer science, Macaque, Stimulus (psychology), Artificial intelligence, Task (project management), Semantic memory, Pattern recognition (psychology), Convolutional neural network, Cognitive psychology, Natural language processing, Cognition, Neuroscience, Psychology, processed, University of Tübingen, PLOSCB},
}
