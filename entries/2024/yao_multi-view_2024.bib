@inproceedings{yao_multi-view_2024,
	title = {Multi-{View} {Causal} {Representation} {Learning} with {Partial} {Observability}},
	shorttitle = {Multi-{View} {Causal} {Representation} {Learning} with {Partial} {Observability}},
	url = {https://arxiv.org/abs/2311.04056},
	doi = {10.48550/arxiv.2311.04056},
	abstract = {Causal representation learning aims to recover the underlying causal variables and their causal structure from high-dimensional observations. Existing methods typically assume that all causal variables are observed in the data. However, in many real-world scenarios, some causal variables are unobserved, leading to partial observability. In this paper, we study the identifiability of causal representations under partial observability using multi-view data. We show that, under certain conditions, the latent causal variables can be identified up to a component-wise transformation, even when some variables are not observed in any view. We propose a novel framework, Multi-View Causal Representation Learning (MVCRL), to learn these representations and demonstrate its effectiveness on synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {The {Twelfth} {International} {Conference} on {Learning} {Representations}},
	publisher = {OpenReview.net},
	author = {Yao, Dingling and Xu, Danru and Lachapelle, Sébastien and Magliacane, Sara and Taslakian, Perouz and Martius, Georg and von Kügelgen, Julius and Locatello, Francesco},
	year = {2024},
	keywords = {Identifiability, Observability, Bijection, Representation (politics), Simple (philosophy), Latent variable, Computer science, Feature learning, Set (abstract data type), Theoretical computer science, Tuple, Encoder, Artificial intelligence, Nonlinear system, Machine learning, Algorithm, Mathematics, Applied mathematics, Discrete mathematics, processed, University of Tübingen, MPI-IS, ICLR},
}
