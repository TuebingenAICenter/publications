@misc{yue_object_2024,
	title = {Object {Recognition} as {Next} {Token} {Prediction}},
	url = {https://jonasgeiping.github.io/publications/},
	doi = {10.48550/arxiv.2312.02142},
	abstract = {We propose a simple framework for object recognition that treats the task as a next-token prediction problem, similar to how large language models are trained. We represent images as sequences of discrete tokens and train a transformer to predict the next token in the sequence, conditioned on the image patches. This approach allows us to leverage the powerful capabilities of transformer architectures and the vast amount of data available for training language models. We show that our method achieves competitive performance on standard object recognition benchmarks, while being significantly simpler and more scalable than traditional approaches.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {IEEE},
	author = {Yue, Kaiyu and Chen, Bor-Chun and Geiping, Jonas and Li, Hengduo and Goldstein, Tom and Lim, Ser-Nam},
	year = {2024},
	keywords = {Computer science, Security token, Construct (python library), Rank (graph theory), Inference, Artificial intelligence, Code (set theory), Object (grammar), Masking (illustration), Process (computing), Pattern recognition (psychology), Prefix, Simple (philosophy), Sample (material), Language model, Natural language processing, Programming language, Mathematics, CVPR},
}
