@inproceedings{zhou_harmonizing_2024,
	title = {Harmonizing {Program} {Induction} with {Rate}-{Distortion} {Theory}},
	shorttitle = {Harmonizing {Program} {Induction}},
	url = {https://arxiv.org/abs/2405.05294},
	doi = {10.48550/arXiv.2405.05294},
	abstract = {Program induction aims to discover the underlying logic of data by searching for programs that explain observations. However, the search space of programs is often vast, and finding the optimal program is computationally intractable. We propose a framework that harmonizes program induction with rate-distortion theory, a branch of information theory that characterizes the trade-off between the rate (complexity) and distortion (error) of a representation. By treating program induction as a rate-distortion problem, we derive a principled objective function that balances the simplicity of a program with its ability to explain the data. We demonstrate that this framework provides a unified perspective on several existing program induction methods and enables the derivation of new, more efficient algorithms. We evaluate our approach on a range of program induction tasks, showing that it achieves state-of-the-art performance while offering theoretical guarantees on the trade-off between complexity and accuracy.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 46th {Annual} {Conference} of the {Cognitive} {Science} {Society}},
	publisher = {Cognitive Science Society},
	author = {Zhou, Hanqi and Nagy, Dávid and Wu, Charley M.},
	editor = {Frank, Stefan L. and Toneva, Mila and Mackey, Aidan and Hazeltine, Erika},
	year = {2024},
	keywords = {Distortion (music), Computer science, Econometrics, Mathematical economics, Economics, Telecommunications, processed, University of Tübingen, COGSCI},
}
