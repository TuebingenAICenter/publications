@inproceedings{press_citeme_2024,
	title = {{CiteME}: {Can} {Language} {Models} {Accurately} {Cite} {Scientific} {Claims}?},
	shorttitle = {{CiteME}},
	url = {https://bethgelab.org/publication/2024_12_press_hochlehnert/},
	doi = {10.48550/arxiv.2407.12861},
	abstract = {Large language models (LLMs) are increasingly used to assist in writing scientific papers. A critical requirement for scientific writing is the ability to provide accurate citations to support claims. However, LLMs are known to hallucinate, and it is unclear whether they can reliably cite scientific literature. We introduce CiteME, a benchmark for evaluating the citation accuracy of LLMs. CiteME consists of 1,000 scientific claims paired with their ground-truth source papers. We evaluate several state-of-the-art LLMs on their ability to retrieve the correct source paper for a given claim. We find that even the most capable models struggle to accurately cite scientific claims, often retrieving irrelevant or non-existent papers. Our results highlight the need for improved citation mechanisms in LLMs and suggest that CiteME can serve as a valuable tool for evaluating and improving these systems.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {Curran Associates, Inc.},
	author = {Press, Ori and Hochlehnert, Andreas and Prabhu, Ameya and Udandarao, Vishaal and Press, Ofir and Bethge, Matthias},
	year = {2024},
	keywords = {Computer science, Linguistics, Epistemology, Mathematical economics, Philosophy, Mathematics, processed, University of Tübingen, NEURIPS},
}
