@misc{ebmeier_fault_2024,
	title = {Fault {Detection} in {Solar} {Thermal} {Systems} {Using} {Probabilistic} {Reconstructions}},
	url = {https://meetingorganizer.copernicus.org/EGU24/EGU24-17521.html},
	doi = {10.5194/egusphere-egu24-17521},
	abstract = {Solar thermal systems are essential for the transition to sustainable heating. However, their performance is often degraded by faults that remain undetected for long periods, leading to significant energy losses. We propose a novel approach for fault detection in solar thermal systems based on probabilistic reconstructions. Our method uses a deep generative model to learn the normal operating behavior of the system. By reconstructing the input data, the model provides a probabilistic measure of the reconstruction error, which serves as an anomaly score. We evaluate our approach on a real-world dataset from a solar thermal plant and demonstrate that it outperforms baseline methods in detecting various types of faults.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Copernicus Publications},
	author = {Ebmeier, Florian and Ludwig, Nicole and Thümmel, Jannik and Martius, Georg and Franz, Volker H.},
	year = {2024},
	keywords = {Anomaly detection, Probabilistic logic, Fault detection and isolation, Overhead (engineering), Deep learning, Fault (geology), Simple (philosophy), Reduction (mathematics), EGU},
}
