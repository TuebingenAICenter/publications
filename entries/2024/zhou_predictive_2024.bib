@inproceedings{zhou_predictive_2024,
	title = {Predictive, scalable and interpretable knowledge tracing on structured domains},
	shorttitle = {{PSI}-{KT}},
	url = {https://openreview.net/forum?id=NgaLU2fP5D},
	doi = {10.48550/arXiv.2403.13179},
	abstract = {Knowledge tracing (KT) aims to model a student's evolving knowledge state over time to predict their future performance. While recent deep learning models have achieved high predictive accuracy, they often function as black boxes and struggle to scale to the complex, structured domains found in real-world educational settings. We introduce PSI-KT, a framework for Predictive, Scalable, and Interpretable Knowledge Tracing on structured domains. PSI-KT leverages a hierarchical Bayesian approach to model knowledge as a latent state on a directed acyclic graph (DAG) of skills, capturing prerequisite relationships. By combining the predictive power of deep learning with the interpretability of structured probabilistic models, PSI-KT provides a transparent view of student learning trajectories. We demonstrate that PSI-KT achieves state-of-the-art predictive performance while remaining computationally efficient and providing meaningful insights into the structure of knowledge acquisition.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {The {Twelfth} {International} {Conference} on {Learning} {Representations}},
	publisher = {OpenReview.net},
	author = {Zhou, Hanqi and Bamler, Robert and Wu, Charley M. and Tejero-Cantero, Álvaro},
	year = {2024},
	keywords = {Tracing, Computer science, Scalability, Artificial intelligence, Data science, Machine learning, Programming language, Database, processed, University of Tübingen, ICLR},
}
