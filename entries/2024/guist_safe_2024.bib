@misc{guist_safe_2024,
	title = {Safe \& {Accurate} at {Speed} with {Tendons}: {A} {Robot} {Arm} for {Exploring} {Dynamic} {Motion}},
	shorttitle = {Safe \& {Accurate} at {Speed} with {Tendons}},
	url = {https://www.roboticsproceedings.org/rss20/p099.html},
	doi = {10.15607/RSS.2024.XX.099},
	abstract = {High-speed robotic manipulation requires robots that are both fast and safe. While traditional rigid robots are often heavy and potentially dangerous, tendon-driven robots offer a promising alternative due to their low moving mass and inherent compliance. However, controlling these systems is challenging due to complex, non-linear dynamics and the unilateral nature of tendon actuation. In this paper, we present a novel tendon-driven robot arm designed for high-speed dynamic motion. We propose a control framework that combines a learned model of the robot's dynamics with a model-predictive control scheme to achieve accurate tracking at high speeds. We demonstrate the effectiveness of our approach through extensive experiments, showing that our robot can perform dynamic tasks with high precision while maintaining safety through its compliant design.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Robotics: Science and Systems Foundation},
	author = {Guist, Simon and Schneider, Jan and Ma, Hao and Chen, Le and Berenz, Vincent and Martus, Julian and Ott, Heiko and Grüninger, Felix and Muehlebach, Michael and Fiene, Jonathan and Schölkopf, Bernhard and Büchler, Dieter},
	month = jul,
	year = {2024},
	keywords = {Robot, Computer science, Robotic arm, Inertia, Robotics, Simulation, Task (project management), Artificial intelligence, Engineering, Control engineering, RSS},
}
