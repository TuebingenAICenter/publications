@article{vetter_neonatal_2024,
	title = {Neonatal apnea and hypopnea prediction in infants with {Robin} sequence with neural additive models for time series},
	copyright = {CC BY 4.0},
	issn = {2767-3170},
	shorttitle = {Neonatal apnea and hypopnea prediction in infants with {Robin} sequence},
	url = {https://journals.plos.org/digitalhealth/article?id=10.1371/journal.pdig.0000678},
	doi = {10.1371/journal.pdig.0000678},
	abstract = {Background: Infants with Robin sequence (RS) are at high risk of obstructive sleep apnea (OSA). Early detection of apnea and hypopnea events could facilitate timely intervention. Methods: We developed a machine learning model to predict apnea and hypopnea events in infants with RS using continuous pulse oximetry and heart rate data. We employed Neural Additive Models (NAMs) for time series, which combine the interpretability of generalized additive models with the predictive power of deep neural networks. We evaluated the model on a dataset of 24 infants with RS. Results: The model achieved an area under the precision-recall curve (AUPRC) of 0.68 for predicting apnea and hypopnea events. The NAMs provided interpretable insights into the contribution of different physiological features to the predictions. Conclusions: Our findings suggest that NAMs are a promising approach for predicting apnea and hypopnea in infants with RS, offering a balance between predictive performance and interpretability.},
	language = {en},
	urldate = {2025-05-22},
	journal = {PLOS Digital Health},
	publisher = {Public Library of Science},
	author = {Vetter, Julius and Lim, Kathleen and Dijkstra, Tjeerd M. H. and Dargaville, Peter A. and Kohlbacher, Oliver and Macke, Jakob H. and Poets, Christian F.},
	year = {2024},
	keywords = {Discriminative model, Apnea, Machine learning, Medicine, Hypopnea, Computer science, Artificial intelligence, Polysomnography, Modalities, Anesthesia, processed, University of Tübingen, MPI-IS, Discriminative model Hypopnea Modalities, University of T'ubingen, PLOSDIGITALHEALTH},
}
