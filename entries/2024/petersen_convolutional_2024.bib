@article{petersen_convolutional_2024,
	title = {Convolutional {Differentiable} {Logic} {Gate} {Networks}},
	shorttitle = {{CDLGNs}},
	url = {https://nips.cc/virtual/2024/poster/96650},
	abstract = {We introduce Convolutional Differentiable Logic Gate Networks (CDLGNs), a novel class of neural networks that replace standard convolutional layers with learnable logic gate circuits. By representing logic gates as differentiable functions, we enable end-to-end training of hardware-efficient, interpretable, and sparse models. CDLGNs achieve competitive performance on image classification tasks while requiring significantly fewer parameters and operations than traditional CNNs, making them particularly suitable for resource-constrained environments.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Advances in Neural Information Processing Systems},
	publisher = {Curran Associates, Inc.},
	author = {Petersen, Felix and Kuehne, Hilde and Borgelt, Christian and Welzel, Julian and Ermon, Stefano},
	year = {2024},
	keywords = {NEURIPS},
}
