@misc{misra_low-shot_2024,
	title = {On the low-shot transferability of [{V}]-{Mamba}},
	shorttitle = {On the low-shot transferability of [{V}]-{Mamba}},
	url = {https://arxiv.org/pdf/2403.10696.pdf},
	doi = {10.48550/arxiv.2403.10696},
	abstract = {State Space Models (SSMs) like Mamba have recently emerged as a promising alternative to Transformers for sequence modeling. While their performance on large-scale pre-training is well-documented, their behavior in low-data regimes remains under-explored. In this work, we investigate the low-shot transferability of Vision Mamba ([V]-Mamba) models. We find that [V]-Mamba exhibits competitive performance compared to Vision Transformers (ViT) in low-shot settings, while offering computational advantages. We provide empirical evidence across multiple datasets and analyze the factors contributing to this transferability.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Misra, Diganta and Gala, Jay and Orvieto, Antonio},
	year = {2024},
	keywords = {Transferability, Shot (pellet), Mathematics, Statistics, Chemistry, CVPR},
}
