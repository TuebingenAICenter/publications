@inproceedings{mendler-dunner_engine_2024,
	title = {An engine not a camera: {Measuring} performative power of online search},
	shorttitle = {An engine not a camera},
	url = {https://arxiv.org/abs/2405.19073},
	doi = {10.52202/079017-1891},
	abstract = {Online search engines are often viewed as passive observers of human information needs. We challenge this view by arguing that search engines are performative: they do not merely reflect existing information needs, but actively shape them. We introduce a framework to measure the performative power of online search, which we define as the extent to which a search engine's ranking policy influences the distribution of user queries. We operationalize this framework by analyzing a large-scale dataset of search logs and show that search engines exert significant performative power, with ranking policies having a measurable impact on the evolution of user interests over time. Our findings suggest that the design of search algorithms has profound implications for the information ecosystem and that performativity should be a central consideration in the evaluation and regulation of search systems.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {Curran Associates, Inc.},
	author = {Mendler-Dünner, Celestine and Carovano, Gabriele and Hardt, Moritz},
	year = {2024},
	keywords = {Performative utterance, Power (physics), Key (lock), Relation (database), processed, MPI-IS, ELLIS Institute Tübingen, NEURIPS},
}
