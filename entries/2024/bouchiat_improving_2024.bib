@inproceedings{bouchiat_improving_2024,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Improving {Neural} {Additive} {Models} with {Bayesian} {Principles}},
	shorttitle = {Improving {Neural} {Additive} {Models} with {Bayesian} {Principles}},
	url = {https://proceedings.mlr.press/v235/bouchiat24a.html},
	abstract = {Neural Additive Models (NAMs) are a class of interpretable models that combine the flexibility of neural networks with the interpretability of generalized additive models. However, they often lack uncertainty quantification and can be prone to overfitting. In this work, we propose a Bayesian approach to training NAMs, which allows for better uncertainty estimation and improved robustness. We introduce a novel prior over the shape functions of the NAM, which encourages smoothness and sparsity. We show that our Bayesian NAMs achieve competitive performance on a range of regression and classification tasks while providing well-calibrated uncertainty estimates.},
	language = {en},
	booktitle = {Proceedings of the 41st {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Bouchiat, K. and Immer, A. and Yèche, H. and Rätsch, G. and Fortuin, V.},
	editor = {Salakhutdinov, Ruslan and Kolter, Zico and Heller, Katherine and Weller, Adrian and Oliver, Nuria and Scarlett, Jonathan and Berkenkamp, Felix},
	month = jul,
	year = {2024},
	keywords = {ICML},
}
