@article{kabadayi_gan-avatar_2024,
	title = {{GAN}-{Avatar}: {Controllable} {Personalized} {GAN}-based {Human} {Head} {Avatar}},
	shorttitle = {{GAN}-{Avatar}},
	url = {https://arxiv.org/abs/2311.13655},
	doi = {10.1109/3dv62453.2024.00058},
	abstract = {We present GAN-Avatar, a novel approach for creating a personalized, controllable, and high-fidelity 3D human head avatar from a monocular video. Our method leverages a pre-trained 3D-aware generative model to learn a personalized avatar that can be animated with novel expressions. To achieve this, we propose a novel optimization strategy that adapts the generative model to the specific identity of the subject in the video. We introduce a latent space optimization that allows for precise control over facial expressions while maintaining the identity and appearance of the subject. Our method produces high-quality, temporally consistent results and outperforms existing state-of-the-art methods in terms of visual quality and controllability.},
	language = {en},
	urldate = {2025-05-14},
	journal = {International Conference on 3D Vision (3DV)},
	publisher = {IEEE},
	author = {Kabadayi, Berna and Zielonka, Wojciech and Bhatnagar, Bharat Lal and Pons-Moll, Gerard and Thies, Justus},
	year = {2024},
	keywords = {Computer science, Facial expression, Leverage (statistics), Artificial intelligence, Computer vision, Avatar, Active appearance model, Generative model, Expression (computer science), Computer facial animation, Usability, Animation, Generative grammar, Human–computer interaction, Computer graphics (images), Computer animation, Image (mathematics), processed, University of Tübingen, MPI-IS, 3DV},
}
