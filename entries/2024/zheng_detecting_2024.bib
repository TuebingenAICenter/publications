@misc{zheng_detecting_2024,
	title = {Detecting and {Identifying} {Selection} {Structure} in {Sequential} {Data}},
	url = {https://proceedings.mlr.press/v235/zheng24k.html},
	doi = {10.48550/arxiv.2407.00529},
	abstract = {Selection bias is a pervasive issue in causal inference and machine learning, often leading to spurious correlations and biased estimates. While existing methods for detecting selection bias primarily focus on static data, many real-world datasets are sequential. In this paper, we investigate the problem of detecting and identifying selection structure in sequential data. We first define the selection structure in a sequential setting, which characterizes how the selection mechanism depends on the observed variables and the underlying causal process. We then propose a novel framework to detect the presence of selection bias and identify the selection structure by leveraging the conditional independence properties of the observed data. We provide theoretical guarantees for the identifiability of the selection structure under certain conditions. Finally, we demonstrate the effectiveness of our proposed method through extensive experiments on both synthetic and real-world datasets.},
	language = {en},
	publisher = {PMLR},
	author = {Zheng, Y. and Tang, Z. and Qiu, Y. and Schölkopf, B. and Zhang, K.},
	editor = {Salakhutdinov, Ruslan and Kolter, Zico and Heller, Katherine and Weller, Adrian and Oliver, Nuria and Scarlett, Jonathan and Berkenkamp, Felix},
	month = jul,
	year = {2024},
	keywords = {Selection (genetic algorithm), Computer science, Artificial intelligence, Data mining, ICML},
}
