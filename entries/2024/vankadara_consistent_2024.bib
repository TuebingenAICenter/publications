@article{vankadara_consistent_2024,
	title = {A consistent estimator for confounding strength},
	issn = {2644-2353},
	url = {https://doi.org/10.4171/msl/47},
	doi = {10.4171/msl/47},
	abstract = {In causal inference, confounding is a major obstacle to identifying causal effects from observational data. While many methods exist to adjust for confounding, they often rely on the assumption of no unobserved confounding. In this paper, we propose a new estimator for the strength of unobserved confounding. Our estimator is based on the idea of comparing the observed association between treatment and outcome with the association that would be expected if there were no unobserved confounding. We prove that our estimator is consistent under mild conditions and demonstrate its performance on synthetic and real-world data. Our results show that the estimator is robust to various forms of confounding and provides a reliable measure of confounding strength.},
	language = {en},
	urldate = {2025-05-31},
	journal = {Mathematical Statistics and Learning},
	publisher = {European Mathematical Society},
	author = {Vankadara, Leena Chennuru and Rendsburg, Luca and von Luxburg, Ulrike and Ghoshdastidar, Debarghya},
	year = {2024},
	keywords = {Confounding, Estimator, Statistics, Econometrics, Mathematics, processed, University of Tübingen},
}
