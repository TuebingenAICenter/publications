@article{deffner_collective_2024,
	title = {Collective incentives reduce over-exploitation of social information in unconstrained human groups},
	copyright = {© The Author(s) 2024},
	issn = {2041-1723},
	shorttitle = {Collective incentives reduce over-exploitation},
	url = {https://www.nature.com/articles/s41467-024-47010-3},
	doi = {10.1038/s41467-024-47010-3},
	abstract = {Social information can improve decision-making, but it can also lead to maladaptive herding. While collective incentives are often proposed as a solution to align individual and group interests, their effectiveness in unconstrained, dynamic environments remains poorly understood. Here, we use a virtual foraging task to show that collective incentives reduce the over-exploitation of social information in human groups. We find that individuals under collective incentives are more likely to explore their environment independently, leading to higher group performance. Our results suggest that collective incentives can promote more efficient information use by mitigating the negative effects of social influence.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Nature Communications},
	publisher = {Nature Portfolio},
	author = {Deffner, Dominik and Mezey, David and Kahl, Benjamin and Schakowski, Alexander and Romanczuk, Pawel and Wu, Charley M. and Kurvers, Ralf H. J. M.},
	year = {2024},
	keywords = {Relocation, Group decision-making, Incentive, Computer science, Collective behavior, Cognitive psychology, Social relation, Cognition, Social decision making, Social group, Adaptation (eye), Psychology, Social psychology, Microeconomics, Economics, Sociology, processed, University of Tübingen, Relocation Group Decision Making Collective Behavior, NATCOMM},
}
