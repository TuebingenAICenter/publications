@inproceedings{mayilvahanan_search_2024,
	title = {In {Search} of {Forgotten} {Domain} {Generalization}},
	shorttitle = {In {Search} of {Forgotten} {Domain} {Generalization}},
	url = {https://arxiv.org/abs/2410.08258},
	doi = {10.48550/arxiv.2410.08258},
	abstract = {Domain generalization (DG) aims to learn models that perform well on unseen target domains. While the field has seen a surge in interest, we observe that the performance of many recent DG methods is often evaluated on a limited set of benchmarks, potentially leading to overfitting to these specific datasets. In this work, we revisit the problem of domain generalization and argue that the current evaluation paradigm is insufficient. We propose a new evaluation framework that considers a wider range of domains and tasks, and we show that many state-of-the-art DG methods do not generalize as well as previously reported. We further identify a set of 'forgotten' domains that are particularly challenging for current models and suggest that future research should focus on these domains to make progress in domain generalization.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the {International} {Conference} on {Learning} {Representations} ({ICLR}) 2025},
	publisher = {arXiv},
	author = {Mayilvahanan, Prasanna and Zimmermann, Roland S and Wiedemer, Thaddäus and Rusak, Evgenia and Juhos, Attila and Bethge, Matthias and Brendel, Wieland},
	year = {2024},
	keywords = {Generalization, Domain (mathematical analysis), Computer science, Artificial intelligence, Mathematics, Epistemology, Philosophy, processed, University of Tübingen, MPI-IS, ELLIS Institute Tübingen, ICLR},
}
