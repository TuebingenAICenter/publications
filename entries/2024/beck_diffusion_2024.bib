@inproceedings{beck_diffusion_2024,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Diffusion {Tempering} {Improves} {Parameter} {Estimation} with {Probabilistic} {Integrators} for {ODEs}},
	shorttitle = {Diffusion {Tempering} {Improves} {Parameter} {Estimation} with {Probabilistic} {Integrators} for {ODEs}},
	url = {https://proceedings.mlr.press/v235/beck24a.html},
	doi = {10.48550/arxiv.2402.12231},
	abstract = {Probabilistic numerical methods for ordinary differential equations (ODEs) provide a principled way to quantify uncertainty arising from numerical discretization. When used for parameter estimation in ODE-based models, they allow for a joint treatment of measurement noise and discretization error. However, the resulting posterior distributions are often highly non-convex and multimodal, making standard inference techniques like Markov chain Monte Carlo (MCMC) prone to getting stuck in local optima. We propose diffusion tempering, a novel sampling strategy that combines tempering with a diffusion-based transition kernel to improve exploration of the posterior. We demonstrate that diffusion tempering significantly improves the performance of probabilistic integrators for parameter estimation on a range of challenging ODE models, including systems with chaotic dynamics and high-dimensional parameter spaces.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 41st {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Beck, J. and Bosch, N. and Deistler, M. and Kadhim, K. L. and Macke, J. H. and Hennig, P. and Berens, P.},
	month = jul,
	year = {2024},
	keywords = {Ordinary differential equation, Probabilistic logic, Tempering, Diffusion, Estimation, Applied mathematics, Mathematics, Integrator, Differential equation, Mathematical analysis, Computer science, Physics, Statistics, Materials science, Economics, Thermodynamics, processed, University of Tübingen, MPI-IS, ICML},
}
