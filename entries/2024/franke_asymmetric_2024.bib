@misc{franke_asymmetric_2024,
	title = {Asymmetric distribution of color-opponent response types across mouse visual cortex supports superior color vision in the sky},
	copyright = {CC BY 4.0},
	shorttitle = {Asymmetric distribution of color-opponent response types},
	url = {https://doi.org/10.7554/eLife.89996},
	doi = {10.7554/eLife.89996},
	abstract = {Mice are dichromats, possessing M- and S-opsins. While it is known that their retina contains color-opponent ganglion cells, it remains unclear how this information is processed in the visual cortex. Here, we show that the mouse visual cortex contains a diverse population of color-opponent neurons. We find that these neurons are not uniformly distributed across the visual field. Instead, they are asymmetrically distributed, with a higher density of S-cone-dominated color-opponent neurons in the dorsal visual field, which corresponds to the sky. This distribution is well-suited for detecting aerial predators against the sky. Our results suggest that the mouse visual system is adapted to the statistics of its natural environment, supporting the idea that color vision is optimized for ethologically relevant tasks.},
	language = {en},
	type = {{journalArticle}},
	urldate = {2025-05-14},
	publisher = {eLife Sciences Publications, Ltd},
	author = {Franke, Katrin and Cai, Chenchen and Ponder, Kayla and Fu, Jiakun and Sokoloski, Sacha and Berens, Philipp and Tolias, Andreas S.},
	month = sep,
	year = {2024},
	keywords = {Sky, Visual cortex, Artificial intelligence, Computer vision, Computer science, Psychology, Neuroscience, Physics, Astrophysics},
}
