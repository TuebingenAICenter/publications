@article{grote_paradigm_2024,
	title = {A paradigm shift?—{On} the ethics of medical large language models},
	issn = {0269-9702},
	shorttitle = {A paradigm shift?},
	url = {https://doi.org/10.1111/bioe.13283},
	doi = {10.1111/bioe.13283},
	abstract = {Large language models (LLMs) are increasingly being integrated into medical practice. While their potential to improve efficiency and patient outcomes is significant, they also raise profound ethical questions. In this paper, we argue that the integration of LLMs into medicine represents a paradigm shift in medical ethics. We identify three key areas where this shift is particularly evident: the nature of medical knowledge, the role of the physician, and the relationship between physician and patient. We argue that these shifts require a new ethical framework that moves beyond traditional principles of medical ethics and incorporates insights from engineering ethics, epistemology, and political science. We conclude by outlining the key components of such a framework.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Bioethics},
	publisher = {Wiley},
	author = {Grote, Thomas and Berens, Philipp},
	month = mar,
	year = {2024},
	keywords = {Paradigm shift, Autonomy, Transparency (behavior), Medical ethics, Engineering ethics, Computer science, Psychology, Political science, Epistemology, Law, Computer security, Psychiatry, processed, University of Tübingen},
}
