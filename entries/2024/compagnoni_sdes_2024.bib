@inproceedings{compagnoni_sdes_2024,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {{SDEs} for {Minimax} {Optimization}},
	url = {https://proceedings.mlr.press/v238/monzio-compagnoni24a.html},
	doi = {10.48550/arxiv.2402.12508},
	abstract = {We study the convergence of continuous-time stochastic processes for solving minimax optimization problems. Specifically, we analyze the long-term behavior of a class of stochastic differential equations (SDEs) that generalize the gradient descent-ascent (GDA) dynamics. We show that, under suitable conditions, these SDEs converge to the set of stationary points of the minimax objective. We further provide a discretization analysis, showing that the discrete-time counterparts of these SDEs, which include several popular minimax optimization algorithms as special cases, inherit the convergence properties of the continuous-time processes. Our results provide a unified framework for analyzing the convergence of a wide range of minimax optimization algorithms and suggest new, more efficient algorithms.},
	booktitle = {Proceedings of the 27th {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Compagnoni, Enea Monzio and Orvieto, Antonio and Kersting, Hans and Proske, Frank and Lucchi, Aurélien},
	year = {2024},
	keywords = {Minimax, Mathematical optimization, Mathematical economics, Computer science, Economics, Mathematics, processed, MPI-IS, ELLIS Institute Tübingen, AISTATS},
}
