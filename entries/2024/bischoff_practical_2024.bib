@article{bischoff_practical_2024,
	title = {A {Practical} {Guide} to {Sample}-based {Statistical} {Distances} for {Evaluating} {Generative} {Models} in {Science}},
	shorttitle = {A {Practical} {Guide} to {Sample}-based {Statistical} {Distances}},
	url = {https://arxiv.org/abs/2403.12636},
	doi = {10.48550/arxiv.2403.12636},
	abstract = {Generative models are increasingly used in the sciences to model complex data distributions. Evaluating these models requires comparing the distribution of generated samples to the distribution of ground-truth data. While many statistical distances exist, choosing the right one for a specific scientific application is often difficult. In this paper, we provide a practical guide to sample-based statistical distances for evaluating generative models. We review common distances, discuss their properties, and provide recommendations for their use in scientific applications. We also provide a software library that implements these distances and facilitates their use in practice.},
	language = {en},
	journal = {Transactions on Machine Learning Research},
	publisher = {Transactions on Machine Learning Research},
	author = {Bischoff, S. and Darcher, A. and Deistler, M. and Gao, R. and Gerken, F. and Gloeckler, M. and Haxel, L. and Macke, J. H.},
	year = {2024},
	keywords = {Generative grammar, Computer science, Data science, Management science, Artificial intelligence, Engineering, processed, University of Tübingen, TMLR},
}
