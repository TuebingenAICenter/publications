@misc{yldz_investigating_2024,
	title = {Investigating {Continual} {Pretraining} in {Large} {Language} {Models}: {Insights} and {Implications}},
	shorttitle = {Investigating {Continual} {Pretraining} in {LLMs}},
	url = {https://bethgelab.org/publication/2024_02_yildiz/},
	doi = {10.48550/arxiv.2402.17400},
	abstract = {Continual pretraining is a common practice to adapt Large Language Models (LLMs) to new domains or languages. Despite its widespread use, the dynamics of continual pretraining remain poorly understood. In this work, we conduct a systematic investigation into the effects of continual pretraining on LLMs. We find that continual pretraining can lead to significant performance degradation on the original pretraining tasks, a phenomenon known as catastrophic forgetting. We also observe that the extent of forgetting is influenced by the similarity between the original and new data, as well as the size of the new data. Furthermore, we show that continual pretraining can lead to a shift in the model's internal representations, which may not always be beneficial for the new tasks. Finally, we discuss the implications of our findings for the design of continual pretraining strategies and suggest directions for future research.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Yıldız, Çağatay and Ravichandran, Nishaanth Kanna and Bethge, Matthias and Ermiş, Beyza},
	year = {2024},
	keywords = {Psychology, Computer science, Cognitive psychology, Linguistics, Natural language processing, Cognitive science, Philosophy},
}
