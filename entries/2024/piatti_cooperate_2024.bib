@inproceedings{piatti_cooperate_2024,
	title = {Cooperate or {Collapse}: {Emergence} of {Sustainability} in a {Society} of {LLM} {Agents}},
	shorttitle = {Cooperate or {Collapse}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2024/file/ca9567d8ef6b2ea2da0d7eed57b933ee-Paper-Conference.pdf},
	doi = {10.48550/arxiv.2404.16698},
	abstract = {The emergence of cooperation is a fundamental problem in evolutionary biology, economics, and political science. While previous work has studied cooperation in simple agents, the recent advent of Large Language Models (LLMs) allows for the study of cooperation in agents with complex reasoning and communication capabilities. In this paper, we introduce a new framework to study the emergence of sustainability in a society of LLM agents. We find that LLM agents can learn to cooperate and sustain a shared resource, but this emergence is fragile and depends on the agents' ability to communicate and their social structure. We further show that the emergence of cooperation is not guaranteed and can collapse under certain conditions, such as when agents are too selfish or when the environment is too harsh. Our results provide new insights into the conditions that foster or hinder the emergence of sustainable cooperation in societies of intelligent agents.},
	language = {en},
	urldate = {2025-05-22},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 37},
	publisher = {Curran Associates, Inc.},
	author = {Piatti, Giorgio and Jin, Zhijing and Kleiman-Weiner, Max and Schölkopf, Bernhard and Sachan, Mrinmaya and Mihalcea, Rada},
	editor = {Globerson, A. and Mackey, L. and Belgrave, D. and Fan, A. and Paquet, U. and Tomczak, J. and Zhang, C.},
	month = dec,
	year = {2024},
	keywords = {Sustainability, Political science, Ecology, Biology, processed, MPI-IS, NEURIPS},
}
