@inproceedings{kortukov_studying_2024-1,
	title = {Studying {Large} {Language} {Model} {Behaviors} {Under} {Realistic} {Knowledge} {Conflicts}},
	shorttitle = {Studying {Large} {Language} {Model} {Behaviors} {Under} {Realistic} {Knowledge} {Conflicts}},
	url = {https://arxiv.org/abs/2404.16032},
	doi = {10.48550/arXiv.2404.16032},
	abstract = {Large Language Models (LLMs) are increasingly used as knowledge bases. However, they are prone to hallucinations and can contain outdated or incorrect information. A critical challenge is how LLMs handle knowledge conflicts, where the model's internal knowledge contradicts information provided in the prompt. Existing benchmarks for knowledge conflicts often rely on synthetic, artificial scenarios that do not reflect real-world complexities. In this work, we introduce a new benchmark, Realistic Knowledge Conflicts (RKC), which consists of real-world knowledge conflicts curated from Wikipedia and news sources. We evaluate several state-of-the-art LLMs on RKC and find that they struggle to consistently prioritize the provided context over their internal knowledge. We further analyze the factors influencing model behavior, such as the source of the conflicting information and the model's confidence. Our findings suggest that current LLMs lack robust mechanisms for handling knowledge conflicts, highlighting the need for more research in this area.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Proceedings of the {First} {Conference} on {Language} {Modeling}},
	publisher = {arXiv},
	author = {Kortukov, Evgenii and Rubinstein, Alexander and Nguyen, Elisa and Oh, Seong Joon},
	year = {2024},
	keywords = {COLM},
}
