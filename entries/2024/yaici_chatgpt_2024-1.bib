@article{yaici_chatgpt_2024-1,
	title = {{ChatGPT} und die deutsche {Facharztprüfung} für {Augenheilkunde}: eine {Evaluierung}},
	issn = {2731-717X},
	shorttitle = {{ChatGPT} und die deutsche {Facharztprüfung} für {Augenheilkunde}},
	url = {https://doi.org/10.1007/s00347-024-02046-0},
	doi = {10.1007/s00347-024-02046-0},
	abstract = {Hintergrund: Die künstliche Intelligenz (KI) ChatGPT hat in verschiedenen medizinischen Fachgebieten bereits ihre Leistungsfähigkeit in standardisierten Prüfungen unter Beweis gestellt. Ziel dieser Studie war es, die Leistungsfähigkeit von ChatGPT-4 in der deutschen Facharztprüfung für Augenheilkunde zu evaluieren. Methoden: Es wurden 100 Fragen aus einer offiziellen Vorbereitungssammlung für die deutsche Facharztprüfung für Augenheilkunde verwendet. Die Fragen wurden ChatGPT-4 in deutscher Sprache vorgelegt. Die Antworten wurden von zwei unabhängigen Experten für Augenheilkunde bewertet. Ergebnisse: ChatGPT-4 erreichte eine Erfolgsquote von 78 \%. Die KI zeigte eine hohe Kompetenz in der Beantwortung von Fragen zu klinischen Szenarien und diagnostischen Verfahren. Schwächen zeigten sich bei komplexen, bildbasierten Fragen und bei Fragen, die ein tiefes Verständnis für spezifische deutsche Leitlinien erforderten. Schlussfolgerung: ChatGPT-4 zeigt ein beachtliches Potenzial als Unterstützungswerkzeug in der ophthalmologischen Weiterbildung. Dennoch ist eine kritische Überprüfung der Antworten durch Experten weiterhin unerlässlich, insbesondere bei komplexen klinischen Fragestellungen.},
	language = {de},
	urldate = {2024-05-27},
	journal = {Die Ophthalmologie},
	publisher = {Springer Nature},
	author = {Yaïci, R. and Cieplucha, M. and Bock, R.},
	month = may,
	year = {2024},
	keywords = {OPHTHALMOLOGIE},
}
