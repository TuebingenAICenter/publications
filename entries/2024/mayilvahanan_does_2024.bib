@inproceedings{mayilvahanan_does_2024,
	title = {Does {CLIP}'s {Generalization} {Performance} {Mainly} {Stem} from {High} {Train}-{Test} {Similarity}?},
	shorttitle = {Does {CLIP}'s {Generalization} {Performance} {Mainly} {Stem} from {High} {Train}-{Test} {Similarity}?},
	url = {https://brendel-group.github.io/publication/2023_10_mayilvahanan/},
	doi = {10.48550/arxiv.2310.09562},
	abstract = {Contrastive Language-Image Pre-training (CLIP) models have demonstrated remarkable zero-shot generalization capabilities on a wide range of downstream tasks. A common hypothesis is that this performance is due to the models learning robust, general-purpose visual representations. However, recent work has suggested that the performance of CLIP models might be largely explained by the high similarity between the pre-training data and the downstream test sets. In this paper, we systematically investigate this hypothesis. We find that the generalization performance of CLIP models is indeed strongly correlated with the similarity between the pre-training data and the downstream test sets. We further show that this correlation holds even when controlling for the model's capacity and the amount of pre-training data. Our results suggest that the generalization performance of CLIP models is, to a large extent, a consequence of the high train-test similarity, rather than the learning of truly robust, general-purpose visual representations.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {The {Twelfth} {International} {Conference} on {Learning} {Representations}},
	publisher = {OpenReview.net},
	author = {Mayilvahanan, Prasanna and Wiedemer, Thaddäus and Rusak, Evgenia and Bethge, Matthias and Brendel, Wieland},
	year = {2024},
	keywords = {Generalization, Similarity (geometry), Computer science, Replicate, Pruning, Artificial intelligence, Machine learning, Range (aeronautics), Test (biology), Engineering, Mathematics, Image (mathematics), processed, University of Tübingen, MPI-IS, ELLIS Institute Tübingen, ICLR},
}
