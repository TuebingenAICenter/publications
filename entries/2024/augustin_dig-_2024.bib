@inproceedings{augustin_dig-_2024,
	title = {{DiG}-{IN}: {Diffusion} {Guidance} for {Investigating} {Networks} – {Uncovering} {Classifier} {Differences}, {Neuron} {Visualisations}, and {Visual} {Counterfactual} {Explanations}},
	shorttitle = {{DiG}-{IN}},
	url = {https://arxiv.org/abs/2311.17833},
	doi = {10.1109/CVPR52733.2024.01055},
	abstract = {Understanding the decision-making process of deep neural networks is crucial for their safe deployment. Existing interpretability methods often struggle to provide meaningful insights into the internal representations of complex models. We propose Diffusion Guidance for Investigating Networks (DiG-IN), a novel framework that leverages the generative power of diffusion models to probe and visualize the internal logic of classifiers. By using the classifier's output as guidance for the diffusion process, DiG-IN can generate images that maximize specific neuron activations or class probabilities, revealing the features that a model relies on. We demonstrate the effectiveness of DiG-IN in uncovering differences between classifiers, visualizing individual neurons, and generating visual counterfactual explanations. Our approach provides a flexible and powerful tool for model analysis, offering new perspectives on the inner workings of deep learning models.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the {IEEE}/{CVF} {Conference} on {Computer} {Vision} and {Pattern} {Recognition} ({CVPR})},
	publisher = {IEEE},
	author = {Augustin, Maximilian and Neuhaus, Yannic and Hein, Matthias},
	year = {2024},
	keywords = {Spurious relationship, Computer science, Counterfactual thinking, Classifier (UML), Artificial intelligence, Machine learning, Visualization, Image (mathematics), Black box, Contextual image classification, Pattern recognition (psychology), Psychology, processed, University of Tübingen, CVPR},
}
