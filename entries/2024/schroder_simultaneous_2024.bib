@inproceedings{schroder_simultaneous_2024,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Simultaneous identification of models and parameters of scientific simulators},
	shorttitle = {Simultaneous identification of models and parameters of scientific simulators},
	url = {https://proceedings.mlr.press/v235/schroder24b.html},
	doi = {10.48550/arxiv.2305.15174},
	abstract = {Scientific simulators are often used to model complex physical systems, but they are typically computationally expensive and their parameters are unknown. Simulation-based inference (SBI) has emerged as a powerful framework for inferring parameters of such simulators. However, SBI usually assumes that the simulator is known and fixed. In many real-world scenarios, the simulator itself might be misspecified or unknown. We propose a framework for simultaneous identification of models and parameters of scientific simulators. Our approach combines SBI with model selection and model averaging, allowing us to infer both the parameters and the model structure. We demonstrate the effectiveness of our approach on several synthetic and real-world examples, showing that it can accurately identify the correct model and parameters even in the presence of model misspecification.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 41st {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Schröder, C. and Macke, J. H.},
	month = jul,
	year = {2024},
	keywords = {Computer science, Inference, Model selection, Bayesian inference, Prior probability, Frequentist inference, Artificial intelligence, Posterior probability, Machine learning, Joint probability distribution, Uncertainty quantification, Bayesian probability, Data mining, Mathematics, processed, University of Tübingen, MPI-IS, ICML},
}
