@misc{guo_out--variable_2024,
	title = {Out-of-{Variable} {Generalization} for {Discriminative} {Models}},
	shorttitle = {Out-of-{Variable} {Generalization}},
	url = {https://arxiv.org/abs/2304.07896},
	doi = {10.48550/arxiv.2304.07896},
	abstract = {Standard machine learning assumes that training and test data are drawn from the same distribution. However, in many real-world scenarios, we encounter data with different sets of variables, a problem we term out-of-variable (OoV) generalization. For instance, a model trained on a set of sensors might need to perform inference when some sensors are missing or new ones are added. In this paper, we formalize the OoV generalization problem using structural causal models. We show that standard discriminative models fail to generalize under variable shifts because they learn to exploit correlations that are specific to the training set of variables. We propose a framework for learning models that are invariant to the set of observed variables, and we provide theoretical guarantees for our approach. We demonstrate the effectiveness of our method on several synthetic and real-world datasets, showing that it significantly outperforms standard baselines.},
	language = {en},
	urldate = {2025-05-14},
	author = {Guo, Siyuan and Wildberger, Jonas and Schölkopf, Bernhard},
	month = may,
	year = {2024},
	keywords = {Generalization, Leverage (statistics), Discriminative model, Computer science, Variable (mathematics), Artificial intelligence, Machine learning, Classifier (UML), Set (abstract data type), Mathematics, ICLR},
}
