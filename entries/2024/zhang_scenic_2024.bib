@misc{zhang_scenic_2024,
	title = {{SCENIC}: {Scene}-aware {Semantic} {Navigation} with {Instruction}-guided {Control}},
	shorttitle = {{SCENIC}},
	url = {https://arxiv.org/abs/2403.11237},
	doi = {10.48550/arXiv.2403.11237},
	abstract = {We present SCENIC, a novel framework for instruction-guided navigation in complex 3D environments. Unlike existing methods that rely on simple point-goal navigation or predefined maps, SCENIC leverages semantic scene understanding to interpret natural language instructions and navigate towards semantically defined goals. Our approach integrates a hierarchical control policy that decomposes high-level instructions into actionable sub-goals, enabling robust navigation in dynamic and unseen environments. We demonstrate that SCENIC significantly outperforms state-of-the-art methods in both simulation and real-world scenarios, showing improved success rates and efficiency in complex navigation tasks.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Zhang, Xiaohan and Starke, Sebastian and Guzov, Vladimir and Dhamo, Helisa and Pérez Pellitero, Eduardo and Pons-Moll, Gerard},
	year = {2024},
	keywords = {Computer science, Control (management), Artificial intelligence, Human–computer interaction, Human-computer interaction, ARXIV},
}
