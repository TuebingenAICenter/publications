@inproceedings{keurti_stitching_2024,
	title = {Stitching {Manifolds}: {Leveraging} {Interaction} to {Compose} {Object} {Representations} into {Scenes}},
	shorttitle = {Stitching {Manifolds}},
	url = {https://openreview.net/forum?id=roehAtQlGX},
	abstract = {Compositionality is a hallmark of human intelligence, allowing us to understand complex scenes by decomposing them into objects and their interactions. While recent generative models have made strides in scene decomposition, they often struggle to generalize to novel object configurations or interactions. We propose Stitching Manifolds, a framework that learns to compose object representations into scenes by leveraging interaction. By treating objects as manifolds in a latent space, we learn to 'stitch' these manifolds together based on their physical interactions. We demonstrate that our approach enables zero-shot composition of objects into novel scenes and improves performance on downstream tasks such as scene manipulation and reasoning.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {{ICML} 2024 {Workshop} on {Geometry}-grounded {Representation} {Learning} and {Generative} {Modeling} ({GRaM})},
	author = {Keurti, H. and Schölkopf, B. and Aceituno, P. V. and Grewe, B.},
	month = jul,
	year = {2024},
	keywords = {processed, MPI-IS, ICML},
}
