@article{nguyen_towards_2024,
	title = {Towards {User}-{Focused} {Research} in {Training} {Data} {Attribution} for {Human}-{Centered} {Explainable} {AI}},
	shorttitle = {Towards {User}-{Focused} {Research} in {Training} {Data} {Attribution}},
	url = {https://arxiv.org/abs/2409.16978},
	abstract = {Training Data Attribution (TDA) methods aim to identify which training examples are most influential for a model's prediction. While TDA has seen significant technical progress, its utility for end-users remains under-explored. In this paper, we argue that the current research trajectory in TDA is overly focused on technical benchmarks, often neglecting the needs and cognitive limitations of human users. We propose a shift towards user-focused TDA research, which prioritizes human interpretability, decision-making support, and trust. We outline a research agenda for human-centered TDA, highlighting key challenges and opportunities for future work.},
	language = {en},
	urldate = {2025-05-14},
	journal = {arXiv},
	publisher = {arXiv},
	author = {Nguyen, Elisa and Bertram, Johannes and Kortukov, Evgenii and Song, Jean Y. and Oh, Seong Joon},
	year = {2024},
	keywords = {ARXIV},
}
