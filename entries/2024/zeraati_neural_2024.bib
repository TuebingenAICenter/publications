@misc{zeraati_neural_2024,
	title = {Neural timescales from a computational perspective},
	shorttitle = {Neural timescales},
	url = {https://arxiv.org/abs/2409.02684},
	doi = {10.48550/arXiv.2409.02684},
	abstract = {Neural activity exhibits fluctuations across a wide range of timescales, from milliseconds to seconds. These timescales are not uniform across the brain but are organized into a hierarchy that is thought to support diverse cognitive functions. While much research has focused on characterizing these timescales empirically, a unifying computational framework for understanding their origin and functional significance remains elusive. In this perspective, we review recent advances in understanding neural timescales from a computational lens. We discuss how timescales emerge from the interplay of circuit architecture, synaptic dynamics, and learning rules, and how they relate to the computational demands of the tasks an organism performs. We highlight the challenges in measuring and interpreting timescales and propose future directions for integrating experimental and theoretical approaches to uncover the principles governing the temporal organization of neural activity.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Zeraati, Roxana and Levina, Anna and Macke, Jakob H. and Gao, Richard},
	year = {2024},
	keywords = {Perspective (graphical), Computer science, Cognitive science, Artificial intelligence, Management science, Psychology, Economics},
}
