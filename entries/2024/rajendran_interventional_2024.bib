@misc{rajendran_interventional_2024,
	title = {An {Interventional} {Perspective} on {Identifiability} in {Gaussian} {LTI} {Systems} with {Independent} {Component} {Analysis}},
	url = {https://proceedings.mlr.press/v236/rajendran24a.html},
	doi = {10.48550/arxiv.2311.18048},
	abstract = {Linear Time-Invariant (LTI) systems are a fundamental class of dynamical systems. While the problem of identifying the parameters of an LTI system from observational data is well-studied, it is known that without further assumptions, the system is only identifiable up to a similarity transformation. In this work, we study the identifiability of Gaussian LTI systems under interventions. We show that even with a single interventional distribution, we can identify the system parameters up to a permutation and scaling of the latent components, provided the noise is non-Gaussian or the system is driven by independent sources. We provide a comprehensive analysis of the identifiability conditions and propose an algorithm for parameter estimation. Our results bridge the gap between classical system identification and modern causal representation learning.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Rajendran, Goutham and Reizinger, Patrik and Brendel, Wieland and Ravikumar, Pradeep Kumar},
	year = {2024},
	keywords = {Identifiability, Dynamical systems theory, Independent component analysis, Perspective (graphical), Gaussian, LTI system theory, Generalization, Markov chain, Linear dynamical system, Representation (politics), Computer science, Component (thermodynamics), Mathematics, Identification (biology), Linear system, Artificial intelligence, Machine learning, AISTATS},
}
