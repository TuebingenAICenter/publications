@misc{schneider_identifying_2024,
	title = {Identifying {Policy} {Gradient} {Subspaces}},
	url = {https://arxiv.org/abs/2401.06604},
	doi = {10.48550/arxiv.2401.06604},
	abstract = {Policy gradient methods are the workhorse of modern reinforcement learning. However, they often suffer from high variance and slow convergence, especially in high-dimensional parameter spaces. We investigate the geometry of the policy gradient and show that it often resides in a low-dimensional subspace. We propose a method to identify this subspace and use it to accelerate learning. Our approach, which we call Subspace Policy Gradient (SPG), projects the gradient onto this subspace, effectively reducing the variance and improving the convergence rate. We demonstrate the effectiveness of our method on a range of continuous control tasks, showing that it outperforms standard policy gradient methods in terms of sample efficiency and final performance.},
	language = {en},
	urldate = {2025-05-14},
	author = {Schneider, Jan and Schumacher, Pierre and Guist, Simon and Chen, Le and Häufle, Daniel and Schölkopf, Bernhard and Büchler, Dieter},
	month = may,
	year = {2024},
	keywords = {Reinforcement learning, Subspace topology, Linear subspace, Benchmark (surveying), Computer science, Artificial intelligence, Mathematical optimization, Trust region, Space (punctuation), Machine learning, Mathematics, ICLR},
}
