@inproceedings{shvetsova_howtocaption_2024,
	title = {{HowToCaption}: {Prompting} {LLMs} to {Transform} {Video} {Annotations} at {Scale}},
	shorttitle = {{HowToCaption}},
	url = {https://arxiv.org/abs/2310.04900},
	abstract = {Large-scale video datasets are essential for training modern video models. However, annotating such data is expensive and time-consuming. While existing datasets often provide instructional or procedural text, these annotations are frequently noisy, inconsistent, or lack the level of detail required for training complex models. In this work, we propose HowToCaption, a framework that leverages Large Language Models (LLMs) to transform existing, noisy video annotations into high-quality, descriptive captions at scale. Our approach utilizes a multi-stage prompting strategy that refines, expands, and structures the original text, resulting in captions that are more informative and better aligned with the visual content. We demonstrate the effectiveness of our method by generating captions for the HowTo100M dataset and show that models trained on these captions achieve superior performance on various downstream tasks, including video-text retrieval and video captioning. Our generated captions and the code to reproduce our results are publicly available.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Proceedings of the {European} {Conference} on {Computer} {Vision} ({ECCV})},
	publisher = {arXiv},
	author = {Shvetsova, Nina and Kukleva, Anna and Hong, Xudong and Rupprecht, Christian and Schiele, Bernt and Kuehne, Hilde},
	year = {2024},
	keywords = {ECCV},
}
