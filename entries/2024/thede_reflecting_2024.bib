@inproceedings{thede_reflecting_2024,
	title = {Reflecting on the {State} of {Rehearsal}-free {Continual} {Learning} with {Pretrained} {Models}},
	shorttitle = {Reflecting on the {State} of {Rehearsal}-free {Continual} {Learning}},
	url = {https://arxiv.org/abs/2406.09384},
	doi = {10.48550/arXiv.2406.09384},
	abstract = {Continual learning (CL) aims to enable models to learn from a stream of data without forgetting previously acquired knowledge. While rehearsal-based methods, which store past data, have dominated the field, rehearsal-free methods are increasingly relevant due to privacy and memory constraints. Recent advances in large-scale pretraining have fundamentally changed the landscape of CL, as pretrained models often exhibit strong transfer capabilities. In this work, we provide a comprehensive analysis of the state of rehearsal-free CL with pretrained models. We identify key factors that contribute to the success of these methods and highlight common pitfalls in experimental design. Our findings suggest that while pretrained models significantly improve performance, the field lacks a unified evaluation framework, leading to inconsistent results. We propose a set of best practices to guide future research in this direction.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the {Third} {Conference} on {Lifelong} {Learning} {Agents}},
	author = {Thede, Lukas and Roth, Karsten and Henaff, Olivier J. and Bethge, Matthias and Akata, Zeynep},
	year = {2024},
	keywords = {State (computer science), Psychology, Computer science, Cognitive psychology, Cognitive science, processed, University of Tübingen, COLLAS},
}
