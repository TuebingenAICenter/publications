@inproceedings{jin_implicit_2024,
	title = {Implicit {Personalization} in {Language} {Models}: {A} {Systematic} {Study}},
	shorttitle = {Implicit {Personalization} in {Language} {Models}},
	url = {https://aclanthology.org/2024.findings-emnlp.717},
	doi = {10.18653/v1/2024.findings-emnlp.717},
	abstract = {Large language models (LLMs) are increasingly used in personalized applications. While explicit personalization (e.g., via fine-tuning or prompting with user data) is well-studied, the extent to which LLMs implicitly personalize—i.e., adapt to user characteristics without explicit instructions—remains under-explored. In this paper, we conduct a systematic study of implicit personalization in LLMs. We introduce a framework to evaluate implicit personalization across three dimensions: (1) user-model interaction, (2) model architecture, and (3) task type. Our experiments reveal that LLMs exhibit significant implicit personalization, which can be both beneficial and problematic. We find that this behavior is influenced by the model's training data and the nature of the task. We further analyze the mechanisms underlying this phenomenon and discuss the implications for the development and deployment of personalized LLMs.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Findings of the {Association} for {Computational} {Linguistics}: {EMNLP}},
	publisher = {Association for Computational Linguistics},
	author = {Jin, Zhijing and Heil, Nils and Liu, Jiarui and Dhuliawala, Shehzaad and Qi, Yahang and Schölkopf, Bernhard and Mihalcea, Rada and Sachan, Mrinmaya},
	month = nov,
	year = {2024},
	keywords = {Personalization, Computer science, Natural language processing, Programming language, World Wide Web, processed, MPI-IS, EMNLP},
}
