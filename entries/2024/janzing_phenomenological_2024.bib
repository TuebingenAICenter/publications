@article{janzing_phenomenological_2024,
	title = {A phenomenological account for causality in terms of elementary actions},
	issn = {2194-6574},
	shorttitle = {A phenomenological account for causality},
	url = {https://www.degruyterbrill.com/document/doi/10.1515/jci-2022-0076/html?lang=de},
	doi = {10.1515/jci-2022-0076},
	abstract = {We propose a framework for causality based on the concept of 'elementary actions'. We argue that causal relations are not primitive, but emerge from the interaction of agents with their environment. By defining elementary actions as the smallest units of intervention, we show how causal structures can be derived from the statistics of these actions. Our approach provides a bridge between the structural causal model framework and a more phenomenological understanding of causality, offering insights into the nature of causal discovery and the limits of causal inference.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Journal of Causal Inference},
	publisher = {De Gruyter},
	author = {Janzing, Dominik and Garrido Mejia, Sebastian},
	year = {2024},
	keywords = {JCI},
}
