@misc{gebhard_parameterizing_2024,
	title = {Parameterizing pressure-temperature profiles of exoplanet atmospheres with neural networks},
	shorttitle = {Parameterizing pressure-temperature profiles},
	url = {https://doi.org/10.1051/0004-6361/202346390},
	doi = {10.1051/0004-6361/202346390},
	abstract = {The characterization of exoplanet atmospheres relies on the retrieval of physical parameters from observed spectra. A key component of this process is the parameterization of the pressure-temperature (P-T) profile. Current standard models often rely on analytical prescriptions that may not capture the full diversity of possible atmospheric structures, or on complex numerical models that are computationally expensive. We propose a new approach to parameterize P-T profiles using neural networks. By training a neural network on a large dataset of physically motivated P-T profiles, we learn a low-dimensional representation that can accurately reconstruct a wide range of atmospheric structures. We demonstrate that our neural network-based parameterization is more flexible and accurate than traditional analytical models, while remaining computationally efficient. This approach has the potential to improve the accuracy and efficiency of atmospheric retrievals for current and future exoplanet observations.},
	language = {en},
	publisher = {EDP Sciences},
	author = {Gebhard, Timothy D. and Angerhausen, Daniel and Konrad, Björn S. and Alei, Eleonora and Quanz, Sascha P. and Schölkopf, Bernhard},
	year = {2024},
	keywords = {Computer science, Exoplanet, Parametric statistics, Artificial neural network, Algorithm, Polynomial, Sensitivity (control systems), Parametric model, Machine learning, Mathematics, Statistics},
}
