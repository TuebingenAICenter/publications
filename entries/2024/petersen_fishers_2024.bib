@inproceedings{petersen_fishers_2024,
	title = {Fishers and {Hessians} of {Continuous} {Relaxations}},
	shorttitle = {Fishers and {Hessians} of {Continuous} {Relaxations}},
	url = {https://nips.cc/virtual/2024/poster/93193},
	abstract = {Continuous relaxations of discrete optimization problems are a cornerstone of modern machine learning. While they allow for gradient-based optimization, they often introduce a mismatch between the continuous objective and the discrete target. In this work, we analyze the geometry of these relaxations by studying their Fisher information matrices and Hessians. We show that for many common relaxations, the Fisher information matrix and the Hessian are closely related, and that their properties can be used to explain the optimization behavior of these relaxations. We further propose a novel relaxation that is specifically designed to have well-behaved curvature, and demonstrate its effectiveness on a range of discrete optimization tasks.},
	language = {en},
	urldate = {2025-05-22},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {Curran Associates, Inc.},
	author = {Petersen, Felix and Borgelt, Christian and Sutter, Tobias and Kuehne, Hilde and Deussen, Oliver and Ermon, Stefano},
	year = {2024},
	keywords = {NEURIPS},
}
