@inproceedings{ruaud_modelling_2024,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Modelling {Microbial} {Communities} with {Graph} {Neural} {Networks}},
	url = {https://proceedings.mlr.press/v235/ruaud24a.html},
	abstract = {Microbial communities are complex systems where interactions between species determine the community's function and stability. Predicting these interactions from observational data is a fundamental challenge in ecology. We propose a framework to model microbial communities using Graph Neural Networks (GNNs). We represent communities as graphs where nodes are species and edges represent interactions. By leveraging the inductive bias of GNNs, our model can learn to predict the growth of species in a community based on the presence and abundance of other species. We demonstrate that our approach outperforms existing methods on synthetic and real-world microbial community datasets, providing a robust tool for understanding and predicting microbial dynamics.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 41st {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Ruaud, Albane and Sancaktar, Cansu and Bagatella, Marco and Ratzke, Christoph and Martius, Georg},
	editor = {Salakhutdinov, Ruslan and Kolter, Zico and Heller, Katherine and Weller, Adrian and Oliver, Nuria and Scarlett, Jonathan and Berkenkamp, Felix},
	month = jul,
	year = {2024},
