@misc{collins_wisdom_2024,
	title = {The {Wisdom} of the {Coherent}: {Improving} {Correspondence} with {Coherence}-{Weighted} {Aggregation}},
	shorttitle = {The {Wisdom} of the {Coherent}},
	url = {https://doi.org/10.1037/dec0000211},
	doi = {10.1037/dec0000211},
	abstract = {Aggregating probability forecasts from multiple individuals often improves accuracy. However, standard methods, such as simple averaging, treat all forecasters as equally reliable. We propose a novel aggregation method, coherence-weighted aggregation (CWA), which weights individual forecasts based on their internal coherence—the extent to which they satisfy the axioms of probability theory. We test CWA across three datasets of geopolitical and economic forecasts. We find that CWA consistently outperforms simple averaging and other common weighting schemes in terms of correspondence (accuracy). We discuss the theoretical implications of these findings for the wisdom of crowds and the practical utility of CWA for improving forecasting performance.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {American Psychological Association},
	author = {Collins, Robert N. and Mandel, David R. and Karvetski, Christopher W. and Wu, Charley M. and Nelson, Jonathan D.},
	year = {2024},
	keywords = {Coherence (philosophical gambling strategy), Weighting, Computer science, Axiom, Relevance (law), Bayesian probability, Artificial intelligence, Leverage (statistics), Function (biology), Bayes' theorem, Data mining, Algorithm, Mathematics, Machine learning, Statistics},
}
