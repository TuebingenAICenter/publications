@inproceedings{sarandi_neural_2024,
	title = {Neural {Localizer} {Fields} for {Continuous} 3D {Human} {Pose} and {Shape} {Estimation}},
	shorttitle = {Neural {Localizer} {Fields}},
	url = {https://arxiv.org/abs/2407.07532},
	doi = {10.48550/arxiv.2407.07532},
	abstract = {We present Neural Localizer Fields (NLF), a novel approach for continuous 3D human pose and shape estimation from monocular video. Existing methods typically rely on frame-by-frame estimation or recurrent architectures, which often struggle with temporal consistency and occlusion. In contrast, NLF represents the human body as a continuous field of localizers that predict the 3D position of body joints and surface vertices. By leveraging a continuous representation, NLF can be queried at any time point, enabling smooth and temporally consistent motion estimation. We demonstrate that NLF achieves state-of-the-art performance on standard benchmarks while providing a more robust and flexible framework for handling challenging scenarios such as fast motion and self-occlusion.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {Curran Associates, Inc.},
	author = {Sárándi, István and Pons-Moll, Gerard},
	year = {2024},
	keywords = {Artificial intelligence, Computer vision, Pose, Computer science, Estimation, Artificial neural network, Pattern recognition (psychology), Engineering, processed, University of Tübingen, NEURIPS},
}
