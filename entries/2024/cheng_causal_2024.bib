@inproceedings{cheng_causal_2024,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Causal {Inference} out of {Control}: {Estimating} {Performativity} without {Treatment} {Randomization}},
	shorttitle = {Causal {Inference} out of {Control}},
	url = {https://arxiv.org/abs/2302.04989},
	abstract = {Performativity describes settings where a model's predictions influence the future data distribution. Estimating the causal effect of a model on the population is a central challenge in this context. Existing approaches typically rely on randomized experiments, which are often infeasible or unethical. We propose a framework for estimating performativity without treatment randomization. Our approach leverages the structure of the decision-making process to identify causal effects from observational data. We provide theoretical guarantees for our estimators and demonstrate their effectiveness on synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 41st {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Cheng, Gary and Hardt, Moritz and Mendler-Dünner, Celestine},
	year = {2024},
	keywords = {processed, University of Tübingen, MPI-IS, ELLIS Institute Tübingen, ICML},
}
