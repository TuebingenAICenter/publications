@inproceedings{gloeckler_all--one_2024,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {All-in-one simulation-based inference},
	url = {https://proceedings.mlr.press/v235/gloeckler24a.html},
	doi = {10.48550/arxiv.2404.09636},
	abstract = {Simulation-based inference (SBI) allows for Bayesian inference in models where the likelihood is intractable but can be simulated. Recent advances in neural SBI have enabled efficient inference for complex models, but typically require choosing between different methods depending on the specific inference task, such as parameter estimation, model comparison, or posterior predictive checks. In this work, we introduce All-in-one SBI, a framework that enables all these tasks within a single, unified approach. Our method is based on learning a conditional density estimator that can be used to perform parameter estimation, model comparison, and posterior predictive checks simultaneously. We demonstrate the effectiveness of our approach on a range of synthetic and real-world examples, showing that it achieves competitive performance while providing a more flexible and unified inference pipeline.},
	language = {en},
	urldate = {2024-07-24},
	booktitle = {Proceedings of the 41st {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Gloeckler, M. and Deistler, M. and Weilbach, C. D. and Wood, F. and Macke, J. H.},
	month = jul,
	year = {2024},
	keywords = {Inference, Computer science, Artificial intelligence, processed, University of Tübingen, MPI-IS, ICML},
}
