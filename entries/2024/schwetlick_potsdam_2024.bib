@article{schwetlick_potsdam_2024,
	title = {Potsdam data set of eye movement on natural scenes ({DAEMONS})},
	copyright = {CC BY 4.0},
	issn = {1664-1078},
	shorttitle = {{DAEMONS}},
	url = {https://www.frontiersin.org/journals/psychology/articles/10.3389/fpsyg.2024.1389609/full},
	doi = {10.3389/fpsyg.2024.1389609},
	abstract = {Eye movement research has long relied on datasets of eye movements on natural scenes to understand human visual attention. However, existing datasets often suffer from limitations such as small sample sizes, restricted stimulus sets, or lack of diversity in viewing conditions. Here, we present the Potsdam data set of eye movement on natural scenes (DAEMONS), a large-scale, high-quality dataset of eye movements recorded from 100 participants viewing 1,000 natural images. The dataset includes high-precision eye-tracking data, detailed stimulus information, and participant metadata. We provide a comprehensive description of the data collection procedure, the stimulus set, and the resulting eye movement data. Furthermore, we demonstrate the utility of the DAEMONS dataset by benchmarking several state-of-the-art saliency models. The DAEMONS dataset is publicly available and provides a valuable resource for researchers in vision science, psychology, and computer vision.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Frontiers in Psychology},
	publisher = {Frontiers Media S.A.},
	author = {Schwetlick, Lisa and Kümmerer, Matthias and Bethge, Matthias and Engbert, Ralf},
	year = {2024},
	keywords = {Natural (archaeology), Set (abstract data type), Eye movement, Data set, Psychology, Movement (music), Front (military), Artificial intelligence, Art, Computer science, Neuroscience, Geography, Aesthetics, Archaeology, Meteorology, processed, University of Tübingen, FRONTIERS},
}
