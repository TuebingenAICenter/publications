@inproceedings{didolkar_metacognitive_2024,
	title = {Metacognitive {Capabilities} of {LLMs}: {An} {Exploration} in {Mathematical} {Problem} {Solving}},
	shorttitle = {Metacognitive {Capabilities} of {LLMs}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2024/file/2318d75a06437eaa257737a5cf3ab83c-Paper-Conference.pdf},
	abstract = {Large Language Models (LLMs) have demonstrated remarkable proficiency in solving complex mathematical problems. However, they often struggle with reliability, frequently hallucinating or making subtle errors. In this work, we investigate the metacognitive capabilities of LLMs—their ability to monitor their own reasoning process and evaluate the correctness of their solutions. We propose a framework to evaluate these capabilities by prompting LLMs to assess their own generated solutions and provide confidence scores. Our findings reveal that while LLMs exhibit some degree of metacognitive awareness, their self-evaluation is often poorly calibrated, particularly for incorrect solutions. We further explore techniques to improve these metacognitive abilities, demonstrating that targeted training and prompting strategies can enhance the model's ability to detect errors and improve overall problem-solving performance.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 37 ({NeurIPS} 2024)},
	publisher = {Curran Associates, Inc.},
	author = {Didolkar, Aniket R. and Goyal, Anirudh and Ke, Nan Rosemary and Guo, Shagun and Valko, Michal and Lillicrap, Timothy P. and Rezende, Danilo J. and Bengio, Yoshua and Mozer, Michael C. and Arora, Sanjeev},
	editor = {Globerson, A. and Mackey, L. and Belgrave, D. and Fan, A. and Paquet, U. and Tomczak, J. and Zhang, C.},
	month = dec,
	year = {2024},
	keywords = {NEURIPS},
}
