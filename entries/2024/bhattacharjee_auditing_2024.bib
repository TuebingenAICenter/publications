@inproceedings{bhattacharjee_auditing_2024,
	title = {Auditing {Local} {Explanations} is {Hard}},
	shorttitle = {Auditing {Local} {Explanations} is {Hard}},
	url = {https://arxiv.org/abs/2407.13281},
	doi = {10.52202/079017-0590},
	abstract = {Local explanation methods, such as LIME and SHAP, are widely used to interpret the predictions of complex machine learning models. However, it has been observed that these methods can be manipulated to hide bias or provide misleading explanations. In this paper, we study the problem of auditing local explanations: given a model and an explanation method, can we determine whether the explanation is faithful to the model's behavior? We show that this problem is computationally hard. Specifically, we prove that for a wide class of local explanation methods, deciding whether an explanation is faithful is NP-hard. We also provide a characterization of the conditions under which auditing is tractable, and discuss the implications of our results for the design and evaluation of explanation methods.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {Curran Associates, Inc.},
	author = {Bhattacharjee, Robi and von Luxburg, Ulrike},
	year = {2024},
	keywords = {processed, University of Tübingen, NEURIPS},
}
