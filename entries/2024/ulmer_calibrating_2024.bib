@inproceedings{ulmer_calibrating_2024,
	title = {Calibrating {Large} {Language} {Models} {Using} {Their} {Generations} {Only}},
	shorttitle = {Calibrating {Large} {Language} {Models} {Using} {Their} {Generations} {Only}},
	url = {https://arxiv.org/abs/2403.05973},
	doi = {10.48550/arXiv.2403.05973},
	abstract = {Large language models (LLMs) are often poorly calibrated: their confidence scores do not reflect the true probability of correctness. Existing calibration methods typically require access to the model's logit outputs or a labeled calibration dataset, which are often unavailable for proprietary models. We propose a novel calibration method that relies solely on the model's generated text. Our approach, which we call Generation-based Calibration (GenCal), uses the model's own generations to estimate its confidence. We show that GenCal significantly improves the calibration of various LLMs across a range of tasks, including question answering and summarization, without requiring any additional training or access to the model's internal states.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 62nd {Annual} {Meeting} of the {Association} for {Computational} {Linguistics} ({Volume} 1: {Long} {Papers})},
	publisher = {Association for Computational Linguistics},
	author = {Ulmer, Dennis and Gubri, Martin and Lee, Hwaran and Yun, Sangdoo and Oh, Seong Joon},
	year = {2024},
	keywords = {Computer science, Natural language processing, Linguistics, Philosophy, processed, University of Tübingen, ACL},
}
