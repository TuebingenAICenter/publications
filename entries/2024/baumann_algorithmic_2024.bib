@inproceedings{baumann_algorithmic_2024,
	title = {Algorithmic {Collective} {Action} in {Recommender} {Systems}: {Promoting} {Songs} by {Reordering} {Playlists}},
	shorttitle = {Algorithmic {Collective} {Action} in {Recommender} {Systems}},
	url = {https://arxiv.org/abs/2404.04269},
	doi = {10.48550/arxiv.2404.04269},
	abstract = {Recommender systems are increasingly central to how cultural goods are discovered and consumed. While these systems are often designed to optimize for user engagement, they also shape the visibility of content creators. In this work, we study how users can engage in collective action to influence the recommendations of a system. Specifically, we consider a scenario where a group of users coordinates to reorder their playlists to promote a specific song. We model this as a game between the recommender system and the users, and analyze the conditions under which such collective action is successful. We find that even small groups of users can significantly influence the recommendations, and that the effectiveness of this action depends on the system's learning algorithm and the users' coordination strategy. Our results highlight the potential for users to collectively shape algorithmic outcomes, and suggest new directions for designing more equitable and transparent recommender systems.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {European {Workshop} on {Algorithmic} {Fairness}},
	publisher = {Curran Associates, Inc.},
	author = {Baumann, Joachim and Mendler-Dünner, Celestine},
	year = {2024},
	keywords = {Recommender system, Computer science, Action (physics), Collective action, World Wide Web, Human–computer interaction, Internet privacy, Political science, processed, MPI-IS, ELLIS Institute Tübingen, NEURIPS, EWAF},
}
