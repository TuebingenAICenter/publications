@article{tsirtsis_optimal_2024,
	title = {Optimal {Decision} {Making} {Under} {Strategic} {Behavior}},
	shorttitle = {Optimal {Decision} {Making} {Under} {Strategic} {Behavior}},
	url = {https://is.mpg.de/ei/publications/tsirtsisetal24},
	doi = {10.1287/mnsc.2021.02567},
	abstract = {We study the problem of designing optimal decision rules when the agents being evaluated are strategic, i.e., they can manipulate their features to improve their outcomes. We model this interaction as a Stackelberg game where the decision maker (leader) commits to a decision rule and the agents (followers) respond by strategically modifying their features to maximize their own utility. We show that, in general, finding the optimal decision rule is NP-hard. However, we identify conditions under which the problem can be solved efficiently. Specifically, we show that if the agents' cost functions are convex and the decision maker's utility function is linear, the problem can be formulated as a convex optimization problem. We also propose a heuristic algorithm for the general case and demonstrate its effectiveness on both synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Management Science},
	publisher = {INFORMS},
	author = {Tsirtsis, Stratis and Tabibian, Behzad and Khajehnejad, M. Amin and Singla, Adish and Schölkopf, Bernhard and Gomez-Rodriguez, Manuel},
	year = {2024},
	keywords = {Computer science, Heuristic, Set (abstract data type), Transparency (behavior), Investment decisions, Decision rule, Optimal decision, Mathematical optimization, Dynamic programming, Order (exchange), Time complexity, Economics, Artificial intelligence, Decision tree, Microeconomics, Mathematics, Behavioral economics, Algorithm, processed, MPI-IS},
}
