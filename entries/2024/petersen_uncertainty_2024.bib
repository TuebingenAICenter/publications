@article{petersen_uncertainty_2024,
	title = {Uncertainty {Quantification} via {Stable} {Distribution} {Propagation}},
	shorttitle = {Uncertainty {Quantification} via {Stable} {Distribution} {Propagation}},
	url = {https://arxiv.org/abs/2402.08324},
	abstract = {We propose a novel method for uncertainty quantification in deep neural networks based on the propagation of stable distributions. Unlike existing methods that rely on Gaussian assumptions or computationally expensive sampling, our approach propagates the parameters of stable distributions through the network layers. This allows for a closed-form approximation of the predictive distribution, which is both computationally efficient and theoretically grounded. We demonstrate the effectiveness of our method on various benchmarks, showing that it provides well-calibrated uncertainty estimates while maintaining competitive predictive performance.},
	language = {en},
	urldate = {2025-05-14},
	journal = {The Twelfth International Conference on Learning Representations},
	publisher = {arXiv},
	author = {Petersen, Felix and Mishra, Aashwin and Kuehne, Hilde and Borgelt, Christian and Deussen, Oliver and Yurochkin, Mikhail},
	year = {2024},
	keywords = {ICLR},
}
