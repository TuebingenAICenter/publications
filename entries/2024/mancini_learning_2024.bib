@article{mancini_learning_2024,
	title = {Learning {Graph} {Embeddings} for {Open} {World} {Compositional} {Zero}-{Shot} {Learning}},
	shorttitle = {Learning {Graph} {Embeddings} for {Open} {World} {Compositional} {Zero}-{Shot} {Learning}},
	url = {https://is.mpg.de/ei/publications/mannaexiaaka22},
	doi = {10.1109/TPAMI.2022.3163667},
	abstract = {Compositional Zero-Shot Learning (CZSL) aims to recognize unseen compositions of state and object primitives. Existing methods typically learn a joint embedding space for state-object pairs, often ignoring the semantic relationships between primitives. In this paper, we propose a novel approach that learns graph embeddings for CZSL. We construct a graph where nodes represent state and object primitives, and edges represent their semantic relationships. We then use a graph convolutional network to learn embeddings for these primitives, which are then used to predict the state-object composition. Our method achieves state-of-the-art performance on several benchmark datasets, demonstrating the effectiveness of leveraging semantic relationships for CZSL.},
	language = {en},
	urldate = {2024-05-23},
	journal = {IEEE Transactions on Pattern Analysis and Machine Intelligence},
	publisher = {IEEE},
	author = {Mancini, M. and Naeem, M. F. and Xian, Y. and Akata, Z.},
	month = mar,
	year = {2024},
	keywords = {Computer science, Embedding, Graph, Artificial intelligence, Theoretical computer science, WordNet, Machine learning, Pattern recognition (psychology), Adjacency matrix, Cosine similarity, Adjacency list, Convolutional neural network, Algorithm, CVPR, TPAMI},
}
