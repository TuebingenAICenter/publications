@misc{gao_deep_2024,
	title = {Deep inverse modeling reveals dynamic-dependent invariances in neural circuit mechanisms},
	url = {https://www.biorxiv.org/content/10.1101/2024.08.21.608969},
	doi = {10.1101/2024.08.21.608969},
	abstract = {Neural circuits are often characterized by a high degree of degeneracy: many different combinations of parameters can produce similar circuit dynamics. This degeneracy poses a challenge for understanding the relationship between circuit structure and function. Here, we introduce a framework based on deep inverse modeling to identify the manifold of parameters that are consistent with observed neural dynamics. We show that this approach can recover the underlying parameter-to-dynamics mapping and identify dynamic-dependent invariances in neural circuit mechanisms. We demonstrate our approach on a range of neural circuit models, including a conductance-based model of a single neuron and a recurrent neural network model of a population of neurons. Our results suggest that deep inverse modeling is a powerful tool for uncovering the principles of neural circuit organization and for understanding how circuit structure constrains neural dynamics.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {bioRxiv},
	author = {Gao, Richard and Deistler, Michael and Schulz, Auguste and Gonçalves, Pedro J. and Macke, Jakob H.},
	month = aug,
	year = {2024},
	keywords = {Computer science, Biological neural network, Artificial neural network, Population, Artificial intelligence, Network dynamics, Computational neuroscience, Biological system, Machine learning, Mathematics, Biology},
}
