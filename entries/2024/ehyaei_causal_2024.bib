@misc{ehyaei_causal_2024,
	title = {Causal {Adversarial} {Perturbations} for {Individual} {Fairness} and {Robustness} in {Heterogeneous} {Data} {Spaces}},
	shorttitle = {Causal {Adversarial} {Perturbations}},
	url = {https://is.mpg.de/hml/publications/ahmadcausal},
	doi = {10.48550/arxiv.2308.08938},
	abstract = {Individual fairness requires that similar individuals receive similar outcomes. However, defining similarity is challenging, especially in heterogeneous data spaces where features have different types and causal relationships. We propose Causal Adversarial Perturbations (CAP), a framework that leverages causal models to generate meaningful perturbations for individual fairness and robustness. CAP identifies causal paths between features and uses them to generate adversarial examples that respect the causal structure of the data. We demonstrate that CAP improves individual fairness and robustness against adversarial attacks in various settings, including tabular and image data.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {AAAI Press},
	author = {Ehyaei, Ahmad-Reza and Mohammadi, Kiarash and Karimi, Amir-Hossein and Samadi, Samira and Farnadi, Golnoosh},
	year = {2024},
	keywords = {Adversarial system, Computer science, Robustness (evolution), Classifier (UML), Artificial intelligence, Machine learning, Causal model, Data mining, Mathematics, Statistics, AAAI},
}
