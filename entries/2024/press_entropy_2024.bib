@inproceedings{press_entropy_2024,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {The {Entropy} {Enigma}: {Success} and {Failure} of {Entropy} {Minimization}},
	shorttitle = {The {Entropy} {Enigma}},
	url = {https://bethgelab.org/publication/2024_07_press/},
	doi = {10.48550/arXiv.2405.05012},
	abstract = {Entropy minimization is a ubiquitous principle in machine learning, appearing in objectives ranging from maximum likelihood estimation and self-training to information bottleneck and contrastive learning. Despite its widespread use, the conditions under which entropy minimization succeeds or fails remain poorly understood. In this work, we provide a theoretical framework to analyze the dynamics of entropy minimization. We show that entropy minimization can be decomposed into two competing forces: a 'clustering' force that pulls samples towards the nearest class prototype, and a 'repulsion' force that pushes samples away from other class prototypes. We demonstrate that the success of entropy minimization depends on the balance between these forces, which is determined by the geometry of the data and the capacity of the model. We further show that when the repulsion force is too strong, entropy minimization can lead to 'collapse' or 'over-clustering', where the model fails to learn meaningful representations. We validate our theoretical findings with extensive experiments on synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 41st {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Press, Ori and Shwartz-Ziv, Ravid and LeCun, Yann and Bethge, Matthias},
	year = {2024},
	keywords = {Entropy (arrow of time), Minification, Mathematics, Econometrics, Statistical physics, Computer science, Thermodynamics, Mathematical optimization, Physics, processed, University of Tübingen, ICML},
}
