@misc{gervelmeyer_interpretable-by-design_2024,
	title = {Interpretable-by-design {Deep} {Survival} {Analysis} for {Disease} {Progression} {Modeling}},
	url = {https://doi.org/10.1007/978-3-031-72117-5_47},
	doi = {10.1007/978-3-031-72117-5_47},
	abstract = {Deep learning models have shown great promise in survival analysis, but their black-box nature often limits their clinical adoption. We propose a novel interpretable-by-design deep survival model that combines the flexibility of deep neural networks with the interpretability of additive models. Our approach learns a non-linear representation of the input features and models the hazard function as a sum of interpretable components. We demonstrate the effectiveness of our model on several clinical datasets, showing that it achieves competitive performance while providing insights into the contribution of individual features to the predicted survival risk.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Springer Nature},
	author = {Gervelmeyer, Julius and Müller, Sarah and Djoumessi, Kerol and Merle, David and Clark, Simon J. and Koch, Lisa and Berens, Philipp},
	month = oct,
	year = {2024},
	keywords = {Survival analysis, Disease, Computer science, Artificial intelligence, Medicine, Internal medicine, MICCAI},
}
