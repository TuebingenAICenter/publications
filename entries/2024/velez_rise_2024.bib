@misc{velez_rise_2024,
	title = {The rise and fall of technological development in virtual communities},
	shorttitle = {The rise and fall of technological development},
	url = {https://doi.org/10.31234/osf.io/tz4dn},
	doi = {10.31234/osf.io/tz4dn},
	abstract = {How do communities develop complex technologies? We study this question using a massive dataset from the multiplayer game One Hour One Life, where players must cooperate to build a technological tree. We find that technological development follows a predictable trajectory: communities initially experience rapid growth, but eventually reach a plateau or decline. We show that this pattern is driven by a tension between the benefits of specialization and the costs of coordination. As communities grow, the need for coordination increases, eventually outpacing the benefits of specialization. We formalize this trade-off in a computational model and show that it accounts for the observed patterns of technological development in the game.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PsyArxiv},
	author = {Vélez, Natalia and Wu, Charley M. and Gershman, Samuel J. and Schulz, Eric},
	year = {2024},
	keywords = {Economic geography, Technological change, Business, Computer science, Geography, Artificial intelligence},
}
