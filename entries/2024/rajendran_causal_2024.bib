@inproceedings{rajendran_causal_2024,
	title = {From {Causal} to {Concept}-{Based} {Representation} {Learning}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2024/file/b76a9959151d377ddd2c77a275a97475-Paper-Conference.pdf},
	doi = {10.52202/079017-3211},
	abstract = {Representation learning aims to extract useful features from data. A common paradigm is to learn representations that are invariant to nuisance factors, often by leveraging causal structure. However, such causal representations may not be sufficient for downstream tasks that require reasoning about the underlying concepts. In this paper, we propose a framework for concept-based representation learning that builds upon causal representation learning. We show that by incorporating concept-based constraints, we can learn representations that are not only causally grounded but also interpretable and useful for a wider range of downstream tasks. We provide theoretical guarantees for our approach and demonstrate its effectiveness on several benchmarks.},
	language = {en},
	urldate = {2025-05-22},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 37},
	publisher = {Curran Associates, Inc.},
	author = {Rajendran, Goutham and Buchholz, Simon and Aragam, Bryon and Schölkopf, Bernhard and Ravikumar, Pradeep K.},
	editor = {Globerson, Amir and Mackey, Lester and Belgrave, Danielle and Fan, Angela and Paquet, Ulrich and Tomczak, Jakub and Zhang, Cheng},
	month = dec,
	year = {2024},
	keywords = {Representation (politics), Feature learning, Feature (linguistics), Knowledge representation and reasoning, Set (abstract data type), processed, MPI-IS, ELLIS Institute Tübingen, NEURIPS},
}
