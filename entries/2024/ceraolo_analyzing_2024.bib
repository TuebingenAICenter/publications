@article{ceraolo_analyzing_2024,
	title = {Analyzing {Human} {Questioning} {Behavior} and {Causal} {Curiosity} through {Natural} {Queries}},
	url = {https://doi.org/10.48550/arXiv.2405.20318},
	doi = {10.48550/arXiv.2405.20318},
	abstract = {Human curiosity is a fundamental driver of learning and discovery. While much research has focused on how humans learn from information, less is known about how they actively seek information through questioning. In this work, we introduce a novel dataset of natural human queries, collected to study questioning behavior and causal curiosity. We analyze the linguistic and structural properties of these queries, and investigate the relationship between questioning behavior and causal curiosity. Our findings reveal that humans exhibit distinct questioning patterns that are linked to their causal curiosity, and that these patterns can be used to predict causal curiosity levels. We also discuss the implications of our findings for the development of more effective information-seeking systems.},
	language = {en},
	urldate = {2024-06-12},
	journal = {arXiv},
	publisher = {arXiv},
	author = {Ceraolo, R. and Kharlapenko, D. and Khan, A. and Reymond, A. and Mihalcea, R. and Sachan, M. and Schölkopf, B. and Jin, Z.},
	year = {2024},
	keywords = {processed, MPI-IS},
}
