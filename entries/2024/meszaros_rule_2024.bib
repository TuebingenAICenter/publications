@inproceedings{meszaros_rule_2024,
	title = {Rule {Extrapolation} in {Language} {Models}: {A} {Study} of {Compositional} {Generalization} on {OOD} {Prompts}},
	shorttitle = {Rule {Extrapolation} in {Language} {Models}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2024/hash/3d9ef68629089da055334c2d41dfcf93-Abstract-Conference.html},
	doi = {10.48550/arXiv.2409.13728},
	abstract = {Compositional generalization—the ability to combine known concepts in novel ways—is a hallmark of human intelligence. While large language models (LLMs) have shown impressive performance on various tasks, their ability to extrapolate rules to out-of-distribution (OOD) prompts remains a subject of debate. In this work, we systematically investigate the compositional generalization capabilities of LLMs by introducing a novel benchmark, RuleExtrap, which requires models to extrapolate simple, rule-based transformations to unseen combinations of inputs. We find that while LLMs can perform well on in-distribution prompts, their performance drops significantly on OOD prompts that require rule extrapolation. Our analysis reveals that this failure is not due to a lack of knowledge, but rather a difficulty in applying rules compositionally. We further show that simple prompting strategies, such as chain-of-thought, do not fully mitigate this issue, suggesting that current LLMs struggle with the fundamental mechanism of rule extrapolation.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {Curran Associates, Inc.},
	author = {Mészáros, Anna and Ujváry, Szilvia and Brendel, Wieland and Reizinger, Patrik and Huszár, Ferenc},
	year = {2024},
	keywords = {Generalization, Extrapolation, Natural language, Feature (linguistics), processed, MPI-IS, ELLIS Institute Tübingen, NEURIPS},
}
