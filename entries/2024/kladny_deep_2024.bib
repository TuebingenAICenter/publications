@misc{kladny_deep_2024,
	title = {Deep {Backtracking} {Counterfactuals} for {Causally} {Compliant} {Explanations}},
	url = {https://openreview.net/pdf?id=Br5esc2CXR},
	doi = {10.48550/arxiv.2310.07665},
	abstract = {Counterfactual explanations are a popular tool for interpreting machine learning models. However, standard approaches often ignore the underlying causal structure of the data-generating process, leading to explanations that are physically impossible or causally inconsistent. In this work, we propose a novel framework for generating causally compliant counterfactuals based on the concept of backtracking counterfactuals. We leverage deep generative models to learn the structural causal model of the data and use it to perform backtracking, which allows us to find counterfactuals that are consistent with the causal mechanisms. We demonstrate the effectiveness of our approach on several synthetic and real-world datasets, showing that it produces more plausible and interpretable explanations than existing methods.},
	language = {en},
	author = {Kladny, Klaus-Rudolf and von Kügelgen, Julius and Schölkopf, Bernhard and Muehlebach, Michael},
	month = jul,
	year = {2024},
	keywords = {Counterfactual conditional, Counterfactual thinking, Backtracking, Computer science, Causal inference, Field (mathematics), Artificial intelligence, Mathematics, Algorithm, Econometrics, Epistemology, Philosophy, TMLR},
}
