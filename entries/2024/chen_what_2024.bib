@article{chen_what_2024,
	title = {What, when, and where? - {Self}-{Supervised} {Spatio}-{Temporal} {Grounding} in {Untrimmed} {Multi}-{Action} {Videos} from {Narrated} {Instructions}},
	shorttitle = {What, when, and where?},
	url = {https://arxiv.org/abs/2303.16990},
	doi = {10.48550/arXiv.2303.16990},
	abstract = {We address the problem of spatio-temporal grounding in untrimmed, multi-action videos using only narrated instructions as supervision. Given a video and its corresponding narration, the goal is to localize the described actions in both time and space. Existing methods for this task typically rely on large-scale, manually annotated datasets, which are expensive and time-consuming to collect. In this work, we propose a self-supervised approach that learns to ground actions by leveraging the temporal alignment between video and narration. We introduce a novel objective that encourages the model to attend to the relevant video regions and time segments that correspond to the narrated instructions. Our method achieves state-of-the-art performance on several benchmarks, demonstrating the effectiveness of our approach in learning spatio-temporal grounding without explicit supervision.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
	publisher = {IEEE},
	author = {Chen, Brian and Shvetsova, Nina and Rouditchenko, Andrew and Kondermann, Daniel and Thomas, Samuel and Chang, Shih-Fu and Feris, Rogerio and Glass, James and Kuehne, Hilde},
	year = {2024},
	keywords = {CVPR},
}
