@misc{meng_gradient_2024,
	title = {Gradient {Descent} on {Logistic} {Regression}: {Non}-{Separable} {Data} and {Large} {Steps}},
	shorttitle = {Gradient {Descent} on {Logistic} {Regression}},
	url = {https://arxiv.org/abs/2406.05033},
	doi = {10.48550/arXiv.2406.05033},
	abstract = {We study the convergence of gradient descent (GD) on logistic regression with non-separable data. While it is well-known that GD converges to the maximum likelihood estimator (MLE) for separable data, the non-separable case is more nuanced. We show that for non-separable data, GD with a constant step size converges to the MLE if the step size is sufficiently small. However, for large step sizes, the behavior is more complex. We provide a comprehensive analysis of the convergence of GD on logistic regression with non-separable data, covering both small and large step sizes. Our results show that for large step sizes, GD can exhibit oscillatory behavior and may not converge to the MLE. We also provide conditions under which GD converges to the MLE for large step sizes.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Meng, Si Yi and Orvieto, Antonio and Cao, Daniel Y. and De Sa, Christopher},
	year = {2024},
	keywords = {Logistic regression, Separable space, Regression, Gradient descent, Statistics, Mathematics, Artificial intelligence, Computer science, Mathematical analysis, Artificial neural network},
}
