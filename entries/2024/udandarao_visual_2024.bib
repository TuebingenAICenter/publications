@inproceedings{udandarao_visual_2024,
	title = {Visual {Data}-{Type} {Understanding} does not emerge from {Scaling} {Vision}-{Language} {Models}},
	shorttitle = {Visual {Data}-{Type} {Understanding}},
	url = {https://bethgelab.org/publication/2024_05_udandarao/},
	doi = {10.48550/arXiv.2310.08577},
	abstract = {Vision-Language Models (VLMs) have demonstrated remarkable capabilities in reasoning about visual content. However, it remains unclear whether these models truly understand the underlying data-types of the visual information they process. In this work, we investigate whether VLMs can identify the data-type of a visual input (e.g., whether an image is a scatter plot, a heatmap, or a natural photograph). We find that despite their impressive performance on general visual tasks, VLMs struggle to identify the data-type of visual inputs. Furthermore, we show that this limitation does not improve with scaling, suggesting that data-type understanding is not an emergent property of current VLM training paradigms. We introduce a new benchmark, SyntheticTypeIdent, to evaluate this capability and demonstrate that even state-of-the-art models perform poorly on this task.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {The {Twelfth} {International} {Conference} on {Learning} {Representations}},
	publisher = {OpenReview.net},
	author = {Udandarao, Vishaal and Burg, Max F. and Albanie, Samuel and Bethge, Matthias},
	year = {2024},
	keywords = {Computer science, Set (abstract data type), Artificial intelligence, Scaling, Task (project management), Data type, Ranging, Natural language processing, Data set, Pattern recognition (psychology), Machine learning, Mathematics, processed, University of Tübingen, ICLR},
}
