@misc{croce_segment_2024,
	title = {Segment ({Almost}) {Nothing}: {Prompt}-{Agnostic} {Adversarial} {Attacks} on {Segmentation} {Models}},
	shorttitle = {Segment ({Almost}) {Nothing}},
	url = {https://arxiv.org/abs/2311.14450},
	doi = {10.48550/arXiv.2311.14450},
	abstract = {Segment Anything Models (SAM) have shown impressive zero-shot performance on image segmentation tasks. However, their robustness to adversarial attacks remains largely unexplored. In this paper, we introduce the first prompt-agnostic adversarial attack on SAM. We show that it is possible to generate a single universal adversarial perturbation that, when added to an image, causes the model to produce incorrect segmentations for any prompt provided by the user. We demonstrate the effectiveness of our attack on the SAM architecture and show that it can be used to bypass the model's safety filters. Our results highlight the vulnerability of foundation models to adversarial attacks and call for more robust training procedures.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Croce, Francesco and Hein, Matthias},
	year = {2024},
	keywords = {Embedding, Segmentation, Computer science, Image (mathematics), Encoder, Object (grammar), Artificial intelligence, Adversarial system, Variety (cybernetics), Bounded function, Image segmentation, Point (geometry), Process (computing), Computer vision, Pattern recognition (psychology), Mathematics, SATML},
}
