@inproceedings{kapoor_latent_2024,
	title = {Latent {Diffusion} for {Neural} {Spiking} {Data}},
	shorttitle = {Latent {Diffusion} for {Neural} {Spiking} {Data}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2024/file/d60b6b7f0ba6bf07d975b3bbdacea702-Paper-Conference.pdf},
	doi = {10.48550/arxiv.2407.08751},
	abstract = {Neural spiking data is high-dimensional, sparse, and exhibits complex temporal dynamics. Generative models for such data are essential for understanding neural population dynamics, data augmentation, and simulation. While diffusion models have achieved state-of-the-art performance in generating continuous data, their application to discrete, sparse spiking data remains challenging. We introduce Latent Diffusion for Spiking Data (LDSD), a framework that learns a continuous latent representation of neural spiking activity and performs diffusion in this latent space. We propose a novel architecture for the latent space that respects the structure of neural data and a diffusion process that effectively handles the latent representations. We demonstrate that LDSD outperforms existing generative models for neural spiking data in terms of sample quality, diversity, and the ability to capture complex temporal dependencies. Our results suggest that latent diffusion is a promising approach for modeling neural population activity.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 37 ({NeurIPS} 2024)},
	publisher = {Curran Associates, Inc.},
	author = {Kapoor, J. and Schulz, A. and Vetter, J. and Pei, F. and Gao, R. and Macke, J. H.},
	month = dec,
	year = {2024},
	keywords = {Spiking neural network, Computer science, Diffusion, Artificial intelligence, Artificial neural network, Physics, Thermodynamics, processed, University of Tübingen, MPI-IS, NEURIPS},
}
