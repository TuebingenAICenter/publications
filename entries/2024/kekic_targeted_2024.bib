@misc{kekic_targeted_2024,
	title = {Targeted {Reduction} of {Causal} {Models}},
	url = {https://proceedings.mlr.press/v244/kekic24a.html},
	doi = {10.48550/arxiv.2311.18639},
	abstract = {Causal models are often too complex to be useful for downstream tasks. We propose a framework for targeted reduction of causal models, which allows us to simplify a causal model while preserving its causal properties relevant to a specific task. Our approach is based on the idea of causal abstraction, where we map a high-dimensional causal model to a lower-dimensional one. We provide theoretical guarantees for our method and demonstrate its effectiveness on several synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Kekić, Armin and Schölkopf, Bernhard and Besserve, Michel},
	editor = {Kiyavash, Negar and Mooij, Joris M.},
	month = jul,
	year = {2024},
	keywords = {Causation, Phenomenon, Computer science, Causality (physics), Set (abstract data type), Causal model, Reduction (mathematics), Data science, Range (aeronautics), Artificial intelligence, Machine learning, Cognitive science, Epistemology, Psychology, Mathematics, Engineering, Physics, Philosophy, UAI},
}
