@inproceedings{schlarmann_robust_2024,
	title = {Robust {CLIP}: {Unsupervised} {Adversarial} {Fine}-{Tuning} of {Vision} {Embeddings} for {Robust} {Large} {Vision}-{Language} {Models}},
	shorttitle = {Robust {CLIP}},
	url = {https://arxiv.org/abs/2402.12336},
	doi = {10.48550/arXiv.2402.12336},
	abstract = {Large Vision-Language Models (LVLMs) have shown impressive capabilities in various tasks. However, they are vulnerable to adversarial attacks on their vision encoder. While adversarial training of the vision encoder is a standard approach to improve robustness, it typically requires labeled data, which is scarce for large-scale vision-language datasets. In this work, we propose Robust CLIP, an unsupervised adversarial fine-tuning method for vision encoders of LVLMs. We show that our method significantly improves the robustness of the vision encoder against adversarial attacks while maintaining or even improving performance on clean data. We demonstrate the effectiveness of our approach on a wide range of downstream tasks, including image classification, object detection, and visual question answering, and show that it leads to more robust LVLMs.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 41st {International} {Conference} on {Machine} {Learning}},
	publisher = {OpenReview.net},
	author = {Schlarmann, Christian and Singh, Naman Deep and Croce, Francesco and Hein, Matthias},
	year = {2024},
	keywords = {Adversarial system, Computer science, Artificial intelligence, Computer vision, processed, University of Tübingen, ICML},
}
