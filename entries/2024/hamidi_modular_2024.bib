@article{hamidi_modular_2024,
	title = {Modular {Growth} of {Hierarchical} {Networks}: {Efficient}, {General}, and {Robust} {Curriculum} {Learning}},
	shorttitle = {Modular {Growth} of {Hierarchical} {Networks}},
	url = {https://doi.org/10.1162/isal_a_00780},
	doi = {10.1162/isal_a_00780},
	abstract = {Curriculum learning is a powerful paradigm for training neural networks, yet designing effective curricula remains a significant challenge. We propose Modular Growth of Hierarchical Networks (MGHN), a novel framework that automates curriculum design by growing network architectures in tandem with task complexity. Inspired by the modular and hierarchical organization of biological brains, MGHN starts with a small, simple network and incrementally adds modules to solve increasingly complex tasks. We demonstrate that MGHN is efficient, general, and robust across a variety of reinforcement learning and supervised learning tasks. Our results show that MGHN outperforms standard curriculum learning methods and static architectures, providing a scalable approach to building complex, hierarchical representations.},
	language = {en},
	urldate = {2025-05-14},
	journal = {ALIFE 2024: Proceedings of the 2024 Artificial Life Conference},
	publisher = {MIT Press},
	author = {Hamidi, Mani and Khajehabdollahi, Sina and Giannakakis, Emmanouil and Schäfer, Tim Jakob and Levina, Anna and Wu, Charley M.},
	year = {2024},
	keywords = {Modular design, Computer science, Curriculum, Artificial intelligence, Computer architecture, Machine learning, Programming language, Sociology, processed, University of Tübingen, ALIFE},
}
