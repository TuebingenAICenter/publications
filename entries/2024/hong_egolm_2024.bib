@misc{hong_egolm_2024,
	title = {{EgoLM}: {Multi}-{Modal} {Language} {Model} of {Egocentric} {Motions}},
	shorttitle = {{EgoLM}},
	url = {https://arxiv.org/abs/2409.18127},
	doi = {10.48550/arXiv.2409.18127},
	abstract = {Egocentric motion understanding is a fundamental task for embodied AI, enabling agents to perceive and interact with the world from a first-person perspective. Existing methods often rely on specialized architectures for specific tasks, lacking a unified representation that can generalize across diverse egocentric activities. In this paper, we introduce EgoLM, a multi-modal language model designed to learn a unified representation of egocentric motions. EgoLM leverages a large-scale pre-trained language model as a backbone and incorporates a motion-to-text encoder to bridge the gap between raw motion data and natural language. By training on a diverse set of egocentric motion datasets, EgoLM learns to capture the nuances of human movement and their semantic meanings. We demonstrate the effectiveness of EgoLM on a variety of downstream tasks, including motion captioning, motion retrieval, and motion-based activity recognition, achieving state-of-the-art performance. Our results suggest that EgoLM provides a powerful and flexible framework for understanding egocentric motions, paving the way for more intelligent and interactive embodied agents.},
	language = {en},
	urldate = {2024-10-24},
	publisher = {arXiv},
	author = {Hong, Fangzhou and Guzov, Vladimir and Kim, Hyo Jin and Ye, Yuting and Newcombe, Richard and Liu, Ziwei and Ma, Lingni},
	month = sep,
	year = {2024},
	keywords = {ARXIV},
}
