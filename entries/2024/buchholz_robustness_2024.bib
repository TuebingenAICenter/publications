@inproceedings{buchholz_robustness_2024,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Robustness of {Nonlinear} {Representation} {Learning}},
	url = {https://proceedings.mlr.press/v235/buchholz24a.html},
	doi = {https://doi.org/10.48550/arXiv.2503.15355},
	abstract = {Nonlinear representation learning is a fundamental task in machine learning, with applications ranging from causal discovery to domain adaptation. A central question is whether the learned representations are identifiable, i.e., whether they recover the underlying ground-truth factors of variation. While recent work has established conditions for identifiability, these often rely on strong assumptions about the data-generating process. In this paper, we study the robustness of nonlinear representation learning to violations of these assumptions. We show that even when the data-generating process deviates from the assumed model, the learned representations can still be robust in the sense that they remain close to the ground-truth factors. We provide theoretical guarantees for this robustness and demonstrate our findings on synthetic and real-world data.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 41st {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Buchholz, Simon and Schölkopf, Bernhard},
	editor = {Salakhutdinov, Ruslan and Kolter, Zico and Heller, Katherine and Weller, Adrian and Oliver, Nuria and Scarlett, Jonathan and Berkenkamp, Felix},
	month = jul,
	year = {2024},
	keywords = {Identifiability, Invertible matrix, Robustness (evolution), Nonlinear system, Representation (politics), A priori and a posteriori, Mixing (physics), Independent component analysis, processed, MPI-IS, ELLIS Institute Tübingen, ICML},
}
