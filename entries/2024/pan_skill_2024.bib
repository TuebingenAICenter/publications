@misc{pan_skill_2024,
	title = {Skill or {Luck}? {Return} {Decomposition} via {Advantage} {Functions}},
	shorttitle = {Skill or {Luck}?},
	url = {https://arxiv.org/abs/2402.12874},
	doi = {10.48550/arxiv.2402.12874},
	abstract = {In many domains, observed outcomes are the result of a combination of skill and luck. Distinguishing between these two factors is crucial for performance evaluation, decision-making, and learning. In this paper, we propose a framework for decomposing returns into skill and luck components using advantage functions. We show that the advantage function, which measures the expected improvement over a baseline, naturally captures the skill component of a return. We demonstrate the effectiveness of our approach in various settings, including sports, finance, and reinforcement learning, and show that it provides a more robust and interpretable measure of skill than traditional methods.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {International Conference on Learning Representations},
	author = {Pan, Hsiao-Ru and Schölkopf, Bernhard},
	month = may,
	year = {2024},
	keywords = {Luck, Decomposition, Computer science, Chemistry, Epistemology, Philosophy, Organic chemistry, ICLR},
}
