@inproceedings{guzov_interaction_2024,
	title = {Interaction {Replica}: {Tracking} human–object interaction and scene changes from human motion},
	shorttitle = {Interaction {Replica}},
	url = {https://virtualhumans.mpi-inf.mpg.de/papers/guzov23ireplica/guzov23ireplica.pdf},
	abstract = {We present Interaction Replica, a method to track human-object interactions and scene changes from a monocular video of a moving person. Existing methods for human motion capture or scene reconstruction often treat the human and the scene as independent entities. However, humans constantly interact with their environment, causing objects to move and the scene to change. We propose a framework that jointly estimates the human motion, the object motion, and the scene changes. Our method leverages a human motion capture model to provide a strong prior on the human pose and shape. We then use this to guide the estimation of object interactions and scene changes. We demonstrate that our method can track complex human-object interactions and scene changes from monocular video, outperforming existing methods.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {International {Conference} on 3D {Vision} (3DV)},
	author = {Guzov, Vladimir and Chibane, Julian and Marin, Riccardo and He, Yannan and Saracoglu, Yunus and Sattler, Torsten and Pons-Moll, Gerard},
	year = {2024},
	keywords = {3DV},
}
