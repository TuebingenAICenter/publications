@inproceedings{ehyaei_designing_2024,
	title = {Designing {Ambiguity} {Sets} for {Distributionally} {Robust} {Optimization} {Using} {Structural} {Causal} {Optimal} {Transport}},
	shorttitle = {Designing {Ambiguity} {Sets} for {DRO}},
	url = {https://is.mpg.de/hml/publications/ahmaddesign},
	doi = {10.1609/aaai.v38i16.29966},
	abstract = {Distributionally Robust Optimization (DRO) is a powerful framework for decision-making under uncertainty, where the goal is to optimize performance against the worst-case distribution within an ambiguity set. A critical challenge in DRO is the design of the ambiguity set: if it is too small, the model may overfit to the training data; if it is too large, the model may be overly conservative. In this paper, we propose a novel approach to design ambiguity sets using Structural Causal Optimal Transport (SCOT). By leveraging the causal structure of the data, we define a distance metric that accounts for the underlying causal mechanisms, allowing us to construct ambiguity sets that are more robust to distribution shifts. We demonstrate the effectiveness of our approach through extensive experiments on synthetic and real-world datasets, showing that our method outperforms existing DRO techniques in terms of both robustness and performance.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the {AAAI} {Conference} on {Artificial} {Intelligence}},
	publisher = {AAAI Press},
	author = {Ehyaei, Ahmad Reza and Farnadi, Golnoosh and Samadi, Samira},
	year = {2024},
	keywords = {Ambiguity, Curse of dimensionality, Robust optimization, Graph, Probability distribution, Key (lock), Optimal design, Robust Optimization, Robust Optimization Optimal design, AAAI},
}
