@misc{zhao_rp1m_2024,
	title = {{RP1M}: {A} {Large}-{Scale} {Motion} {Dataset} for {Piano} {Playing} with {Bi}-{Manual} {Dexterous} {Robot} {Hands}},
	shorttitle = {{RP1M}},
	url = {https://proceedings.mlr.press/v270/zhao25d.html},
	doi = {10.48550/arxiv.2408.11048},
	abstract = {We introduce RP1M, a large-scale motion dataset for piano playing with bi-manual dexterous robot hands. The dataset contains 1 million frames of high-quality motion data, captured from a human pianist using a motion capture system and retargeted to a pair of dexterous robot hands. We provide the dataset to facilitate research in dexterous manipulation, imitation learning, and music generation. We also provide a set of baseline models for motion retargeting and piano playing.},
	language = {en},
	publisher = {PMLR},
	author = {Zhao, Yi and Chen, Le and Schneider, Jan and Gao, Quankai and Kannala, Juho and Schölkopf, Bernhard and Pajarinen, Joni and Büchler, Dieter},
	editor = {Agrawal, Pulkit and Kroemer, Oliver and Burgard, Wolfram},
	month = nov,
	year = {2024},
	keywords = {Piano, Scale (ratio), Motion (physics), Robot, Computer science, Artificial intelligence, Computer vision, Human–computer interaction, Art, Geography, Art history, Cartography, CORL},
}
