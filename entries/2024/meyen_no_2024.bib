@article{meyen_no_2024,
	title = {No evidence for contextual cueing beyond explicit recognition},
	issn = {1531-5320},
	shorttitle = {No evidence for contextual cueing beyond explicit recognition},
	url = {https://link.springer.com/article/10.3758/s13423-023-02358-3},
	doi = {10.3758/s13423-023-02358-3},
	abstract = {The contextual cueing effect is a well-known phenomenon in visual search, where search performance is faster for repeated displays compared to novel displays. It is often claimed that this effect is implicit, meaning that it occurs without the observer's conscious knowledge of the repeated displays. However, this claim has been challenged by several studies. In this paper, we re-examine the evidence for implicit contextual cueing. We conducted a large-scale experiment with a design that allowed us to measure both search performance and explicit recognition of the repeated displays. Our results show that the contextual cueing effect is strongly correlated with explicit recognition. When we controlled for explicit recognition, the contextual cueing effect disappeared. These findings suggest that the contextual cueing effect may not be as implicit as previously thought and that explicit knowledge of the repeated displays plays a crucial role in the effect.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Psychonomic Bulletin \& Review},
	publisher = {Springer Nature},
	author = {Meyen, Sascha and Vadillo, Miguel A. and von Luxburg, Ulrike and Franz, Volker H.},
	year = {2024},
	keywords = {Psychology, Cognitive psychology, Cognitive science, Communication, PBR},
}
