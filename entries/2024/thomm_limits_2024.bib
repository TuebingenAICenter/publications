@article{thomm_limits_2024,
	title = {Limits of {Transformer} {Language} {Models} on {Learning} to {Compose} {Algorithms}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2024/file/0e797d5139ad94fc2dc2080c09119f29-Paper-Conference.pdf},
	doi = {10.52202/079017-0245},
	abstract = {We investigate the ability of Transformer language models to learn to compose algorithms. We focus on the task of learning to execute a composition of two simple algorithms, such as sorting and searching, or two arithmetic operations. We find that while Transformers can learn to execute individual algorithms, they struggle to compose them, even when the individual algorithms are learned well. We analyze the failure modes and find that they are related to the model's inability to maintain the state of the computation across the composition boundary. We propose a simple architectural modification that significantly improves the performance of Transformers on this task.},
	language = {en},
	journal = {Advances in Neural Information Processing Systems 37},
	publisher = {Curran Associates, Inc.},
	author = {Thomm, Jonathan and Camposampiero, Giacomo and Terzic, Aleksandar and Hersche, Michael and Schölkopf, Bernhard and Rahimi, Abbas},
	month = dec,
	year = {2024},
	keywords = {Transformer, Language model, Natural language, Modeling language, NEURIPS},
}
