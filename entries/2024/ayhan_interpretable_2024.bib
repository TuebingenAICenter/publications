@article{ayhan_interpretable_2024,
	title = {Interpretable detection of epiretinal membrane from optical coherence tomography with deep neural networks},
	copyright = {© 2024 The Author(s)},
	issn = {2045-2322},
	shorttitle = {Interpretable detection of epiretinal membrane},
	url = {https://www.nature.com/articles/s41598-024-57798-1},
	doi = {10.1038/s41598-024-57798-1},
	abstract = {Epiretinal membrane (ERM) is a common vitreoretinal interface disorder that can lead to visual impairment. Early detection and monitoring are crucial for timely intervention. Deep learning models have shown promise in automated analysis of optical coherence tomography (OCT) images, but their clinical adoption is often hindered by a lack of interpretability. In this study, we developed and validated a deep learning-based approach for the automated detection of ERM in OCT scans. We trained a convolutional neural network on a large dataset of OCT images and employed class activation mapping to provide visual explanations for the model's predictions. Our model achieved high diagnostic accuracy, with an area under the receiver operating characteristic curve of 0.98. Furthermore, the class activation maps demonstrated that the model focused on clinically relevant features, such as the presence of a hyper-reflective membrane and retinal distortion, thereby enhancing the interpretability of the system. Our findings suggest that deep learning models can provide accurate and interpretable detection of ERM, potentially facilitating clinical decision-making and improving patient outcomes.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Scientific Reports},
	publisher = {Nature Portfolio},
	author = {Ayhan, Murat Seckin and Neubauer, Jonas and Uzel, Mehmet Murat and Gelisken, Faik and Berens, Philipp},
	month = apr,
	year = {2024},
	keywords = {Optical coherence tomography, Retinal, Computer science, Receiver operating characteristic, Artificial intelligence, Data set, Epiretinal membrane, Set (abstract data type), Test set, Pattern recognition (psychology), Ophthalmology, Medicine, Vitrectomy, Machine learning, processed, University of Tübingen, SCIREP},
}
