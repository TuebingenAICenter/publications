@inproceedings{hzl_identifying_2024,
	title = {Identifying latent state transition in non-linear dynamical systems},
	url = {https://bethgelab.org/publication/2024_06_hizli_yildiz/},
	doi = {10.48550/arxiv.2406.03337},
	abstract = {Non-linear dynamical systems are ubiquitous in science and engineering, yet identifying their latent state transitions remains a significant challenge. We propose a novel framework for identifying latent state transitions in non-linear dynamical systems by leveraging the Koopman operator theory. Our approach learns a global linear representation of the non-linear dynamics in a latent space, where state transitions are identified as changes in the Koopman operator. We demonstrate the effectiveness of our method on several synthetic and real-world datasets, showing that it outperforms existing methods in identifying latent state transitions and predicting future states.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {{ICLR} 2025},
	publisher = {University of Tübingen},
	author = {Hızlı, Çağlar and Yıldız, Çağatay and Bethge, Matthias and John, ST and Marttinen, Pekka},
	year = {2024},
	keywords = {Transition (genetics), State (computer science), Statistical physics, Dynamical systems theory, Computer science, Physics, Algorithm, Chemistry, Quantum mechanics, processed, University of Tübingen, ICLR},
}
