@misc{koprucu_towards_2024,
	title = {Towards {Robust} and {Principled} {Processing} of {Point} {Clouds} {With} {SSMs}},
	shorttitle = {{NIMBA}},
	url = {https://arxiv.org/abs/2411.00151},
	doi = {10.48550/arxiv.2411.00151},
	abstract = {State Space Models (SSMs) have recently emerged as a powerful alternative to Transformers for sequence modeling, offering linear scaling with sequence length. While their success in language and audio is well-documented, their application to 3D point clouds remains largely unexplored. In this work, we introduce NIMBA, a novel framework for processing point clouds using SSMs. We identify that standard SSM formulations are ill-suited for the unordered and irregular nature of point clouds. To address this, we propose a principled approach that leverages the geometric properties of point clouds, ensuring permutation invariance and robustness to noise. Our experiments demonstrate that NIMBA achieves state-of-the-art performance on standard benchmarks while maintaining computational efficiency. We provide theoretical insights into the stability and expressivity of our proposed architecture, bridging the gap between SSMs and geometric deep learning.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Köprücü, Nursena and Okpekpe, Destiny and Orvieto, Antonio},
	year = {2024},
	keywords = {Point cloud, Point (geometry), Computer science, Artificial intelligence, Mathematics, Geometry},
}
