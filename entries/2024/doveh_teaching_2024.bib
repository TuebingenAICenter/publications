@inproceedings{doveh_teaching_2024,
	title = {Teaching {VLMs} to {Localize} {Specific} {Objects} from {In}-context {Examples} ({IPLoc})},
	shorttitle = {{IPLoc}},
	url = {https://arxiv.org/abs/2411.13317v1},
	abstract = {Vision-Language Models (VLMs) have demonstrated remarkable capabilities in understanding images and text. However, their ability to perform precise object localization based on few-shot in-context examples remains limited. In this work, we introduce IPLoc, a novel approach to teach VLMs to localize specific objects from in-context examples. We propose a simple yet effective method that leverages the VLM's inherent ability to process visual and textual information to perform object localization. We demonstrate that our approach significantly improves the localization performance of VLMs on a variety of benchmarks, outperforming existing methods while requiring minimal training.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the {IEEE}/{CVF} {International} {Conference} on {Computer} {Vision} ({ICCV})},
	publisher = {arXiv},
	author = {Doveh, Sivan and Shabtay, Nimrod and Lin, Wei and Schwartz, Eli and Kuehne, Hilde and Giryes, Raja and Feris, Rogerio and Karlinsky, Leonid and Glass, James and Arbelle, Assaf and Ullman, Shimon and Mirza, M. Jehanzeb},
	month = nov,
	year = {2024},
	keywords = {ICCV},
}
