@inproceedings{buchholz_products_2024,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Products, {Abstractions} and {Inclusions} of {Causal} {Spaces}},
	url = {https://proceedings.mlr.press/v244/buchholz24a.html},
	doi = {10.48550/arxiv.2406.00388},
	abstract = {Causal models are typically defined on a fixed set of variables. However, in many real-world scenarios, we encounter systems where the set of variables is not fixed, or where we want to relate models at different levels of abstraction. We introduce the framework of causal spaces, which allows for a formal treatment of causal models on arbitrary sets of variables. We define products of causal spaces, which allow for the combination of independent causal systems, and abstractions, which allow for the mapping of a causal space to a coarser one. We show that these operations are well-behaved and satisfy a number of desirable properties. Finally, we define inclusions of causal spaces, which allow for the embedding of a causal space into a larger one, and show that this framework provides a unified language for discussing causal models across different levels of granularity.},
	language = {en},
	booktitle = {Proceedings of {Machine} {Learning} {Research}},
	publisher = {PMLR},
	author = {Buchholz, Simon and Park, Jun-Hyung and Schölkopf, Bernhard},
	editor = {Kiyavash, Negar and Mooij, Joris M.},
	month = jul,
	year = {2024},
	keywords = {Computer science, processed, MPI-IS, UAI},
}
