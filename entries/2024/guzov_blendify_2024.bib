@misc{guzov_blendify_2024,
	title = {Blendify: {A} {Python} {Rendering} {Framework} for {Blender}},
	shorttitle = {Blendify},
	url = {https://arxiv.org/abs/2410.17858},
	doi = {10.48550/arXiv.2410.17858},
	abstract = {Rendering is a fundamental component of many computer vision and graphics pipelines. While Blender is a powerful tool for high-quality rendering, its Python API can be complex and verbose for simple tasks. We introduce Blendify, a lightweight Python framework that simplifies the interaction with Blender's rendering engine. Blendify provides a high-level, intuitive interface for scene setup, object manipulation, and rendering, making it easier to integrate Blender into research workflows. Our framework supports common rendering tasks such as camera placement, lighting, and material assignment, and is designed to be easily extensible. We demonstrate the utility of Blendify through several examples, including synthetic data generation and visualization of 3D models.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Guzov, Vladimir and Petrov, Ilya A. and Pons-Moll, Gerard},
	year = {2024},
	keywords = {Python (programming language), Computer graphics (images), Rendering (computer graphics), Computer science, Programming language},
}
