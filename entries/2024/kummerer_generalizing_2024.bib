@article{kummerer_generalizing_2024,
	title = {Generalizing fixation predictions within and across datasets: towards a universal model of free-viewing fixations},
	issn = {1534-7362},
	shorttitle = {Generalizing fixation predictions},
	url = {https://jov.arvojournals.org/article.aspx?articleid=2801820},
	doi = {10.1167/jov.24.10.1268},
	abstract = {Predicting where humans look in natural images is a fundamental task in vision science. While deep learning models have achieved high performance on specific datasets, their ability to generalize across different datasets and viewing conditions remains limited. Here, we investigate the factors that hinder generalization and propose a path towards a universal model of free-viewing fixations. We evaluate several state-of-the-art models on a diverse set of eye-tracking datasets and find that performance drops significantly when models are tested on datasets they were not trained on. We identify dataset-specific biases, such as differences in image content, task instructions, and recording setups, as key drivers of this performance gap. To address these issues, we introduce a novel training framework that incorporates data augmentation and domain adaptation techniques. Our results demonstrate that this approach significantly improves cross-dataset generalization, bringing us closer to a universal model of human fixation behavior.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Vision},
	publisher = {Association for Research in Vision and Ophthalmology},
	author = {Kümmerer, Matthias and Khanuja, Harneet Singh and Bethge, Matthias},
	year = {2024},
	keywords = {Fixation (population genetics), Computer science, Artificial intelligence, Mathematics, Biology, Genetics, processed, University of Tübingen, JOV},
}
