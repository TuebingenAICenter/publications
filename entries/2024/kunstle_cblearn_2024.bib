	shorttitle = {cblearn},
	url = {https://joss.theoj.org/papers/10.21105/joss.06139},
	doi = {10.21105/joss.06139},
	abstract = {Comparison-based machine learning (CBML) is a subfield of machine learning that deals with data in the form of comparisons (e.g., “object A is more similar to object B than to object C”) rather than absolute measurements. While many algorithms for CBML have been proposed in the literature, there is a lack of a unified, easy-to-use software library that implements these methods. cblearn is a Python library that provides a scikit-learn-compatible interface for comparison-based machine learning. It includes implementations of algorithms for ordinal embedding, comparison-based clustering, and comparison-based classification. The library is designed to be modular and extensible, allowing users to easily add new algorithms and datasets. cblearn is available on PyPI and GitHub, and is documented with examples and tutorials.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Open Source Software},
	publisher = {The Open Journal},
	author = {Künstle, David and von Luxburg, Ulrike},
	year = {2024},
	keywords = {Python (programming language), Computer science, Cluster analysis, Artificial intelligence, Similarity (geometry), Machine learning, Pattern recognition (psychology), Programming language, processed, University of Tübingen, Python, JOSS},
}
