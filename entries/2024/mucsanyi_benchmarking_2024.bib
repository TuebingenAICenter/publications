@inproceedings{mucsanyi_benchmarking_2024,
	title = {Benchmarking {Uncertainty} {Disentanglement}: {Specialized} {Uncertainties} for {Specialized} {Tasks}},
	shorttitle = {Benchmarking {Uncertainty} {Disentanglement}},
	url = {https://arxiv.org/abs/2402.19460},
	abstract = {Uncertainty estimation is crucial for reliable machine learning. While many methods exist to quantify uncertainty, they often conflate different sources of uncertainty, such as aleatoric (data-inherent) and epistemic (model-inherent) uncertainty. Recent works have proposed methods to disentangle these, but a systematic evaluation of their performance across different tasks is lacking. In this work, we introduce a comprehensive benchmark for uncertainty disentanglement. We curate a diverse set of tasks, including classification, regression, and out-of-distribution detection, and evaluate a wide range of disentanglement methods. Our results reveal that no single method consistently outperforms others across all tasks, highlighting the need for specialized uncertainty estimation methods tailored to specific tasks. We provide a unified framework and codebase to facilitate future research in this direction.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 38},
	publisher = {arXiv},
	author = {Mucsányi, Bálint and Kirchhof, Michael and Oh, Seong Joon},
	year = {2024},
	keywords = {processed, University of Tübingen, NEURIPS},
}
