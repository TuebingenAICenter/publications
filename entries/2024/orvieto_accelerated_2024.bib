@article{orvieto_accelerated_2024,
	title = {An accelerated {Lyapunov} function for {Polyak}’s {Heavy}-ball on convex quadratics},
	issn = {1862-4472},
	shorttitle = {An accelerated {Lyapunov} function for {Polyak}’s {Heavy}-ball},
	url = {https://doi.org/10.1007/s11590-024-02119-8},
	doi = {10.1007/s11590-024-02119-8},
	abstract = {We provide a new Lyapunov function for Polyak’s Heavy-ball method applied to convex quadratic functions. This Lyapunov function is 'accelerated' in the sense that it directly captures the optimal convergence rate of the method, which is faster than the standard rate of gradient descent. We show that this Lyapunov function can be used to provide a simple and direct proof of the convergence of the Heavy-ball method, and we discuss its implications for the design of new optimization algorithms.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Optimization Letters},
	publisher = {Springer},
	author = {Orvieto, Antonio},
	year = {2024},
	keywords = {Ball (mathematics), Lyapunov function, Regular polygon, Mathematics, Computational intelligence, Function (biology), Convex function, Mathematical optimization, Combinatorics, Computer science, Applied mathematics, Artificial intelligence, Mathematical analysis, Physics, Geometry, processed, MPI-IS, ELLIS Institute Tübingen, OPTL},
}
