@article{dziadzio_infinite_2024,
	title = {Infinite {dSprites} for {Disentangled} {Continual} {Learning}: {Separating} {Memory} {Edits} from {Generalization}},
	shorttitle = {Infinite {dSprites}},
	url = {https://arxiv.org/abs/2312.16731},
	doi = {10.48550/arxiv.2312.16731},
	abstract = {Continual learning (CL) aims to enable neural networks to learn from a stream of data without forgetting previously acquired knowledge. However, evaluating CL methods is often hindered by the lack of suitable benchmarks that allow for a clear distinction between memorization and generalization. In this work, we introduce Infinite dSprites (IdSprites), a novel, procedurally generated dataset designed to facilitate the study of disentangled representations in CL. IdSprites provides a controlled environment where the underlying factors of variation are known, allowing us to precisely measure how well a model generalizes to unseen combinations of factors versus how much it relies on memorizing specific samples. We use IdSprites to evaluate several state-of-the-art CL methods and show that they often struggle to disentangle the factors of variation, leading to poor generalization and a reliance on memorization. Our findings highlight the importance of disentanglement in CL and provide a new benchmark for future research in this direction.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of The 3rd Conference on Lifelong Learning Agents},
	publisher = {PMLR},
	author = {Dziadzio, Sebastian and Yıldız, Çağatay and van de Ven, Gido M. and Trzciński, Tomasz and Tuytelaars, Tinne and Bethge, Matthias},
	year = {2024},
	keywords = {Forgetting, Computer science, Memorization, Generalization, Class (philosophy), Artificial intelligence, Machine learning, Artificial neural network, Task (project management), Set (abstract data type), Isolation (microbiology), Control (management), Generative grammar, processed, University of Tübingen, COLLAS},
}
