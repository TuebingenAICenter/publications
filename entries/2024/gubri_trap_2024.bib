@inproceedings{gubri_trap_2024,
	title = {{TRAP}: {Targeted} {Random} {Adversarial} {Prompt} {Honeypot} for {Black}-{Box} {Identification}},
	shorttitle = {{TRAP}},
	url = {https://arxiv.org/abs/2402.12991},
	doi = {10.18653/v1/2024.findings-acl.683},
	abstract = {Large Language Models (LLMs) are increasingly deployed behind black-box APIs. While these models are proprietary, they are often vulnerable to model extraction and prompt leakage attacks. In this work, we propose TRAP (Targeted Random Adversarial Prompt), a novel honeypot-based defense mechanism to identify black-box LLM providers. TRAP injects unique, non-functional, and adversarial-looking prompts into the model's context. If these prompts are leaked or used to generate responses, they act as a digital watermark, allowing the model owner to identify the specific black-box API or user that leaked the prompt. We demonstrate the effectiveness of TRAP in identifying black-box models and discuss its potential as a deterrent against unauthorized model usage.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Findings of the {Association} for {Computational} {Linguistics}: {ACL} 2024},
	publisher = {Association for Computational Linguistics},
	author = {Gubri, Martin and Ulmer, Dennis and Lee, Hwaran and Yun, Sangdoo and Oh, Seong Joon},
	year = {2024},
	keywords = {Trap (plumbing), Honeypot, Identification (biology), Adversarial system, Black box, Computer science, Computer security, Physics, Artificial intelligence, Biology, Meteorology, processed, University of Tübingen, Honeypot Trap (plumbing) Identification Black box, ACL},
}
