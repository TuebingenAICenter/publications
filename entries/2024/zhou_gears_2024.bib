@inproceedings{zhou_gears_2024,
	title = {{GEARS}: {Local} {Geometry}-{Aware} {Hand}-{Object} {Interaction} {Synthesis}},
	shorttitle = {{GEARS}},
	url = {https://arxiv.org/abs/2404.01758},
	doi = {10.48550/arxiv.2404.01758},
	abstract = {Synthesizing realistic hand-object interactions is a challenging task due to the complex contact patterns and the high degrees of freedom of the human hand. Existing methods often struggle to generate precise contact and physically plausible motions, especially when dealing with diverse objects. In this paper, we propose GEARS, a novel framework for local geometry-aware hand-object interaction synthesis. Our key insight is that local geometry, specifically the local surface normals and distances, provides a strong prior for contact and interaction. We introduce a geometry-aware representation that encodes the local interaction context, enabling the model to learn fine-grained contact patterns. Furthermore, we propose a novel interaction synthesis module that leverages this representation to generate physically plausible hand motions. Extensive experiments on standard benchmarks demonstrate that GEARS significantly outperforms existing state-of-the-art methods in terms of contact accuracy, motion realism, and physical plausibility.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the {IEEE}/{CVF} {Conference} on {Computer} {Vision} and {Pattern} {Recognition} ({CVPR})},
	publisher = {IEEE},
	author = {Zhou, Keyang and Bhatnagar, Bharat Lal and Lenssen, Jan Eric and Pons-Moll, Gerard},
	year = {2024},
	keywords = {Geometry, Object (grammar), Computer science, Human–computer interaction, Mathematics, Artificial intelligence, processed, University of Tübingen, CVPR},
}
