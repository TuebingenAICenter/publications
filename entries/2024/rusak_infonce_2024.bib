@inproceedings{rusak_infonce_2024,
	title = {{InfoNCE}: {Identifying} the {Gap} {Between} {Theory} and {Practice}},
	shorttitle = {{InfoNCE}},
	url = {https://arxiv.org/abs/2407.00143},
	doi = {10.48550/arxiv.2407.00143},
	abstract = {The InfoNCE loss is the de facto standard for contrastive learning. While its theoretical properties are well-understood—specifically, its relationship to mutual information maximization—the practical behavior of InfoNCE is often at odds with these theoretical foundations. In this paper, we identify and analyze the gap between the theoretical objective and the practical implementation of InfoNCE. We show that the standard implementation of InfoNCE is not a direct estimator of mutual information, but rather a biased estimator that is heavily influenced by the choice of the batch size and the distribution of the negative samples. We provide a theoretical framework to quantify this bias and demonstrate that it can lead to suboptimal representations. Finally, we propose a simple modification to the InfoNCE loss that mitigates this bias and improves performance on downstream tasks.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 28th {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {arXiv},
	author = {Rusak, Evgenia and Reizinger, Patrik and Juhos, Attila and Bringmann, Oliver and Zimmermann, Roland S. and Brendel, Wieland},
	year = {2024},
	keywords = {Psychology, Epistemology, Philosophy, processed, University of Tübingen, MPI-IS, ELLIS Institute Tübingen, AISTATS},
}
