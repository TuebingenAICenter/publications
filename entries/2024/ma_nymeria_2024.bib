@inproceedings{ma_nymeria_2024,
	title = {Nymeria: {A} {Massive} {Collection} of {Multimodal} {Egocentric} {Daily} {Motion} in the {Wild}},
	shorttitle = {Nymeria},
	url = {https://arxiv.org/abs/2406.09905},
	doi = {10.48550/arXiv.2406.09905},
	abstract = {We present Nymeria, a massive, multimodal, egocentric dataset of daily human motion in the wild. Nymeria contains 1,200 hours of data from 300 participants performing diverse daily activities in various indoor and outdoor environments. The dataset is captured using the Project Aria glasses, providing synchronized egocentric video, IMU, eye-tracking, and 6DoF head pose, alongside high-fidelity 3D body motion captured via a multi-view motion capture system. To demonstrate the utility of Nymeria, we propose a novel task of egocentric motion reconstruction from sparse inputs and provide strong baselines. We believe Nymeria will facilitate research in egocentric perception, human motion modeling, and embodied AI.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {European {Conference} on {Computer} {Vision} ({ECCV})},
	author = {Ma, Lingni and Ye, Yuting and Hong, Fangzhou and Guzov, Vladimir and Jiang, Yifeng and Postyeni, Rowan and Pesqueira, Luis and Gamino, Alexander and Baiyya, Vijay and Kim, Hyo Jin and Bailey, Kevin and Fosas, David S. and Liu, C. Karen and Liu, Ziwei and Engel, Jakob and De Nardi, Renzo and Newcombe, Richard},
	year = {2024},
	keywords = {ECCV},
}
