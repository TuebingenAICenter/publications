@inproceedings{mir_generating_2024,
	title = {Generating {Continual} {Human} {Motion} in {Diverse} 3D {Scenes}},
	shorttitle = {{ORIGIN}},
	url = {https://arxiv.org/abs/2304.02061},
	doi = {10.1109/3dv62453.2024.00061},
	abstract = {Generating long-term, natural human motion in 3D scenes is a challenging task that requires understanding the interplay between human movement and the environment. Existing methods often focus on short-term motion prediction or generating motion in static, simple environments. In this paper, we propose ORIGIN, a method for generating continual human motion in diverse 3D scenes. Our approach leverages a hierarchical framework that first predicts a sequence of navigation goals and then generates the corresponding human motion. We introduce a novel scene-aware motion generation model that conditions on the 3D scene geometry and the navigation goals. To train our model, we curate a large-scale dataset of human motion in diverse 3D scenes. We demonstrate that our method generates natural, long-term human motion that is consistent with the 3D environment and outperforms existing baselines in both motion quality and scene consistency.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {International {Conference} on 3D {Vision} (3DV)},
	publisher = {IEEE},
	author = {Mir, Aymen and Puig, Xavier and Kanazawa, Angjoo and Pons-Moll, Gerard},
	year = {2024},
	keywords = {Motion (physics), Computer vision, Computer science, Artificial intelligence, Motion capture, Sequence (biology), Set (abstract data type), Human motion, Frame (networking), Key (lock), Computer graphics (images), processed, University of Tübingen, 3DV},
}
