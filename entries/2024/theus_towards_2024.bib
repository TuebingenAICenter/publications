@inproceedings{theus_towards_2024,
	title = {Towards {Meta}-{Pruning} via {Optimal} {Transport}},
	shorttitle = {Towards {Meta}-{Pruning} via {Optimal} {Transport}},
	url = {https://arxiv.org/abs/2402.07839},
	abstract = {Pruning deep neural networks is a standard technique to reduce their computational footprint. While many pruning methods exist, they often rely on heuristics or require expensive retraining. In this work, we propose a novel meta-pruning approach that leverages optimal transport to learn a pruning policy. Our method, which we call Meta-Pruning via Optimal Transport (MPOT), learns to map the weights of a pre-trained network to a pruned version by minimizing the Wasserstein distance between their activation distributions. We demonstrate that MPOT achieves competitive performance on various benchmarks while being significantly more efficient than existing meta-pruning techniques.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {The {Twelfth} {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Theus, A. and Geimer, O. and Wicke, F. and Hofmann, T. and Anagnostidis, S. and Singh, S. P.},
	month = may,
	year = {2024},
	keywords = {ICLR},
}
