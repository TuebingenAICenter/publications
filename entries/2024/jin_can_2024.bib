@inproceedings{jin_can_2024,
	title = {Can {Large} {Language} {Models} {Infer} {Causation} from {Correlation}?},
	shorttitle = {Can {Large} {Language} {Models} {Infer} {Causation} from {Correlation}?},
	url = {https://openreview.net/pdf?id=vqIH0ObdqL},
	doi = {10.48550/arxiv.2306.05836},
	abstract = {Large Language Models (LLMs) have demonstrated remarkable performance on various natural language processing tasks. However, their ability to perform causal reasoning—a hallmark of human intelligence—remains under-explored. In this paper, we investigate whether LLMs can infer causation from correlation. We curate a comprehensive benchmark, CausalBench, which consists of causal discovery tasks from diverse domains, including social science, medical science, and economics. We evaluate a range of state-of-the-art LLMs on CausalBench and find that while they show some promise, they still struggle to consistently infer causal relationships from observational data. We further analyze the factors that contribute to their performance and discuss the implications of our findings for the development of more robust and reliable causal reasoning systems.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {The {Twelfth} {International} {Conference} on {Learning} {Representations}},
	publisher = {OpenReview.net},
	author = {Jin, Zhijing and Liu, Jiarui and Lyu, Zhiheng and Poff, Spencer and Sachan, Mrinmaya and Mihalcea, Rada and Diab, Mona and Schölkopf, Bernhard},
	month = may,
	year = {2024},
	keywords = {Causal inference, Inference, Causality (physics), Task (project management), Generalizability theory, Computer science, Set (abstract data type), Causation, Artificial intelligence, Causal model, Causal reasoning, Machine learning, Benchmark (surveying), Natural language processing, Cognitive psychology, Data science, Psychology, Econometrics, Epistemology, Statistics, Mathematics, Developmental psychology, processed, MPI-IS, ICLR},
}
