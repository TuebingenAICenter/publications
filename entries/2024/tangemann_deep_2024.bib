@article{tangemann_deep_2024,
	title = {Deep feature matching vs spatio-temporal energy filtering for robust moving object segmentation},
	issn = {1534-7362},
	url = {https://bethgelab.org/publication/2024_05_tangemann/},
	doi = {10.1167/jov.24.10.872},
	abstract = {Moving object segmentation is a fundamental task in biological and computer vision. While classical models rely on spatio-temporal energy filtering, recent deep learning approaches often use feature matching. Here, we compare these two approaches on a challenging dataset of naturalistic videos. We find that deep feature matching outperforms spatio-temporal energy filtering, especially in the presence of complex backgrounds and varying illumination. Our results suggest that deep feature matching is a promising direction for robust moving object segmentation.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Vision},
	publisher = {Association for Research in Vision and Ophthalmology},
	author = {Tangemann, Matthias and Kümmerer, Matthias and Bethge, Matthias},
	year = {2024},
	keywords = {Artificial intelligence, Segmentation, Matching (statistics), Pattern recognition (psychology), Feature (linguistics), Object (grammar), Computer vision, Feature matching, Computer science, Energy (signal processing), Geology, Feature extraction, Mathematics, Statistics, processed, University of Tübingen, Feature (linguistics) Feature Matching, JOV},
}
