@inproceedings{orvieto_universality_2024,
	title = {Universality of {Linear} {Recurrences} {Followed} by {Nonlinear} {Projections}},
	shorttitle = {Universality of {Linear} {Recurrences}},
	url = {https://arxiv.org/abs/2307.11888},
	doi = {10.48550/arXiv.2307.11888},
	abstract = {We study the expressive power of a simple class of models consisting of a linear recurrence followed by a fixed nonlinear projection. We show that this architecture is universal: it can approximate any continuous sequence-to-sequence mapping, provided the state dimension is sufficiently large. We provide quantitative bounds on the approximation error, showing that the required state dimension scales polynomially with the sequence length and the desired precision. Our results hold for a wide range of nonlinearities, including those commonly used in deep learning. We further show that this architecture can be trained efficiently using gradient descent, and that it can achieve competitive performance on a range of sequence modeling tasks.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Proceedings of the 41st {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Orvieto, Antonio and De, Soham and Gulcehre, Caglar and Pascanu, Razvan and Smith, Samuel L.},
	year = {2024},
	keywords = {Initialization, Computer science, Universality (dynamical systems), Sequence (biology), Recurrent neural network, Nonlinear system, Theoretical computer science, Algorithm, Linear model, Diagonal, Artificial intelligence, Artificial neural network, Mathematics, Machine learning, processed, MPI-IS, ELLIS Institute Tübingen, ICML},
}
