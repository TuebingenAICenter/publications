@inproceedings{khajehabdollahi_emergent_2024,
	series = {{ICLR} 2024},
	title = {Emergent mechanisms for long timescales depend on training curriculum and affect performance in memory tasks},
	shorttitle = {Emergent mechanisms for long timescales},
	url = {https://openreview.net/forum?id=xwKt6bUkXj},
	doi = {10.48550/arxiv.2309.12927},
	abstract = {Recurrent neural networks (RNNs) are powerful tools for processing sequential information, yet their ability to maintain information over long timescales remains a challenge. While various architectural modifications have been proposed to address this, the role of the training curriculum in shaping the emergent dynamics of RNNs is less understood. Here, we investigate how the distribution of timescales in the training data influences the internal mechanisms that RNNs develop to solve memory tasks. We find that training on a curriculum with a diverse range of timescales leads to the emergence of specialized neuronal populations, each tuned to different temporal scales. In contrast, training on a uniform distribution of timescales results in less specialized representations and poorer performance on long-term memory tasks. We further show that these emergent mechanisms are robust to changes in network architecture and are consistent across different tasks. Our results suggest that the training curriculum is a critical factor in shaping the temporal processing capabilities of RNNs, providing insights into how to design more effective training protocols for sequence learning.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {The {Twelfth} {International} {Conference} on {Learning} {Representations}},
	publisher = {OpenReview.net},
	author = {Khajehabdollahi, Sina and Zeraati, Roxana and Giannakakis, Emmanouil and Schäfer, Tim Jakob and Martius, Georg and Levina, Anna},
	year = {2024},
	keywords = {Recurrent neural network, Computer science, Forgetting, Task (project management), Sequence learning, Artificial intelligence, Chunking (psychology), Artificial neural network, Stability (learning theory), Machine learning, Cognitive psychology, Psychology, processed, University of Tübingen, MPI-IS, ICLR},
}
