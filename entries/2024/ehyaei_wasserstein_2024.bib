@inproceedings{ehyaei_wasserstein_2024,
	title = {Wasserstein {Distributionally} {Robust} {Optimization} {Through} the {Lens} of {Structural} {Causal} {Models} and {Individual} {Fairness}},
	shorttitle = {Wasserstein {Distributionally} {Robust} {Optimization}},
	url = {https://is.mpg.de/hml/publications/ahmadwasser},
	doi = {10.48550/arxiv.2509.26275},
	abstract = {Distributionally Robust Optimization (DRO) is a powerful framework for learning models that are robust to distribution shifts. However, standard DRO approaches often rely on ambiguity sets defined by statistical distances, such as the Wasserstein distance, which may not capture the underlying causal structure of the data-generating process. This can lead to overly conservative models or models that fail to generalize to relevant interventions. In this paper, we propose a novel framework for Wasserstein DRO that incorporates structural causal models (SCMs) to define more meaningful ambiguity sets. We show that our approach, which we call Causal-Wasserstein DRO, allows for the incorporation of causal knowledge to improve robustness and fairness. We provide theoretical guarantees for our approach and demonstrate its effectiveness on synthetic and real-world datasets, showing that it outperforms standard DRO methods in terms of both robustness and individual fairness.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 38},
	publisher = {Curran Associates, Inc.},
	author = {Ehyaei, Ahmad Reza and Farnadi, Golnoosh and Samadi, Samira},
	year = {2024},
	keywords = {Robust optimization, Causality (physics), Optimization problem, Dual (grammatical number), Causal model, Sample (material), processed, MPI-IS, NEURIPS},
}
