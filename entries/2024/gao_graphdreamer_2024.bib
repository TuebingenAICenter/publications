@inproceedings{gao_graphdreamer_2024,
	title = {{GraphDreamer}: {Compositional} 3D {Scene} {Synthesis} from {Scene} {Graphs}},
	shorttitle = {{GraphDreamer}},
	url = {https://ieeexplore.ieee.org/document/10657819},
	doi = {10.1109/CVPR52733.2024.02012},
	abstract = {We present GraphDreamer, a framework for compositional 3D scene synthesis from scene graphs. Given a scene graph as input, our method generates a 3D scene by optimizing a set of 3D assets and their spatial arrangements. To achieve this, we propose a novel compositional 3D representation that allows for independent optimization of individual objects while maintaining global scene consistency. We leverage a pre-trained 2D diffusion model as a prior to guide the optimization process, ensuring that the generated scenes are both visually plausible and faithful to the input scene graph. Our experiments demonstrate that GraphDreamer can generate high-quality 3D scenes with complex spatial relationships and diverse object categories, outperforming existing methods in both visual quality and structural fidelity.},
	language = {en},
	booktitle = {{IEEE}/{CVF} {Conference} on {Computer} {Vision} and {Pattern} {Recognition} ({CVPR})},
	publisher = {IEEE},
	author = {Gao, Gege and Liu, Weiyang and Chen, Anpei and Geiger, Andreas and Schölkopf, Bernhard},
	month = sep,
	year = {2024},
	keywords = {Scene graph, Computer science, Object (grammar), Representation (politics), Artificial intelligence, Fidelity, Constraint (computer-aided design), Image (mathematics), Graph, Computer vision, 3d model, Information retrieval, Theoretical computer science, Computer graphics (images), Rendering (computer graphics), processed, University of Tübingen, MPI-IS, CVPR},
}
