@inproceedings{bagatella_active_2024,
	title = {Active {Fine}-{Tuning} of {Generalist} {Policies}},
	url = {https://is.mpg.de/al/publications/bagatellahubotter2024-fine-tuning},
	doi = {10.48550/arxiv.2410.05026},
	abstract = {Generalist policies, trained on diverse datasets, have shown remarkable capabilities in robotics. However, adapting these policies to new, unseen tasks remains a challenge. Standard fine-tuning often requires large amounts of task-specific data, which is expensive to collect. In this work, we propose Active Fine-Tuning (AFT), a framework that enables generalist policies to efficiently adapt to new tasks by actively selecting the most informative data for fine-tuning. We introduce a novel acquisition function based on the expected information gain about the optimal policy parameters. We demonstrate that AFT significantly outperforms standard fine-tuning and other active learning baselines in various robotic manipulation tasks, requiring fewer environment interactions to achieve high performance.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Forty-second {International} {Conference} on {Machine} {Learning}, 2025},
	publisher = {University of Tübingen},
	author = {Bagatella, Marco and Hübotter, Jonas and Martius, Georg and Krause, Andreas},
	month = oct,
	year = {2024},
	keywords = {processed, University of Tübingen, MPI-IS, Fine-tuning, ICLR},
}
