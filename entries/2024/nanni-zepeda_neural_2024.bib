@article{nanni-zepeda_neural_2024,
	title = {Neural signatures of shared subjective affective engagement and disengagement during movie viewing},
	copyright = {© 2024 Wiley Periodicals LLC.},
	issn = {1065-9471},
	shorttitle = {Neural signatures of shared subjective affective engagement},
	url = {https://doi.org/10.1002/hbm.26622},
	doi = {10.1002/hbm.26622},
	abstract = {Naturalistic stimuli, such as movies, are increasingly used in neuroimaging to study brain function in complex, real-world contexts. While inter-subject correlation (ISC) of brain activity is a common metric for shared neural processing, it remains unclear how these neural signatures relate to the subjective experience of engagement. Here, we investigated the neural correlates of shared subjective affective engagement and disengagement during movie viewing. Participants (N = 48) watched a movie while undergoing fMRI and provided continuous, real-time ratings of their affective engagement. We used a novel approach to identify moments of high shared engagement and disengagement across participants. We found that shared engagement was associated with increased ISC in the default mode network (DMN) and the dorsal attention network (DAN), suggesting a synchronization of both internal and external processing. In contrast, shared disengagement was associated with decreased ISC in these networks, but increased ISC in the visual cortex, potentially reflecting a shift toward sensory processing. These findings provide evidence for a neural basis of shared subjective affective states and highlight the role of large-scale brain networks in mediating engagement with naturalistic stimuli.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Human Brain Mapping},
	publisher = {Wiley},
	author = {Nanni-Zepeda, Melanni and DeGutis, Joseph and Wu, Charley M. and Rothlein, David and Fan, Yan and Grimm, Simone and Walter, Martin and Esterman, Michael and Zuberer, Agnieszka},
	year = {2024},
	keywords = {Disengagement theory, Psychology, Functional magnetic resonance imaging, Ventromedial prefrontal cortex, Cognitive psychology, Neural correlates of consciousness, Narrative, Prefrontal cortex, Cognition, Neuroscience, HBM},
}
