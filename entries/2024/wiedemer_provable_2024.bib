@inproceedings{wiedemer_provable_2024,
	title = {Provable {Compositional} {Generalization} for {Object}-{Centric} {Learning}},
	shorttitle = {Provable {Compositional} {Generalization}},
	url = {https://openreview.net/forum?id=7VPTUWkiDQ},
	doi = {10.48550/arxiv.2310.05327},
	abstract = {Object-centric learning aims to decompose scenes into individual objects, which is widely believed to be a prerequisite for compositional generalization. However, current object-centric models often fail to generalize to novel combinations of objects, even when they achieve high reconstruction quality. In this paper, we provide a theoretical framework to analyze the compositional generalization of object-centric models. We identify a fundamental identifiability gap: even if a model perfectly reconstructs the training data, it may fail to learn the true underlying causal factors of the scene. We prove that this gap can be closed by enforcing a specific form of consistency across different scenes. Based on this, we propose a novel training objective that provably improves compositional generalization. We demonstrate the effectiveness of our approach on several synthetic and real-world datasets, showing that it significantly outperforms existing methods in terms of compositional generalization.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {The {Twelfth} {International} {Conference} on {Learning} {Representations}},
	publisher = {OpenReview.net},
	author = {Wiedemer, Thaddäus and Brady, Jack and Panfilov, Alexander and Juhos, Attila and Bethge, Matthias and Brendel, Wieland},
	year = {2024},
	keywords = {Generalization, Computer science, Artificial intelligence, Object (grammar), Theoretical computer science, Consistency (knowledge bases), Identifiability, Encoder, Relevance (law), Conjecture, Machine learning, Cognitive science, Mathematics, Psychology, processed, University of Tübingen, MPI-IS, ELLIS Institute Tübingen, ICLR},
}
