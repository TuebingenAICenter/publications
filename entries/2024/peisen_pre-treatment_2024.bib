@article{peisen_pre-treatment_2024,
	title = {Pre-treatment 18F-{FDG}-{PET}/{CT} parameters as biomarkers for progression free survival, best overall response and overall survival in metastatic melanoma patients undergoing first-line immunotherapy},
	copyright = {CC BY 4.0},
	issn = {1932-6203},
	shorttitle = {Pre-treatment 18F-{FDG}-{PET}/{CT} parameters},
	url = {https://doi.org/10.1371/journal.pone.0296253},
	doi = {10.1371/journal.pone.0296253},
	abstract = {Background: Metastatic melanoma patients treated with immune checkpoint inhibitors (ICI) show heterogeneous responses. We aimed to evaluate the prognostic value of pre-treatment 18F-FDG-PET/CT parameters in this cohort. Methods: In this retrospective study, 78 patients with metastatic melanoma undergoing first-line ICI were included. Pre-treatment 18F-FDG-PET/CT scans were analyzed for metabolic tumor volume (MTV), total lesion glycolysis (TLG), and maximum standardized uptake value (SUVmax). Associations with progression-free survival (PFS), best overall response (BOR), and overall survival (OS) were assessed using Cox regression and logistic regression models. Results: Higher MTV and TLG were significantly associated with shorter PFS (p 0.001) and OS (p 0.001). SUVmax did not show significant prognostic value. In multivariate analysis, MTV remained an independent predictor for PFS and OS. Furthermore, higher MTV and TLG were associated with progressive disease as best overall response. Conclusion: Pre-treatment MTV and TLG are robust prognostic biomarkers for survival and treatment response in metastatic melanoma patients undergoing first-line ICI, potentially aiding in patient stratification.},
	language = {en},
	urldate = {2024-05-22},
	journal = {PLOS ONE},
	publisher = {Public Library of Science},
	author = {Peisen, F. and Gerken, A. and Dahm, I. and Nikolaou, K. and Eigentler, T. and Amaral, T. and Moltz, J. H. and Othman, A. E. and Gatidis, S.},
	month = jan,
	year = {2024},
	keywords = {PLOS ONE},
}
