@inproceedings{lin_stochastic_2024,
	title = {Stochastic {Gradient} {Descent} for {Gaussian} {Processes} {Done} {Right}},
	shorttitle = {Stochastic {Gradient} {Descent} for {Gaussian} {Processes} {Done} {Right}},
	url = {https://arxiv.org/abs/2310.20581},
	abstract = {Gaussian processes (GPs) are powerful tools for uncertainty quantification, but their computational cost scales cubically with the number of data points. While stochastic gradient descent (SGD) is the standard for training large-scale models, its application to GPs remains challenging due to the need to maintain a posterior over function values. We propose a new approach to training GPs with SGD that is both scalable and robust. Our method, which we call SGD-GP, uses a novel variational inference objective that allows for mini-batch training while maintaining the full GP posterior. We demonstrate that SGD-GP achieves state-of-the-art performance on a range of regression and classification tasks, while being significantly faster than existing methods.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {The {Twelfth} {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Lin, J. A. and Padhy, S. and Antorán, J. and Tripp, A. and Terenin, A. and Szepesvari, C. and Hernández-Lobato, J. M. and Janz, D.},
	month = may,
	year = {2024},
	keywords = {ICLR},
}
