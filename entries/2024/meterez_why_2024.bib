@inproceedings{meterez_why_2024,
	title = {Why do {Learning} {Rates} {Transfer}? {Reconciling} {Optimization} and {Scaling} {Limits} for {Deep} {Learning}},
	shorttitle = {Why do {Learning} {Rates} {Transfer}?},
	url = {https://arxiv.org/pdf/2402.17457v1.pdf},
	abstract = {The phenomenon of learning rate transfer—where optimal hyperparameters found on smaller models or datasets perform well on larger ones—is a cornerstone of modern deep learning. Despite its empirical success, a theoretical understanding remains elusive. In this work, we provide a theoretical framework to explain this phenomenon by reconciling optimization dynamics with scaling limits. We show that for a wide class of architectures, the optimization trajectory is governed by a continuous-time limit that is invariant to scale, provided the learning rate is appropriately rescaled. We derive the scaling laws for the learning rate and show that they are determined by the interplay between the initialization variance and the activation function. Our results provide a principled way to predict optimal learning rates for large-scale models from small-scale experiments, and we validate our findings with extensive empirical evidence.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	author = {Meterez, Andrei and Noci, Lorenzo and Hofmann, Thomas and Orvieto, Antonio},
	year = {2024},
	keywords = {NEURIPS},
}
