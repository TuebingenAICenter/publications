	urldate = {2025-05-14},
	booktitle = {Proceedings of the 41st {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Ben-Dov, O. and Fawkes, J. and Samadi, S. and Sanyal, A.},
	editor = {Salakhutdinov, Ruslan and Kolter, Zico and Heller, Katherine and Weller, Adrian and Oliver, Nuria and Scarlett, Jonathan and Berkenkamp, Felix},
	month = jul,
	year = {2024},
	keywords = {Action (physics), Collective action, Computer science, Algorithm, Artificial intelligence, Political science, Physics, Law, processed, MPI-IS, ICML},
