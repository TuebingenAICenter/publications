@inproceedings{ben-dov_role_2024,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {The {Role} of {Learning} {Algorithms} in {Collective} {Action}},
	url = {https://proceedings.mlr.press/v235/ben-dov24a.html},
	doi = {https://doi.org/10.48550/arXiv.2405.06582},
	abstract = {Collective action problems are central to social and economic life, yet they are notoriously difficult to solve. We study the role of learning algorithms in collective action by modeling a group of agents who must decide whether to contribute to a public good. We show that when agents use standard reinforcement learning algorithms to update their strategies, the system can converge to a state where the public good is provided, even when the underlying game is a prisoner's dilemma. However, we also show that this outcome is fragile: small changes in the learning dynamics or the environment can lead to a collapse of cooperation. Our results highlight the importance of understanding the interplay between learning dynamics and social incentives in the design of algorithmic systems.},
