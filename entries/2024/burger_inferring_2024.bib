@article{burger_inferring_2024,
	title = {Inferring ancestry with the hierarchical soft clustering approach {tangleGen}},
	issn = {1088-9051},
	shorttitle = {{tangleGen}},
	url = {https://genome.cshlp.org/content/34/12/2244},
	doi = {10.1101/gr.278865.124},
	abstract = {The inference of population structure is a fundamental task in population genetics. Most existing methods rely on hard clustering, assigning each individual to a single ancestral population. However, this approach fails to capture the continuous nature of genetic variation and the complex relationships between populations. We introduce tangleGen, a hierarchical soft clustering approach that models genetic data as a mixture of ancestral populations. tangleGen is based on a hierarchical model that allows for the representation of population structure at different levels of granularity. We demonstrate the effectiveness of tangleGen on simulated and real-world datasets, showing that it outperforms existing methods in capturing population structure and identifying ancestral relationships. tangleGen is implemented as an R package and is freely available.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Genome Research},
	publisher = {Cold Spring Harbor Laboratory Press},
	author = {Burger, Klara and Klepper, Solveig and von Luxburg, Ulrike and Baumdicker, Franz},
	year = {2024},
	keywords = {Cluster analysis, Hierarchical clustering, Computer science, Evolutionary biology, Artificial intelligence, Biology, processed, University of Tübingen},
}
