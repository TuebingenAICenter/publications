@article{ghosh_onebench_2024,
	title = {{ONEBench} to {Test} {Them} {All}: {Sample}-{Level} {Benchmarking} {Over} {Open}-{Ended} {Capabilities}},
	shorttitle = {{ONEBench}},
	url = {https://arxiv.org/abs/2412.06745},
	doi = {10.18653/v1/2025.acl-long.1560},
	abstract = {Current benchmarks for large multimodal models (LMMs) are often static, limited in scope, and prone to data contamination. To address these issues, we introduce ONEBench, a sample-level benchmarking framework designed to evaluate LMMs across a diverse range of open-ended capabilities. ONEBench leverages a dynamic, sample-level evaluation approach that allows for continuous updates and fine-grained analysis of model performance. We demonstrate the utility of ONEBench by evaluating several state-of-the-art LMMs, revealing significant performance gaps and highlighting the importance of sample-level benchmarking for robust model assessment.},
	language = {en},
	urldate = {2025-05-14},
	journal = {arXiv},
	publisher = {arXiv},
	author = {Ghosh, Adhiraj and Dziadzio, Sebastian and Udandarao, Vishaal and Prabhu, Ameya and Albanie, Samuel and Bethge, Matthias},
	year = {2024},
	keywords = {Benchmarking, Computer science, Sample (material), Test (biology), Business, Marketing},
}
