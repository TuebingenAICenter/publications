@inproceedings{islamov_novel_2024,
	title = {A {Novel} {Approach} to {Loss} {Landscape} {Characterization} without {Over}-{Parametrization}},
	shorttitle = {A {Novel} {Approach} to {Loss} {Landscape} {Characterization}},
	url = {https://arxiv.org/pdf/2410.12455},
	abstract = {The loss landscape of neural networks is a central object of study in deep learning. While many works have focused on the role of over-parametrization in shaping the landscape, we propose a novel approach to characterize the loss landscape that does not rely on this assumption. Our method is based on the analysis of the Hessian spectrum of the loss function, which we show can be effectively approximated using a low-rank structure. We demonstrate that this approach provides a robust and interpretable characterization of the loss landscape, and we show its utility in understanding the training dynamics of neural networks.},
	language = {en},
	urldate = {2024-10-22},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {arXiv},
	author = {Islamov, Rustem and Ajroldi, Nicolo and Orvieto, Antonio and Lucchi, Aurelien},
	year = {2024},
	keywords = {NEURIPS},
}
