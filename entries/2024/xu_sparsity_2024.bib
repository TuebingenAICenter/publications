@inproceedings{xu_sparsity_2024,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {A {Sparsity} {Principle} for {Partially} {Observable} {Causal} {Representation} {Learning}},
	shorttitle = {A {Sparsity} {Principle} for {Partially} {Observable} {Causal} {Representation} {Learning}},
	url = {https://proceedings.mlr.press/v235/xu24ac.html},
	abstract = {Causal representation learning aims to recover the underlying causal variables and their causal structure from high-dimensional observations. A major challenge in this field is partial observability, where some causal variables are unobserved (confounders). In this work, we propose a new identifiability framework for partially observable causal representation learning. We introduce a sparsity principle based on the observation that the causal graph is often sparse, and that the influence of unobserved confounders on the observed variables is limited. We show that this principle allows for the identifiability of the causal variables and the causal structure up to a permutation and component-wise transformations. We provide theoretical guarantees for our approach and demonstrate its effectiveness on synthetic and real-world datasets.},
	language = {en},
	booktitle = {Proceedings of the 41st {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Xu, D. and Yao, D. and Lachapelle, S. and Taslakian, P. and von Kügelgen, J. and Locatello, F. and Magliacane, S.},
	month = jul,
	year = {2024},
	keywords = {ICML},
}
