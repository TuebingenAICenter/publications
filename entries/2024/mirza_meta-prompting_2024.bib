@article{mirza_meta-prompting_2024,
	series = {Lecture {Notes} in {Computer} {Science}},
	title = {Meta-{Prompting} for {Automating} {Zero}-shot {Visual} {Recognition} with {LLMs}},
	issn = {1611-3349},
	shorttitle = {Meta-{Prompting}},
	url = {https://arxiv.org/abs/2403.11755},
	doi = {10.1007/978-3-031-72636-1_22},
	abstract = {Zero-shot visual recognition has been significantly advanced by vision-language models (VLMs) like CLIP, which rely on textual prompts to describe visual concepts. However, the performance of these models is highly sensitive to the choice of prompts, and manually engineering optimal prompts for every new task is labor-intensive and often suboptimal. In this work, we propose Meta-Prompting, a novel framework that automates the generation of effective prompts for zero-shot visual recognition using Large Language Models (LLMs). Instead of relying on human-crafted templates, our approach leverages the reasoning capabilities of LLMs to generate task-specific, descriptive, and diverse prompts. We introduce a meta-prompting strategy that guides the LLM to synthesize prompts by considering the visual characteristics of the target classes and the requirements of the downstream task. Our extensive experiments on various benchmarks demonstrate that Meta-Prompting consistently outperforms existing prompt engineering methods and achieves state-of-the-art performance in zero-shot classification, while significantly reducing the need for manual intervention.},
	language = {en},
	number = {14812},
	urldate = {2025-05-14},
	journal = {European Conference on Computer Vision},
	publisher = {Springer Nature Switzerland},
	author = {Mirza, M. Jehanzeb and Karlinsky, Leonid and Lin, Wei and Doveh, Sivan and Micorek, Jakub and Kozinski, Mateusz and Kuehne, Hilde and Possegger, Horst},
	year = {2024},
	keywords = {Computer science, Gaussian, Artificial intelligence, Computer vision, Computer graphics (images), Physics, processed, University of Tübingen, University of T'ubingen, ECCV},
}
