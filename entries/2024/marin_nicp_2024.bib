@article{marin_nicp_2024,
	series = {Lecture {Notes} in {Computer} {Science}},
	title = {{NICP}: {Neural} {ICP} for 3D {Human} {Registration} at {Scale}},
	issn = {1611-3349},
	shorttitle = {{NICP}},
	url = {https://arxiv.org/abs/2312.14024},
	doi = {10.1007/978-3-031-73636-0_16},
	abstract = {We present Neural ICP (NICP), a novel approach for registering 3D human scans to a template model. Traditional Iterative Closest Point (ICP) methods are robust but often struggle with large deformations and require good initial alignment. Conversely, recent learning-based methods are fast but often lack the precision of optimization-based approaches. NICP bridges this gap by learning a neural field that predicts the optimal correspondence and deformation for a given scan. Our method is trained on a large-scale dataset of human motions and can be applied to unseen subjects and poses. We demonstrate that NICP achieves state-of-the-art performance on standard benchmarks while being significantly faster than traditional optimization-based methods.},
	language = {en},
	number = {15116},
	urldate = {2025-05-14},
	journal = {Computer Vision – ECCV 2024},
	publisher = {Springer Nature Switzerland},
	author = {Marin, Riccardo and Corona, Enric and Pons-Moll, Gerard},
	year = {2024},
	keywords = {Scale (ratio), Pattern recognition (psychology), Artificial neural network, Image registration, Computer science, Leverage (statistics), Artificial intelligence, Point cloud, Scalability, Pipeline (software), Field (mathematics), Animation, Machine learning, Computer vision, Database, Cartography, Geography, processed, University of Tübingen, ECCV},
}
