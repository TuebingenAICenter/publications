@inproceedings{zhang_recurrent_2024,
	title = {Recurrent {Distance}-{Encoding} {Neural} {Networks} for {Graph} {Representation} {Learning}},
	shorttitle = {{RDEN}},
	url = {https://arxiv.org/abs/2312.01538},
	doi = {10.48550/arXiv.2312.01538},
	abstract = {Distance encoding (DE) has emerged as a powerful technique to enhance the expressive power of graph neural networks (GNNs) by injecting structural information into node representations. However, existing DE-based GNNs often suffer from high computational complexity, as they typically require pre-computing all-pairs shortest path distances or rely on expensive sampling strategies. In this paper, we propose Recurrent Distance-Encoding Neural Networks (RDEN), a novel framework that learns to encode distances in a recurrent manner. RDEN avoids the need for explicit distance pre-computation by iteratively updating distance-aware representations through message passing. We theoretically analyze the expressive power of RDEN and show that it can distinguish non-isomorphic graphs that are indistinguishable by 1-WL. Extensive experiments on various graph learning benchmarks demonstrate that RDEN achieves competitive performance while being significantly more efficient than existing DE-based methods.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Proceedings of the 41st {International} {Conference} on {Machine} {Learning}},
	author = {Zhang, Jiawei and Han, Haoyu and Liu, Qing and Liu, Yong},
	year = {2024},
	keywords = {Encoding (memory), Computer science, Graph, Representation (politics), Artificial intelligence, Artificial neural network, Theoretical computer science, Political science, ICML},
}
