@misc{pace_delphic_2024,
	title = {Delphic {Offline} {Reinforcement} {Learning} under {Nonidentifiable} {Hidden} {Confounding}},
	shorttitle = {Delphic {Offline} {Reinforcement} {Learning}},
	url = {https://arxiv.org/abs/2306.01157},
	doi = {10.48550/arxiv.2306.01157},
	abstract = {Offline reinforcement learning (RL) from observational data is often hindered by hidden confounding, which violates the standard assumption of unconfoundedness. While recent works have proposed methods to handle hidden confounding, they typically rely on strong identifiability assumptions, such as the existence of proxy variables or specific structural constraints. In this work, we study the problem of offline RL under nonidentifiable hidden confounding, where the causal effect of actions on rewards is not point-identifiable. We propose Delphic, a framework that learns a set of plausible policies by leveraging the partial identification of the optimal policy. We provide theoretical guarantees on the performance of our approach and demonstrate its effectiveness on a range of offline RL benchmarks.},
	language = {en},
	urldate = {2025-05-14},
	author = {Pace, Alizée and Yèche, Hugo and Schölkopf, Bernhard and Rätsch, Gunnar and Tennenholtz, Guy},
	month = may,
	year = {2024},
	keywords = {Confounding, Computer science, Benchmark (surveying), Artificial intelligence, Machine learning, Reinforcement learning, Econometrics, Statistics, Mathematics, ICLR},
}
