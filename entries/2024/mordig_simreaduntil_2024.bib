@article{mordig_simreaduntil_2024,
	title = {{SimReadUntil} for benchmarking selective sequencing algorithms on {ONT} devices},
	issn = {1367-4803},
	shorttitle = {{SimReadUntil}},
	url = {https://doi.org/10.1093/bioinformatics/btae199},
	doi = {10.1093/bioinformatics/btae199},
	abstract = {Selective sequencing on Oxford Nanopore Technologies (ONT) devices allows for the real-time enrichment of specific genomic regions by selectively rejecting DNA molecules during the sequencing process. This technique is increasingly used in various applications, such as pathogen detection and targeted sequencing. However, the development and benchmarking of algorithms for selective sequencing are challenging due to the high cost and variability of wet-lab experiments. To address this, we present SimReadUntil, a simulation framework that enables the benchmarking of selective sequencing algorithms using existing sequencing data. SimReadUntil provides a realistic simulation of the ONT sequencing process, including the signal acquisition and the decision-making process of the ReadUntil software. We demonstrate the utility of SimReadUntil by benchmarking several selective sequencing algorithms on different datasets, showing that it can accurately predict the performance of these algorithms in wet-lab experiments.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Bioinformatics},
	publisher = {Oxford University Press},
	author = {Mordig, Maximilian and Ratsch, Gunnar and Kahles, Andre},
	month = apr,
	year = {2024},
	keywords = {BIOINFORMATICS},
}
