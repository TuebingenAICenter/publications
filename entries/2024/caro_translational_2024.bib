@article{caro_translational_2024,
	title = {Translational symmetry in convolutions with localized kernels causes an implicit bias toward high frequency adversarial examples},
	copyright = {© 2024 Caro, Ju, Pyle, Dey, Brendel, Anselmi and Patel. This is an open-access article distributed under the terms of the Creative Commons Attribution License (CC BY).},
	issn = {1662-5188},
	shorttitle = {Translational symmetry in convolutions},
	url = {https://www.frontiersin.org/articles/10.3389/fncom.2024.1387077/full},
	doi = {10.3389/fncom.2024.1387077},
	abstract = {Convolutional neural networks (CNNs) are the standard architecture for computer vision tasks. Despite their success, they are notoriously vulnerable to adversarial examples—small, imperceptible perturbations to an input that cause the model to misclassify it. A common observation is that these adversarial perturbations are often high-frequency. In this work, we show that this phenomenon is not merely a consequence of training, but is instead an implicit bias of the convolutional architecture itself. Specifically, we prove that translational symmetry, combined with the use of localized kernels, forces the network to be more sensitive to high-frequency components of the input. We demonstrate this theoretically and empirically, showing that even randomly initialized CNNs exhibit this bias. Our results provide a fundamental explanation for the prevalence of high-frequency adversarial examples in CNNs and suggest that architectural priors play a significant role in their vulnerability.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Frontiers in Computational Neuroscience},
	publisher = {Frontiers Media S.A.},
	author = {Caro, Josue O. and Ju, Yilong and Pyle, Ryan and Dey, Sourav and Brendel, Wieland and Anselmi, Fabio and Patel, Ankit B.},
	year = {2024},
	keywords = {Frequency domain, Adversarial system, Computer science, Robustness (evolution), Kernel (algebra), Convolutional neural network, Algorithm, Artificial intelligence, Mathematics, Computer vision},
}
