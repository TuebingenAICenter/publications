@inproceedings{cirone_theoretical_2024,
	title = {Theoretical {Foundations} of {Deep} {Selective} {State}-{Space} {Models}},
	shorttitle = {Theoretical {Foundations} of {Deep} {Selective} {State}-{Space} {Models}},
	url = {https://arxiv.org/abs/2402.19047},
	doi = {10.48550/arXiv.2402.19047},
	abstract = {Selective State-Space Models (SSMs) have recently emerged as a powerful alternative to Transformers for sequence modeling, achieving state-of-the-art performance on long-range tasks. Despite their empirical success, a rigorous theoretical understanding of their capabilities and limitations remains elusive. In this work, we provide a comprehensive theoretical analysis of deep selective SSMs. We first show that selective SSMs can efficiently approximate any sequence-to-sequence function that can be represented by a broad class of recurrent neural networks, including those with high-order interactions. We then establish that selective SSMs can solve long-range dependency tasks that are provably hard for standard linear SSMs. Finally, we provide a theoretical justification for the selection mechanism, showing that it allows the model to adaptively focus on relevant parts of the input sequence, effectively performing a form of dynamic memory management. Our results provide a solid foundation for the design and analysis of future selective SSM architectures.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {Curran Associates, Inc.},
	author = {Cirone, Nicola Muca and Orvieto, Antonio and Walker, Benjamin and Salvi, Cristopher and Lyons, Terry J.},
	year = {2024},
	keywords = {State (computer science), State space, Space (punctuation), Mathematical economics, Computer science, Political science, Theoretical physics, Epistemology, Statistical physics, Physics, Mathematics, Philosophy, Algorithm, Statistics, processed, MPI-IS, ELLIS Institute Tübingen, NEURIPS},
}
