@misc{lorch_causal_2024,
	title = {Causal {Modeling} with {Stationary} {Diffusions}},
	url = {https://proceedings.mlr.press/v238/lorch24a.html},
	doi = {10.48550/arxiv.2310.17405},
	abstract = {We propose a framework for causal modeling based on stationary diffusion processes. By leveraging the connection between stochastic differential equations and causal mechanisms, we show that stationary diffusions can represent a wide class of causal models. We demonstrate that our approach allows for flexible causal discovery and inference, and we provide theoretical guarantees for the identifiability of the causal structure. Our experiments on synthetic and real-world data show that our method outperforms existing approaches in terms of accuracy and robustness.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Lorch, Lars and Krause, Andreas and Schölkopf, Bernhard},
	editor = {Dasgupta, Sanjoy and Mandt, Stephan and Li, Yingzhen},
	month = may,
	year = {2024},
	keywords = {Inference, Causal inference, Formalism (music), Stochastic differential equation, Mathematics, Applied mathematics, Kernel (algebra), Hilbert space, Graph, Causal model, Computer science, Statistical physics, Econometrics, Pure mathematics, Artificial intelligence, Discrete mathematics, Statistics, Physics, AISTATS},
