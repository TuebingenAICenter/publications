@inproceedings{schumacher_learning_2024-1,
	title = {Learning to {Control} {Emulated} {Muscles} in {Real} {Robots}: {A} {Software} {Test} {Bed} for {Bio}-{Inspired} {Actuators} in {Hardware}},
	shorttitle = {Learning to {Control} {Emulated} {Muscles} in {Real} {Robots}},
	url = {https://ieeexplore.ieee.org/document/10719699},
	doi = {10.1109/BIOROB60516.2024.10719699},
	abstract = {Bio-inspired actuators, such as emulated muscles, offer the potential to improve the energy efficiency and adaptability of robots. However, controlling these actuators is challenging due to their complex, non-linear dynamics. Reinforcement learning (RL) has shown promise in controlling such systems, but training in simulation often fails to transfer to real hardware due to the reality gap. In this paper, we present a software test bed that enables the training and evaluation of RL agents on real robots equipped with emulated muscles. Our test bed provides a standardized interface for hardware-in-the-loop training, facilitating the development and benchmarking of control strategies. We demonstrate the effectiveness of our approach by training an RL agent to control a robotic arm driven by emulated muscles, achieving performance comparable to simulation-based training while significantly reducing the reality gap.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings 10th {International} {Conference} on {Biomedical} {Robotics} and {Biomechatronics} ({BioRob})},
	publisher = {IEEE},
	author = {Schumacher, P. and Krause, L. and Schneider, J. and Büchler, D. and Martius, G. and Haeufle, D.},
	month = sep,
	year = {2024},
	keywords = {Actuator, Robot, Software, Computer science, Embedded system, Computer hardware, Test (biology), Control (management), Artificial intelligence, Operating system, BIOROB},
}
