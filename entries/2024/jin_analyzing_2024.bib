@inproceedings{jin_analyzing_2024,
	title = {Analyzing the {Role} of {Semantic} {Representations} in the {Era} of {Large} {Language} {Models}},
	url = {https://aclanthology.org/2024.naacl-long.209},
	doi = {10.18653/v1/2024.naacl-long.209},
	abstract = {Semantic representations have been a cornerstone of natural language processing (NLP) for decades. With the advent of large language models (LLMs), the field has shifted towards end-to-end learning, raising the question of whether explicit semantic representations are still necessary. In this paper, we investigate the role of semantic representations in the era of LLMs. We conduct a comprehensive study across a range of tasks and models, evaluating the impact of incorporating semantic information on model performance, robustness, and interpretability. Our findings suggest that while LLMs are capable of learning implicit semantic representations, explicit semantic information can still provide significant benefits, particularly in low-resource settings and for tasks requiring complex reasoning. We conclude by discussing the implications of our findings for future research in NLP.},
	language = {en},
	booktitle = {Annual {Conference} of the {North} {American} {Chapter} of the {Association} for {Computational} {Linguistics}},
	publisher = {Association for Computational Linguistics},
	author = {Jin, Zhijing and Chen, Yuen and Gonzalez, Fernando and Liu, Jiarui and Zhang, Jiayi and Michael, Julian and Schölkopf, Bernhard and Diab, Mona},
	editor = {Duh, Kevin and Gomez, Helena and Bethard, Steven},
	month = jun,
	year = {2024},
	keywords = {Computer science, Natural language processing, Linguistics, Artificial intelligence, Philosophy, processed, MPI-IS, NAACL},
}
