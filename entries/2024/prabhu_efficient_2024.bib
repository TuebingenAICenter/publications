@inproceedings{prabhu_efficient_2024,
	title = {Efficient {Lifelong} {Model} {Evaluation} in an {Era} of {Rapid} {Progress}},
	url = {https://bethgelab.org/publication/2024_12_udandarao2/},
	doi = {10.52202/079017-2357},
	abstract = {The rapid pace of progress in machine learning has led to a proliferation of models, making it increasingly difficult to evaluate them on lifelong learning benchmarks. Current evaluation practices are computationally expensive, often requiring full retraining or extensive inference passes for every new model. We introduce a framework for efficient lifelong model evaluation that leverages the structure of lifelong learning benchmarks to significantly reduce the computational cost of evaluation. Our approach, which we call Sort-and-Search, enables the evaluation of new models on lifelong benchmarks with a fraction of the compute required by standard methods. We demonstrate the effectiveness of our approach on a range of lifelong learning benchmarks, showing that it can achieve significant speedups while maintaining high accuracy.},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	author = {Prabhu, Ameya and Udandarao, Vishaal and Torr, Philip and Bethge, Matthias and Bibi, Adel and Albanie, Samuel},
	year = {2024},
	keywords = {Lifelong learning, Psychology, Medicine, Intensive care medicine, Pedagogy, Process (computing), Field (mathematics), Work (physics), Context (archaeology), processed, University of Tübingen, NEURIPS},
}
