@article{agrawal_causalcite_2024,
	title = {{CausalCite}: {A} {Causal} {Formulation} of {Paper} {Citations}},
	shorttitle = {{CausalCite}},
	url = {https://aclanthology.org/2024.findings-acl.497},
	doi = {10.18653/v1/2024.findings-acl.497},
	abstract = {Citations are a fundamental metric for measuring the impact of scientific work. However, the citation process is complex and influenced by many factors, such as the quality of the paper, the reputation of the authors, and the visibility of the venue. In this paper, we propose CausalCite, a causal formulation of paper citations. We model the citation process as a structural causal model (SCM) and use it to identify the causal effect of a paper's quality on its citation count. We show that our model can effectively disentangle the causal effect of quality from other confounding factors. We also demonstrate the utility of our model in a variety of tasks, including predicting citation counts and identifying influential papers.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Findings of the Association for Computational Linguistics (ACL)},
	publisher = {Association for Computational Linguistics},
	author = {Agrawal, Ishan and Jin, Zhijing and Mokhtarian, Ehsan and Guo, Siyuan and Chen, Yuen and Sachan, Mrinmaya and Schölkopf, Bernhard},
	editor = {Ku, Lun-Wei and Martins, Andre and Srikumar, Vivek},
	month = aug,
	year = {2024},
	keywords = {Computer science, processed, MPI-IS, ACL},
}
