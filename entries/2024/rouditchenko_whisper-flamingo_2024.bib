@article{rouditchenko_whisper-flamingo_2024,
	title = {Whisper-{Flamingo}: {Integrating} {Visual} {Features} into {Whisper} for {Audio}-{Visual} {Speech} {Recognition} and {Translation}},
	shorttitle = {Whisper-{Flamingo}},
	url = {https://arxiv.org/abs/2406.10082},
	abstract = {We present Whisper-Flamingo, a novel architecture that integrates visual features into the Whisper model for audio-visual speech recognition (AVSR) and audio-visual speech translation (AVST). By leveraging the pre-trained Whisper model and a Flamingo-style cross-attention mechanism, our model effectively incorporates visual information to improve performance in challenging acoustic environments. We demonstrate that Whisper-Flamingo achieves state-of-the-art results on several benchmark datasets, showing significant improvements over audio-only and existing audio-visual models.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Interspeech 2024},
	publisher = {arXiv},
	author = {Rouditchenko, Andrew and Gong, Yuan and Thomas, Samuel and Karlinsky, Leonid and Kuehne, Hilde and Feris, Rogerio and Glass, James},
	year = {2024},
	keywords = {INTERSPEECH},
}
