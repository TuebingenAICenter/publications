@article{yunus_recent_2024,
	title = {Recent {Trends} in 3D {Reconstruction} of {General} {Non}-{Rigid} {Scenes}},
	issn = {0167-7055},
	shorttitle = {Recent {Trends} in 3D {Reconstruction}},
	url = {https://arxiv.org/abs/2403.15064},
	doi = {10.1111/cgf.15062},
	abstract = {The reconstruction of non-rigid 3D scenes from monocular or multi-view video is a fundamental problem in computer vision and computer graphics. While traditional methods relied on template-based approaches or strong priors, the field has recently witnessed a paradigm shift towards template-free, data-driven, and neural representations. This survey provides a comprehensive overview of the recent trends in 3D reconstruction of general non-rigid scenes. We categorize existing methods based on their underlying representation, such as point-based, mesh-based, and volumetric representations, and discuss their strengths and limitations. Furthermore, we analyze the role of different supervision signals, including multi-view consistency, photometric loss, and learned priors. Finally, we identify open challenges and promising future research directions in this rapidly evolving field.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Computer Graphics Forum},
	publisher = {Wiley},
	author = {Yunus, Raza and Lenssen, Jan Eric and Niemeyer, Michael and Liao, Yiyi and Rupprecht, Christian and Theobalt, Christian and Pons-Moll, Gerard and Huang, Jia-Bin and Golyanik, Vladislav and Ilg, Eddy},
	year = {2024},
	keywords = {Computer science, Computer vision, Computer graphics (images), Artificial intelligence, processed, University of Tübingen, Monocular 3D Reconstruction, CGF},
}
