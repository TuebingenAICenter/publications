@inproceedings{khromov_intriguing_2024,
	title = {Some {Intriguing} {Aspects} about {Lipschitz} {Continuity} of {Neural} {Networks}},
	shorttitle = {Some {Intriguing} {Aspects} about {Lipschitz} {Continuity} of {Neural} {Networks}},
	url = {https://arxiv.org/abs/2302.10886},
	abstract = {Lipschitz continuity is a fundamental property of neural networks, often used to guarantee robustness, stability, and generalization. In this work, we revisit the Lipschitz constant of neural networks and uncover several intriguing aspects. First, we show that for a wide class of activation functions, the Lipschitz constant of a neural network is not just a property of the weights, but is also heavily influenced by the input domain. Second, we demonstrate that the standard practice of bounding the Lipschitz constant by the product of the spectral norms of the weight matrices can be extremely loose, and we provide tighter bounds. Finally, we propose a novel method for estimating the Lipschitz constant of a neural network that is both computationally efficient and accurate.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {The {Twelfth} {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Khromov, G. and Singh, S. P.},
	month = may,
	year = {2024},
	keywords = {ICLR},
}
