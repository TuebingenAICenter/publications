@inproceedings{kim_paint-it_2024,
	title = {Paint-it: {Text}-to-{Texture} {Synthesis} via {Deep} {Convolutional} {Texture} {Map} {Optimization} and {Physically}-{Based} {Rendering}},
	shorttitle = {Paint-it},
	url = {https://arxiv.org/abs/2312.11360},
	doi = {10.1109/CVPR52733.2024.00416},
	abstract = {We present Paint-it, a novel framework for generating high-quality, physically-based textures for 3D meshes from text prompts. Existing methods for text-to-3D texture generation often suffer from view-inconsistency, baked-in lighting, or low-resolution textures. To address these issues, we propose a two-stage optimization process. First, we optimize a texture map using a pre-trained text-to-image diffusion model, leveraging a physically-based rendering (PBR) pipeline to ensure view-consistency and disentangle lighting from material properties. Second, we introduce a deep convolutional texture map optimization technique that refines the texture map by learning to predict high-frequency details and correcting artifacts. Our method produces high-resolution, PBR-ready textures that are consistent across views and free from baked-in lighting, significantly outperforming existing state-of-the-art approaches in both visual quality and geometric fidelity.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {{IEEE}/{CVF} {Conference} on {Computer} {Vision} and {Pattern} {Recognition} ({CVPR})},
	publisher = {IEEE},
	author = {Kim, Youwang and Oh, Tae-Hyun and Pons-Moll, Gerard},
	year = {2024},
	keywords = {Rendering (computer graphics), Texture atlas, Texture synthesis, Computer science, Artificial intelligence, Texture compression, Projective texture mapping, Texture filtering, Convolutional neural network, Parameterized complexity, Pixel, Texture mapping, Texture memory, Computer vision, Pattern recognition (psychology), Image texture, Segmentation, Computer graphics, Algorithm, Image segmentation, 3D computer graphics, Software rendering, processed, University of Tübingen, CVPR},
}
