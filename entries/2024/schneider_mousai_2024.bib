@article{schneider_mousai_2024,
	title = {Moûsai: {Efficient} {Text}-to-{Music} {Diffusion} {Models}},
	shorttitle = {Moûsai},
	url = {https://aclanthology.org/2024.acl-long.437},
	doi = {10.18653/v1/2024.acl-long.437},
	abstract = {Diffusion models have recently achieved state-of-the-art performance in generative tasks, including text-to-audio. However, their high computational cost remains a significant barrier to widespread adoption. In this work, we introduce Moûsai, a novel architecture for efficient text-to-music generation. Moûsai leverages a cascaded diffusion approach, combining a latent diffusion model with a high-fidelity neural audio codec. By operating in a compressed latent space, Moûsai significantly reduces the computational requirements for both training and inference, while maintaining high audio quality. We demonstrate that Moûsai achieves competitive performance on standard benchmarks while being significantly more efficient than existing methods. Our code and pre-trained models are publicly available.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 62nd Annual Meeting of the Association for Computational Linguistics (Volume 1: Long Papers)},
	publisher = {Association for Computational Linguistics},
	author = {Schneider, Flavio and Kamal, Ojasv and Jin, Zhijing and Schölkopf, Bernhard},
	month = aug,
	year = {2024},
	keywords = {Diffusion, Computer science, Speech recognition, Physics, Thermodynamics, processed, MPI-IS, ACL},
}
