@article{lause_art_2024,
	title = {The art of seeing the elephant in the room: 2D embeddings of single-cell data do make sense},
	copyright = {© 2024 Lause et al. This is an open access article distributed under the terms of the Creative Commons Attribution License, which permits unrestricted use, distribution, and reproduction in any medium, provided the original author and source are credited.},
	issn = {1553-7358},
	shorttitle = {The art of seeing the elephant in the room},
	url = {https://doi.org/10.1371/journal.pcbi.1012403},
	doi = {10.1371/journal.pcbi.1012403},
	abstract = {Dimensionality reduction is a cornerstone of single-cell data analysis. While t-SNE and UMAP are widely used to visualize single-cell data in 2D, their ability to preserve global structure has been a subject of intense debate. Critics argue that 2D embeddings are misleading and should not be used for biological interpretation. Here, we argue that this criticism is often overstated. We show that 2D embeddings of single-cell data can faithfully represent the global structure of the data, provided that the embedding algorithm is initialized and parameterized correctly. We demonstrate that the apparent lack of global structure in many published embeddings is often a consequence of poor choices in algorithm parameters rather than an inherent limitation of 2D visualization. We provide guidelines for generating informative 2D embeddings and discuss the limitations of current approaches.},
	language = {en},
	urldate = {2025-05-14},
	journal = {PLOS Computational Biology},
	publisher = {Public Library of Science},
	author = {Lause, Jan and Berens, Philipp and Kobak, Dmitry},
	month = oct,
	year = {2024},
	keywords = {Sense (electronics), Art, Computer science, Communication, Aesthetics, Visual arts, Psychology, Engineering, Electrical engineering, processed, University of Tübingen},
}
