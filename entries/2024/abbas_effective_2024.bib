@inproceedings{abbas_effective_2024,
	title = {Effective pruning of web-scale datasets based on complexity of concept clusters},
	shorttitle = {Effective pruning of web-scale datasets},
	url = {https://arxiv.org/abs/2401.04578},
	doi = {10.48550/arxiv.2401.04578},
	abstract = {Data pruning, the task of selecting a subset of a large training dataset that maintains model performance, is a promising approach to reduce the computational cost of training deep learning models. However, existing pruning methods often rely on expensive metrics or are not scalable to web-scale datasets. In this work, we propose a novel, scalable pruning method based on the complexity of concept clusters. We first cluster the data into semantically meaningful concepts using a pre-trained model. We then prune the data by selecting samples that are representative of these concepts, while also considering the complexity of each concept. We show that our method, which we call Concept-based Pruning (CBP), is highly effective and scalable, achieving state-of-the-art performance on several benchmarks, including ImageNet-1K and LAION-400M. Our method is also computationally efficient, requiring only a fraction of the time compared to existing methods.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {The {Twelfth} {International} {Conference} on {Learning} {Representations}},
	publisher = {OpenReview},
	author = {Abbas, Amro and Rusak, Evgenia and Tirumala, Kushal and Brendel, Wieland and Chaudhuri, Kamalika and Morcos, Ari S.},
	year = {2024},
	keywords = {Pruning, Computer science, Benchmark (surveying), Machine learning, Scale (ratio), Artificial intelligence, Embedding, Training set, Set (abstract data type), Data mining, processed, University of Tübingen, MPI-IS, ELLIS Institute Tübingen, ICLR},
}
