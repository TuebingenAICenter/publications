@inproceedings{meterez_towards_2024,
	title = {Towards {Training} {Without} {Depth} {Limits}: {Batch} {Normalization} {Without} {Gradient} {Explosion}},
	shorttitle = {Towards {Training} {Without} {Depth} {Limits}},
	url = {https://arxiv.org/abs/2310.02012},
	abstract = {Batch Normalization (BN) is a cornerstone of modern deep learning, yet its theoretical properties remain poorly understood. A common belief is that BN stabilizes training by controlling the internal covariate shift. However, recent studies suggest that BN's success is more closely linked to the smoothness of the optimization landscape. In this work, we provide a theoretical analysis of BN in deep networks, focusing on the stability of the gradients. We show that standard BN can lead to gradient explosion in very deep networks, and we propose a simple modification to BN that prevents this phenomenon. Our theoretical findings are supported by empirical results on various architectures and datasets, demonstrating that our proposed method enables training of extremely deep networks without the need for specialized initialization or architectural modifications.},
	language = {en},
	urldate = {2024-05-22},
	author = {Meterez, A. and Joudaki, A. and Orabona, Francesco and Immer, Alexander and Rätsch, Gunnar and Daneshmand, Hadi},
	month = may,
	year = {2024},
	keywords = {ICLR},
}
