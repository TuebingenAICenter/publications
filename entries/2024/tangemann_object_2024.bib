@inproceedings{tangemann_object_2024,
	title = {Object segmentation from common fate: {Motion} energy processing enables human-like zero-shot generalization to random dot stimuli},
	shorttitle = {Object segmentation from common fate},
	url = {https://bethgelab.org/publication/2024_12_tangemann/},
	doi = {10.52202/079017-4357},
	abstract = {The ability to segment objects from a background is a fundamental task of the visual system. While deep learning models have achieved impressive performance on object segmentation in natural images, they often struggle with stimuli that require grouping based on motion cues, such as random dot kinematograms. In this work, we show that standard deep learning models fail to segment objects defined solely by common fate, even when trained on large datasets. We hypothesize that this failure is due to the lack of explicit motion energy processing in standard architectures. We propose a simple, biologically inspired motion energy module that can be integrated into existing architectures. We demonstrate that this module enables zero-shot generalization to random dot stimuli, achieving human-like performance on a variety of segmentation tasks. Our results suggest that motion energy processing is a crucial component for robust object segmentation and that incorporating such mechanisms can bridge the gap between artificial and biological vision.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 38},
	publisher = {Curran Associates, Inc.},
	author = {Tangemann, Matthias and Kümmerer, Matthias and Bethge, Matthias},
	year = {2024},
	keywords = {Segmentation, Object (grammar), Generalization, Energy (signal processing), Motion (physics), Pattern recognition (psychology), Image segmentation, processed, University of Tübingen, NEURIPS},
}
