@inproceedings{sieber_understanding_2024-1,
	title = {Understanding the differences in {Foundation} {Models}},
	shorttitle = {Understanding the differences in {Foundation} {Models}},
	url = {https://arxiv.org/pdf/2405.15731},
	abstract = {Foundation models are typically trained on massive datasets using self-supervised learning. While they often exhibit similar emergent capabilities, they differ significantly in their architecture, training objectives, and data curation. In this work, we provide a systematic framework to understand and quantify these differences. We introduce a set of metrics based on the geometry of the learned representations and the dynamics of the training process. We apply our framework to a suite of state-of-the-art foundation models, revealing distinct clusters that correspond to different design choices. Our findings provide insights into the trade-offs between different pre-training paradigms and offer a principled way to select models for downstream tasks.},
	language = {en},
	urldate = {2024-05-24},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {arXiv},
	author = {Sieber, J. and Amo Alonso, C. and Didier, A. and Zeilinger, M. N. and Orvieto, A.},
	year = {2024},
	keywords = {NEURIPS},
}
