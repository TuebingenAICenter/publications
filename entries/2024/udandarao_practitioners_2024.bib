@inproceedings{udandarao_practitioners_2024,
	title = {A {Practitioner}'s {Guide} to {Continual} {Multimodal} {Pretraining}},
	shorttitle = {A {Practitioner}'s {Guide} to {Continual} {Multimodal} {Pretraining}},
	url = {https://bethgelab.org/publication/2024_12_udandarao/},
	doi = {10.48550/arxiv.2408.14471},
	abstract = {Large-scale multimodal pretraining has become the cornerstone of modern computer vision. However, the static nature of current pretraining datasets is at odds with the dynamic, evolving nature of the real world. In this work, we investigate the challenges of continual multimodal pretraining, where a model is exposed to a sequence of data distributions over time. We first introduce a comprehensive benchmark, FOMO-in-Flux, designed to evaluate multimodal models in realistic continual learning scenarios. We then conduct an extensive empirical study of existing continual learning strategies, revealing that simple approaches often struggle to balance plasticity and stability. To address this, we propose a set of best practices for practitioners, including effective replay strategies and architectural modifications, which significantly improve performance in continual settings. Our findings provide a roadmap for developing more robust and adaptable multimodal models.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {NeurIPS},
	author = {Udandarao, Vishaal and Roth, Karsten and Dziadzio, Sebastian and Prabhu, Ameya and Cherti, Mehdi and Vinyals, Oriol and Henaff, Olivier and Albanie, Samuel and Akata, Zeynep and Bethge, Matthias},
	year = {2024},
	keywords = {Psychology, Psychotherapist, Modality (human–computer interaction), Set (abstract data type), Identification (biology), Action (physics), processed, University of Tübingen, NEURIPS},
}
