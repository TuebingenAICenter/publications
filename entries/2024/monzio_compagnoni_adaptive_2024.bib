@inproceedings{monzio_compagnoni_adaptive_2024,
	title = {Adaptive {Methods} through the {Lens} of {SDEs}},
	shorttitle = {Adaptive {Methods} through the {Lens} of {SDEs}},
	url = {https://arxiv.org/abs/2411.15958},
	doi = {10.48550/arXiv.2411.15958},
	abstract = {Adaptive optimization methods, such as Adam, are the workhorses of modern machine learning. Despite their empirical success, their theoretical understanding remains incomplete, particularly regarding their continuous-time limits. In this work, we provide a systematic derivation of the stochastic differential equations (SDEs) associated with a broad class of adaptive methods. We show that these methods converge to a specific class of SDEs characterized by state-dependent noise and preconditioning. By analyzing these SDEs, we provide new insights into the convergence behavior of adaptive methods, including their ability to escape saddle points and their implicit regularization properties. We further validate our theoretical findings with extensive numerical experiments.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {The {Thirteenth} {International} {Conference} on {Learning} {Representations}},
	publisher = {arXiv},
	author = {Monzio Compagnoni, Edoardo and Liu, Tao and Islamov, Rustem and Proske, Frank N. and Orvieto, Antonio and Lucchi, Aurélien},
	month = nov,
	year = {2024},
	keywords = {Through-the-lens metering, Noise (video), Lens (geology), Computer science, Psychology, Physics, Artificial intelligence, Optics, Image (mathematics), ICLR},
}
