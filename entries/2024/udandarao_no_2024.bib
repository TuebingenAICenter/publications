@inproceedings{udandarao_no_2024,
	title = {No {Zero}-{Shot} {Without} {Exponential} {Data}: {Pretraining} {Concept} {Frequency} {Determines} {Multimodal} {Model} {Performance}},
	shorttitle = {No {Zero}-{Shot} {Without} {Exponential} {Data}},
	url = {https://bethgelab.org/publication/2024_12_udandarao3/},
	doi = {10.48550/arXiv.2404.04125},
	abstract = {The impressive zero-shot performance of large-scale multimodal models is often attributed to their ability to generalize to unseen concepts. However, the extent to which this performance is truly 'zero-shot' remains a subject of debate. In this work, we investigate the relationship between the frequency of concepts in pretraining data and the zero-shot performance of multimodal models. We find that the zero-shot performance of these models is strongly correlated with the frequency of the concepts in the pretraining data. Specifically, we show that for a wide range of concepts, the zero-shot performance follows an exponential relationship with the pretraining frequency. Our results suggest that the 'zero-shot' capabilities of these models are largely driven by the sheer scale of the pretraining data, rather than a fundamental ability to generalize from limited examples. We further demonstrate that this relationship holds across different model architectures and pretraining datasets, highlighting the critical role of data distribution in determining model performance.},
	language = {en},
	urldate = {2025-05-22},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {Curran Associates, Inc.},
	author = {Udandarao, Vishaal and Prabhu, Ameya and Ghosh, Adhiraj and Sharma, Yash and Torr, Philip and Bibi, Adel and Albanie, Samuel and Bethge, Matthias},
	year = {2024},
	keywords = {Exponential function, Component (thermodynamics), Control theory (sociology), Generalization, processed, University of Tübingen, NEURIPS},
}
