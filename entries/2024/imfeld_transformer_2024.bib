@inproceedings{imfeld_transformer_2024,
	title = {Transformer {Fusion} with {Optimal} {Transport}},
	shorttitle = {Transformer {Fusion} with {Optimal} {Transport}},
	url = {https://arxiv.org/abs/2310.05719},
	abstract = {Model merging is a promising technique to combine the knowledge of multiple pre-trained models without further training. However, existing methods often struggle with the permutation invariance of neural network weights, which makes it difficult to align corresponding neurons across different models. In this work, we propose a novel approach to model merging based on Optimal Transport (OT). We formulate the alignment of transformer layers as an OT problem, which allows us to find a soft matching between neurons of different models. We show that our method, which we call OT-Fusion, can effectively merge transformer models and outperforms existing baselines on various benchmarks. Furthermore, we provide a theoretical analysis of our approach and show that it is robust to different initialization schemes and model architectures.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {The {Twelfth} {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Imfeld, M. and Graldi, J. and Giordano, M. and Hofmann, T. and Anagnostidis, S. and Singh, S. P.},
	month = may,
	year = {2024},
	keywords = {ICLR},
}
