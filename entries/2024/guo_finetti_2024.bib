@misc{guo_finetti_2024,
	title = {Do {Finetti}: {On} {Causal} {Effects} for {Exchangeable} {Data}},
	shorttitle = {Do {Finetti}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2024/file/e656933e4e9626f5ada42349bcadffb8-Paper-Conference.pdf},
	doi = {10.48550/arxiv.2405.18836},
	abstract = {Causal inference typically relies on the assumption of independent and identically distributed (i.i.d.) data. However, many real-world datasets are not i.i.d. but rather exchangeable. De Finetti's representation theorem states that an infinite exchangeable sequence is a mixture of i.i.d. sequences. This suggests that causal inference for exchangeable data can be framed as a hierarchical model where we first infer the latent distribution (the "de Finetti measure") and then perform causal inference conditional on this measure. In this paper, we formalize this intuition. We define causal effects for exchangeable data and show that they can be identified under a set of conditions that generalize the standard assumptions of causal inference. We provide a practical framework for estimating these effects and demonstrate its utility on synthetic and real-world data.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Guo, S. and Zhang, C. and Muhan, K. and Huszár, F. and Schölkopf, B.},
	editor = {Globerson, A. and Mackey, L. and Belgrave, D. and Fan, A. and Paquet, U. and Tomczak, J. and Zhang, C.},
	year = {2024},
	keywords = {Econometrics, Economics, NEURIPS},
}
