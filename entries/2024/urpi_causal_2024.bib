@article{urpi_causal_2024,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Causal {Action} {Influence} {Aware} {Counterfactual} {Data} {Augmentation}},
	shorttitle = {{CAI}-{CDA}},
	url = {https://proceedings.mlr.press/v235/armengol-urpi-24a.html},
	doi = {10.48550/arxiv.2405.18917},
	abstract = {Data augmentation is a powerful tool to improve the generalization of machine learning models. However, standard augmentation techniques often fail to capture the causal structure of the data-generating process, leading to models that are sensitive to spurious correlations. In this work, we propose Causal Action Influence Aware Counterfactual Data Augmentation (CAI-CDA), a novel framework that leverages causal models to generate counterfactual data points that are consistent with the underlying causal structure. We show that our method improves the robustness of models to distribution shifts and outperforms existing data augmentation techniques on several benchmarks.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 41st International Conference on Machine Learning},
	publisher = {PMLR},
	author = {Urpi, N. A. and Bagatella, M. and Vlastelica, M. and Martius, G.},
	month = jul,
	year = {2024},
	keywords = {Counterfactual thinking, Action (physics), Econometrics, Psychology, Computer science, Economics, Cognitive psychology, Social psychology, Physics, ICML},
}
