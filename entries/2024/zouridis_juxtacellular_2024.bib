@article{zouridis_juxtacellular_2024,
	title = {Juxtacellular recordings from identified neurons in the mouse locus coeruleus},
	copyright = {© 2024 The Authors. European Journal of Neuroscience published by Federation of European Neuroscience Societies and John Wiley \& Sons Ltd.},
	issn = {0953-816X},
	shorttitle = {Juxtacellular recordings from identified neurons in the mouse locus coeruleus},
	url = {https://doi.org/10.1111/ejn.16368},
	doi = {10.1111/ejn.16368},
	abstract = {The locus coeruleus (LC) is the primary source of norepinephrine in the mammalian brain and plays a critical role in arousal, attention, and cognitive control. Despite its importance, the functional properties of LC neurons in vivo remain incompletely understood, partly due to the difficulty of identifying these neurons during extracellular recordings. Here, we describe a method for juxtacellular labeling of LC neurons in the anesthetized mouse, which allows for the subsequent histological identification of the recorded cells. We show that this technique enables the reliable identification of tyrosine hydroxylase-positive LC neurons. Furthermore, we characterize the electrophysiological properties of these identified neurons, including their spontaneous firing rates, waveform characteristics, and responses to sensory stimuli. Our results provide a framework for future studies aiming to link the activity of specific LC neurons to their functional roles in behavior and cognition.},
	language = {en},
	urldate = {2025-05-14},
	journal = {European Journal of Neuroscience},
	publisher = {John Wiley \& Sons Ltd},
	author = {Zouridis, Ioannis S. and Schmors, Lisa and Fischer, Kathrin Maite and Berens, Philipp and Preston-Ferrer, Patricia and Burgalossi, Andrea},
	month = jun,
	year = {2024},
	keywords = {Locus coeruleus, Neuroscience, Electrophysiology, Tyrosine hydroxylase, Biology, Excitatory postsynaptic potential, Stimulus (psychology), Norepinephrine, Nucleus, Psychology, Inhibitory postsynaptic potential, Dopamine, processed, University of Tübingen, EJN},
}
