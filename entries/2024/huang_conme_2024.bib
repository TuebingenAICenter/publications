@article{huang_conme_2024,
	title = {{ConMe}: {Rethinking} {Evaluation} of {Compositional} {Reasoning} for {Modern} {VLMs}},
	shorttitle = {{ConMe}},
	url = {https://arxiv.org/abs/2406.08164},
	abstract = {Compositional reasoning is a fundamental capability for Vision-Language Models (VLMs). While recent benchmarks have attempted to evaluate this, they often suffer from issues such as data contamination, limited scope, or lack of fine-grained control. In this paper, we introduce ConMe, a new benchmark designed to rigorously evaluate the compositional reasoning capabilities of modern VLMs. ConMe consists of a diverse set of tasks that require models to understand and reason about the relationships between objects, attributes, and actions in images. We find that while current VLMs show impressive performance on general visual tasks, they still struggle with complex compositional reasoning, highlighting the need for more robust evaluation and training strategies.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Advances in Neural Information Processing Systems},
	publisher = {arXiv},
	author = {Huang, Irene and Lin, Wei and Mirza, Muhammad and Hansen, Jacob and Doveh, Sivan and Butoi, Victor and Herzig, Roei and Arbelle, Assaf and Kuehne, Hilde and Darrell, Trevor and Gan, Chuang and Oliva, Aude and Feris, Rogerio and Karlinsky, Leonid},
	year = {2024},
	keywords = {NEURIPS},
}
