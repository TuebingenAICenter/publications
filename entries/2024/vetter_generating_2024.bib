@article{vetter_generating_2024,
	title = {Generating realistic neurophysiological time series with denoising diffusion probabilistic models},
	copyright = {© 2024 The Author(s). Published by Elsevier Inc.},
	issn = {2666-3899},
	shorttitle = {Generating realistic neurophysiological time series},
	url = {https://www.sciencedirect.com/science/article/pii/S2666389924001892},
	doi = {10.1016/j.patter.2024.101047},
	abstract = {Neurophysiological time series, such as those from electroencephalography (EEG) or local field potentials (LFPs), are essential for understanding brain function. However, the scarcity of high-quality, labeled data and the complexity of these signals pose significant challenges for data-driven modeling. Generative models offer a promising solution by synthesizing realistic data, but existing methods often struggle to capture the intricate temporal dynamics and non-stationary nature of neurophysiological signals. Here, we introduce a framework based on denoising diffusion probabilistic models (DDPMs) to generate realistic neurophysiological time series. Our approach leverages the power of diffusion models to learn the underlying distribution of complex, multi-channel signals. We demonstrate that our model can generate synthetic data that are statistically indistinguishable from real recordings across various metrics, including power spectral density, cross-channel correlations, and phase-amplitude coupling. Furthermore, we show that our model can be conditioned on experimental variables, enabling the generation of data that reflect specific physiological states. Our results suggest that diffusion-based generative models are a powerful tool for augmenting neurophysiological datasets and advancing our understanding of brain dynamics.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Patterns},
	publisher = {Elsevier},
	author = {Vetter, Julius and Macke, Jakob H. and Gao, Richard},
	year = {2024},
	keywords = {Computer science, Probabilistic logic, Neurophysiology, Artificial intelligence, Machine learning, Generative model, Pattern recognition (psychology), Neuroscience, Generative grammar, Psychology, processed, University of Tübingen, MPI-IS},
}
