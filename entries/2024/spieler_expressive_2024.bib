@inproceedings{spieler_expressive_2024,
	title = {The {Expressive} {Leaky} {Memory} {Neuron}: an {Efficient} and {Expressive} {Phenomenological} {Neuron} {Model} {Can} {Solve} {Long}-{Horizon} {Tasks}},
	shorttitle = {The {Expressive} {Leaky} {Memory} {Neuron}},
	url = {https://arxiv.org/abs/2306.16922},
	doi = {10.48550/arXiv.2306.16922},
	abstract = {Recurrent neural networks (RNNs) are the standard architecture for processing sequential data. However, training them on long-horizon tasks remains challenging due to the vanishing gradient problem and the high computational cost of backpropagation through time. While gating mechanisms like LSTMs and GRUs mitigate these issues, they are computationally expensive and biologically implausible. Here, we introduce the Expressive Leaky Memory (ELM) neuron, a novel phenomenological neuron model that combines the computational efficiency of leaky integrate-and-fire neurons with the expressive power of gated recurrent units. The ELM neuron features a learnable time constant and a gating mechanism that allows it to adaptively integrate information over multiple timescales. We demonstrate that the ELM neuron achieves state-of-the-art performance on several long-horizon benchmarks while being significantly more efficient than standard RNNs. Our results suggest that the ELM neuron is a promising building block for efficient and scalable recurrent architectures.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {The {Twelfth} {International} {Conference} on {Learning} {Representations}},
	publisher = {OpenReview.net},
	author = {Spieler, Aaron and Rahaman, Nasim and Martius, Georg and Schölkopf, Bernhard and Levina, Anna},
	year = {2024},
	keywords = {Computer science, Biological neuron model, Neuromorphic engineering, Neuron, Context (archaeology), Artificial intelligence, Artificial neural network, Neuroscience, Psychology, processed, University of Tübingen, MPI-IS, ICLR},
}
