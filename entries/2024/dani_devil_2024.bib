@inproceedings{dani_devil_2024,
	series = {Lecture {Notes} in {Computer} {Science}},
	title = {{DeViL}: {Decoding} {Vision} features into {Language}},
	isbn = {978-3-031-54605-1},
	shorttitle = {{DeViL}},
	url = {https://link.springer.com/chapter/10.1007/978-3-031-54605-1_24},
	doi = {10.1007/978-3-031-54605-1_24},
	abstract = {Vision-Language Models (VLMs) have demonstrated remarkable capabilities in understanding visual content by aligning visual and textual representations. However, these models often rely on large-scale pre-training and complex architectures, making them computationally expensive and difficult to interpret. In this work, we propose DeViL, a novel approach to decode vision features into language. Instead of relying on end-to-end training, we leverage a pre-trained vision encoder and a frozen language model, and learn a lightweight mapping module to bridge the gap between visual and textual modalities. Our method achieves competitive performance on various vision-language tasks while being significantly more efficient and interpretable than existing approaches.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Lecture {Notes} in {Computer} {Science}},
	publisher = {Springer Nature},
	author = {Dani, Meghal and Rio-Torto, Isabel and Alaniz, Stephan and Akata, Zeynep},
	year = {2024},
	keywords = {Computer science, Closed captioning, Artificial intelligence, Language model, Natural language processing, Natural language, Vocabulary, Decoding methods, Image (mathematics), Linguistics, ECCV},
}
