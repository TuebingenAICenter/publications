@misc{orvieto_adaptive_2024,
	title = {An {Adaptive} {Method} with {Non}-negative {Gauss}-{Newton} {Stepsizes}},
	shorttitle = {An {Adaptive} {Method} with {Non}-negative {Gauss}-{Newton} {Stepsizes}},
	url = {https://arxiv.org/abs/2407.04358v1},
	doi = {10.48550/arxiv.2407.04358},
	abstract = {We propose a new adaptive optimization method for solving non-linear least-squares problems. The method uses a non-negative Gauss-Newton stepsize, which is derived from a local quadratic approximation of the objective function. We prove that the method converges to a stationary point under standard assumptions. Numerical experiments demonstrate that the proposed method is competitive with existing adaptive methods.},
	language = {en},
	urldate = {2024-05-22},
	publisher = {arXiv},
	author = {Orvieto, Antonio and Xiao, Lin},
	year = {2024},
	keywords = {Gauss, Applied mathematics, Computer science, Mathematics, Physics, Quantum mechanics, ARXIV},
}
