@article{koch_distribution_2024,
	title = {Distribution shift detection for the postmarket surveillance of medical {AI} algorithms: a retrospective simulation study},
	copyright = {© The Author(s) 2024},
	issn = {2398-6352},
	shorttitle = {Distribution shift detection for the postmarket surveillance of medical {AI} algorithms},
	url = {https://www.nature.com/articles/s41746-024-01085-w},
	doi = {10.1038/s41746-024-01085-w},
	abstract = {Medical AI algorithms are increasingly deployed in clinical practice. However, their performance can degrade over time due to distribution shifts, such as changes in patient populations or imaging hardware. Postmarket surveillance is therefore essential to ensure patient safety. Here, we propose a framework for the postmarket surveillance of medical AI algorithms based on distribution shift detection. We evaluate the performance of different shift detection methods in a retrospective simulation study using a large-scale chest X-ray dataset. We find that monitoring the distribution of the model's output probabilities is a robust and sensitive approach for detecting various types of distribution shifts. Our results demonstrate that this approach can effectively trigger alerts for performance degradation, providing a basis for proactive model maintenance and updates in clinical settings.},
	language = {en},
	urldate = {2025-01-24},
	journal = {npj Digital Medicine},
	publisher = {Nature Portfolio},
	author = {Koch, Lisa M. and Baumgartner, Christian F. and Berens, Philipp},
	month = may,
	year = {2024},
	keywords = {Computer science, Algorithm, Distribution (mathematics), Medicine, Data mining, Mathematics, processed, University of Tübingen, NPJDM},
}
