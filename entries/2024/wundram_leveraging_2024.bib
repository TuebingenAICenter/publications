@article{wundram_leveraging_2024,
	title = {Leveraging {Probabilistic} {Segmentation} {Models} for {Improved} {Glaucoma} {Diagnosis}: {A} {Clinical} {Pipeline} {Approach}},
	url = {https://openreview.net/forum?id=kcbAZwxCFV},
	abstract = {Glaucoma is a leading cause of irreversible blindness worldwide. Early detection is crucial for preventing vision loss, yet it remains challenging due to the subtle nature of early glaucomatous changes. Automated segmentation of the optic nerve head (ONH) is a key component in clinical diagnostic pipelines. However, standard segmentation models often provide point estimates, failing to capture the inherent uncertainty in medical image segmentation. In this work, we propose a clinical pipeline that leverages probabilistic segmentation models to quantify uncertainty in ONH segmentation. We demonstrate that incorporating uncertainty estimates significantly improves the diagnostic performance for glaucoma detection compared to standard deterministic models. Our approach provides a more robust and interpretable framework for clinical decision support, paving the way for more reliable automated glaucoma screening.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Medical Imaging with Deep Learning},
	publisher = {OpenReview},
	author = {Wundram, Anna-Maria and Fischer, Philipp and Wunderlich, Svenja and Faber, Hanna and Koch, Lukas M. and Berens, Philipp and Baumgartner, Constantin F.},
	month = jun,
	year = {2024},
	keywords = {MIDL},
}
