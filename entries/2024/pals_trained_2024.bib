@article{pals_trained_2024,
	title = {Trained recurrent neural networks develop phase-locked limit cycles in a working memory task},
	copyright = {CC BY 4.0},
	issn = {1553-7358},
	shorttitle = {Trained recurrent neural networks develop phase-locked limit cycles},
	url = {https://doi.org/10.1371/journal.pcbi.1011852},
	doi = {10.1371/journal.pcbi.1011852},
	abstract = {Recurrent neural networks (RNNs) are widely used to model neural dynamics in cognitive tasks. While it is known that RNNs can solve these tasks, the underlying dynamical mechanisms are often complex and high-dimensional. Here, we study RNNs trained on a working memory task that requires the maintenance of a continuous variable. We find that these networks develop a specific dynamical structure: the activity converges to a limit cycle, where the phase of the cycle encodes the stored variable. This phase-locked limit cycle structure is robust across different network initializations and training procedures. We show that this mechanism is distinct from the fixed-point attractors typically associated with working memory, and we provide a theoretical framework to understand how the network parameters shape the limit cycle dynamics. Our results suggest that phase-locked limit cycles are a viable and efficient strategy for working memory in recurrent networks.},
	language = {en},
	urldate = {2024-05-22},
	journal = {PLOS Computational Biology},
	publisher = {Public Library of Science},
	author = {Pals, M. and Macke, J. H. and Barak, O.},
	month = feb,
	year = {2024},
	keywords = {Task (project management), Limit (mathematics), Computer science, Working memory, Recurrent neural network, Phase (matter), Artificial neural network, Artificial intelligence, Cognitive psychology, Psychology, Mathematics, Neuroscience, Engineering, Physics, Cognition, processed, University of Tübingen, MPI-IS, PLOSCB},
}
