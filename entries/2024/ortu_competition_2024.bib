@article{ortu_competition_2024,
	title = {Competition of {Mechanisms}: {Tracing} {How} {Language} {Models} {Handle} {Facts} and {Counterfactuals}},
	shorttitle = {Competition of {Mechanisms}},
	url = {https://aclanthology.org/2024.acl-long.458},
	doi = {10.18653/v1/2024.acl-long.458},
	abstract = {Large Language Models (LLMs) have demonstrated remarkable capabilities in reasoning and knowledge retrieval. However, their internal mechanisms for processing factual versus counterfactual information remain poorly understood. In this work, we investigate the competition between factual and counterfactual mechanisms in LLMs. We introduce a novel framework to trace the internal representations and attention patterns of LLMs when they are presented with factual and counterfactual prompts. Our findings reveal that LLMs often rely on a mixture of mechanisms, where factual knowledge can interfere with counterfactual reasoning. We further demonstrate that this interference can be mitigated by targeted interventions, leading to improved performance on counterfactual tasks. Our results provide new insights into the interpretability of LLMs and suggest pathways for enhancing their robustness in reasoning tasks.},
	language = {en},
	journal = {Proceedings of the 62nd Annual Meeting of the Association for Computational Linguistics (ACL)},
	publisher = {Association for Computational Linguistics},
	author = {Ortu, Francesco and Jin, Zhijing and Doimo, Diego and Sachan, Mrinmaya and Cazzaniga, Alberto and Schölkopf, Bernhard},
	editor = {Ku, Lun-Wei and Martins, Andre and Srikumar, Vivek},
	month = aug,
	year = {2024},
	keywords = {Counterfactual conditional, Tracing, Computer science, Competition (biology), Programming language, Counterfactual thinking, Epistemology, processed, MPI-IS, ACL},
}
