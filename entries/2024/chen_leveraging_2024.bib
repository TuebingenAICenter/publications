@article{chen_leveraging_2024,
	title = {Leveraging {Task} {Structures} for {Improved} {Identifiability} in {Neural} {Network} {Representations}},
	shorttitle = {Leveraging {Task} {Structures} for {Improved} {Identifiability}},
	url = {https://openreview.net/forum?id=WLcPrq6pu0},
	abstract = {Deep neural networks are powerful function approximators, but their internal representations are often uninterpretable and lack identifiability, meaning that different training runs can lead to vastly different latent spaces even when they achieve similar predictive performance. This lack of identifiability hinders our ability to understand what features the model has learned and makes it difficult to compare representations across models. In this work, we propose a framework to improve the identifiability of neural network representations by leveraging the underlying task structure. We show that by incorporating auxiliary tasks that are structurally related to the primary task, we can constrain the latent space and encourage the model to learn more consistent and identifiable representations. We demonstrate the effectiveness of our approach on a variety of synthetic and real-world datasets, showing that our method leads to significantly improved identifiability compared to standard training, while maintaining or improving predictive performance.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Transactions on Machine Learning Research},
	author = {Chen, W. and Horwood, J. and Heo, J. and Hernández-Lobato, J. M.},
	month = aug,
	year = {2024},
	keywords = {TMLR},
}
