@article{kirchhof_pretrained_2024,
	title = {Pretrained {Visual} {Uncertainties}},
	shorttitle = {Pretrained {Visual} {Uncertainties}},
	url = {https://arxiv.org/abs/2402.16569},
	doi = {10.48550/arXiv.2402.16569},
	abstract = {Modern vision models are typically trained to output a single point estimate for a given input. However, in many real-world applications, it is crucial to quantify the uncertainty of these predictions. While various methods exist to estimate uncertainty, they often require additional training or multiple forward passes, which can be computationally expensive. In this work, we propose a simple yet effective approach to obtain uncertainty estimates from pretrained vision models without any additional training or fine-tuning. We leverage the internal representations of these models to estimate the aleatoric and epistemic uncertainty of their predictions. We demonstrate that our method, which we call Pretrained Visual Uncertainties (PVU), achieves competitive performance on a range of uncertainty estimation tasks, including out-of-distribution detection and misclassification detection, while being significantly more efficient than existing methods.},
	language = {en},
	urldate = {2025-05-14},
	journal = {arXiv},
	publisher = {arXiv},
	author = {Kirchhof, Michael and Collier, Mark and Oh, Seong Joon and Kasneci, Enkelejda},
	year = {2024},
	keywords = {ARXIV},
}
