@inproceedings{cruz_evaluating_2024,
	title = {Evaluating language models as risk scores},
	shorttitle = {Evaluating {Language} {Models} as {Risk} {Scores}},
	url = {https://arxiv.org/abs/2407.14614v1},
	doi = {10.48550/arxiv.2407.14614},
	abstract = {Language models (LMs) are increasingly used to predict outcomes in high-stakes domains like medicine, finance, and criminal justice. In these settings, the model's output is often interpreted as a risk score. We investigate the validity of using LMs as risk scores by evaluating their calibration and discrimination properties. We find that while LMs can achieve high predictive accuracy, they are often poorly calibrated, leading to overconfident and potentially biased risk assessments. We propose a framework for evaluating LMs as risk scores and demonstrate its utility on several real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {Curran Associates, Inc.},
	author = {Cruz, André F. and Hardt, Moritz and Mendler-Dünner, Celestine},
	year = {2024},
	keywords = {Econometrics, Psychology, Actuarial science, Linguistics, Computer science, Economics, Philosophy, processed, MPI-IS, ELLIS Institute Tübingen, NEURIPS},
}
