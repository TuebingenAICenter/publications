@inproceedings{xie_template_2024,
	title = {Template {Free} {Reconstruction} of {Human}-object {Interaction} with {Procedural} {Interaction} {Generation}},
	shorttitle = {Template {Free} {Reconstruction} of {Human}-object {Interaction}},
	url = {https://arxiv.org/abs/2312.07063},
	doi = {10.1109/CVPR52733.2024.00954},
	abstract = {Reconstructing human-object interaction (HOI) from monocular images is a challenging task due to the complex contact and occlusion between the human and the object. Existing methods typically rely on pre-defined human and object templates, which limits their ability to generalize to unseen objects or diverse human shapes. In this paper, we propose a template-free approach for HOI reconstruction. We introduce a novel procedural interaction generation (ProcIGen) framework that learns to generate interaction-aware human and object representations from images. Our method does not require any template, allowing it to handle arbitrary human shapes and object geometries. We demonstrate that our approach achieves state-of-the-art performance on standard benchmarks and generalizes well to in-the-wild images.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {{IEEE}/{CVF} {Conference} on {Computer} {Vision} and {Pattern} {Recognition} ({CVPR})},
	publisher = {IEEE},
	author = {Xie, Xianghui and Bhatnagar, Bharat Lal and Lenssen, Jan Eric and Pons-Moll, Gerard},
	year = {2024},
	keywords = {Computer science, Leverage (statistics), Artificial intelligence, Object (grammar), Generalization, Polygon mesh, Template, Computer vision, Prior probability, Pattern recognition (psychology), Computer graphics (images), Mathematics, processed, University of Tübingen, CVPR},
}
