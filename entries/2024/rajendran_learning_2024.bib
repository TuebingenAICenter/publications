@misc{rajendran_learning_2024,
	title = {Learning {Interpretable} {Concepts}: {Unifying} {Causal} {Representation} {Learning} and {Foundation} {Models}},
	shorttitle = {Learning {Interpretable} {Concepts}},
	url = {https://arxiv.org/abs/2402.09236},
	doi = {10.48550/arxiv.2402.09236},
	abstract = {Foundation models have demonstrated remarkable capabilities in learning representations that are useful for a wide range of downstream tasks. However, these representations are often opaque, making it difficult to understand the concepts they capture. Causal representation learning, on the other hand, aims to learn representations that correspond to the underlying causal factors of the data-generating process. In this paper, we propose a framework that unifies these two paradigms. We show that by leveraging the causal structure of the data, we can learn representations that are not only useful for downstream tasks but also interpretable in terms of causal concepts. We demonstrate the effectiveness of our approach on a variety of tasks, including image classification, object detection, and causal discovery.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Rajendran, Goutham and Buchholz, Simon and Aragam, Bryon and Schölkopf, Bernhard and Ravikumar, Pradeep},
	year = {2024},
	keywords = {Foundation (evidence), Representation (politics), Cognitive science, Artificial intelligence, Computer science, Epistemology, Psychology, Philosophy, Political science},
}
