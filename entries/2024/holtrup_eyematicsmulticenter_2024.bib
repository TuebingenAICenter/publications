@article{holtrup_eyematicsmulticenter_2024,
	title = {{EyeMatics}—{Multicenter} data evaluation of real-world data with interoperable medical informatics},
	issn = {2731-717X},
	shorttitle = {{EyeMatics}},
	url = {https://doi.org/10.1007/s00347-024-02135-0},
	doi = {10.1007/s00347-024-02135-0},
	abstract = {Die Digitalisierung in der Augenheilkunde schreitet voran, doch die Nutzung von Real-World-Daten (RWD) aus der klinischen Routine für die Forschung bleibt aufgrund heterogener Datenstrukturen und fehlender Interoperabilität eine Herausforderung. Das Projekt EyeMatics adressiert diese Problematik durch die Etablierung einer interoperablen Dateninfrastruktur, die eine multizentrische Auswertung von RWD ermöglicht. Ziel ist es, durch standardisierte Datenformate und automatisierte Extraktionsprozesse eine valide Datenbasis für klinische Studien und Versorgungsforschung zu schaffen.},
	language = {de},
	urldate = {2025-05-22},
	journal = {Ophthalmologie},
	publisher = {Springer Nature},
	author = {Holtrup, Lukas and Varghese, Julian and Schuster, Alexander K.},
	month = nov,
	year = {2024},
	keywords = {Medicine, Humanities, Gynecology, Art, OPHTHALMOLOGIE},
}
