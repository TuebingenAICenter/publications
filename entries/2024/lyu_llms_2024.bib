@inproceedings{lyu_llms_2024,
	title = {Do {LLMs} {Think} {Fast} and {Slow}? {A} {Causal} {Study} on {Sentiment} {Analysis}},
	shorttitle = {Do {LLMs} {Think} {Fast} and {Slow}?},
	url = {https://aclanthology.org/2024.findings-emnlp.547},
	doi = {10.18653/v1/2024.findings-emnlp.547},
	abstract = {Large Language Models (LLMs) have demonstrated remarkable performance across various tasks, yet their underlying reasoning processes remain a subject of intense debate. Drawing inspiration from the dual-process theory of human cognition—which distinguishes between fast, intuitive (System 1) and slow, deliberate (System 2) thinking—we investigate whether LLMs exhibit similar cognitive patterns. We propose a causal framework to disentangle these processes in LLMs, specifically within the context of sentiment analysis. By manipulating the input and the model's internal states, we isolate the contributions of intuitive associations versus deliberate reasoning. Our findings reveal that while LLMs are capable of both modes of thinking, their reliance on System 1 versus System 2 is highly sensitive to task complexity and prompt design. This study provides a novel causal perspective on LLM reasoning, offering insights into the mechanisms that drive their performance and limitations.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Findings of the {Association} for {Computational} {Linguistics}: {EMNLP}},
	publisher = {Association for Computational Linguistics},
	author = {Lyu, Zhiheng and Jin, Zhijing and Gonzalez, Fernando and Mihalcea, Rada and Schölkopf, Bernhard and Sachan, Mrinmaya},
	editor = {Al-Onaizan, Yaser and Bansal, Mohit and Chen, Yun-Nung},
	month = nov,
	year = {2024},
	keywords = {Sentiment analysis, Computer science, Causal analysis, Econometrics, Economics, Natural language processing, processed, MPI-IS, EMNLP},
}
