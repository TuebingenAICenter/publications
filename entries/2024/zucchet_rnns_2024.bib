@inproceedings{zucchet_rnns_2024,
	title = {{RNNs}: {Vanishing} gradients are not the end of the story},
	shorttitle = {{RNNs}: {Vanishing} gradients are not the end of the story},
	url = {https://arxiv.org/abs/2405.21064},
	doi = {10.48550/arXiv.2405.21064},
	abstract = {Recurrent Neural Networks (RNNs) are often criticized for their inability to capture long-range dependencies, a phenomenon commonly attributed to the vanishing gradient problem. In this work, we challenge this narrative. We show that the vanishing gradient is not a fundamental limitation of RNNs, but rather a consequence of the specific initialization and optimization strategies typically employed. By analyzing the dynamics of RNNs through the lens of dynamical systems and control theory, we demonstrate that RNNs can be trained to capture long-range dependencies even in the presence of vanishing gradients. We provide theoretical guarantees and empirical evidence supporting our claims, showing that simple RNNs can achieve performance comparable to state-of-the-art architectures on long-range dependency tasks.},
	language = {en},
	urldate = {2024-05-30},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {arXiv},
	author = {Zucchet, Nicola and Orvieto, Antonio},
	year = {2024},
	keywords = {Artificial neural network, End-to-end principle, Physics, Computer science, Artificial intelligence, Geology, processed, MPI-IS, ELLIS Institute Tübingen, NEURIPS},
}
