@inproceedings{pals_inferring_2024,
	title = {Inferring stochastic low-rank recurrent neural networks from neural data},
	url = {https://proceedings.neurips.cc/paper_files/paper/2024/file/209423f076b6479ab3a4f45886e30306-Paper-Conference.pdf},
	doi = {10.48550/arxiv.2406.16749},
	abstract = {Recurrent neural networks (RNNs) are powerful models for understanding the dynamics of neural populations. However, fitting high-dimensional RNNs to neural data is challenging due to the large number of parameters and the difficulty of inferring latent dynamics. Low-rank RNNs have emerged as a promising alternative, as they can capture complex dynamics with a small number of parameters. In this paper, we propose a method for inferring stochastic low-rank RNNs from neural data. Our approach combines variational inference with a low-rank parameterization of the recurrent weights, allowing us to learn the latent dynamics and the noise structure of the neural population simultaneously. We demonstrate the effectiveness of our method on synthetic data and on recordings from the primary visual cortex of mice, showing that it can recover the underlying dynamics and predict neural activity with high accuracy.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 37},
	publisher = {Curran Associates, Inc.},
	author = {Pals, M. and Sağtekin, A. E. and Pei, F. and Gloeckler, M. and Macke, J. H.},
	month = dec,
	year = {2024},
	keywords = {Artificial neural network, Rank (graph theory), Computer science, Stochastic neural network, Recurrent neural network, Artificial intelligence, Mathematics, Combinatorics, processed, University of Tübingen, MPI-IS, NEURIPS, NeurIPS},
}
