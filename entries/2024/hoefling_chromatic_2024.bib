@article{hoefling_chromatic_2024,
	title = {A chromatic feature detector in the retina signals visual context changes},
	copyright = {CC BY 4.0},
	issn = {2050-084X},
	shorttitle = {A chromatic feature detector in the retina},
	url = {https://doi.org/10.7554/eLife.86860},
	doi = {10.7554/eLife.86860},
	abstract = {The retina is often viewed as a filter that extracts basic visual features. However, recent work suggests that it also performs more complex computations, such as signaling deviations from expected visual statistics. Here, we identify a specific retinal ganglion cell type in the mouse, the J-RGC, that acts as a chromatic feature detector. We show that J-RGCs are tuned to the spectral composition of the visual scene and that their responses are modulated by the global chromatic context. Specifically, J-RGCs are suppressed by the background color to which they are tuned, but respond strongly when this context changes. This mechanism allows the retina to signal changes in the spectral composition of the environment, a computation that may be important for color constancy and the detection of novel visual stimuli.},
	language = {en},
	urldate = {2025-05-14},
	journal = {eLife},
	publisher = {eLife Sciences Publications, Ltd},
	author = {Hoefling, Larissa and Szatko, Klaudia P. and Behrens, Christian and Deng, Yuyao and Qiu, Yongrong and Klindt, David Alexander and Jessen, Zachary and Schwartz, Gregory W. and Bethge, Matthias and Berens, Philipp and Franke, Katrin and Ecker, Alexander S. and Euler, Thomas},
	year = {2024},
	keywords = {Chromatic scale, Neuroscience, Looming, Computer science, Stimulus (psychology), Retina, Artificial intelligence, Context (archaeology), Contrast (vision), Convolutional neural network, Pattern recognition (psychology), Biology, Psychology, Physics, Cognitive psychology, Optics, processed, University of Tübingen, ELIFE},
}
