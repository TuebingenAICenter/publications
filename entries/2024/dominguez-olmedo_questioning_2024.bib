@inproceedings{dominguez-olmedo_questioning_2024,
	title = {Questioning the {Survey} {Responses} of {Large} {Language} {Models}},
	shorttitle = {Questioning the {Survey} {Responses} of {Large} {Language} {Models}},
	url = {https://arxiv.org/abs/2306.07951},
	doi = {10.48550/arxiv.2306.07951},
	abstract = {Large language models (LLMs) are increasingly used to simulate human survey respondents. Proponents argue that LLMs can replace human participants in social science research, citing their ability to replicate demographic distributions and survey responses. We investigate this claim by comparing LLM responses to the American Community Survey (ACS), a large-scale, high-quality demographic survey. We find that LLMs do not reliably replicate the distribution of responses in the ACS. Instead, LLM responses are highly sensitive to the prompt and the model's internal biases. We show that LLMs often fail to capture the nuances of human survey responses, such as the relationship between demographic characteristics and survey answers. Our results suggest that LLMs should be used with caution in social science research and that further research is needed to understand the limitations of LLMs as survey respondents.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {Curran Associates, Inc.},
	author = {Dominguez-Olmedo, Ricardo and Hardt, Moritz and Mendler-Dünner, Celestine},
	year = {2024},
	keywords = {Census, American Community Survey, Language model, Population, Econometrics, Principle of maximum entropy, Survey data collection, De facto, Entropy (arrow of time), Computer science, Classifier (UML), Psychology, Statistics, Data science, Artificial intelligence, Demography, Mathematics, Sociology, Political science, processed, MPI-IS, ELLIS Institute Tübingen, NEURIPS},
}
