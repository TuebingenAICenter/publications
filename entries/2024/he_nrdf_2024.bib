@inproceedings{he_nrdf_2024,
	title = {{NRDF}: {Neural} {Riemannian} {Distance} {Fields} for {Learning} {Articulated} {Pose} {Priors}},
	shorttitle = {{NRDF}},
	url = {https://arxiv.org/abs/2403.03122},
	doi = {10.1109/CVPR52733.2024.00164},
	abstract = {Learning a prior over articulated poses is a fundamental problem in computer vision, with applications ranging from motion capture to pose estimation. Existing methods often rely on simple parametric models or data-driven approaches that struggle to generalize to unseen poses or complex articulations. In this paper, we introduce Neural Riemannian Distance Fields (NRDF), a novel representation for learning articulated pose priors. NRDF represents the pose distribution as a distance field defined on a Riemannian manifold, where the distance to the manifold of valid poses is learned. By leveraging the Riemannian structure, NRDF can effectively capture the geometry of the pose space and provide a robust prior for various downstream tasks. We demonstrate the effectiveness of NRDF on several benchmarks, showing that it outperforms existing methods in terms of both accuracy and generalization.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the {IEEE}/{CVF} {Conference} on {Computer} {Vision} and {Pattern} {Recognition} ({CVPR})},
	publisher = {IEEE},
	author = {He, Yannan and Tiwari, Garvita and Birdal, Tolga and Lenssen, Jan Eric and Pons-Moll, Gerard},
	year = {2024},
	keywords = {Prior probability, Artificial intelligence, Computer science, Machine learning, Mathematics, Bayesian probability, processed, University of Tübingen, CVPR},
}
