@inproceedings{vetter_sourcerer_2024,
	title = {Sourcerer: {Sample}-based {Maximum} {Entropy} {Source} {Distribution} {Estimation}},
	shorttitle = {Sourcerer},
	url = {https://proceedings.neurips.cc/paper_files/paper/2024/file/a1caa7bf30226ac9370889d00cbd74da-Paper-Conference.pdf},
	doi = {10.52202/079017-2817},
	abstract = {We introduce Sourcerer, a framework for estimating source distributions in inverse problems where the forward model is a black-box simulator. Sourcerer leverages the principle of maximum entropy to identify the most parsimonious source distribution consistent with observed data. By utilizing sample-based approximations, we avoid the need for explicit likelihood evaluations, making the method applicable to a wide range of complex simulators. We demonstrate the effectiveness of Sourcerer on several challenging inverse problems, showing that it provides robust and accurate estimates of the underlying source distributions.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 37 ({NeurIPS} 2024)},
	publisher = {Curran Associates, Inc.},
	author = {Vetter, J. and Moss, G. and Schröder, C. and Gao, R. and Macke, J. H.},
	month = dec,
	year = {2024},
	keywords = {Maximum entropy spectral estimation, Principle of maximum entropy, Entropy (arrow of time), Estimation theory, Maximum likelihood, Maximum entropy probability distribution, processed, University of Tübingen, MPI-IS, NEURIPS},
}
