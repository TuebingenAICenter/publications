@inproceedings{gebhard_inferring_2024,
	title = {Inferring {Atmospheric} {Properties} of {Exoplanets} with {Flow} {Matching} and {Neural} {Importance} {Sampling}},
	shorttitle = {Inferring {Atmospheric} {Properties} of {Exoplanets}},
	url = {https://ai-2-ase.github.io/papers/26%5cCameraReady%5ccamera-ready.pdf},
	abstract = {Atmospheric characterization of exoplanets is a central goal of modern astronomy. It requires solving an inverse problem: inferring physical parameters from observed spectra. This is typically done using Bayesian inference, which is computationally expensive due to the need for millions of forward model evaluations. Simulation-based inference (SBI) has emerged as a promising alternative, allowing for amortized inference. However, current SBI methods often struggle with high-dimensional parameter spaces and complex likelihood surfaces. In this work, we propose a novel approach for atmospheric retrieval using flow matching and neural importance sampling. We demonstrate that our method can accurately infer atmospheric parameters from synthetic spectra, while significantly reducing the computational cost compared to traditional methods.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {3rd {Annual} {AAAI} {Workshop} on {AI} to {Accelerate} {Science} and {Engineering} ({AI2ASE})},
	author = {Gebhard, T. D. and Wildberger, J. and Dax, M. and Angerhausen, D. and Quanz, S. P. and Schölkopf, B.},
	month = feb,
	year = {2024},
	keywords = {AI2ASE},
}
