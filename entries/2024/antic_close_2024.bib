@inproceedings{antic_close_2024,
	title = {{CloSe}: {A} 3D {Clothing} {Segmentation} {Dataset} and {Model}},
	isbn = {979-8-3503-8566-3},
	shorttitle = {{CloSe}},
	url = {https://arxiv.org/abs/2401.12051},
	doi = {10.1109/3dv62453.2024.00020},
	abstract = {Clothing segmentation is a fundamental task for many applications in computer vision and graphics, such as virtual try-on, clothing transfer, and animation. However, existing datasets for 3D clothing segmentation are limited in scale, diversity, and annotation quality. In this paper, we introduce CloSe, a large-scale 3D clothing segmentation dataset containing 1,000 high-quality 3D scans of people in diverse clothing, annotated with 15 clothing categories. We also propose a novel model for 3D clothing segmentation that leverages a transformer-based architecture to capture long-range dependencies and local geometric features. Our model achieves state-of-the-art performance on our dataset and generalizes well to unseen clothing types and body shapes. We demonstrate the utility of our dataset and model through various downstream applications, including clothing transfer and virtual try-on.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {2024 {International} {Conference} on 3D {Vision} (3DV)},
	publisher = {IEEE},
	author = {Antić, Dimitrije and Tiwari, Garvita and Ozcomlekci, Batuhan and Marin, Riccardo and Pons-Moll, Gerard},
	year = {2024},
	keywords = {Computer science, Segmentation, Clothing, Market segmentation, Artificial intelligence, Point (geometry), Point cloud, Personalization, Generalization, Animation, Machine learning, Computer vision, Computer graphics (images), World Wide Web, processed, University of Tübingen, 3DV},
}
