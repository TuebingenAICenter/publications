@article{agudelo-espana_learning_2022,
	title = {Learning {Random} {Feature} {Dynamics} for {Uncertainty} {Quantification}},
	url = {https://ieeexplore.ieee.org/document/9993152},
	doi = {10.1109/CDC51059.2022.9993152},
	abstract = {We propose a framework for uncertainty quantification in dynamical systems by learning the evolution of random features. By leveraging the kernel trick and the theory of reproducing kernel Hilbert spaces, we approximate the Koopman operator, which governs the evolution of observables in a dynamical system. Our approach allows for the construction of a probabilistic model that captures both aleatoric and epistemic uncertainty. We demonstrate the effectiveness of our method on several benchmark problems, showing that it provides reliable uncertainty estimates while maintaining competitive predictive performance.},
	language = {en},
	urldate = {2025-05-14},
	journal = {2022 IEEE 61st IEEE Conference on Decision and Control (CDC)},
	publisher = {IEEE},
	author = {Agudelo-España, Diego and Nemmour, Yassine and Schölkopf, Bernhard and Zhu, Jia-Jie},
	month = dec,
	year = {2022},
	keywords = {Pointwise, Computer science, Leverage (statistics), Artificial neural network, System dynamics, Artificial intelligence, Feature (linguistics), Function approximation, Hilbert space, Kernel (algebra), Optimal control, Machine learning, Mathematical optimization, Algorithm, Mathematics, CDC},
}
