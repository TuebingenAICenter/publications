@misc{charusaie_sample_2022,
	title = {Sample {Efficient} {Learning} of {Predictors} that {Complement} {Humans}},
	url = {https://proceedings.mlr.press/v162/charusaie22a.html},
	doi = {10.48550/arxiv.2207.09584},
	abstract = {We study the problem of learning a predictor that complements a human decision-maker. In this setting, a model can either predict the label itself or defer to a human. We provide a theoretical framework for sample-efficient learning in this setting. We show that the sample complexity of learning a deferral model is related to the complexity of learning the predictor and the human's accuracy. We also provide an algorithm for learning a deferral model that is sample-efficient and achieves a low regret. We validate our theoretical findings with experiments on synthetic and real-world datasets.},
	language = {en},
	publisher = {PMLR},
	author = {Charusaie, Mohammad-Amin and Mozannar, Hussein and Sontag, David and Samadi, Samira},
	year = {2022},
	keywords = {Deferral, Complement (music), Computer science, Machine learning, Sample (material), Artificial intelligence, Order (exchange), Business, ICML},
}
