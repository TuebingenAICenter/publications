@misc{croce_interplay_2022,
	title = {On the interplay of adversarial robustness and architecture components: patches, convolution and attention},
	shorttitle = {On the interplay of adversarial robustness and architecture components},
	url = {https://arxiv.org/abs/2209.06953},
	doi = {10.48550/arxiv.2209.06953},
	abstract = {Recent work has shown that Vision Transformers (ViTs) can achieve higher adversarial robustness than standard CNNs when trained with adversarial training. However, it is unclear which components of the architecture are responsible for this gain. In this paper, we perform a systematic study of the interplay between architecture components and adversarial robustness. We find that the patch-based input representation is the main driver of the robustness gain of ViTs, while the self-attention mechanism plays a secondary role. We further show that a simple CNN with a patch-based input representation can match the robustness of ViTs, suggesting that the patch-based input is the key architectural component for adversarial robustness.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Croce, Francesco and Hein, Matthias},
	year = {2022},
	keywords = {Interpretability, Robustness (evolution), Architecture, Computer science, Adversarial system, Artificial intelligence, Machine learning, Transformer, Pattern recognition (psychology), Engineering, Geography, ICML},
}
