@inproceedings{toth_active_2022,
	title = {Active {Bayesian} {Causal} {Inference}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2022/hash/675e371eeeea99551ce47797ed6ed33e-Abstract-Conference.html},
	abstract = {We consider the problem of active causal structure learning, where an agent aims to identify the causal graph of a system by performing interventions. While existing approaches often rely on greedy heuristics or assume a specific functional form, we propose a principled Bayesian framework for active causal structure learning. Our approach maintains a posterior distribution over causal graphs and selects interventions that maximize the expected information gain. To make this computationally tractable, we introduce a variational approximation that allows for efficient inference and decision-making. We demonstrate the effectiveness of our method on synthetic and real-world causal discovery tasks, showing that it outperforms existing active learning strategies.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 35 ({NeurIPS} 2022)},
	publisher = {Curran Associates, Inc.},
	author = {Toth, C. and Lorch, L. and Knoll, C. and Krause, A. and Pernkopf, F. and Peharz, R. and von Kügelgen, J.},
	editor = {Koyejo, S. and Mohamed, S. and Agarwal, A. and Belgrave, D. and Cho, K. and Oh, A.},
	month = dec,
	year = {2022},
	keywords = {NEURIPS},
}
