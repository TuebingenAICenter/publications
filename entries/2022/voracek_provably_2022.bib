@misc{voracek_provably_2022,
	title = {Provably {Adversarially} {Robust} {Nearest} {Prototype} {Classifiers}},
	shorttitle = {Provably {Adversarially} {Robust} {Nearest} {Prototype} {Classifiers}},
	url = {https://arxiv.org/abs/2207.07208},
	doi = {10.48550/arXiv.2207.07208},
	abstract = {Nearest Prototype Classifiers (NPCs) are a simple and interpretable alternative to deep neural networks. While they are known to be robust to adversarial attacks in theory, their empirical robustness is often limited by the choice of the metric and the prototype selection. In this paper, we propose a novel training procedure for NPCs that guarantees adversarial robustness for a given perturbation budget. We show that our method leads to state-of-the-art certified robustness on several datasets, while maintaining high clean accuracy. Furthermore, we demonstrate that our approach is scalable to large datasets and high-dimensional inputs, making it a viable alternative to robust deep learning models.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Voráček, Václav and Hein, Matthias},
	year = {2022},
	keywords = {MNIST database, Robustness (evolution), k-nearest neighbors algorithm, Computation, Metric (unit), Scalability, Artificial neural network, Separable space, Computer science, Artificial intelligence, Algorithm, Certification, Mathematics, Discrete mathematics, Combinatorics, Engineering, Mathematical analysis, ICML},
}
