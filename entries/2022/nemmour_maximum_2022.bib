@misc{nemmour_maximum_2022,
	title = {Maximum {Mean} {Discrepancy} {Distributionally} {Robust} {Nonlinear} {Chance}-{Constrained} {Optimization} with {Finite}-{Sample} {Guarantee}},
	shorttitle = {{MMD} {Distributionally} {Robust} {Nonlinear} {Chance}-{Constrained} {Optimization}},
	url = {https://is.mpg.de/ei/publications/nemkreschzhu22},
	doi = {10.1109/CDC51059.2022.9993212},
	abstract = {We consider the problem of nonlinear chance-constrained optimization under distribution uncertainty. We propose a distributionally robust optimization (DRO) framework where the ambiguity set is defined as a ball in the space of probability measures centered at the empirical distribution, with the radius defined by the Maximum Mean Discrepancy (MMD). We show that the resulting DRO problem can be reformulated as a tractable convex optimization problem. Furthermore, we provide a finite-sample guarantee for the feasibility of the solution, which is independent of the dimension of the uncertainty space. We demonstrate the effectiveness of our approach on a nonlinear control problem.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {IEEE},
	author = {Nemmour, Yassine and Kremer, Heiner and Schölkopf, Bernhard and Zhu, Jia-Jie},
	month = dec,
	year = {2022},
	keywords = {Ambiguity, Mathematical optimization, Mathematics, Constraint (computer-aided design), Convex optimization, Dimension (graph theory), Nonlinear system, Measure (data warehouse), Robust optimization, Regular polygon, Computer science, Combinatorics, CDC},
}
