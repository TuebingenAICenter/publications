@inproceedings{bordt_bandit_2022,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {A {Bandit} {Model} for {Human}-{Machine} {Decision} {Making} with {Private} {Information} and {Opacity}},
	shorttitle = {A {Bandit} {Model} for {Human}-{Machine} {Decision} {Making}},
	url = {https://proceedings.mlr.press/v151/bordt22a.html},
	doi = {10.48550/arxiv.2007.04800},
	abstract = {We study a human-machine decision making system where a human and a machine collaborate to make a sequence of decisions. The machine provides recommendations to the human, who makes the final decision. We model this as a bandit problem where the machine has access to some features, but the human possesses private information that is not available to the machine. Furthermore, the machine's decision process is opaque to the human. We analyze the regret of this system and show that the human's private information can be used to improve the machine's performance. We also show that the opacity of the machine's decision process can lead to suboptimal decisions.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 25th {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Bordt, S. and von Luxburg, U.},
	editor = {Camps-Valls, Gustau and Ruiz, Francisco J. R. and Valera, Isabel},
	month = mar,
	year = {2022},
	keywords = {Minimax, Imperfect, Computer science, Private information retrieval, Simple (philosophy), Range (aeronautics), Perfect information, Artificial intelligence, Optimal decision, Machine learning, Upper and lower bounds, Decision maker, Mathematical optimization, Operations research, Mathematical economics, Mathematics, Decision tree, Engineering, AISTATS},
}
