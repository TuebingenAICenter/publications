@inproceedings{ma_distilling_2022,
	title = {Distilling {Knowledge} from {Self}-{Supervised} {Teacher} by {Embedding} {Graph} {Alignment}},
	url = {https://bmvc2022.mpi-inf.mpg.de/0973.pdf},
	doi = {10.48550/arxiv.2211.13264},
	abstract = {Knowledge distillation (KD) has been widely used to compress large models into smaller ones. While most existing KD methods focus on distilling knowledge from supervised teachers, we explore distilling knowledge from self-supervised teachers. We observe that self-supervised teachers learn rich structural information about the data, which is not fully captured by standard feature-based distillation. To address this, we propose a novel distillation framework, Embedding Graph Alignment (EGA), which aligns the embedding graphs of the teacher and student models. Specifically, we construct a graph for each batch of data where nodes represent samples and edges represent the similarity between samples. By minimizing the distance between the teacher's and student's embedding graphs, the student can learn the structural relationships captured by the self-supervised teacher. We demonstrate the effectiveness of our method on several benchmarks, showing that EGA consistently outperforms existing distillation methods.},
	language = {en},
	booktitle = {The 33rd {British} {Machine} {Vision} {Conference} {Proceedings}},
	publisher = {BMVA Press},
	author = {Ma, Y. and Chen, Y. and Akata, Z.},
	month = nov,
	year = {2022},
	keywords = {Computer science, Embedding, Machine learning, Artificial intelligence, Graph, Feature learning, Benchmark (surveying), Scheme (mathematics), Supervised learning, Representation (politics), Distillation, Theoretical computer science, Artificial neural network, Mathematics, BMVC},
}
