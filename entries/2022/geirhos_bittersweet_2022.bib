@article{geirhos_bittersweet_2022,
	title = {The bittersweet lesson: data-rich models narrow the behavioural gap to human vision},
	issn = {1534-7362},
	shorttitle = {The bittersweet lesson},
	url = {https://jov.arvojournals.org/article.aspx?articleid=2784043},
	doi = {10.1167/jov.22.14.3273},
	abstract = {Deep neural networks (DNNs) have become the standard model for biological vision. However, a persistent gap remains: DNNs are typically less robust to image perturbations than humans, and their error patterns differ. Here, we investigate whether this gap is due to the architecture of the models or the amount of training data. We systematically compare the behavioural consistency of various architectures (CNNs, Transformers, MLPs) trained on datasets of increasing size (from 1 million to 3.5 billion images). We find that the behavioural gap to human vision is primarily driven by the amount of training data rather than the architecture. Specifically, we show that as models are trained on more data, they become more robust to common corruptions, more similar to human error patterns, and more consistent with human object recognition. This suggests that the 'bittersweet lesson' of deep learning is that while we can narrow the gap to human vision by simply scaling up data, we may be missing fundamental inductive biases that would allow for more sample-efficient and human-like learning.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Vision},
	publisher = {Association for Research in Vision and Ophthalmology},
	author = {Geirhos, Robert and Narayanappa, Kantharaju and Mitzkus, Benjamin and Thieringer, Tizian and Bethge, Matthias and Wichmann, Felix A. and Brendel, Wieland},
	year = {2022},
	keywords = {Computer science, Artificial intelligence, Machine learning, Robustness (evolution), Parallels, Python (programming language), Consistency (knowledge bases), JOV},
}
