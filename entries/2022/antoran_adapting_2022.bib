@inproceedings{antoran_adapting_2022,
	title = {Adapting the {Linearised} {Laplace} {Model} {Evidence} for {Modern} {Deep} {Learning}},
	shorttitle = {Adapting the {Linearised} {Laplace} {Model} {Evidence}},
	url = {https://proceedings.mlr.press/v162/antoran22a.html},
	abstract = {The Laplace approximation is a popular method for Bayesian deep learning due to its computational efficiency. However, its performance is often limited by the quality of the underlying Gaussian approximation. In this work, we propose a new approach to improve the Laplace approximation by adapting the linearised Laplace model evidence. We show that our method, which we call the Linearised Laplace Model Evidence (LLME), can be used to improve the performance of the Laplace approximation in a variety of settings, including classification and regression tasks. We also provide a theoretical analysis of our method and show that it is consistent with the true model evidence in the limit of infinite data.},
	language = {en},
	booktitle = {Proceedings of the 39th {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Antoran, J. and Janz, D. and Allingham, J. U. and Daxberger, E. and Barbano, R. R. and Nalisnick, E. and Hernandez-Lobato, J. M.},
	month = jul,
	year = {2022},
	keywords = {ICML},
}
