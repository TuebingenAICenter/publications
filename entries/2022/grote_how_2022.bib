@article{grote_how_2022,
	title = {How competitors become collaborators—{Bridging} the gap(s) between machine learning algorithms and clinicians},
	issn = {0269-9702},
	shorttitle = {How competitors become collaborators},
	url = {https://onlinelibrary.wiley.com/doi/full/10.1111/bioe.12957},
	doi = {10.1111/bioe.12957},
	abstract = {Machine learning (ML) algorithms are increasingly used in clinical practice. However, their integration into clinical workflows remains challenging. A common narrative in the literature is that ML algorithms and clinicians are competitors, with the former potentially replacing the latter. In this paper, we argue that this competitive framing is unhelpful and that we should instead focus on how they can become collaborators. We identify three gaps that hinder this collaboration: the epistemic gap, the agency gap, and the responsibility gap. We then propose a framework for bridging these gaps, which involves fostering mutual understanding, clarifying roles and responsibilities, and designing systems that support human-AI interaction. We conclude by discussing the implications of our framework for the development and deployment of ML algorithms in clinical settings.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Bioethics},
	publisher = {Wiley},
	author = {Grote, Thomas and Berens, Philipp},
	month = feb,
	year = {2022},
	keywords = {Bridging (networking), Competitor analysis, Computer science, Artificial intelligence, Algorithm, Machine learning, Psychology, Business, Marketing, Computer security},
}
