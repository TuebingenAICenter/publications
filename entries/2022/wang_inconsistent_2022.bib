@misc{wang_inconsistent_2022,
	title = {Inconsistent {Few}-{Shot} {Relation} {Classification} via {Cross}-{Attentional} {Prototype} {Networks} with {Contrastive} {Learning}},
	shorttitle = {Inconsistent {Few}-{Shot} {Relation} {Classification}},
	url = {https://arxiv.org/abs/2110.08254},
	abstract = {Few-shot relation classification aims to identify the semantic relation between two entities in a sentence given only a few labeled examples. Existing methods typically assume that the few-shot support set is consistent, i.e., all instances in the support set belong to the same relation class. However, in real-world scenarios, the support set is often inconsistent due to noisy labeling or the inherent ambiguity of relations. In this paper, we propose a novel framework, Cross-Attentional Prototype Networks with Contrastive Learning (CAPN), to address the inconsistent few-shot relation classification problem. Specifically, we design a cross-attentional mechanism to capture the interaction between the query instance and the support instances, which helps to alleviate the impact of inconsistent instances. Furthermore, we introduce a contrastive learning objective to learn more discriminative prototype representations by pulling together instances of the same relation and pushing apart instances of different relations. Extensive experiments on two benchmark datasets demonstrate that our proposed CAPN significantly outperforms state-of-the-art methods in both consistent and inconsistent few-shot relation classification settings.},
	language = {en},
	urldate = {2024-05-23},
	publisher = {arXiv},
	author = {Wang, H. and Jin, Z. and Cao, J. and Fung, G. P. C. and Wong, K.-F.},
	year = {2022},
	keywords = {ACL},
}
