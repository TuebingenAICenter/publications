@article{chen_semi-supervised_2022,
	title = {Semi-{Supervised} and {Unsupervised} {Deep} {Visual} {Learning}: {A} {Survey}},
	shorttitle = {Semi-{Supervised} and {Unsupervised} {Deep} {Visual} {Learning}},
	url = {https://is.mpg.de/ei/publications/chemanzhuaka22},
	doi = {10.1109/TPAMI.2022.3201576},
	abstract = {Deep learning has achieved remarkable success in various computer vision tasks, typically relying on large-scale labeled datasets. However, the acquisition of high-quality labels is often expensive and time-consuming. To address this, semi-supervised and unsupervised learning have emerged as promising paradigms to leverage unlabeled data. In this survey, we provide a comprehensive review of recent advances in semi-supervised and unsupervised deep visual learning. We categorize existing methods based on their learning objectives and underlying mechanisms, and discuss their strengths and limitations. Furthermore, we highlight key challenges and potential future research directions in this rapidly evolving field.},
	language = {en},
	urldate = {2024-05-23},
	journal = {IEEE Transactions on Pattern Analysis and Machine Intelligence},
	publisher = {IEEE},
	author = {Chen, Y. and Mancini, M. and Zhu, X. and Akata, Z.},
	month = aug,
	year = {2022},
	keywords = {Computer science, Artificial intelligence, Unsupervised learning, Generalizability theory, Categorization, Machine learning, Deep learning, Initialization, Generalization, Data science, TPAMI},
}
