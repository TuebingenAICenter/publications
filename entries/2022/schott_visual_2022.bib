@misc{schott_visual_2022,
	title = {Visual {Representation} {Learning} {Does} {Not} {Generalize} {Strongly} {Within} the {Same} {Domain}},
	shorttitle = {Visual representation learning does not generalize strongly},
	url = {https://openreview.net/forum?id=9RUHPlladgh},
	doi = {10.48550/arxiv.2107.08221},
	abstract = {Deep learning models are often criticized for their lack of robustness to distribution shifts. However, it is often assumed that representations learned on large-scale datasets are robust and generalize well within the same domain. In this paper, we challenge this assumption. We show that even for state-of-the-art self-supervised and supervised models, representations do not generalize strongly within the same domain. We find that performance drops significantly when models are evaluated on data that is visually similar to the training data but contains different combinations of factors of variation. We propose a new evaluation framework to quantify this lack of generalization and show that it is a pervasive phenomenon across a wide range of architectures and training objectives.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {International Conference on Learning Representations},
	author = {Schott, Lukas and von Kügelgen, Julius and Träuble, Frederik and Gehler, Peter and Russell, Chris and Bethge, Matthias and Schölkopf, Bernhard and Locatello, Francesco and Brendel, Wieland},
	month = apr,
	year = {2022},
	keywords = {Computer science, Machine learning, Artificial intelligence, Generalization, Robustness (evolution), Variation (astronomy), Generative model, Representation (politics), Modular design, Generative grammar, Contrast (vision), Mathematics, ICLR, NEURIPS},
}
