@article{koch_hidden_2022,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Hidden in plain sight: {Subgroup} shifts escape ood detection},
	issn = {2640-3498},
	shorttitle = {Hidden in plain sight},
	url = {https://openreview.net/forum?id=aZgiUNye2Cz},
	abstract = {Deep learning models are increasingly deployed in medical imaging, where they are expected to perform reliably on diverse patient populations. However, models often fail when encountering data that differs from their training distribution, a problem known as out-of-distribution (OOD) detection. While most OOD detection research focuses on detecting entirely new classes or datasets, we investigate a more subtle but clinically relevant problem: subgroup shifts, where the distribution of subgroups within a known class changes. We show that state-of-the-art OOD detection methods often fail to detect these shifts, even when they lead to significant performance drops. We analyze the reasons for this failure and propose a simple yet effective approach to improve detection performance.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of Medical Imaging with Deep Learning},
	publisher = {PMLR},
	author = {Koch, Laura M. and Schürch, Christian M. and Gretton, Arthur and Berens, Philipp},
	month = feb,
	year = {2022},
	keywords = {MIDL},
}
