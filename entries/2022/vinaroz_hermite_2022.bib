@inproceedings{vinaroz_hermite_2022,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Hermite {Polynomial} {Features} for {Private} {Data} {Generation}},
	url = {https://proceedings.mlr.press/v162/vinaroz22a.html},
	abstract = {We propose a novel method for generating synthetic data under differential privacy. Our approach relies on approximating the data distribution using a truncated expansion of Hermite polynomials. This allows us to capture complex dependencies in the data while maintaining a low-dimensional representation, which is crucial for privacy. We provide theoretical guarantees on the privacy loss and the approximation error. Our empirical results demonstrate that our method outperforms existing state-of-the-art approaches on several benchmark datasets, especially in high-dimensional settings.},
	language = {en},
	booktitle = {Proceedings of the 39th {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Vinaroz, Margarita and Charusaie, Mohammad-Amin and Harder, Frederik and Adamczewski, Kamil and Park, Mi Jung},
	editor = {Chaudhuri, Kamalika and Jegelka, Stefanie and Song, Le and Szepesvari, Csaba and Niu, Gang and Sabato, Sivan},
	month = jul,
	year = {2022},
	keywords = {ICML},
}
