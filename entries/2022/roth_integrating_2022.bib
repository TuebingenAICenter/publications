@inproceedings{roth_integrating_2022,
	title = {Integrating {Language} {Guidance} into {Vision}-based {Deep} {Metric} {Learning}},
	shorttitle = {Integrating {Language} {Guidance} into {Vision}-based {Deep} {Metric} {Learning}},
	url = {https://openaccess.thecvf.com/content/CVPR2022/papers/Roth_Integrating_Language_Guidance_Into_Vision-Based_Deep_Metric_Learning_CVPR_2022_paper.pdf},
	doi = {10.1109/CVPR52688.2022.01570},
	abstract = {Deep Metric Learning (DML) aims to learn an embedding space where semantically similar images are close to each other. While standard DML relies solely on visual information, we argue that language can provide a powerful, complementary signal to resolve ambiguities in visual similarity. In this work, we propose a novel framework that integrates language guidance into vision-based DML. Our approach leverages a pre-trained vision-language model to extract language-based semantic guidance, which is then used to adapt the visual embedding space. We demonstrate that our method significantly improves performance on standard DML benchmarks and provides a more interpretable embedding space. Furthermore, we show that our approach is robust to noisy language descriptions and can be applied to zero-shot and few-shot learning scenarios.},
	language = {en},
	booktitle = {2022 {IEEE}/{CVF} {Conference} on {Computer} {Vision} and {Pattern} {Recognition} ({CVPR})},
	publisher = {IEEE},
	author = {Roth, Karsten and Vinyals, Oriol and Akata, Zeynep},
	month = jun,
	year = {2022},
	keywords = {Computer science, Embedding, Generalizability theory, Artificial intelligence, Metric (unit), Semantics (computer science), Natural language processing, Context (archaeology), Semantic similarity, Class (philosophy), Consistency (knowledge bases), Representation (politics), Machine learning, Mathematics, Programming language, CVPR},
}
