@inproceedings{deistler_truncated_2022,
	title = {Truncated {Proposals} for scalable and hassle-free simulation-based inference},
	shorttitle = {Truncated {Proposals}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2022/file/9278abf072b58caf21d48dd670b4c721-Paper-Conference.pdf},
	doi = {10.48550/arxiv.2210.04815},
	abstract = {Simulation-based inference (SBI) allows for Bayesian inference in models where the likelihood is intractable but simulation is possible. Recent advances in neural SBI have enabled efficient posterior estimation by learning conditional density estimators. However, these methods often struggle with high-dimensional parameters or complex posterior geometries, and they can be sensitive to the choice of the proposal distribution used for simulation. We introduce Truncated Proposals, a method for SBI that adaptively truncates the proposal distribution to focus simulation on regions of high posterior probability. This approach improves sample efficiency, enables inference in higher dimensions, and reduces the need for manual tuning of the proposal distribution. We demonstrate the effectiveness of our method on a range of benchmarks and a complex neuroscience model.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 35 ({NeurIPS} 2022)},
	publisher = {Curran Associates, Inc.},
	author = {Deistler, Michael and Gonçalves, Pedro J. and Macke, Jakob H.},
	editor = {Koyejo, S. and Mohamed, S. and Agarwal, A. and Belgrave, D. and Cho, K. and Oh, A.},
	month = dec,
	year = {2022},
	keywords = {Inference, Computer science, Scalability, Benchmark (surveying), Machine learning, Scale (ratio), Artificial intelligence, Data mining, NEURIPS},
}
