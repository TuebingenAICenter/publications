@inproceedings{goyal_coordination_2022,
	title = {Coordination {Among} {Neural} {Modules} {Through} a {Shared} {Global} {Workspace}},
	shorttitle = {Coordination {Among} {Neural} {Modules} {Through} a {Shared} {Global} {Workspace}},
	url = {https://openreview.net/forum?id=XzTtHjgPDsT},
	abstract = {The ability to decompose a complex task into simpler, reusable sub-tasks is a hallmark of human intelligence. In the context of deep learning, this suggests a modular architecture where different modules specialize in different sub-tasks. However, a key challenge is how to coordinate these modules to solve a given task. In this paper, we propose a novel architecture, the Global Workspace (GW), which acts as a communication bottleneck between a set of specialized modules. The GW allows modules to read from and write to a shared memory, enabling them to coordinate their actions. We show that our proposed architecture can learn to solve complex tasks by decomposing them into sub-tasks, and that the learned modules are reusable across different tasks. We evaluate our approach on a variety of tasks, including multi-task reinforcement learning and image classification, and show that it outperforms existing modular architectures.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {The {Tenth} {International} {Conference} on {Learning} {Representations} ({ICLR} 2022)},
	author = {Goyal, Anirudh and Didolkar, Aniket R. and Lamb, Alex and Badola, Kartik and Ke, Nan Rosemary and Rahaman, Nasim and Binas, Jonathan and Blundell, Charles and Mozer, Michael C. and Bengio, Yoshua},
	month = apr,
	year = {2022},
	keywords = {ICLR},
}
