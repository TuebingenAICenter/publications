@inproceedings{xu_vgse_2022,
	title = {{VGSE}: {Visually}-{Grounded} {Semantic} {Embeddings} for {Zero}-{Shot} {Learning}},
	shorttitle = {{VGSE}},
	url = {https://openaccess.thecvf.com/content/CVPR2022/papers/Xu_VGSE_Visually-Grounded_Semantic_Embeddings_for_Zero-Shot_Learning_CVPR_2022_paper.pdf},
	doi = {10.1109/CVPR52688.2022.00910},
	abstract = {Zero-shot learning (ZSL) aims to recognize objects from unseen classes by transferring knowledge from seen classes via semantic embeddings. Existing methods typically rely on static semantic embeddings, such as word vectors or attribute vectors, which are often noisy and lack visual grounding. In this paper, we propose Visually-Grounded Semantic Embeddings (VGSE), which learn to refine semantic embeddings by grounding them in visual features. Specifically, we introduce a visual-semantic alignment module that learns to map semantic embeddings into a visual space, and a visual-semantic consistency module that enforces the consistency between the visual features and the refined semantic embeddings. We demonstrate the effectiveness of our approach on several ZSL benchmarks, where it achieves state-of-the-art performance.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {2022 {IEEE}/{CVF} {Conference} on {Computer} {Vision} and {Pattern} {Recognition} ({CVPR})},
	publisher = {IEEE},
	author = {Xu, W. and Xian, Y. and Wang, J. and Schiele, B. and Akata, Z.},
	month = jun,
	year = {2022},
	keywords = {Computer science, Natural language processing, Word (group theory), Artificial intelligence, Discriminative model, Annotation, Set (abstract data type), Class (philosophy), Similarity (geometry), Margin (machine learning), Zero (linguistics), Semantic similarity, Process (computing), Image (mathematics), Shot (pellet), Information retrieval, Machine learning, Mathematics, Linguistics, CVPR},
}
