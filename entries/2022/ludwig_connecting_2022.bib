@misc{ludwig_connecting_2022,
	title = {Connecting {Exploration}, {Generalization}, and {Planning} in {Correlated} {Trees}},
	shorttitle = {Connecting {Exploration}, {Generalization}, and {Planning}},
	url = {https://doi.org/10.31234/osf.io/72wda},
	doi = {10.31234/osf.io/72wda},
	abstract = {How do humans navigate complex environments where rewards are correlated? We introduce a novel task, the Correlated Trees task, which allows us to study how people generalize information across a hierarchical structure to guide exploration and planning. We compare human behavior against a range of computational models, including a Bayesian model that generalizes across the tree structure, and a heuristic model that relies on local information. Our results show that humans are able to generalize across the tree structure, using information from observed nodes to guide exploration in unobserved branches. We find that a model combining Bayesian generalization with a planning heuristic best captures human behavior, suggesting that humans integrate generalization and planning to navigate complex, correlated environments.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Cognitive Science Society},
	author = {Ludwig, Tobias and Wu, Charley M. and Schulz, Eric},
	editor = {Culbertson, Jennifer and Perfors, Adele and Rabagliati, Hugh and Ramenzoni, Veronica},
	year = {2022},
	keywords = {Generalization, Computer science, Generative grammar, Reinforcement learning, Task (project management), Scalability, Artificial intelligence, Machine learning, Generative model, Mathematics, Engineering, Systems engineering, COGSCI},
}
