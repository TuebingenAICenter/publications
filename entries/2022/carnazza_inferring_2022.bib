@misc{carnazza_inferring_2022,
	title = {Inferring {Markovian} quantum master equations of few-body observables in interacting spin chains},
	url = {https://doi.org/10.1088/1367-2630/ac7df6},
	doi = {10.1088/1367-2630/ac7df6},
	abstract = {We present a method for the inference of Markovian quantum master equations for few-body observables in interacting many-body systems. The approach relies on the observation of the time evolution of a set of local observables and the subsequent reconstruction of the generator of the dynamics. We demonstrate the effectiveness of our method by applying it to a one-dimensional spin chain, where we show that it is possible to accurately learn the master equation even in the presence of strong interactions and for systems that are not in the weak-coupling regime. Our results suggest that this framework is a powerful tool for the characterization of the dynamics of open quantum systems and for the development of reduced-order models for complex quantum many-body dynamics.},
	language = {en},
	publisher = {IOP Publishing},
	author = {Carnazza, Francesco and Carollo, Federico and Zietlow, Dominik and Andergassen, Sabine and Martius, Georg and Lesanovsky, Igor},
	year = {2022},
	keywords = {Observable, Master equation, Quantum, Statistical physics, Computer science, Quantum dynamics, Quantum decoherence, Open quantum system, Generator (circuit theory), Quantum system, Physics, Quantum mechanics, NJP},
}
