@misc{hattori_unpopular_2022,
	title = {The unpopular {Package}: {A} {Data}-driven {Approach} to {Detrending} {TESS} {Full}-frame {Image} {Light} {Curves}},
	shorttitle = {The unpopular {Package}},
	url = {https://iopscience.iop.org/article/10.3847/1538-3881/ac625a},
	doi = {10.3847/1538-3881/ac625a},
	abstract = {The Transiting Exoplanet Survey Satellite (TESS) provides high-precision photometry for millions of stars. However, the light curves extracted from TESS full-frame images (FFIs) are often affected by systematic noise, such as spacecraft jitter, thermal variations, and scattered light. We present the unpopular package, a data-driven method for detrending TESS FFI light curves. Our method uses a matrix factorization approach to model the systematic noise in the light curves, which is then removed to reveal the underlying stellar variability. We demonstrate the effectiveness of our method by applying it to a sample of TESS FFI light curves and comparing the results with those obtained using other common detrending techniques. The unpopular package is open-source and available for use by the community.},
	language = {en},
	publisher = {American Astronomical Society},
	author = {Hattori, Soichiro and Foreman-Mackey, Daniel and Hogg, David W. and Montet, Benjamin T. and Angus, Ruth and Pritchard, T. A. and Curtis, Jason L. and Schölkopf, Bernhard},
	month = may,
	year = {2022},
	keywords = {Light curve, Exoplanet, Pixel, Physics, Python (programming language), Computer science, Algorithm, Astrophysics, Astronomy, Stars, Artificial intelligence, AJ},
}
