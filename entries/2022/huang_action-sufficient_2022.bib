@misc{huang_action-sufficient_2022,
	title = {Action-{Sufficient} {State} {Representation} {Learning} for {Control} with {Structural} {Constraints}},
	url = {https://proceedings.mlr.press/v162/huang22f.html},
	doi = {10.48550/arxiv.2110.05721},
	abstract = {Learning effective state representations is a fundamental problem in reinforcement learning and control. In many real-world scenarios, the underlying state space is high-dimensional and partially observed, and the dynamics are governed by causal mechanisms. In this paper, we propose a novel framework for learning action-sufficient state representations that are robust to changes in the environment. We introduce structural constraints based on the causal structure of the environment, which allows us to identify the latent state variables that are necessary and sufficient for predicting the effects of actions. We demonstrate the effectiveness of our approach on a variety of control tasks, showing that it outperforms existing methods in terms of sample efficiency and generalization to unseen environments.},
	language = {en},
	urldate = {2025-02-07},
	publisher = {PMLR},
	author = {Huang, Biwei and Lu, Chaochao and Liu, Leqi and Hernández-Lobato, José Miguel and Glymour, Clark and Schölkopf, Bernhard and Zhang, Kun},
	editor = {Chaudhuri, Kamalika and Jegelka, Stefanie and Song, Le and Szepesvari, Csaba and Niu, Gang and Sabato, Sivan},
	month = jul,
	year = {2022},
	keywords = {Computer science, Representation (politics), Generalization, Latent variable, Generative model, Reinforcement learning, Artificial intelligence, Set (abstract data type), Encoder, Feature learning, Action (physics), Machine learning, Component (thermodynamics), State space, State (computer science), Generative grammar, Algorithm, Mathematics, ICML},
}
