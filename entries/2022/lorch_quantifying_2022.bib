@misc{lorch_quantifying_2022,
	title = {Quantifying the effects of contact tracing, testing, and containment measures in the presence of infection hotspots},
	url = {https://dl.acm.org/doi/10.1145/3530774},
	doi = {10.1145/3530774},
	abstract = {The COVID-19 pandemic has forced many countries to implement non-pharmaceutical interventions, such as contact tracing, testing, and social distancing, to contain the spread of the virus. However, it remains unclear how these measures interact and how their effectiveness depends on the underlying structure of the population and the presence of infection hotspots. In this paper, we propose a stochastic model of disease transmission that accounts for the heterogeneity in contact patterns and the presence of infection hotspots. We use this model to quantify the effects of contact tracing, testing, and containment measures on the spread of the virus. Our results show that the effectiveness of these measures is highly dependent on the population structure and that, in the presence of infection hotspots, contact tracing and testing can be significantly more effective than in a homogeneous population. We also show that the combination of these measures can lead to a significant reduction in the number of infections, even in the presence of high levels of transmission.},
	language = {en},
	publisher = {Association for Computing Machinery},
	author = {Lorch, Lars and Kremer, Heiner and Trouleau, William and Tsirtsis, Stratis and Szanto, Aron and Schölkopf, Bernhard and Gomez-Rodriguez, Manuel},
	month = nov,
	year = {2022},
	keywords = {Contact tracing, Computer science, Bayesian probability, Flexibility (engineering), Transmission (telecommunications), Tracing, Econometrics, R package, Infectious disease (medical specialty), Data science, Geography, Coronavirus disease 2019 (COVID-19), Statistics, Disease, Artificial intelligence, Medicine, Mathematics},
}
