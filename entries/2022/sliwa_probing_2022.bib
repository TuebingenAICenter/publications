@misc{sliwa_probing_2022,
	title = {Probing the {Robustness} of {Independent} {Mechanism} {Analysis} for {Representation} {Learning}},
	url = {https://openreview.net/forum?id=MnKSQVBVpBQ},
	doi = {10.48550/arxiv.2207.06137},
	abstract = {Independent Mechanism Analysis (IMA) is a framework for learning causal representations from data by exploiting the independence of causal mechanisms. While theoretical identifiability results for IMA exist, their practical implications remain under-explored. In this work, we empirically investigate the robustness of IMA to violations of its core assumptions. We find that IMA is sensitive to the choice of the independence measure and the architecture of the neural networks used to model the causal mechanisms. Furthermore, we show that IMA can struggle to recover the true causal factors when the data generating process deviates from the assumed structural causal model. Our results highlight the need for more robust methods for causal representation learning.},
	language = {en},
	author = {Sliwa, Joanna and Ghosh, Shubhangi and Stimper, Vincent and Gresele, Luigi and Schölkopf, Bernhard},
	month = aug,
	year = {2022},
	keywords = {Robustness (evolution), Regularization (linguistics), Computer science, Latent variable, Representation (politics), Algorithm, Artificial intelligence, Mathematics, UAI},
}
