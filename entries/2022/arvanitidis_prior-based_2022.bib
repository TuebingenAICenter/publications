@misc{arvanitidis_prior-based_2022,
	title = {A prior-based approximate latent {Riemannian} metric},
	url = {https://proceedings.mlr.press/v151/arvanitidis22a.html},
	doi = {10.48550/arxiv.2103.05290},
	abstract = {Latent variable models are powerful tools for learning representations of complex data. However, the geometry of the latent space is often ignored, which limits our ability to perform meaningful operations such as measuring distances or interpolating between data points. In this paper, we propose a novel approach to define a Riemannian metric on the latent space of a generative model. Our approach is based on the idea of using a prior distribution to define a metric that reflects the density of the data in the latent space. We show that this metric can be approximated efficiently, even for high-dimensional latent spaces, and that it leads to more meaningful distances and interpolations compared to the standard Euclidean metric. We demonstrate the effectiveness of our approach on several synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Arvanitidis, Georgios and Georgiev, Bogdan and Schölkopf, Bernhard},
	editor = {Camps-Valls, Gustau and Ruiz, Francisco J. R. and Valera, Isabel},
	month = mar,
	year = {2022},
	keywords = {Metric (unit), Mathematics, Applied mathematics, Econometrics, Economics, AISTATS},
}
