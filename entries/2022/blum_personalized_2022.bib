@article{blum_personalized_2022,
	title = {Personalized neurorehabilitative precision medicine: from data to therapies ({MWKNeuroReha}) – a multi-centre prospective observational clinical trial to predict long-term outcome of patients with acute motor stroke},
	copyright = {© The Author(s) 2022},
	issn = {1471-2377},
	shorttitle = {Personalized neurorehabilitative precision medicine},
	url = {https://bmcneurol.biomedcentral.com/articles/10.1186/s12883-022-02759-2},
	doi = {10.1186/s12883-022-02759-2},
	abstract = {Background: Stroke is a leading cause of long-term disability worldwide. Despite the availability of standardized rehabilitation protocols, the individual recovery trajectory remains difficult to predict. Precision medicine approaches, which integrate multi-modal data to tailor therapeutic interventions, hold promise for improving outcomes. The MWKNeuroReha study aims to develop predictive models for long-term functional recovery in patients with acute motor stroke. Methods: This is a multi-centre, prospective, observational clinical trial. Patients with acute motor stroke will be recruited from multiple stroke units and rehabilitation centres. Comprehensive data, including clinical assessments, neuroimaging, and longitudinal functional outcomes, will be collected. The primary endpoint is the functional status at 6 months post-stroke, measured by the modified Rankin Scale (mRS). Secondary endpoints include motor function, quality of life, and cognitive performance. Machine learning algorithms will be employed to integrate these data and identify predictors of recovery. Discussion: The MWKNeuroReha study will provide a unique dataset to advance our understanding of stroke recovery and facilitate the development of personalized neurorehabilitative strategies. The findings may inform clinical decision-making and optimize resource allocation in stroke rehabilitation.},
	language = {en},
	urldate = {2025-05-14},
	journal = {BMC Neurology},
	publisher = {BioMed Central},
	author = {Blum, Corinna and Baur, David and Achauer, Lars-Christian and Berens, Philipp and Biergans, Stephanie and Erb, Michael and Hömberg, V. and Huang, Ziwei and Kohlbacher, Oliver and Liepert, Joachim and Lindig, Tobias and Lohmann, Gabriele and Macke, Jakob H. and Römhild, Jörg and Rösinger-Hein, Christine and Zrenner, Brigitte and Ziemann, Ulf},
	year = {2022},
	keywords = {Medicine, Observational study, Stroke (engine), Rehabilitation, Physical therapy, Modified Rankin Scale, Physical medicine and rehabilitation, Clinical trial, Neurology, Clinical endpoint, Internal medicine, Ischemic stroke, BMC NEUROLOGY},
}
