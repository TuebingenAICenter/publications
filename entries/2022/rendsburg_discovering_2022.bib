@misc{rendsburg_discovering_2022,
	title = {Discovering {Inductive} {Bias} with {Gibbs} {Priors}: {A} {Diagnostic} {Tool} for {Approximate} {Bayesian} {Inference}},
	shorttitle = {Discovering {Inductive} {Bias} with {Gibbs} {Priors}},
	url = {http://tml.cs.uni-tuebingen.de/team/luxburg/publications/2022_Rendsburg_Luxburg.pdf},
	doi = {10.48550/arxiv.2203.03353},
	abstract = {Approximate Bayesian inference methods are ubiquitous in machine learning. However, they often introduce implicit inductive biases that are difficult to characterize. In this paper, we propose a diagnostic tool to discover the inductive bias of an approximate inference method. We frame the approximate posterior as the exact posterior of a Gibbs prior, which is a perturbation of the original prior. By analyzing this Gibbs prior, we can interpret the inductive bias of the approximation as a modification of the prior. We demonstrate our approach on several examples, including Gaussian process regression and multi-task learning, and show that it provides insights into the behavior of approximate inference methods.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Rendsburg, Luca and Kristiadi, Agustinus and Hennig, Philipp and von Luxburg, Ulrike},
	year = {2022},
	keywords = {Gibbs sampling, Inference, Prior probability, Bayesian inference, Bayesian probability, Computer science, Frequentist inference, Machine learning, Expectation propagation, Posterior probability, Inductive bias, Artificial intelligence, Algorithm, Gaussian, Gaussian process, Multi-task learning, Engineering, Physics, AISTATS},
}
