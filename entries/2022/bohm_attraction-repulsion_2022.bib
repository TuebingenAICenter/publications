@misc{bohm_attraction-repulsion_2022,
	title = {Attraction-repulsion spectrum in neighbor embeddings},
	shorttitle = {Attraction-repulsion spectrum},
	url = {https://dl.acm.org/doi/abs/10.5555/3586589.3586684},
	doi = {10.5555/3586589.3586684},
	abstract = {Neighbor embedding methods like t-SNE and UMAP are widely used for visualizing high-dimensional data. They are often described as balancing attraction between similar points and repulsion between dissimilar points. However, the exact nature of this balance is rarely quantified. Here, we show that many neighbor embedding methods can be interpreted as minimizing a force-based energy function. We introduce the attraction-repulsion spectrum, a framework that allows us to analyze these methods by varying the relative strength of attraction and repulsion. We show that this spectrum reveals a phase transition in the embedding behavior: for strong repulsion, the embedding is dominated by the global structure, while for weak repulsion, it is dominated by the local structure. We demonstrate that this framework provides a unified view of many popular embedding methods and allows for a principled way to tune their hyperparameters.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Journal of Machine Learning Research},
	author = {Böhm, Jan Niklas and Berens, Philipp and Kobak, Dmitry},
	month = feb,
	year = {2022},
	keywords = {Attraction, Embedding, Laplace operator, Simple (philosophy), Cluster (spacecraft), Spectrum (functional analysis), Manifold (fluid mechanics), Computer science, Statistical physics, Mathematics, Physics, Artificial intelligence, Mathematical analysis, JMLR},
}
