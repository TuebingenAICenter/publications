@article{loeckel_identification_2022,
	title = {Identification and modelling of race driving styles},
	issn = {0042-3114},
	shorttitle = {Identification and modelling of race driving styles},
	url = {https://www.tandfonline.com/doi/full/10.1080/00423114.2021.1930070},
	doi = {10.1080/00423114.2021.1930070},
	abstract = {In professional motor racing, the driver's individual driving style is a key factor for performance. While vehicle dynamics are well understood, the driver's influence is often treated as a black box. In this paper, we propose a framework to identify and model individual race driving styles. We represent driving styles as a set of parameters in a driver model that maps the vehicle state to steering and pedal inputs. To identify these parameters from data, we use a two-stage approach: first, we estimate the driver's intent using a model-predictive control approach; second, we use a Gaussian process regression to learn the mapping from the vehicle state to the driver's inputs. We evaluate our approach using data from a professional racing simulator and show that our model can accurately predict the driving style of different drivers and that it can be used to generate synthetic driving data that is indistinguishable from human driving.},
	language = {en},
	urldate = {2024-05-23},
	journal = {Vehicle System Dynamics},
	publisher = {Taylor \& Francis},
	author = {Loeckel, S. and Kretschia, A. and van Vliet, P. and Peters, J.},
	year = {2022},
	keywords = {VSD},
}
