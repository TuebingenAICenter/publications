@inproceedings{xian_any-shot_2022,
	title = {Any-{Shot} {GIN}: {Generalizing} {Implicit} {Networks} for {Reconstructing} {Novel} {Classes}},
	shorttitle = {Any-{Shot} {GIN}},
	url = {https://virtualhumans.mpi-inf.mpg.de/gin/GIN.pdf},
	doi = {10.1109/3DV57658.2022.00064},
	abstract = {Implicit neural representations have shown great potential for 3D shape reconstruction. However, existing methods are typically trained on a fixed set of object classes and struggle to generalize to novel categories. In this paper, we propose Any-Shot GIN, a framework that enables implicit networks to reconstruct 3D shapes of novel classes given only a few observations. Our approach leverages a meta-learning strategy to learn a shape prior that can be adapted to unseen categories with minimal supervision. We demonstrate that our method achieves state-of-the-art performance on few-shot 3D reconstruction tasks across various datasets.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {International {Conference} on 3D {Vision} (3DV)},
	publisher = {IEEE},
	author = {Xian, Yongqin and Chibane, Julian and Bhatnagar, Bharat Lal and Schiele, Bernt and Akata, Zeynep and Pons-Moll, Gerard},
	month = sep,
	year = {2022},
	keywords = {Computer science, Differentiable function, Artificial intelligence, Benchmark (surveying), Class (philosophy), Image (mathematics), Prior probability, Key (lock), Voxel, Task (project management), Shot (pellet), Iterative reconstruction, Pattern recognition (psychology), Algorithm, Computer vision, Mathematics, 3DV},
}
