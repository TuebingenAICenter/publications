@misc{soleymani_causal_2022,
	title = {Causal {Feature} {Selection} via {Orthogonal} {Search}},
	url = {https://openreview.net/forum?id=Q54jBjc896},
	abstract = {Feature selection is a fundamental problem in machine learning and statistics. While traditional methods focus on predictive performance, they often fail to identify the causal features that are truly responsible for the target variable. In this paper, we propose a novel causal feature selection method based on orthogonal search. Our approach leverages the causal structure of the data to identify a subset of features that are causally related to the target. We demonstrate the effectiveness of our method on both synthetic and real-world datasets, showing that it outperforms existing methods in terms of both predictive accuracy and causal discovery.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Transactions on Machine Learning Research},
	author = {Soleymani, Ashkan and Raj, Anant and Bauer, Stefan and Schölkopf, Bernhard and Besserve, Michel},
	month = sep,
	year = {2022},
	keywords = {Feature selection, Computer science, Machine learning, Feature (linguistics), Artificial intelligence, Variable (mathematics), Exploit, Causal model, Field (mathematics), Set (abstract data type), Observational study, Causality (physics), Causal inference, Nonlinear system, Data mining, Econometrics, Mathematics, Statistics, TMLR},
}
