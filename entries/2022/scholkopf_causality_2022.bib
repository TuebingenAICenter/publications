@misc{scholkopf_causality_2022,
	title = {Causality for {Machine} {Learning}},
	url = {https://doi.org/10.1145/3501714.3501755},
	doi = {10.1145/3501714.3501755},
	abstract = {Machine learning has made impressive progress in recent years, largely due to the success of deep learning in finding statistical patterns in large datasets. However, these systems often struggle to generalize to new environments or to understand the causal mechanisms that generate the data. This chapter discusses the role of causality in machine learning, arguing that causal models are essential for building more robust and interpretable systems. We review the fundamental concepts of causal inference, including structural causal models and the do-calculus, and discuss how they can be integrated into machine learning pipelines to improve performance and reliability.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Association for Computing Machinery},
	author = {Schölkopf, Bernhard},
	year = {2022},
	keywords = {Causality (physics), Causal inference, Artificial intelligence, Field (mathematics), Computer science, Inference, Key (lock), Pearl, Connection (principal bundle), Cognitive science, Machine learning, Graphical model, Psychology, Engineering, Philosophy, Mathematics, Computer security},
}
