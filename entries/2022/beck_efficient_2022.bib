@inproceedings{beck_efficient_2022,
	title = {Efficient identification of informative features in simulation-based inference},
	shorttitle = {Efficient identification of informative features in simulation-based inference},
	url = {https://proceedings.neurips.cc/paper_files/paper/2022/hash/7a7f6cc5dc2a84fb4edf0feb8e5cfd50-Abstract-Conference.html},
	doi = {10.48550/arxiv.2210.11915},
	abstract = {Simulation-based inference (SBI) allows for Bayesian parameter inference in models where the likelihood is intractable but samples can be generated. A common challenge in SBI is that the data often contains many uninformative features, which can hinder the performance of inference algorithms. Here, we propose a method for identifying informative features in SBI. Our approach is based on learning a summary statistic that is both informative about the parameters and low-dimensional. We show that our method can be used to perform efficient inference in high-dimensional settings and that it outperforms existing methods on a range of benchmarks.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	publisher = {Curran Associates, Inc.},
	author = {Beck, J. and Deistler, M. and Bernaerts, Y. and Macke, J. H. and Berens, P.},
	month = dec,
	year = {2022},
	keywords = {Inference, Computer science, Feature (linguistics), Bayesian inference, Posterior probability, Artificial intelligence, Bayesian probability, Machine learning, Set (abstract data type), Pattern recognition (psychology), Data mining, NEURIPS},
}
