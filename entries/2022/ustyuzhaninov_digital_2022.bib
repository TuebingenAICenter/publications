@misc{ustyuzhaninov_digital_2022,
	title = {Digital twin reveals combinatorial code of non-linear computations in the mouse primary visual cortex},
	shorttitle = {Digital twin reveals combinatorial code},
	url = {https://www.biorxiv.org/content/10.1101/2022.02.10.479884},
	doi = {10.1101/2022.02.10.479884},
	abstract = {The primary visual cortex (V1) is a key model system for understanding how neural circuits perform non-linear computations. However, the exact nature of these computations remains elusive. Here, we introduce a digital twin approach to study the non-linear computations in the mouse V1. We trained a deep convolutional neural network to predict the responses of thousands of neurons in the mouse V1 to natural images. The model achieved high predictive accuracy, allowing us to use it as a digital twin of the V1. We then used this digital twin to systematically explore the non-linear computations performed by the V1. We found that the V1 performs a combinatorial code of non-linear computations, where different neurons are tuned to different combinations of non-linear features. Our results suggest that the V1 is a highly flexible and efficient system for processing visual information.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {bioRxiv},
	author = {Ustyuzhaninov, Ivan and Burg, Max F. and Cadena, Santiago A. and Fu, Jiakun and Muhammad, Taliah and Ponder, Kayla and Froudarakis, Emmanouil and Ding, Zhiwei and Bethge, Matthias and Tolias, Andreas S. and Ecker, Alexander S.},
	year = {2022},
	keywords = {Visual cortex, Neuroscience, Computer science, Stimulus (psychology), Excitatory postsynaptic potential, Population, Artificial intelligence, Pattern recognition (psychology), Biology, Psychology, Inhibitory postsynaptic potential},
}
