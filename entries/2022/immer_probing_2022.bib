@inproceedings{immer_probing_2022,
	title = {Probing as {Quantifying} {Inductive} {Bias}},
	shorttitle = {Probing as {Quantifying} {Inductive} {Bias}},
	url = {https://aclanthology.org/2022.acl-long.129/},
	doi = {10.18653/v1/2022.acl-long.129},
	abstract = {Probing is a popular method for evaluating the linguistic knowledge encoded in representations learned by neural networks. However, the interpretation of probing results is often debated. In this paper, we propose a new perspective on probing: we frame it as a method for quantifying the inductive bias of a representation. We show that this perspective allows us to derive a formal relationship between probing performance and the sample complexity of learning a task from a representation. We validate our theoretical findings with experiments on a variety of tasks and representations, showing that our proposed measure of inductive bias is predictive of downstream performance.},
	language = {en},
	urldate = {2024-05-22},
	publisher = {Association for Computational Linguistics},
	author = {Immer, Alexander and Torroba Hennigen, Lucas and Fortuin, Vincent and Cotterell, Ryan},
	editor = {Muresan, Smaranda and Nakov, Preslav and Villavicencio, Aline},
	month = may,
	year = {2022},
	keywords = {ACL},
}
