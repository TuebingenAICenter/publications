@misc{tigas_interventions_2022,
	title = {Interventions, {Where} and {How}? {Experimental} {Design} for {Causal} {Models} at {Scale}},
	shorttitle = {Interventions, {Where} and {How}?},
	url = {https://proceedings.neurips.cc/paper_files/paper/2022/hash/98a5c0470e57d518ade4e56c6ee0b363-Abstract-Conference.html},
	doi = {10.48550/arxiv.2203.02016},
	abstract = {Causal models are powerful tools for decision making, yet their utility is often limited by the availability of interventional data. While active learning for causal discovery has been studied, existing methods often struggle to scale to high-dimensional settings or complex causal structures. In this work, we propose a novel framework for experimental design in causal models that leverages the power of deep generative models to perform interventions in latent spaces. We introduce a method to learn an optimal intervention policy that maximizes the information gain about the underlying causal structure. Our approach is scalable and can be applied to a wide range of causal models, including those with non-linear relationships and latent variables. We demonstrate the effectiveness of our method on a variety of synthetic and real-world datasets, showing that it outperforms existing baselines in terms of both sample efficiency and the quality of the learned causal structure.},
	language = {en},
	publisher = {Curran Associates, Inc.},
	author = {Tigas, Panagiotis and Annadani, Yashas and Jesson, Andrew and Schölkopf, Bernhard and Gal, Yarin and Bauer, Stefan},
	year = {2022},
	keywords = {Identifiability, Computer science, Causal model, Bayesian probability, Causal inference, Machine learning, Bayesian network, Identification (biology), Scale (ratio), Data mining, Observational study, Artificial intelligence, Econometrics, Mathematics, Statistics, NEURIPS},
}
