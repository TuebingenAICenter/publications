@inproceedings{kramer_probabilistic_2022,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Probabilistic {ODE} {Solutions} in {Millions} of {Dimensions}},
	shorttitle = {Probabilistic {ODE} {Solutions} in {Millions} of {Dimensions}},
	url = {https://proceedings.mlr.press/v162/kramer22b.html},
	doi = {10.48550/arxiv.2110.11812},
	abstract = {Probabilistic numerical methods for ordinary differential equations (ODEs) quantify the uncertainty arising from the discretization of the continuous-time problem. However, existing methods are computationally expensive, typically scaling cubically with the dimension of the ODE. This limits their application to small-scale problems. We propose a new class of probabilistic ODE solvers that scale linearly with the dimension of the ODE. We achieve this by using a Kronecker-factored structure for the covariance of the Gaussian process prior. We demonstrate that our method is competitive with state-of-the-art deterministic solvers in terms of accuracy and computational cost, while providing well-calibrated uncertainty estimates in millions of dimensions.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 39th {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Krämer, N. and Bosch, N. and Schmidt, J. and Hennig, P.},
	editor = {Chaudhuri, Kamalika and Jegelka, Stefanie and Song, Le and Szepesvari, Csaba and Niu, Gang and Sabato, Sivan},
	month = jul,
	year = {2022},
	keywords = {Ode, Probabilistic logic, Ordinary differential equation, Applied mathematics, Matrix (chemical analysis), Solver, Computer science, Independence (probability theory), Inference, Dynamical systems theory, Mathematics, Range (aeronautics), Kronecker delta, Mathematical optimization, Differential equation, Mathematical analysis, Artificial intelligence, ICML},
}
