@misc{besserve_cause-effect_2022,
	title = {Cause-effect inference through spectral independence in linear dynamical systems: theoretical foundations},
	url = {https://proceedings.mlr.press/v177/besserve22a/besserve22a.pdf},
	doi = {10.48550/arxiv.2110.15595},
	abstract = {We consider the problem of inferring the causal direction between two time series generated by a linear dynamical system. We propose a method based on the spectral independence of the noise sources driving the system. We show that under certain conditions, the spectral density matrix of the observed variables is diagonal if and only if the causal direction is correctly identified. We provide theoretical foundations for this approach and demonstrate its effectiveness on synthetic and real-world data.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Besserve, M. and Shajarisales, N. and Janzing, D. and Schölkopf, B.},
	editor = {Schölkopf, Bernhard and Uhler, Caroline and Zhang, Kun},
	month = apr,
	year = {2022},
	keywords = {Causal inference, Independence (probability theory), Inference, Econometrics, Robustness (evolution), Series (stratigraphy), Context (archaeology), Mathematics, Computer science, Time series, Statistical physics, Artificial intelligence, Statistics, Physics, Geography, C2},
}
