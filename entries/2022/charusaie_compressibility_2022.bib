@article{charusaie_compressibility_2022,
	title = {Compressibility {Measures} for {Affinely} {Singular} {Random} {Vectors}},
	shorttitle = {Compressibility {Measures} for {Affinely} {Singular} {Random} {Vectors}},
	url = {https://is.mpg.de/hml/publications/9779613},
	doi = {10.1109/TIT.2022.3174623},
	abstract = {The notion of compressibility is central to compressed sensing and high-dimensional statistics. While the compressibility of a vector is often defined via the decay rate of its sorted coefficients, this definition is not always suitable for random vectors, especially when the underlying distribution is not supported on a coordinate-aligned set. In this paper, we introduce a new framework for the compressibility of random vectors based on the notion of affine singularity. A random vector is said to be affinely singular if it is supported on a low-dimensional affine subspace. We propose a measure of compressibility for such vectors, which we call the affine compressibility measure, and show that it captures the essential features of compressibility in a coordinate-independent manner. We further demonstrate the utility of this measure by providing new bounds on the performance of compressed sensing recovery algorithms for affinely singular signals.},
	language = {en},
	urldate = {2024-05-22},
	journal = {IEEE Transactions on Information Theory},
	publisher = {IEEE},
	author = {Charusaie, Mohammad-Amin and Amini, Arash and Rini, Stefano},
	year = {2022},
	keywords = {ISIT, TIT},
}
