@article{faber_ocular_2022,
	title = {Ocular changes as a diagnostic tool for malaria},
	issn = {0941-293X},
	url = {https://link.springer.com/article/10.1007/s00347-021-01554-7},
	doi = {10.1007/s00347-021-01554-7},
	abstract = {Malaria is a life-threatening disease caused by Plasmodium parasites. Early diagnosis is crucial for a favorable prognosis. In addition to the gold standard of microscopic blood smear examination, rapid diagnostic tests (RDTs) are used. However, these methods have limitations, particularly in resource-limited settings. Ocular changes, such as retinal hemorrhages, cotton-wool spots, and papilledema, have been described in patients with malaria, particularly in cases of cerebral malaria. These ocular findings can be detected by ophthalmoscopy, which is a non-invasive and relatively simple procedure. This review summarizes the current knowledge on ocular changes in malaria and discusses their potential as a diagnostic tool.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Der Ophthalmologe},
	publisher = {Springer Nature},
	author = {Faber, H. and Berens, P. and Rohrbach, J. M.},
	month = jan,
	year = {2022},
	keywords = {OPHTHALMOLOGE},
}
