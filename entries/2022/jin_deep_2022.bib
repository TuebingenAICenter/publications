@article{jin_deep_2022,
	title = {Deep {Learning} for {Text} {Style} {Transfer}: {A} {Survey}},
	issn = {0891-2017},
	shorttitle = {Deep {Learning} for {Text} {Style} {Transfer}},
	url = {https://direct.mit.edu/coli/article/48/1/155/108845/Deep-Learning-for-Text-Style-Transfer-A-Survey},
	doi = {10.1162/coli_a_00426},
	abstract = {Text style transfer is a task that aims to change the style of a text while preserving its content. In recent years, deep learning has achieved remarkable success in this task. In this survey, we provide a comprehensive overview of deep learning-based text style transfer. We first categorize the existing methods into three groups: supervised, weakly supervised, and unsupervised, based on the availability of parallel data. We then discuss the evaluation metrics and datasets commonly used in this field. Finally, we summarize the challenges and future directions for text style transfer.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Computational Linguistics},
	publisher = {MIT Press},
	author = {Jin, Di and Jin, Zhijing and Hu, Zheng and Vechtomova, Olga and Mihalcea, Rada},
	month = mar,
	year = {2022},
	keywords = {CL},
}
