@misc{funke_disentanglement_2022,
	title = {Disentanglement and {Generalization} {Under} {Correlation} {Shifts}},
	url = {https://proceedings.mlr.press/v199/funke22a.html},
	doi = {10.48550/arxiv.2112.14754},
	abstract = {Deep learning models often rely on spurious correlations present in the training data, which can lead to poor generalization when these correlations shift at test time. A common hypothesis is that learning disentangled representations—where independent factors of variation are captured by separate dimensions—can improve robustness to such shifts. In this work, we investigate this hypothesis by evaluating the relationship between disentanglement and generalization under correlation shifts. We perform a systematic study using controlled synthetic datasets and find that, contrary to common intuition, higher disentanglement does not consistently lead to better generalization under correlation shifts. We further analyze the conditions under which disentanglement might be beneficial and discuss the implications for representation learning.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Funke, Christina M. and Vicol, Paul and Wang, Kuan-Chieh and Kümmerer, Matthias and Zemel, Richard and Bethge, Matthias},
	year = {2022},
	keywords = {Linear subspace, MNIST database, Categorical variable, Mutual information, Conditional independence, Variation (astronomy), Correlation, Computer science, Generalization, Independence (probability theory), Artificial intelligence, Machine learning, Data mining, Mathematics, Statistics, Artificial neural network, AISTATS},
}
