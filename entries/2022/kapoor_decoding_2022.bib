@article{kapoor_decoding_2022,
	title = {Decoding internally generated transitions of conscious contents in the prefrontal cortex without subjective reports},
	copyright = {© The Author(s) 2022},
	issn = {2041-1723},
	shorttitle = {Decoding internally generated transitions of conscious contents},
	url = {https://www.nature.com/articles/s41467-022-28897-2},
	doi = {10.1038/s41467-022-28897-2},
	abstract = {The neural correlates of consciousness are typically studied by comparing brain activity during conscious versus unconscious states, or by contrasting reportable versus non-reportable stimuli. However, these approaches often confound consciousness with task-related processes such as attention, decision-making, and motor report. Here, we investigate the neural basis of conscious content transitions in the absence of subjective reports, using a binocular rivalry paradigm in monkeys. We show that the prefrontal cortex (PFC) contains information about the dominant percept during rivalry, and that this information is present even when the animal is not required to report its percept. Furthermore, we find that the PFC activity predicts the timing of perceptual transitions. Our results suggest that the PFC plays a key role in the maintenance and transition of conscious contents, independent of task-related report requirements.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Nature Communications},
	publisher = {Nature Portfolio},
	author = {Kapoor, Vishal and Dwarakanath, Anirvan and Safavi, Sadegh and Werner, Jens and Besserve, Michel and Panagiotaropoulos, Theofanis I. and Logothetis, Nikos K.},
	month = mar,
	year = {2022},
	keywords = {Nature Communications},
}
