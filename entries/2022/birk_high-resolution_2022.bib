@article{birk_high-resolution_2022,
	title = {High-resolution neural network-driven mapping of multiple diffusion metrics leveraging asymmetries in the balanced steady-state free precession frequency profile},
	shorttitle = {High-resolution neural network-driven mapping of multiple diffusion metrics},
	url = {https://is.mpg.de/ei/publications/birketal22},
	doi = {10.1002/nbm.4669},
	abstract = {Balanced steady-state free precession (bSSFP) is a fast magnetic resonance imaging sequence that is highly sensitive to diffusion. However, the bSSFP signal is also sensitive to off-resonance effects, which can lead to signal voids and artifacts. In this work, we propose a neural network-driven approach to map multiple diffusion metrics from bSSFP data, leveraging the asymmetries in the bSSFP frequency profile. We demonstrate that our method can produce high-resolution diffusion maps in a fraction of the time required by conventional methods.},
	language = {en},
	urldate = {2024-05-22},
	journal = {NMR in Biomedicine},
	publisher = {Wiley},
	author = {Birk, F. and Glang, F. and Loktyushin, A. and Birkl, C. and Ehses, P. and Scheffler, K. and Heule, R.},
	year = {2022},
}
