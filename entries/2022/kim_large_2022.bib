@inproceedings{kim_large_2022,
	title = {Large {Loss} {Matters} in {Weakly} {Supervised} {Multi}-{Label} {Classification}},
	shorttitle = {Large {Loss} {Matters}},
	url = {https://openaccess.thecvf.com/content/CVPR2022/papers/Kim_Large_Loss_Matters_in_Weakly_Supervised_Multi-Label_Classification_CVPR_2022_paper.pdf},
	doi = {10.1109/CVPR52688.2022.01376},
	abstract = {Weakly supervised multi-label classification (WSML) aims to learn a multi-label classifier from image-level labels, which are often incomplete. A common approach is to treat missing labels as negative, but this introduces noise. Existing methods typically address this by either estimating the missing labels or by designing robust loss functions. In this paper, we observe that the loss values of the samples are highly informative for identifying the missing labels. Specifically, we find that samples with large loss values are more likely to contain missing positive labels. Based on this observation, we propose a simple yet effective method, called Large Loss Matters (LLM), which utilizes the large loss samples to identify and correct the missing labels. We show that our method achieves state-of-the-art performance on several benchmark datasets, including MS-COCO, Pascal VOC, and NUS-WIDE.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {2022 {IEEE}/{CVF} {Conference} on {Computer} {Vision} and {Pattern} {Recognition} ({CVPR})},
	publisher = {IEEE},
	author = {Kim, Youngkyu and Kim, Jong Min and Akata, Zeynep and Lee, Jonghyun},
	month = jun,
	year = {2022},
	keywords = {Multi-label classification, Memorization, Computer science, Pascal (unit), Artificial intelligence, Machine learning, Task (project management), Pattern recognition (psychology), Class (philosophy), Annotation, Code (set theory), Mathematics, Set (abstract data type), CVPR},
}
