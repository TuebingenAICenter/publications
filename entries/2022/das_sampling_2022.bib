@misc{das_sampling_2022,
	title = {Sampling without {Replacement} {Leads} to {Faster} {Rates} in {Finite}-{Sum} {Minimax} {Optimization}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2022/hash/2ce4f0b8e24c45318352068603153590-Abstract-Conference.html},
	doi = {10.48550/arxiv.2206.02953},
	abstract = {We study stochastic gradient descent-ascent (SGDA) for solving finite-sum minimax optimization problems. While standard SGDA typically relies on sampling with replacement, we show that sampling without replacement (shuffling) leads to faster convergence rates. Specifically, for strongly-convex-strongly-concave objectives, we prove that shuffling achieves a convergence rate of O(1/nˆ2 + 1/T) where n is the number of components and T is the number of iterations, improving upon the O(1/n + 1/T) rate of sampling with replacement. We provide a unified analysis for both smooth and non-smooth settings and demonstrate the effectiveness of our theoretical findings through numerical experiments.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Das, Aniket and Schölkopf, Bernhard and Muehlebach, Michael},
	editor = {Koyejo, S. and Mohamed, S. and Agarwal, A. and Belgrave, D. and Cho, K. and Oh, A.},
	year = {2022},
	keywords = {Minimax, Sampling (signal processing), Convexity, Mathematical optimization, Convergence (economics), Mathematics, Shuffling, Rate of convergence, Point (geometry), Applied mathematics, Computer science, Statistics, NEURIPS},
}
