@article{kart_automated_2022,
	title = {Automated imaging-based abdominal organ segmentation and quality control in 20,000 participants of the {UK} {Biobank} and {German} {National} {Cohort} {Studies}},
	copyright = {© The Author(s) 2022},
	issn = {2045-2322},
	url = {https://doi.org/10.1038/s41598-022-23632-9},
	doi = {10.1038/s41598-022-23632-9},
	abstract = {Large-scale population-based imaging studies provide a unique opportunity to study the association of organ-specific morphology with health and disease. However, the manual analysis of such large datasets is infeasible. We developed a fully automated pipeline for the segmentation of six abdominal organs (liver, spleen, right and left kidney, pancreas, and gallbladder) in abdominal magnetic resonance imaging (MRI) data. The pipeline is based on a deep learning approach using a nnU-Net architecture. We trained and validated the model on 400 manually annotated datasets from the UK Biobank and the German National Cohort (NAKO). We then applied the pipeline to 20,000 participants of the UK Biobank and NAKO. Furthermore, we developed a quality control (QC) classifier to automatically identify segmentation failures. The segmentation pipeline achieved high Dice similarity coefficients (DSC) for all organs (mean DSC 0.95 for liver, 0.94 for spleen, 0.94 for kidneys, 0.84 for pancreas, and 0.82 for gallbladder). The QC classifier achieved an area under the receiver operating characteristic curve (AUC) of 0.98 for the detection of segmentation failures. Our pipeline enables the large-scale analysis of abdominal organ morphology in population-based imaging studies.},
	language = {en},
	journal = {Scientific Reports},
	publisher = {Nature Portfolio},
	author = {Kart, Turkay and Fischer, Marc and Winzeck, Stefan and Glocker, Ben and Bai, Wenjia and Bülow, Robin and Emmel, Carina and Friedrich, Lena and Kauczor, Hans-Ulrich and Keil, Thomas and Kröncke, Thomas and Mayer, Philipp and Niendorf, Thoralf and Peters, Annette and Pischon, Tobias and Schaarschmidt, Benedikt M. and Schmidt, Börge and Schulze, Matthias B. and Umutle, Lale and Völzke, Henry and Küstner, Thomas and Bamberg, Fabian and Schölkopf, Bernhard and Rueckert, Daniel and Gatidis, Sergios},
	month = nov,
	year = {2022},
	keywords = {Biobank, Segmentation, Pipeline (software), Artificial intelligence, Magnetic resonance imaging, Computer science, Population, Image segmentation, Data quality, Medicine, Cohort, Image quality, Data mining, Medical physics, Radiology, Pathology, Bioinformatics, Image (mathematics)},
}
