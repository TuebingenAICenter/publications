@article{bordt_post-hoc_2022,
	title = {Post-{Hoc} {Explanations} {Fail} to {Achieve} their {Purpose} in {Adversarial} {Contexts}},
	shorttitle = {Post-{Hoc} {Explanations} {Fail}},
	url = {https://doi.org/10.1145/3531146.3533153},
	doi = {10.1145/3531146.3533153},
	abstract = {Post-hoc explanations are a popular tool to make machine learning models more interpretable. They are often used to justify decisions in high-stakes domains, such as credit lending or criminal justice. However, it is unclear whether these explanations are robust to adversarial attacks. In this paper, we show that post-hoc explanations can be easily manipulated. We demonstrate that for any given input and any target explanation, one can construct an adversarial input that is visually indistinguishable from the original input but has a completely different explanation. We formalize this problem and provide a theoretical analysis of the conditions under which such attacks are possible. We also propose a simple and effective attack algorithm and demonstrate its performance on several state-of-the-art explanation methods and datasets. Our results suggest that post-hoc explanations should be used with caution in adversarial contexts, as they may not reflect the true decision-making process of the model.},
	language = {en},
	urldate = {2025-05-14},
	journal = {2022 ACM Conference on Fairness, Accountability, and Transparency},
	publisher = {Association for Computing Machinery},
	author = {Bordt, Sebastian and Finck, Michèle and Raidl, Éric and von Luxburg, Ulrike},
	year = {2022},
	keywords = {Adversarial system, Computer science, Wireless ad hoc network, Post hoc, Mobile ad hoc network, Computer security, Artificial intelligence, Wireless, Telecommunications, FACCT},
}
