@misc{boreiko_sparse_2022,
	title = {Sparse {Visual} {Counterfactual} {Explanations} in {Image} {Space}},
	shorttitle = {Sparse {Visual} {Counterfactual} {Explanations}},
	url = {https://arxiv.org/abs/2205.07972},
	doi = {10.48550/arxiv.2205.07972},
	abstract = {Counterfactual explanations are a popular tool to interpret the decisions of machine learning models. They answer the question: 'What is the smallest change to the input such that the model prediction changes to a target class?'. While many methods exist, they often produce counterfactuals that are either not sparse or not visually plausible. In this paper, we propose a new method for generating sparse visual counterfactuals in image space. We use a combination of a sparsity-inducing penalty and a generative model to ensure that the counterfactuals are both sparse and visually plausible. We demonstrate the effectiveness of our method on several datasets and show that it outperforms existing methods in terms of sparsity and visual quality.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Springer},
	author = {Boreiko, Valentyn and Augustin, Maximilian and Croce, Francesco and Berens, Philipp and Hein, Matthias},
	year = {2022},
	keywords = {Spurious relationship, Counterfactual thinking, Artificial intelligence, Computer science, Classifier (UML), Image (mathematics), Pattern recognition (psychology), Contextual image classification, Adversarial system, Space (punctuation), Machine learning, GCPR},
}
