@article{quirin_achievement_2022,
	title = {The {Achievement} {Motive} in the {Brain}: {BOLD} {Responses} to {Pictures} of {Challenging} {Activities} {Predicted} by {Implicit} {Versus} {Explicit} {Achievement} {Motives}},
	copyright = {CC BY 4.0},
	issn = {1664-1078},
	shorttitle = {The {Achievement} {Motive} in the {Brain}},
	url = {https://doi.org/10.3389/fpsyg.2022.845910},
	doi = {10.3389/fpsyg.2022.845910},
	abstract = {The achievement motive is a central construct in personality psychology. While implicit and explicit motives are assumed to be distinct, their neural underpinnings remain poorly understood. We investigated the neural correlates of implicit and explicit achievement motives using functional magnetic resonance imaging (fMRI). Participants were presented with pictures of challenging activities and neutral control pictures. We found that the implicit achievement motive was associated with BOLD responses in the ventral striatum and the medial prefrontal cortex, whereas the explicit achievement motive was associated with BOLD responses in the dorsolateral prefrontal cortex. These findings suggest that implicit and explicit achievement motives are mediated by distinct neural systems, supporting the dual-process model of motivation.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Frontiers in Psychology},
	publisher = {Frontiers Media SA},
	author = {Quirin, Markus and Loktyushin, Alexander and Küstermann, Eva and Kuhl, Julius},
	month = jul,
	year = {2022},
	keywords = {FRONTIERS},
}
