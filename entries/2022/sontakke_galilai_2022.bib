@misc{sontakke_galilai_2022,
	title = {{GalilAI}: {Out}-of-{Task} {Distribution} {Detection} using {Causal} {Active} {Experimentation} for {Safe} {Transfer} {RL}},
	shorttitle = {{GalilAI}},
	url = {https://proceedings.mlr.press/v151/sontakke22a.html},
	doi = {10.48550/arxiv.2110.15489},
	abstract = {Transferring reinforcement learning (RL) agents to new environments is challenging due to the potential for catastrophic failure when the agent encounters out-of-task (OoT) distributions. We propose GalilAI, a framework for detecting OoT distributions in RL by leveraging causal models. GalilAI uses active experimentation to learn a causal model of the environment and uses this model to detect when the agent is in an OoT state. We demonstrate that GalilAI can effectively detect OoT distributions and prevent catastrophic failure in several simulated environments.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Sontakke, S. A. and Iota, S. and Hu, Z. and Mehrjou, A. and Itti, L. and Schölkopf, B.},
	editor = {Camps-Valls, Gustau and Ruiz, Francisco J. R. and Valera, Isabel},
	month = mar,
	year = {2022},
	keywords = {Computer science, Reinforcement learning, Generalization, Task (project management), Artificial intelligence, Probabilistic logic, Machine learning, Bridge (graph theory), Engineering, Mathematics, AISTATS},
}
