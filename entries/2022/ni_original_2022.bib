@misc{ni_original_2022,
	title = {Original or {Translated}? {A} {Causal} {Analysis} of the {Impact} of {Translationese} on {Machine} {Translation} {Performance}},
	shorttitle = {Original or {Translated}?},
	url = {https://aclanthology.org/2022.naacl-main.389/},
	doi = {10.18653/v1/2022.naacl-main.389},
	abstract = {Translationese, the distinct linguistic style of translated texts, is known to affect the performance of machine translation (MT) systems. However, it remains unclear whether translationese is a nuisance that should be removed or a useful signal that should be leveraged. In this paper, we provide a causal analysis of the impact of translationese on MT performance. We first formalize the causal relationship between translationese and MT performance using a structural causal model. We then propose a set of interventions to disentangle the effect of translationese from other factors. Our experiments on multiple language pairs and datasets show that translationese is a significant factor in MT performance, and that its impact is not uniform across different settings. We further demonstrate that our causal framework can be used to improve MT performance by selectively training on or adapting to translationese.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Association for Computational Linguistics},
	author = {Ni, Jingwei and Jin, Zhijing and Freitag, Markus and Sachan, Mrinmaya and Schölkopf, Bernhard},
	month = jul,
	year = {2022},
	keywords = {Computer science, Machine translation, Training set, Translation (biology), Test (biology), Set (abstract data type), Artificial intelligence, Work (physics), Natural language processing, Code (set theory), Test set, Test data, Machine learning, Software engineering, Engineering, Programming language, NAACL},
}
