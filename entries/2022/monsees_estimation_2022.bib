@article{monsees_estimation_2022,
	title = {Estimation of skeletal kinematics in freely moving rodents},
	copyright = {© 2022, Springer Nature Limited},
	issn = {1548-7091},
	shorttitle = {Estimation of skeletal kinematics in freely moving rodents},
	url = {https://is.mpg.de/ei/publications/monseesetal22},
	doi = {10.1038/s41592-022-01634-9},
	abstract = {Quantifying the movement of the skeleton in freely moving animals is essential for understanding the neural basis of behavior. However, current methods for tracking skeletal kinematics are either invasive, require specialized laboratory environments or are limited in their ability to capture complex, three-dimensional movements. Here we present DeepLabCut-based skeletal kinematics (DSK), a framework for estimating the 3D pose of the skeleton in freely moving rodents using only video data. DSK combines deep learning-based markerless pose estimation with a kinematic model of the rodent skeleton to recover 3D joint angles and limb positions. We demonstrate that DSK can accurately track skeletal kinematics in freely moving mice and rats across a range of behaviors, including locomotion, grooming and rearing, without the need for markers or specialized hardware. DSK provides a robust and accessible tool for studying the neural control of movement in freely moving animals.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Nature Methods},
	publisher = {Nature Portfolio},
	author = {Monsees, A. and Voit, K.-M. and Wallace, D. J. and Sawinski, J. and Charyasz, E. and Scheffler, K. and Macke, J. H. and Kerr, J. N. D.},
	month = nov,
	year = {2022},
	keywords = {Kinematics, Computational biology, Computer science, Biology, Artificial intelligence, Physics, Classical mechanics, NATURE METHODS},
}
