@misc{zhang_adversarial_2022,
	title = {Adversarial {Robustness} {Through} the {Lens} of {Causality}},
	url = {https://openreview.net/forum?id=cZAi1yWpiXQ},
	doi = {10.48550/arxiv.2106.06196},
	abstract = {Deep neural networks are vulnerable to adversarial examples, which are inputs with small, human-imperceptible perturbations that cause the model to make incorrect predictions. Existing defenses against adversarial examples mainly focus on robust optimization, which often leads to a trade-off between standard accuracy and adversarial robustness. In this paper, we investigate the adversarial vulnerability of deep neural networks from a causal perspective. We show that adversarial examples are often caused by the model's reliance on non-robust features, which are statistically correlated with the label but are not causally related to it. We propose a causal framework for adversarial robustness, which aims to learn a model that relies on causal features. We further propose a method, called CausalAdv, to learn such a model. Experimental results on several benchmark datasets demonstrate that our method achieves state-of-the-art adversarial robustness while maintaining high standard accuracy.},
	language = {en},
	author = {Zhang, Y. and Gong, M. and Liu, T. and Niu, G. and Tian, X. and Han, B. and Schölkopf, B. and Zhang, K.},
	month = apr,
	year = {2022},
	keywords = {Adversarial system, Spurious relationship, Computer science, Artificial intelligence, Intuition, Causality (physics), Machine learning, Psychology, Cognitive science, ICLR},
}
