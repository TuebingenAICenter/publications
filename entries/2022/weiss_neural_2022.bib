@article{weiss_neural_2022,
	title = {Neural {Attentive} {Circuits}},
	shorttitle = {{NACs}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2022/hash/32f227c41a0b4e36f65bebb4aeda94a2-Abstract-Conference.html},
	doi = {10.48550/arxiv.2210.08031},
	abstract = {We introduce Neural Attentive Circuits (NACs), a novel neural network architecture that combines the benefits of modularity and attention. NACs are composed of a set of specialized modules that are dynamically selected and combined using an attention mechanism. This allows the network to adapt its computation to the input, leading to improved performance and interpretability. We demonstrate the effectiveness of NACs on a variety of tasks, including image classification, language modeling, and reinforcement learning, showing that they can achieve state-of-the-art results while being more parameter-efficient than traditional architectures.},
