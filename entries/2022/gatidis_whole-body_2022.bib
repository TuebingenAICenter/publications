	issn = {2052-4463},
	shorttitle = {A whole-body {FDG}-{PET}/{CT} {Dataset}},
	url = {https://doi.org/10.1038/s41597-022-01718-3},
	doi = {10.1038/s41597-022-01718-3},
	abstract = {We present a large-scale, multi-center dataset of whole-body FDG-PET/CT scans from 288 patients with various malignant tumors. The dataset contains 288 PET/CT scans, with a total of 1049 manually annotated tumor lesions. The annotations were performed by experienced radiologists and nuclear medicine physicians. The dataset is intended to facilitate the development and evaluation of automated tumor detection and segmentation algorithms in whole-body PET/CT imaging.},
