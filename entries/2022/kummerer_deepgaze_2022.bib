@article{kummerer_deepgaze_2022,
	title = {{DeepGaze} {III}: {Modeling} free-viewing human scanpaths with deep learning},
	issn = {1534-7362},
	shorttitle = {{DeepGaze} {III}},
	url = {https://iovs.arvojournals.org/article.aspx?articleid=2778776},
	doi = {10.1167/jov.22.5.7},
	abstract = {We present DeepGaze III, a deep learning model for predicting human scanpaths in free-viewing tasks. DeepGaze III builds on the DeepGaze IIE saliency model and extends it to predict sequences of fixations. The model uses a recurrent neural network to model the dependency of the next fixation on the previous fixations and the image content. We show that DeepGaze III outperforms existing models on the MIT/Tuebingen saliency benchmark and the SALICON dataset. Furthermore, we demonstrate that the model can be used to generate realistic scanpaths that are indistinguishable from human scanpaths in a visual Turing test.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Vision},
	publisher = {Association for Research in Vision and Ophthalmology (ARVO)},
	author = {Kümmerer, Matthias and Bethge, Matthias and Wallis, Thomas S. A.},
	year = {2022},
	keywords = {Fixation (population genetics), Computer science, Artificial intelligence, Deep learning, Eye movement, Selection (genetic algorithm), Machine learning, Population, JOV},
}
