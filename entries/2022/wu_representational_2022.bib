@incollection{wu_representational_2022,
	title = {Representational exchange in human social learning: {Balancing} efficiency and flexibility},
	isbn = {9781009026949},
	shorttitle = {Representational exchange in human social learning},
	url = {https://doi.org/10.1017/9781009026949.009},
	doi = {10.1017/9781009026949.009},
	abstract = {Social learning is a cornerstone of human intelligence, allowing us to acquire complex behaviors and knowledge without having to learn everything from scratch. However, social learning is not a simple process of copying; it requires a delicate balance between efficiency (learning quickly) and flexibility (adapting to new environments). In this chapter, we propose a framework of 'representational exchange' to understand how humans navigate this trade-off. We argue that social learners do not simply copy the actions of others, but rather infer the underlying representations—the goals, beliefs, and strategies—that drive those actions. By exchanging these representations, learners can achieve a more flexible and efficient form of social learning that goes beyond simple imitation.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {The {Drive} for {Knowledge}: {The} {Science} of {Human} {Information}-{Seeking}},
	publisher = {Cambridge University Press},
	author = {Wu, Charley M. and Vélez, Natalia and Cushman, Fiery},
	editor = {Dezza, I. C. and Schulz, E. and Wu, C. M.},
	year = {2022},
	keywords = {Inference, Computer science, Imitation, Social learning, Artificial intelligence, Flexibility (engineering), Fidelity, Cognitive science, Cognitive psychology, Machine learning, Psychology, Knowledge management, Social psychology, Mathematics},
}
