@inproceedings{pace_poetree_2022,
	title = {{POETREE}: {Interpretable} {Policy} {Learning} with {Adaptive} {Decision} {Trees}},
	shorttitle = {{POETREE}},
	url = {https://openreview.net/forum?id=AJsI-ymaKn_},
	abstract = {We propose POETREE, a framework for learning interpretable policies in reinforcement learning. POETREE learns a decision tree policy by iteratively growing the tree using a novel adaptive splitting criterion. The criterion is based on the expected improvement in the value function, which allows the tree to grow in a way that balances interpretability and performance. We demonstrate the effectiveness of POETREE on a variety of reinforcement learning tasks, showing that it can achieve performance comparable to black-box policies while being significantly more interpretable.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {10th {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Pace, A. and Chand, A. and van der Schaar, M.},
	month = apr,
	year = {2022},
	keywords = {ICLR},
}
