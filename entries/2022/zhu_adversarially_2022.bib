@misc{zhu_adversarially_2022,
	title = {Adversarially {Robust} {Kernel} {Smoothing}},
	url = {https://proceedings.mlr.press/v151/zhu22d.html},
	doi = {10.48550/arxiv.2102.08474},
	abstract = {We study the robustness of kernel methods against adversarial perturbations. We propose a framework for adversarially robust kernel smoothing, which consists of a robust kernel density estimator and a robust kernel regression estimator. We show that these estimators are robust to adversarial perturbations in the input space, and we provide theoretical guarantees for their robustness. We also demonstrate the effectiveness of our approach on several benchmark datasets.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Zhu, J.-J. and Kouridi, C. and Nemmour, Y. and Schölkopf, B.},
	editor = {Camps-Valls, Gustau and Ruiz, Francisco J. R. and Valera, Isabel},
	month = mar,
	year = {2022},
	keywords = {Robustness (evolution), Computer science, Smoothing, Mathematical optimization, Kernel (algebra), Scalability, Regular polygon, Operator (biology), Robust optimization, Artificial intelligence, Algorithm, Mathematics, AISTATS},
}
