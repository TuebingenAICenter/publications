@article{muller_perturbing_2022,
	title = {Perturbing {BatchNorm} and {Only} {BatchNorm} {Benefits} {Sharpness}-{Aware} {Minimization}},
	shorttitle = {Perturbing {BatchNorm} and {Only} {BatchNorm} {Benefits} {Sharpness}-{Aware} {Minimization}},
	url = {https://openreview.net/pdf?id=yL_iq-Q-ORS},
	abstract = {Sharpness-Aware Minimization (SAM) has been shown to improve generalization by finding flat minima. However, SAM is computationally expensive as it requires two forward-backward passes per update. In this work, we propose a simple modification to SAM that significantly reduces its computational overhead while maintaining its generalization benefits. We show that perturbing only the BatchNorm parameters is sufficient to achieve the generalization benefits of SAM. We call this method BatchNorm-SAM (BN-SAM). We demonstrate that BN-SAM achieves similar or better performance than SAM on various datasets and architectures while being significantly faster.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Has it Trained Yet? Algorithmic Efficiency in Practical Neural Network Training (NeurIPS 2022 Workshop)},
	author = {Müller, M. and Hein, M.},
	year = {2022},
	keywords = {NEURIPS},
}
