@inproceedings{glockler_variational_2022,
	title = {Variational methods for simulation-based inference},
	shorttitle = {Variational methods for simulation-based inference},
	url = {https://openreview.net/forum?id=kZ0UYdhqkNY},
	doi = {10.48550/arxiv.2203.04176},
	abstract = {Simulation-based inference (SBI) allows for Bayesian inference in models where the likelihood is intractable but simulation is possible. Recent approaches to SBI have focused on learning the posterior distribution using neural density estimators. However, these methods often struggle with high-dimensional data or complex posterior geometries. In this paper, we propose a new framework for SBI based on variational inference. We introduce a novel objective function that allows for the direct optimization of the variational posterior, bypassing the need for explicit density estimation. We demonstrate the effectiveness of our approach on a range of synthetic and real-world benchmarks, showing that it achieves state-of-the-art performance in terms of both accuracy and computational efficiency.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {International {Conference} on {Learning} {Representations} ({ICLR} 2022)},
	publisher = {OpenReview},
	author = {Glöckler, M. and Deistler, M. and Macke, J. H.},
	month = apr,
	year = {2022},
	keywords = {Inference, Computer science, Flexibility (engineering), Bayesian inference, Benchmark (surveying), Markov chain Monte Carlo, Posterior probability, Algorithm, Bayesian probability, Artificial intelligence, Machine learning, Mathematics, Statistics, ICLR},
}
