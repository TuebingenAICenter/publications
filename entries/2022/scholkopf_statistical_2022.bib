@misc{scholkopf_statistical_2022,
	title = {From statistical to causal learning},
	url = {https://ems.press/books/standalone/279/5610},
	doi = {10.4171/ICM2022/173},
	abstract = {Machine learning has been remarkably successful at finding statistical patterns in large datasets. However, these patterns often fail to generalize when the environment changes, because they do not capture the underlying causal structure of the world. In this paper, we argue that moving from statistical to causal learning is a necessary step for the next generation of AI systems. We review the foundations of causal inference, discuss how they can be integrated into machine learning, and highlight the potential of causal models to improve robustness, interpretability, and data efficiency.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {EMS Press},
	author = {Schölkopf, Bernhard and von Kügelgen, Julius},
	month = jul,
	year = {2022},
	keywords = {Causality (physics), Computer science, Artificial intelligence, Statistical learning, Causal model, Cognitive science, Machine learning, Data science, Psychology, Mathematics},
}
