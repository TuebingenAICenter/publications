@article{peters_causal_2022,
	title = {Causal {Models} for {Dynamical} {Systems}},
	shorttitle = {Causal {Models} for {Dynamical} {Systems}},
	url = {https://is.mpg.de/ei/publications/petbaupfi20},
	doi = {10.1145/3501714.3501752},
	abstract = {Causal models are often used to describe static systems. In this chapter, we discuss how these models can be extended to dynamical systems. We focus on structural causal models (SCMs) and their application to time series data. We discuss the concept of intervention in dynamical systems and how it relates to the notion of causality. We also review some recent approaches for learning causal models from time series data.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Probabilistic and Causal Inference: The Works of Judea Pearl},
	publisher = {Association for Computing Machinery},
	author = {Peters, Jonas and Bauer, Sebastian and Pfister, Niklas},
	year = {2022},
	keywords = {Causal Inference, Dynamical Systems},
}
