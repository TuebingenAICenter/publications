@misc{liu_structural_2022,
	title = {Structural {Causal} 3D {Reconstruction}},
	url = {https://is.mpg.de/ei/publications/liuetal22b},
	doi = {10.1007/978-3-031-19769-7_9},
	abstract = {3D reconstruction from 2D images is a fundamental problem in computer vision. Most existing methods rely on deep neural networks to learn the mapping from images to 3D shapes, which often suffer from poor generalization and lack of interpretability. In this paper, we propose a structural causal 3D reconstruction framework that explicitly models the causal relationships between 3D shapes and 2D images. By leveraging the structural causal model, we can disentangle the causal factors of 3D shapes and 2D images, leading to more robust and interpretable 3D reconstruction. We demonstrate the effectiveness of our method on several challenging 3D reconstruction tasks, showing that it outperforms state-of-the-art methods in terms of both reconstruction accuracy and generalization capability.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Springer},
	author = {Liu, Weiyang and Liu, Zhen and Paull, Liam and Weller, Adrian and Schölkopf, Bernhard},
	editor = {Avidan, Shai and Brostow, Gabriel J. and Cissé, Moustapha and Farinella, Giovanni Maria and Hassner, Tal},
	month = oct,
	year = {2022},
	keywords = {Causal structure, Regularization (linguistics), Ambiguity, Latent variable, Directed acyclic graph, Computer science, Space (punctuation), Graph, Algorithm, Artificial intelligence, Mathematics, Theoretical computer science, Physics, ECCV},
}
