@inproceedings{ramesh_gatsbi_2022,
	title = {{GATSBI}: {Generative} {Adversarial} {Training} for {Simulation}-{Based} {Inference}},
	shorttitle = {{GATSBI}},
	url = {https://openreview.net/forum?id=kR1hC6j48Tp},
	doi = {10.48550/arxiv.2203.06481},
	abstract = {Simulation-based inference (SBI) allows for Bayesian inference in models where the likelihood is intractable but simulation is possible. Recent approaches to SBI have focused on learning conditional density estimators, such as normalizing flows, to approximate the posterior distribution. However, these methods often struggle with high-dimensional data or complex, multi-modal posteriors. We propose GATSBI, a framework for SBI that leverages generative adversarial networks (GANs) to learn the posterior distribution. By framing SBI as a conditional density estimation problem, GATSBI can handle complex, high-dimensional data and provides a flexible way to incorporate prior knowledge. We demonstrate the effectiveness of GATSBI on several benchmark problems and show that it outperforms existing SBI methods in terms of accuracy and robustness.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {International {Conference} on {Learning} {Representations}},
	publisher = {arXiv},
	author = {Ramesh, P. and Lueckmann, J.-M. and Boelts, J. and Tejero-Cantero, A. and Greenberg, D. S. and Goncalves, P. J. and Macke, J. H.},
	month = apr,
	year = {2022},
	keywords = {Inference, Computer science, Adversarial system, Prior probability, Benchmark (surveying), Generative grammar, Bayesian inference, Posterior probability, Machine learning, Artificial intelligence, Focus (optics), Algorithm, Bayesian probability, Geology, ICLR},
}
