@article{boelts_flexible_2022,
	title = {Flexible and efficient simulation-based inference for models of decision-making},
	copyright = {CC BY 4.0},
	issn = {2050-084X},
	shorttitle = {Flexible and efficient simulation-based inference},
	url = {https://doi.org/10.7554/eLife.77220},
	doi = {10.7554/eLife.77220},
	abstract = {Simulation-based inference (SBI) allows for Bayesian parameter inference in models where the likelihood is intractable but simulations are possible. While SBI has been successfully applied to a wide range of scientific problems, it remains challenging to apply to complex models of decision-making, which often involve stochastic processes and require expensive simulations. Here, we present a framework for SBI that is both flexible and efficient, allowing for the inference of parameters in models of decision-making. We demonstrate the effectiveness of our approach on a range of models, including a drift-diffusion model and a more complex model of decision-making in a dynamic environment. Our approach is based on neural density estimation and allows for the amortized inference of posterior distributions. We show that our method is more efficient than traditional methods and can be applied to models that were previously considered intractable.},
	language = {en},
	urldate = {2024-05-22},
	journal = {eLife},
	publisher = {eLife Sciences Publications, Ltd},
	author = {Boelts, Jan-Matthis and Lueckmann, Jan-Matthis and Gao, Richard and Macke, Jakob H.},
	month = jul,
	year = {2022},
	keywords = {Computer science, Inference, Estimator, Bayesian inference, Approximate Bayesian computation, Bayesian probability, Statistical inference, Machine learning, Artificial intelligence, Markov chain Monte Carlo, Algorithm, Data mining, Statistics, Mathematics, ELIFE},
}
