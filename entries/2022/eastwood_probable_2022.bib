@misc{eastwood_probable_2022,
	title = {Probable {Domain} {Generalization} via {Quantile} {Risk} {Minimization}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2022/hash/6f11132f6ecbbcafafdf6decfc98f7be-Abstract-Conference.html},
	doi = {10.48550/arxiv.2207.09944},
	abstract = {We study the problem of domain generalization (DG), where the goal is to learn a model that performs well on unseen target domains. Existing approaches often rely on empirical risk minimization (ERM) or variants that minimize the average loss across training domains. However, such methods can perform poorly on domains where the model's performance is particularly bad. In this paper, we propose Quantile Risk Minimization (QRM), a framework for DG that minimizes a quantile of the loss distribution across training domains. We show that QRM is equivalent to minimizing a robust objective that is less sensitive to outliers and can provide better worst-case performance guarantees. We provide theoretical analysis of the generalization properties of QRM and demonstrate its effectiveness on several benchmark datasets.},
	language = {en},
	publisher = {Curran Associates, Inc.},
	author = {Eastwood, Cian and Robey, Alexander and Singh, Shashank and von Kügelgen, Julius and Hassani, Hamed and Pappas, George J. and Schölkopf, Bernhard},
	editor = {Koyejo, S. and Mohamed, S. and Agarwal, A. and Belgrave, D. and Cho, K. and Oh, A.},
	month = dec,
	year = {2022},
	keywords = {Quantile, Probabilistic logic, Computer science, Generalization, Robustness (evolution), Empirical risk minimization, Minification, Machine learning, Alpha (finance), Quantile regression, Artificial intelligence, Mathematical optimization, Econometrics, Mathematics, Statistics, NEURIPS},
}
