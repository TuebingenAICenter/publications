@article{rusak_imagenet-d_2022,
	title = {{ImageNet}-{D}: {A} {New} {Challenging} {Robustness} {Dataset} {Inspired} by {Domain} {Adaptation}},
	shorttitle = {{ImageNet}-{D}},
	url = {https://brendel-group.github.io/publication/2022_01_rusaka/},
	abstract = {Robustness to distribution shifts is a key requirement for the deployment of deep learning models in the real world. While many robustness benchmarks exist, they often focus on synthetic corruptions or specific types of domain shifts. In this work, we introduce ImageNet-D, a new robustness dataset inspired by domain adaptation. ImageNet-D consists of images from the ImageNet validation set that have been filtered to only include samples that are correctly classified by a standard ResNet-50 model, but are misclassified by a model trained on a different domain. We show that ImageNet-D is significantly more challenging than existing robustness benchmarks and that it reveals new insights into the robustness of state-of-the-art models.},
	language = {en},
	urldate = {2025-05-14},
	journal = {ICML 2022 Shift Happens Workshop},
	author = {Rusak, Evgenia and Schneider, Steffen and Gehler, Peter Vincent and Bringmann, Oliver and Brendel, Wieland and Bethge, Matthias},
	year = {2022},
	keywords = {ICML},
}
