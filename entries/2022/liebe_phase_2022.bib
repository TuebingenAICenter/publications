@misc{liebe_phase_2022,
	title = {Phase of firing does not reflect temporal order in sequence memory of humans and recurrent neural networks},
	copyright = {© 2022, Posted by the authors. This article is a preprint and has not been certified by peer review.},
	shorttitle = {Phase of firing does not reflect temporal order},
	url = {https://www.biorxiv.org/content/10.1101/2022.09.25.509370v1},
	doi = {10.1101/2022.09.25.509370},
	abstract = {The temporal organization of neural activity is thought to be a fundamental mechanism for memory. In the rodent hippocampus, the phase of firing of neurons relative to the theta oscillation (theta phase precession) is a well-established mechanism for representing temporal order. Whether this mechanism generalizes to human sequence memory remains debated. Here, we investigated whether phase of firing relative to local field potential oscillations reflects the temporal order of items in human sequence memory. We recorded single-unit activity and local field potentials from the human medial temporal lobe while patients performed a sequence memory task. We found no evidence for phase precession or any other systematic relationship between the phase of firing and the temporal order of items. To investigate whether this absence of evidence might be due to task-specific or species-specific differences, we trained recurrent neural networks (RNNs) to perform the same sequence memory task. We found that RNNs could successfully perform the task without relying on phase-of-firing codes. Our results suggest that phase of firing is not a universal mechanism for representing temporal order in sequence memory.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {bioRxiv},
	author = {Liebe, S. and Niediek, Johannes and Pals, Matthijs and Reber, Thomas P. and Faber, Jenny and Bostroem, Jan and Elger, Christian E. and Macke, Jakob H. and Mormann, Florian},
	month = sep,
	year = {2022},
	keywords = {Neuroscience, Local field potential, Stimulus (psychology), Temporal lobe, Neural ensemble, Recurrent neural network, Artificial neural network, Computer science, Sequence (biology), Neuron, Oscillation (cell signaling), Psychology, Artificial intelligence, Cognitive psychology, Epilepsy, Biology},
}
