@article{ciranka_asymmetric_2022,
	title = {Asymmetric learning facilitates human inference of transitive relations},
	issn = {2397-3374},
	shorttitle = {Asymmetric learning facilitates human inference},
	url = {https://www.nature.com/articles/s41562-021-01263-w},
	doi = {10.1038/s41562-021-01263-w},
	abstract = {Transitive inference—the ability to derive relations between items that have not been directly compared—is a hallmark of human cognition. While normative models of transitive inference often assume that all relations are learned with equal precision, human memory is inherently asymmetric: we often remember the first or last items in a sequence better than those in the middle. Here we show that this asymmetry is not a limitation but a feature that facilitates transitive inference. Across three experiments, we demonstrate that human participants learn relations between items in a transitive hierarchy with systematic asymmetries, prioritizing the ends of the hierarchy. We show that this pattern of learning is optimal for transitive inference, as it maximizes the information gain for the most critical relations in the hierarchy. Our results suggest that human transitive inference is supported by a learning mechanism that strategically allocates resources to the most informative relations, providing a new perspective on the interplay between memory and reasoning.},
	language = {en},
	urldate = {2024-05-23},
	journal = {Nature Human Behaviour},
	publisher = {Nature Portfolio},
	author = {Ciranka, Sebastian and Linde-Domingo, Jaume and Padezhki, Iliya and Wicharz, Christian and Wu, Charley M. and Spitzer, Bernhard},
	month = feb,
	year = {2022},
	keywords = {Transitive relation, Inference, Reinforcement learning, Reinforcement, Cognitive science, Computer science, Artificial intelligence, Cognitive psychology, Psychology, Social psychology, Mathematics, Combinatorics, NHB},
}
