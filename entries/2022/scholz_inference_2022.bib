@article{scholz_inference_2022,
	title = {Inference of affordances and active motor control in simulated agents},
	issn = {1662-5218},
	shorttitle = {Inference of affordances and active motor control},
	url = {https://dx.doi.org/10.3389/fnbot.2022.881673},
	doi = {10.3389/fnbot.2022.881673},
	abstract = {The ability to interact with the environment is a fundamental requirement for autonomous agents. This requires the agent to understand which actions are possible in a given situation, a concept known as affordances. In this paper, we propose a framework for the inference of affordances and active motor control in simulated agents. We use a deep reinforcement learning approach where the agent learns to predict the outcome of its actions and to select actions that lead to desired outcomes. We demonstrate our approach in a simulated environment where an agent has to learn to interact with objects to achieve a goal. Our results show that the agent can learn to infer affordances and use them for active motor control, leading to more efficient and robust behavior.},
	language = {en},
	urldate = {2024-05-23},
	journal = {Frontiers in Neurorobotics},
	publisher = {Frontiers Media SA},
	author = {Scholz, Fedor and Gumbsch, Christian and Otte, Sebastian and Butz, Martin V},
	year = {2022},
	keywords = {FNBOT},
}
