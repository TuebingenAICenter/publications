@misc{lorch_amortized_2022,
	title = {Amortized {Inference} for {Causal} {Structure} {Learning}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2022/hash/54f7125dee9b8b3dc798bb9a082b09e2-Abstract-Conference.html},
	doi = {10.48550/arxiv.2205.12934},
	abstract = {Causal structure learning aims to recover the causal relationships between variables from observational data. Most existing methods are either constraint-based or score-based, both of which typically require a costly search over the space of possible causal structures for each new dataset. In this work, we propose a novel approach to causal structure learning that amortizes this search. We train a neural network to map observational data directly to a posterior distribution over causal structures. Our method, which we call Amortized Causal Discovery (ACD), is based on a permutation-based formulation of the structure learning problem and leverages a transformer-based architecture to handle datasets of varying sizes and variable orderings. We demonstrate that ACD can learn to perform causal structure learning in a single forward pass, achieving competitive performance with state-of-the-art methods while being orders of magnitude faster at inference time. Furthermore, we show that our model can generalize to datasets with different numbers of variables and different causal mechanisms than those seen during training.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Lorch, Lars and Sussex, Scott and Rothfuss, Jonas and Krause, Andreas and Schölkopf, Bernhard},
	year = {2022},
	keywords = {Inference, Generalization, Computer science, Machine learning, Permutation (music), Causal structure, Artificial intelligence, Causal inference, Domain (mathematical analysis), Code (set theory), Data structure, Conditional independence, Theoretical computer science, Data mining, Mathematics, Econometrics, NEURIPS},
}
