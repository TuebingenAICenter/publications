@misc{augustin_diffusion_2022,
	title = {Diffusion {Visual} {Counterfactual} {Explanations}},
	shorttitle = {{DVCEs}},
	url = {https://arxiv.org/abs/2210.11841},
	doi = {10.48550/arXiv.2210.11841},
	abstract = {Counterfactual explanations are a popular tool to explain the decisions of machine learning models by showing how an input would need to change to change the model's prediction. While many methods exist for tabular data, generating high-quality counterfactuals for images remains challenging. We propose Diffusion Visual Counterfactual Explanations (DVCEs), a method that leverages the generative power of diffusion models to produce realistic and diverse counterfactuals. Our approach optimizes the latent space of a pre-trained diffusion model to find a counterfactual that is close to the original image in the latent space while satisfying the target class constraint. We demonstrate that our method produces high-quality counterfactuals that are more realistic and diverse than existing methods, and we show that they can be used to improve the robustness of classifiers.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Augustin, Maximilian and Boreiko, Valentyn and Croce, Francesco and Hein, Matthias},
	year = {2022},
	keywords = {Counterfactual thinking, Computer science, Classifier (UML), Artificial intelligence, Regularization (linguistics), Machine learning, Hyperparameter, Pattern recognition (psychology), NEURIPS},
}
