@inproceedings{kristiadi_being_2022,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Being a {Bit} {Frequentist} {Improves} {Bayesian} {Neural} {Networks}},
	shorttitle = {Being a {Bit} {Frequentist} {Improves} {Bayesian} {Neural} {Networks}},
	url = {https://proceedings.mlr.press/v151/kristiadi22a.html},
	doi = {10.48550/arxiv.2106.10065},
	abstract = {Bayesian neural networks (BNNs) are often criticized for their poor predictive performance compared to their deterministic counterparts. We argue that this is partly due to the standard Bayesian approach of using a single, global prior over all weights, which is often misspecified. We propose a hybrid approach that combines Bayesian inference with frequentist regularization. Specifically, we use a frequentist penalty on the weights to encourage them to be close to a pre-trained deterministic model, while using a Bayesian approach to capture uncertainty. We show that this approach leads to BNNs that are more robust and have better predictive performance than standard BNNs, while still providing well-calibrated uncertainty estimates.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 25th {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Kristiadi, Augustin and Hein, Matthias and Hennig, Philipp},
	editor = {Camps-Valls, Gustau and Ruiz, Francisco J. R. and Valera, Isabel},
	month = mar,
	year = {2022},
	keywords = {Frequentist inference, Bayesian probability, Inference, Machine learning, Computer science, Artificial intelligence, Robustness (evolution), Bayesian inference, AISTATS},
}
