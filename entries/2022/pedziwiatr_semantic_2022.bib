@article{pedziwiatr_semantic_2022,
	title = {Semantic object-scene inconsistencies affect eye movements, but not in the way predicted by contextualized meaning maps},
	issn = {1534-7362},
	shorttitle = {Semantic object-scene inconsistencies},
	url = {https://bethgelab.org/publication/2022_01_pedziwiatr/},
	doi = {10.1167/jov.22.2.9},
	abstract = {The influence of semantic object-scene consistency on eye movements is a long-standing topic in vision research. Recent computational models, such as meaning maps, have been proposed to predict where people look in natural scenes. These models are based on the assumption that semantic information is a key driver of eye movements. However, it remains unclear whether these models can account for the effects of semantic object-scene inconsistencies. Here, we tested whether semantic object-scene inconsistencies affect eye movements and whether these effects are captured by contextualized meaning maps. We found that semantic inconsistencies do affect eye movements, but these effects are not predicted by current meaning map models. Our results suggest that while semantic information is important for eye movement control, the way it is integrated into current models of scene viewing is insufficient to account for the effects of semantic inconsistencies.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Journal of Vision},
	publisher = {Association for Research in Vision and Ophthalmology},
	author = {Pedziwiatr, Marek A and Kümmerer, Matthias and Wallis, Thomas SA and Bethge, Matthias and Teufel, Christoph},
	year = {2022},
	keywords = {Meaning (existential), Affect (linguistics), Object (grammar), Computer science, Linguistics, Artificial intelligence, Natural language processing, Communication, Psychology, Philosophy, JOV},
}
