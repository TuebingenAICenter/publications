@misc{wochner_learning_2022,
	title = {Learning with {Muscles}: {Benefits} for {Data}-{Efficiency} and {Robustness} in {Anthropomorphic} {Tasks}},
	shorttitle = {Learning with {Muscles}},
	url = {https://proceedings.mlr.press/v205/wochner23a.html},
	doi = {10.48550/arxiv.2207.03952},
	abstract = {Anthropomorphic robots are often controlled by electric motors, which differ significantly from biological muscles in their force-generation properties. Muscles are nonlinear, force-velocity dependent, and have intrinsic dynamics. In this paper, we investigate whether these biological properties can be beneficial for robot control. We compare a muscle-like actuator model with a standard electric motor model in a reinforcement learning setting. We find that the muscle-like actuator model leads to higher data-efficiency and robustness in anthropomorphic tasks. Our results suggest that incorporating biological properties into robot control can be a promising direction for future research.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Wochner, I. and Schumacher, P. and Martius, G. and Büchler, D. and Schmitt, S. and Haeufle, D.},
	editor = {Liu, Karen and Kulic, Dana and Ichnowski, Jeff},
	month = dec,
	year = {2022},
	keywords = {Robustness (evolution), Artificial intelligence, Computer science, Robotics, Machine learning, Scratch, Robot, Hyperparameter, Actuator, Nonlinear system, Biology, CORL},
}
