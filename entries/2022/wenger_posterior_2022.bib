@inproceedings{wenger_posterior_2022,
	title = {Posterior and {Computational} {Uncertainty} in {Gaussian} {Processes}},
	shorttitle = {Posterior and {Computational} {Uncertainty} in {Gaussian} {Processes}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2022/hash/4683beb6bab325650db13afd05d1a14a-Abstract-Conference.html},
	doi = {10.48550/arxiv.2205.15449},
	abstract = {Gaussian processes (GPs) are a cornerstone of Bayesian non-parametric regression. While they provide a principled framework for quantifying uncertainty, their computational cost is prohibitive for large datasets. Consequently, a vast literature on approximate GP inference has emerged. However, these approximations introduce a second source of uncertainty: computational uncertainty, which arises from the fact that the approximation is not the exact posterior. In this paper, we argue that this computational uncertainty is often ignored, leading to overconfident predictions. We propose a framework for quantifying both posterior and computational uncertainty in GPs. We demonstrate that our framework provides a more realistic assessment of uncertainty and leads to better-calibrated predictions in a variety of settings.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 35},
	publisher = {Curran Associates, Inc.},
	author = {Wenger, Jonathan and Pleiss, Geoff and Pförtner, Marvin and Hennig, Philipp and Cunningham, John P.},
	editor = {Koyejo, S. and Mohamed, S. and Agarwal, A. and Belgrave, D. and Cho, K. and Oh, A.},
	month = dec,
	year = {2022},
	keywords = {Cholesky decomposition, Covariance, Computation, Applied mathematics, Gaussian, Mathematics, Generalization, Posterior probability, Benchmark (surveying), Gaussian process, Mathematical optimization, Computer science, Convergence (economics), Algorithm, Bayesian probability, Statistics, Eigenvalues and eigenvectors, gaussian processes, probabilistic numerics, numerical analysis, NEURIPS},
}
