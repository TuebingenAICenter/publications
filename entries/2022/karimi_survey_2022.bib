@article{karimi_survey_2022,
	title = {A survey of algorithmic recourse: contrastive explanations and consequential recommendations},
	shorttitle = {A survey of algorithmic recourse},
	url = {https://dl.acm.org/doi/10.1145/3527848},
	doi = {10.1145/3527848},
	abstract = {As machine learning models are increasingly used to inform consequential decisions in areas such as lending, hiring, and criminal justice, there is a growing demand for transparency and accountability. A key requirement for accountability is the ability to provide individuals with recourse: actionable information on how they can change their unfavorable outcomes. In this survey, we provide a comprehensive overview of the emerging field of algorithmic recourse. We categorize existing methods based on their underlying assumptions, the types of explanations they provide, and the guarantees they offer. We also discuss the challenges of evaluating recourse methods and highlight open problems for future research.},
	language = {en},
	journal = {ACM Computing Surveys},
	publisher = {Association for Computing Machinery (ACM)},
	author = {Karimi, Amir-Hossein and Barthe, Gilles and Schölkopf, Bernhard and Valera, Isabel},
	month = dec,
	year = {2022},
	keywords = {Computer science, Accountability, Focus (optics), Work (physics), Management science, Data science, Risk analysis (engineering), Political science, Law, CSUR},
}
