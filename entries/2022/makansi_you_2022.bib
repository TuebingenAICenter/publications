@misc{makansi_you_2022,
	title = {You {Mostly} {Walk} {Alone}: {Analyzing} {Feature} {Attribution} in {Trajectory} {Prediction}},
	shorttitle = {You {Mostly} {Walk} {Alone}},
	url = {https://openreview.net/forum?id=POxF-LEqnF},
	doi = {10.48550/arxiv.2110.05304},
	abstract = {Trajectory prediction is a core component of autonomous systems. While deep learning models have achieved impressive performance, they are often treated as black boxes. In this work, we analyze the feature attribution of state-of-the-art trajectory prediction models. We find that these models rely heavily on the target agent's own history, while the influence of neighboring agents is surprisingly small. We investigate whether this is a desired behavior or a failure to capture social interactions. To this end, we propose a causal framework to analyze feature attribution and find that the models often fail to learn meaningful social interactions, instead relying on spurious correlations. We hope our findings will encourage the development of more robust and interpretable trajectory prediction models.},
	language = {en},
	urldate = {2025-05-14},
	author = {Makansi, Osama and von Kügelgen, Julius and Locatello, Francesco and Gehler, Peter and Janzing, Dominik and Brox, Thomas and Schölkopf, Bernhard},
	month = apr,
	year = {2022},
	keywords = {Trajectory, Benchmark (surveying), Computer science, Feature (linguistics), Artificial intelligence, Causality (physics), Machine learning, Task (project management), Black box, Engineering, ICLR},
}
