@article{oesterle_probabilistic_2022,
	title = {Probabilistic solvers enable a straight-forward exploration of numerical uncertainty in neuroscience models},
	shorttitle = {Probabilistic solvers enable a straight-forward exploration of numerical uncertainty in neuroscience models},
	url = {https://is.mpg.de/ei/publications/oesterleetal22},
	doi = {10.1007/s10827-022-00827-7},
	abstract = {Numerical simulations are a cornerstone of modern neuroscience. However, they are typically treated as ground truth, ignoring the fact that numerical solvers introduce errors. Here, we propose the use of probabilistic numerical solvers to quantify this numerical uncertainty. We demonstrate that probabilistic solvers can be used to propagate numerical uncertainty through neuroscience models, providing a principled way to assess the reliability of simulation results. We illustrate this approach with two examples: a Hodgkin-Huxley model and a model of a neural network.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Computational Neuroscience},
	publisher = {Springer Nature},
	author = {Oesterle, J. and Krämer, N. and Hennig, P. and Berens, P.},
	month = aug,
	year = {2022},
	keywords = {Theory of computation, Probabilistic logic, Computational neuroscience, Computer science, Cognitive science, Cognitive neuroscience, Neuroscience, Data science, Artificial intelligence, Psychology, Algorithm, Cognition, Ode, Spike (software development), Computation, Uncertainty quantification, Ordinary differential equation, Scalar (mathematics), Models of neural computation, Artificial neural network, Differential equation, Machine learning, Applied mathematics, Mathematics, JCN},
}
