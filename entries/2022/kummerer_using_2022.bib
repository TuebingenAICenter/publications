@article{kummerer_using_2022,
	title = {Using the {DeepGaze} {III} model to decompose spatial and dynamic contributions to fixation placement over time},
	issn = {1534-7362},
	shorttitle = {Using the {DeepGaze} {III} model},
	url = {https://jov.arvojournals.org/article.aspx?articleid=2784505},
	doi = {10.1167/jov.22.14.3964},
	abstract = {Human fixation behavior is driven by a complex interplay of spatial image features and temporal dynamics. While spatial models of saliency have reached high predictive performance, they often ignore the temporal evolution of gaze. Here, we introduce DeepGaze III, a model that combines a deep neural network for spatial feature extraction with a recurrent neural network to model the temporal dynamics of fixation placement. We use DeepGaze III to decompose the contributions of spatial image features and temporal dynamics to fixation placement over time. We find that spatial features are the primary driver of fixation placement, but that temporal dynamics play a significant role, particularly in the early stages of viewing. Our results suggest that the temporal evolution of gaze is not merely a consequence of spatial saliency but reflects a distinct process that is essential for understanding human fixation behavior.},
	language = {en},
	journal = {Journal of Vision},
	publisher = {Association for Research in Vision and Ophthalmology},
	author = {Kümmerer, Matthias and Wallis, Thomas S. A. and Bethge, Matthias},
	year = {2022},
	keywords = {Fixation (population genetics), Predictability, Gaze, Computer science, Artificial intelligence, Eye movement, Salient, Saccade, Eye tracking, Computer vision, Mathematics, JOV},
}
