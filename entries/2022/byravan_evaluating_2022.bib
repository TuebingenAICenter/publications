@inproceedings{byravan_evaluating_2022,
	title = {Evaluating {Model}-{Based} {Planning} and {Planner} {Amortization} for {Continuous} {Control}},
	shorttitle = {Evaluating {Model}-{Based} {Planning} and {Planner} {Amortization} for {Continuous} {Control}},
	url = {https://openreview.net/forum?id=SS8F6tFX3-},
	abstract = {Model-based reinforcement learning (MBRL) promises sample-efficient learning by leveraging a learned model of the environment. A common approach is to use the model for online planning, e.g., via Model Predictive Control (MPC). However, online planning can be computationally expensive at test time. Amortized approaches, such as policy distillation, aim to mitigate this by learning a policy that mimics the planner. In this work, we perform a systematic evaluation of model-based planning and planner amortization in continuous control. We investigate the performance of different planning algorithms, the impact of model accuracy, and the effectiveness of different amortization strategies. Our results show that while planning can significantly improve performance, the benefits of amortization are highly dependent on the task and the quality of the model. We provide insights into when and why amortization succeeds or fails, and suggest directions for future research.},
	language = {en},
	booktitle = {10th {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Byravan, Arun and Hasenclever, Leonard and Trochim, Piotr and Mirza, Mehdi and Ialongo, Alessandro D. and Tassa, Yuval and Springenberg, Jost Tobias and Abdolmaleki, Abbas and Heess, Nicolas and Merel, Josh and Riedmiller, Martin},
	month = apr,
	year = {2022},
	keywords = {ICLR},
}
