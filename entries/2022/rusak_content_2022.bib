@article{rusak_content_2022,
	title = {Content suppresses style: dimensionality collapse in contrastive learning},
	shorttitle = {Content suppresses style},
	url = {https://brendel-group.github.io/publication/2022_01_rusak/},
	abstract = {Contrastive learning has emerged as a powerful paradigm for self-supervised representation learning. While it is known that contrastive models are prone to dimensional collapse, the mechanisms behind this phenomenon are not fully understood. In this work, we show that contrastive learning is susceptible to a specific form of collapse, which we term 'content-style collapse'. We demonstrate that contrastive models tend to ignore style information in favor of content information, leading to a reduction in the effective dimensionality of the learned representations. We provide a theoretical analysis of this phenomenon and show that it is driven by the contrastive loss function. Finally, we propose a simple modification to the contrastive loss that mitigates this collapse and improves the quality of the learned representations.},
	language = {en},
	urldate = {2025-05-14},
	journal = {NeurIPS 2022 Workshop on Self-Supervised Learning},
	author = {Rusak, Evgenia and Reizinger, Patrik and Zimmermann, Roland S and Bringmann, Oliver and Brendel, Wieland},
	year = {2022},
	keywords = {NEURIPS},
}
