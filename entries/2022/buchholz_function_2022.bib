@misc{buchholz_function_2022,
	title = {Function {Classes} for {Identifiable} {Nonlinear} {Independent} {Component} {Analysis}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2022/hash/6c5da478b9d13f541993d67897a0bb30-Abstract-Conference.html},
	doi = {10.48550/arxiv.2208.06406},
	abstract = {Nonlinear Independent Component Analysis (ICA) aims to recover independent latent sources from observed data that are generated by a nonlinear mixing function. While this problem is generally ill-posed, recent work has shown that identifiability can be achieved by imposing constraints on the mixing function or by using auxiliary information. In this paper, we study the identifiability of nonlinear ICA from the perspective of function classes. We provide a general framework that characterizes the identifiability of the mixing function based on the properties of the function class it belongs to. We show that for a wide range of function classes, including those defined by neural networks, identifiability can be guaranteed if the function class is sufficiently rich and the sources are non-Gaussian. Our results provide a theoretical foundation for understanding the success of recent deep learning-based approaches to nonlinear ICA and suggest new directions for designing identifiable models.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Buchholz, Simon and Besserve, Michel and Schölkopf, Bernhard},
	year = {2022},
	keywords = {Identifiability, Spurious relationship, Jacobian matrix and determinant, Orthogonality, Nonlinear system, Generalization, Independent component analysis, Function (biology), Component (thermodynamics), Computer science, Mathematics, Applied mathematics, Artificial intelligence, Machine learning, Mathematical analysis, NEURIPS},
}
