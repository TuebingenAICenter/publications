@misc{barthe_listening_2022,
	title = {Listening to {Bluetooth} beacons for epidemic risk mitigation},
	copyright = {Creative Commons Attribution 4.0 International License},
	shorttitle = {Listening to {Bluetooth} beacons},
	url = {https://doi.org/10.1038/s41598-022-09440-1},
	doi = {10.1038/s41598-022-09440-1},
	abstract = {Digital contact tracing systems based on Bluetooth Low Energy (BLE) have been deployed worldwide to mitigate the spread of COVID-19. These systems rely on smartphones to broadcast and receive BLE beacons to estimate proximity between users. However, the accuracy of these proximity estimates is limited by the high variability of the received signal strength indicator (RSSI) in indoor environments. In this paper, we propose a new approach to digital contact tracing that leverages the fact that smartphones can listen to BLE beacons broadcast by other devices in their vicinity. We show that this approach can significantly improve the accuracy of proximity estimation compared to existing systems. We also demonstrate that our approach can be implemented on existing smartphones without requiring changes to the operating system or the Bluetooth stack. Finally, we evaluate our approach using a large-scale dataset of BLE beacon measurements collected in a real-world environment and show that it can achieve a significant reduction in the number of false positives and false negatives in contact tracing.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Nature Portfolio},
	author = {Barthe, Gilles and De Viti, Roberta and Druschel, Peter and Garg, Deepak and Gomez-Rodriguez, Manuel and Ingo, Pierfrancesco and Kremer, Heiner and Lentz, Matthew and Lorch, Lars and Mehta, Aastha and Schölkopf, Bernhard},
	month = apr,
	year = {2022},
	keywords = {Beacon, Contact tracing, Computer science, Bluetooth, Interoperability, Tracing, Isolation (microbiology), Computer security, Coronavirus disease 2019 (COVID-19), Real-time computing, Telecommunications, Wireless, World Wide Web, Operating system, Internet privacy, Active listening, Pairwise comparison, Artificial intelligence, Psychology, Medicine},
}
