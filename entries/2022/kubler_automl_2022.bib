@misc{kubler_automl_2022,
	title = {{AutoML} {Two}-{Sample} {Test}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2022/hash/66247b78cb1aa7259dcf856a18c9e294-Abstract-Conference.html},
	doi = {10.48550/arxiv.2206.08843},
	abstract = {The two-sample test is a fundamental problem in statistics, aiming to determine whether two samples are drawn from the same distribution. Kernel-based tests, such as the Maximum Mean Discrepancy (MMD), are popular due to their flexibility and ability to detect complex differences. However, their performance heavily depends on the choice of the kernel and its hyperparameters. In this paper, we propose an AutoML approach to the two-sample test. We formulate the problem of finding an optimal test as a hyperparameter optimization problem, where we aim to maximize the test power. We propose a novel objective function that is a differentiable proxy for the test power, allowing us to use gradient-based optimization to learn the kernel parameters. We demonstrate that our approach significantly outperforms existing methods on a wide range of synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Kübler, Jonas M. and Stimper, Vincent and Buchholz, Simon and Muandet, Krikamol and Schölkopf, Bernhard},
	editor = {Koyejo, S. and Mohamed, S. and Agarwal, A. and Belgrave, D. and Cho, K. and Oh, A.},
	month = dec,
	year = {2022},
	keywords = {Leverage (statistics), Computer science, Statistic, Sample (material), Statistical hypothesis testing, Test statistic, Python (programming language), Sample size determination, Machine learning, Witness, Benchmark (surveying), Artificial intelligence, Statistics, Mathematics, NEURIPS},
}
