@misc{dittadi_generalization_2022,
	title = {Generalization and {Robustness} {Implications} in {Object}-{Centric} {Learning}},
	url = {https://proceedings.mlr.press/v162/dittadi22a.html},
	doi = {10.48550/arxiv.2107.00637},
	abstract = {Object-centric learning aims to decompose scenes into individual objects, which is hypothesized to be a key step towards human-level intelligence. While recent methods have shown impressive results in scene decomposition, their impact on downstream tasks remains under-explored. In this work, we systematically evaluate the generalization and robustness of object-centric models on a variety of downstream tasks. We find that object-centric models do not consistently outperform standard monolithic architectures. In fact, we identify a trade-off between scene decomposition quality and downstream performance. We further show that object-centric models are not inherently more robust to distribution shifts than monolithic models. Our results suggest that current object-centric models may not yet be capturing the right inductive biases for general-purpose representation learning.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Dittadi, Andrea and Papa, Samuele S. and De Vita, Michele and Schölkopf, Bernhard and Winther, Ole and Locatello, Francesco},
	editor = {Chaudhuri, Kamalika and Jegelka, Stefanie and Song, Le and Szepesvari, Csaba and Niu, Gang and Sabato, Sivan},
	year = {2022},
	keywords = {Robustness (evolution), Artificial intelligence, Generalization, Computer science, Object (grammar), Inductive bias, Segmentation, Representation (politics), Cognitive neuroscience of visual object recognition, Feature learning, Artificial neural network, Pattern recognition (psychology), Computer vision, Machine learning, Mathematics, Multi-task learning, Engineering, ICML},
}
