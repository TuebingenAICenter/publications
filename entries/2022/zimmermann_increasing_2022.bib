@misc{zimmermann_increasing_2022,
	title = {Increasing {Confidence} in {Adversarial} {Robustness} {Evaluations}},
	shorttitle = {Increasing {Confidence} in {Adversarial} {Robustness} {Evaluations}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2022/hash/5545d9bcefb7d03d5ad39a905d14fbe3-Abstract-Conference.html},
	doi = {10.48550/arxiv.2206.13991},
	abstract = {Adversarial robustness is a central topic in machine learning, yet evaluating it remains notoriously difficult. A common practice is to report the robust accuracy of a model against a set of chosen attacks. However, this approach is often misleading: a model might appear robust simply because the chosen attacks are not strong enough or are ill-suited for the model. In this paper, we propose a new framework for evaluating adversarial robustness that provides a more reliable estimate of a model's true robustness. Our framework is based on the observation that the robust accuracy of a model is a function of the attack's computational budget. By measuring the robust accuracy across a range of budgets, we can identify the point at which the model's performance plateaus, providing a more robust and interpretable metric. We demonstrate the effectiveness of our framework on a variety of models and datasets, showing that it can reveal vulnerabilities that are missed by standard evaluation protocols.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Zimmermann, Roland S. and Brendel, Wieland and Tramer, Florian and Carlini, Nicholas},
	year = {2022},
	keywords = {Adversarial system, Robustness (evolution), Computer science, Skepticism, Deep neural networks, Artificial intelligence, Artificial neural network, Machine learning, Computer security, Epistemology, NEURIPS},
}
