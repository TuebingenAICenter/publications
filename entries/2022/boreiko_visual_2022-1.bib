@inproceedings{boreiko_visual_2022-1,
	title = {Visual counterfactual explanations for robust disease detection in ophthalmology},
	shorttitle = {Visual counterfactual explanations},
	url = {https://www.medrxiv.org/content/10.1101/2022.07.06.22276633v1},
	doi = {10.1101/2022.07.06.22276633},
	abstract = {Deep learning models have achieved high performance in medical image analysis, but their lack of interpretability remains a barrier to clinical adoption. Counterfactual explanations, which show how an input image would need to change to alter the model's prediction, are a promising approach to provide intuitive explanations. In this work, we propose a method to generate visual counterfactual explanations for disease detection in ophthalmology. We demonstrate that our method can generate realistic and clinically plausible counterfactuals for retinal images. Furthermore, we show that our counterfactuals can be used to identify model biases and improve the robustness of disease detection models.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {Medical {Image} {Computing} and {Computer} {Assisted} {Intervention} – {MICCAI} 2022},
	publisher = {medRxiv},
	author = {Boreiko, Valerii and Ilanchezian, Ilan and Ayhan, Mert and Müller, Simon and Koch, Lukas and Berens, Philipp and Hein, Matthias},
	year = {2022},
	keywords = {MICCAI},
}
