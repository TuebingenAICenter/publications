@article{ma_learning-based_2022,
	title = {A {Learning}-based {Iterative} {Control} {Framework} for {Controlling} a {Robot} {Arm} with {Pneumatic} {Artificial} {Muscles}},
	url = {http://www.roboticsproceedings.org/rss18/p029.html},
	doi = {10.15607/RSS.2022.XVIII.029},
	abstract = {Pneumatic artificial muscles (PAMs) are attractive actuators for soft robotics due to their high power-to-weight ratio and inherent compliance. However, their highly nonlinear, hysteretic, and time-varying dynamics make them notoriously difficult to control. In this paper, we propose a learning-based iterative control framework that combines a physics-based model with a learned model to achieve high-precision trajectory tracking. We use an iterative learning control (ILC) scheme that updates the control input based on the tracking error of previous trials. The learned model is used to compensate for the unmodeled dynamics and disturbances. We demonstrate the effectiveness of our approach on a robot arm actuated by PAMs, showing that it achieves superior tracking performance compared to a baseline controller.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of Robotics: Science and Systems XVIII},
	publisher = {Robotics: Science and Systems Foundation},
	author = {Ma, H. and Büchler, D. and Schölkopf, B. and Muehlebach, M.},
	month = jun,
	year = {2022},
	keywords = {RSS},
}
