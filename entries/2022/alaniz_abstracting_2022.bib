@inproceedings{alaniz_abstracting_2022,
	series = {Lecture {Notes} in {Computer} {Science}},
	title = {Abstracting {Sketches} through {Simple} {Primitives}},
	url = {https://is.mpg.de/ei/publications/alanizetal22},
	doi = {10.1007/978-3-031-19818-2_23},
	abstract = {Free-hand sketches are a natural way for humans to communicate visual concepts. However, their sparse and abstract nature makes them challenging to process for machines. Existing approaches often rely on complex deep learning models that are difficult to interpret and require large amounts of data. In this paper, we propose a novel approach to abstract sketches through simple primitives. Our method decomposes a sketch into a set of geometric primitives, such as lines, circles, and ellipses, which are then used to represent the sketch. This representation is not only compact and interpretable but also robust to variations in drawing style. We demonstrate the effectiveness of our approach on several sketch-based tasks, including sketch classification, retrieval, and generation, showing that our primitive-based representation achieves competitive performance while being significantly more efficient and interpretable than existing methods.},
	language = {en},
	publisher = {Springer},
	author = {Alaniz, S. and Mancini, M. and Dutta, A. and Marcos, D. and Akata, Z.},
	month = oct,
	year = {2022},
	keywords = {Sketch, Computer science, Abstraction, Set (abstract data type), Sketch recognition, Object (grammar), Affine transformation, Task (project management), Matching (statistics), Code (set theory), Simple (philosophy), Artificial intelligence, Theoretical computer science, Abstraction layer, Protocol (science), Programming language, Information retrieval, Algorithm, Software, Mathematics, ECCV},
}
