@inproceedings{immer_invariance_2022,
	title = {Invariance {Learning} in {Deep} {Neural} {Networks} with {Differentiable} {Laplace} {Approximations}},
	shorttitle = {Invariance {Learning} in {Deep} {Neural} {Networks}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2022/hash/50d005f92a6c5c9646db4b761da676ba-Abstract-Conference.html},
	abstract = {Deep neural networks are often required to be invariant to certain transformations of the input. While data augmentation is the standard approach to enforce such invariances, it can be computationally expensive and does not guarantee exact invariance. In this work, we propose a method to learn invariant representations by marginalizing over the transformation group using a differentiable Laplace approximation. Our approach allows for efficient training and provides a principled way to incorporate prior knowledge about invariances. We demonstrate the effectiveness of our method on several benchmarks, showing that it achieves competitive performance while being more robust to distribution shifts.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 35},
	publisher = {Curran Associates, Inc.},
	author = {Immer, Alexander and van der Ouderaa, T. F. A. and Rätsch, Gunnar and Fortuin, Vincent and van der Wilk, Mark},
	editor = {Koyejo, S. and Mohamed, S. and Agarwal, A. and Belgrave, D. and Cho, K. and Oh, A.},
	month = dec,
	year = {2022},
	keywords = {NEURIPS},
}
