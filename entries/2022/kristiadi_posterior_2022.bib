@inproceedings{kristiadi_posterior_2022,
	title = {Posterior {Refinement} {Improves} {Sample} {Efficiency} in {Bayesian} {Neural} {Networks}},
	shorttitle = {Posterior {Refinement} {Improves} {Sample} {Efficiency} in {Bayesian} {Neural} {Networks}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2022/hash/c3f9c42965b7572d4f06ec0e983df0aa-Abstract-Conference.html},
	doi = {10.48550/arXiv.2205.10041},
	abstract = {Bayesian neural networks (BNNs) are often trained using variational inference (VI) because it is computationally efficient. However, VI typically underestimates the uncertainty of the posterior distribution, which can lead to poor predictive performance. In this paper, we propose a simple and effective method to refine the posterior distribution of BNNs. Our method, which we call posterior refinement, uses a small number of additional samples to improve the quality of the variational posterior. We show that posterior refinement significantly improves the sample efficiency of BNNs on a variety of tasks, including regression and classification. We also show that our method is complementary to existing VI methods and can be easily integrated into existing pipelines.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 35 ({NeurIPS} 2022)},
	publisher = {Curran Associates, Inc.},
	author = {Kristiadi, Agustinus and Eschenhagen, Robert and Hennig, Philipp},
	month = dec,
	year = {2022},
	keywords = {Artificial neural network, Bayesian probability, Sample (material), Pattern recognition (psychology), Bayesian network, Bayesian inference, NEURIPS},
}
