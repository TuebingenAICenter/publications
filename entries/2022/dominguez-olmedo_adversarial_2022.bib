@misc{dominguez-olmedo_adversarial_2022,
	title = {On the {Adversarial} {Robustness} of {Causal} {Algorithmic} {Recourse}},
	url = {https://proceedings.mlr.press/v162/dominguez-olmedo22a.html},
	doi = {10.1609/aaai.v36i9.21192},
	abstract = {Algorithmic recourse aims to provide individuals with actionable recommendations to change an unfavorable decision made by a machine learning model. Recent work has shown that recourse can be achieved by leveraging causal models of the data-generating process. However, we show that such causal recourse methods are vulnerable to adversarial attacks: an adversary can manipulate the causal model or the recourse mechanism to provide recourse that is either invalid or harmful to the individual. We formalize this problem and propose a robust framework for causal algorithmic recourse that is resilient to such attacks. We demonstrate the effectiveness of our approach through extensive experiments on synthetic and real-world datasets.},
	language = {en},
	publisher = {PMLR},
	author = {Dominguez-Olmedo, Ricardo and Karimi, Amir-Hossein and Schölkopf, Bernhard},
	month = jul,
	year = {2022},
	keywords = {Counterfactual thinking, Computer science, Classifier (UML), Perspective (graphical), Fairness measure, Artificial intelligence, Machine learning, Social psychology, Psychology, Throughput, Robustness (evolution), Adversarial system, Risk analysis (engineering), Process (computing), Outcome (game theory), Microeconomics, Economics, Business, Differentiable function, Mathematical optimization, Mathematics, AAAI, ICML},
}
