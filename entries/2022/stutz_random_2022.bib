@misc{stutz_random_2022,
	title = {Random and {Adversarial} {Bit} {Error} {Robustness}: {Energy}-{Efficient} and {Secure} {DNN} {Accelerators}},
	shorttitle = {Random and {Adversarial} {Bit} {Error} {Robustness}},
	url = {https://arxiv.org/abs/2104.08323},
	doi = {10.1109/TPAMI.2022.3166560},
	abstract = {Deep neural networks (DNNs) are increasingly deployed on resource-constrained hardware, where energy efficiency is critical. One way to improve energy efficiency is to reduce the supply voltage, which, however, increases the probability of bit errors in memory. While random bit errors can be mitigated by training with noise, adversarial bit errors—where an attacker flips specific bits to cause misclassification—pose a significant security threat. In this paper, we propose a novel training framework to improve the robustness of DNNs against both random and adversarial bit errors. We formulate the problem as a min-max optimization problem, where the inner maximization finds the worst-case bit error pattern for a given input, and the outer minimization updates the network weights to be robust against these errors. We show that our approach significantly improves robustness against both random and adversarial bit errors compared to existing methods, while maintaining high accuracy on clean inputs. Furthermore, we demonstrate that our robust models can be deployed on energy-efficient hardware with reduced supply voltage without significant performance degradation.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {IEEE},
	author = {Stutz, David and Chandramoorthy, Nandhini and Hein, Matthias and Schiele, Bernt},
	year = {2022},
	keywords = {Computer science, Robustness (evolution), Quantization (signal processing), Energy consumption, Voltage, Computer engineering, Algorithm, Electrical engineering, Engineering, TPAMI},
}
