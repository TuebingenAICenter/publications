@misc{besserve_learning_2022,
	title = {Learning soft interventions in complex equilibrium systems},
	url = {https://proceedings.mlr.press/v180/besserve22a.html},
	doi = {10.48550/arxiv.2112.05729},
	abstract = {We consider the problem of learning the effect of interventions in complex systems at equilibrium. While standard causal discovery methods often assume that interventions are hard (i.e., they fix a variable to a constant value), many real-world interventions are soft, meaning they modify the mechanism of a variable without fixing it. We propose a framework to learn soft interventions in equilibrium systems, based on the assumption that the system is governed by a set of differential equations. We show that under certain conditions, the effect of soft interventions can be identified from observational data and a limited number of interventional experiments. We demonstrate the effectiveness of our approach on synthetic and real-world data.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Besserve, M. and Schölkopf, B.},
	editor = {Cussens, James and Zhang, Kun},
	year = {2022},
	keywords = {Counterintuitive, Differentiable function, Psychological intervention, Computer science, Complex system, Lead (geology), Graph, Risk analysis (engineering), Theoretical computer science, Artificial intelligence, Mathematics, Psychology, Business, Epistemology, UAI},
}
