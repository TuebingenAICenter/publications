@article{vankadara_interpolation_2022,
	title = {Interpolation and {Regularization} for {Causal} {Learning}},
	url = {http://tml.cs.uni-tuebingen.de/team/luxburg/publications/2022_VankadaraEtal.pdf},
	doi = {10.52202/068431-2654},
	abstract = {Causal learning from observational data is a fundamental problem in machine learning. A common approach is to use structural causal models (SCMs) and to estimate the causal structure from data. However, in many real-world scenarios, the number of variables is large, and the number of samples is small, making the estimation of the causal structure difficult. In this paper, we propose a new approach to causal learning that combines interpolation and regularization. We show that this approach can be used to learn causal structures from observational data even in the high-dimensional setting. We provide theoretical guarantees for our approach and demonstrate its effectiveness on synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Advances in Neural Information Processing Systems},
	publisher = {Curran Associates, Inc.},
	author = {Vankadara, Leena Chennuru and Rendsburg, Luca and von Luxburg, Ulrike and Ghoshdastidar, Debarghya},
	year = {2022},
	keywords = {Interpolation (computer graphics), Regularization (linguistics), Causal model, Multivariate interpolation, Key (lock), NEURIPS},
}
