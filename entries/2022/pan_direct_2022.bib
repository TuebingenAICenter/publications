@article{pan_direct_2022,
	title = {Direct {Advantage} {Estimation}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2022/hash/4d893f766ab60e5337659b9e71883af4-Abstract-Conference.html},
	doi = {10.52202/068431-0862},
	abstract = {Advantage estimation is a core component of many reinforcement learning algorithms. Most existing methods rely on temporal difference (TD) learning, which can be biased due to function approximation and bootstrapping. In this paper, we propose Direct Advantage Estimation (DAE), a method that estimates the advantage function directly from data without relying on TD learning. DAE is based on the observation that the advantage function can be expressed as the difference between the action-value function and the state-value function. We show that DAE can be implemented using a simple regression objective and that it is consistent under mild conditions. We demonstrate the effectiveness of DAE on a variety of continuous control tasks, showing that it can improve the performance of existing policy gradient methods.},
	language = {en},
	journal = {Advances in Neural Information Processing Systems},
	publisher = {Curran Associates, Inc.},
	author = {Pan, Hsiao-Ru and Gürtler, Nico and Neitz, Alexander and Schölkopf, Bernhard},
	editor = {Koyejo, S. and Mohamed, S. and Agarwal, A. and Belgrave, D. and Cho, K. and Oh, A.},
	month = dec,
	year = {2022},
	keywords = {NEURIPS},
}
