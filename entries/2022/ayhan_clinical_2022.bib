@misc{ayhan_clinical_2022,
	title = {Clinical validation of saliency maps for understanding deep neural networks in ophthalmology},
	shorttitle = {Clinical validation of saliency maps},
	url = {https://www.sciencedirect.com/science/article/abs/pii/S1361841522000172},
	doi = {10.1016/j.media.2022.102364},
	abstract = {Deep neural networks (DNNs) have shown great promise for the automated analysis of medical images. However, their lack of interpretability remains a major hurdle for clinical adoption. Saliency maps are a popular tool to visualize the features that drive a model's decision. While they are widely used in research, their clinical utility is largely unproven. In this study, we systematically evaluated the clinical validity of saliency maps for a DNN trained to detect referable diabetic retinopathy in fundus images. We compared saliency maps generated by four different methods (Gradient, Integrated Gradients, SmoothGrad, and Grad-CAM) against manual annotations from three retina specialists. We found that while saliency maps often highlight relevant anatomical structures, they also frequently focus on irrelevant image regions. Furthermore, we observed significant inter-method variability and a lack of correlation between saliency map quality and model performance. Our results suggest that current saliency map methods should be used with caution in clinical settings and highlight the need for more robust and clinically-grounded interpretability methods.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Elsevier},
	author = {Ayhan, Murat Seckin and Kümmerle, Louis B. and Kühlewein, Laura and Inhoffen, W. and Aliyeva, Gulnar and Ziemssen, Focke and Berens, Philipp},
	month = jan,
	year = {2022},
	keywords = {Computer science, Deep neural networks, Artificial intelligence, Fundus (uterus), Saliency map, Artificial neural network, Retinal, Set (abstract data type), Visualization, Pattern recognition (psychology), Machine learning, Image (mathematics), Medicine, Radiology, Ophthalmology, MEDIA},
}
