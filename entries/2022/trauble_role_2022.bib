@article{trauble_role_2022,
	title = {The {Role} of {Pretrained} {Representations} for the {OOD} {Generalization} of {RL} {Agents}},
	url = {https://openreview.net/forum?id=8eb12UQYxrG},
	doi = {10.48550/arxiv.2107.05686},
	abstract = {Deep reinforcement learning (RL) agents often struggle to generalize to out-of-distribution (OOD) tasks. A common approach to improve generalization is to leverage pretrained representations, for example, from self-supervised learning. However, it is currently unclear which properties of these representations are beneficial for OOD generalization in RL. In this work, we perform a large-scale empirical study to investigate the role of pretrained representations for OOD generalization in RL. We evaluate a wide range of representation learning methods on a diverse set of RL environments with varying types of OOD shifts. We find that while pretrained representations can significantly improve OOD generalization, their performance is highly sensitive to the choice of the pretraining task and the nature of the OOD shift. We further identify key properties of representations that correlate with OOD generalization performance, such as the alignment with the task-relevant features and the robustness to task-irrelevant variations.},
	language = {en},
	journal = {The Tenth International Conference on Learning Representations (ICLR 2022)},
	author = {Träuble, Frederik and Dittadi, Andrea and Wüthrich, Manuel and Widmaier, Felix and Gehler, Peter and Winther, Ole and Locatello, Francesco and Bachem, Olivier and Schölkopf, Bernhard and Bauer, Stefan},
	year = {2022},
	keywords = {Generalization, Reinforcement learning, Computer science, Artificial intelligence, Proxy (statistics), Machine learning, Reinforcement, Mathematics, Psychology, Natural language processing, ICLR},
}
