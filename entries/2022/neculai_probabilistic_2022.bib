@inproceedings{neculai_probabilistic_2022,
	title = {Probabilistic {Compositional} {Embeddings} for {Multimodal} {Image} {Retrieval}},
	shorttitle = {Probabilistic {Compositional} {Embeddings}},
	url = {https://is.mpg.de/ei/publications/neccheaka22},
	doi = {10.1109/CVPRW56347.2022.00501},
	abstract = {Compositional image retrieval aims to retrieve a target image based on a query image and a text modification. Existing methods typically learn a deterministic mapping from the image-text pair to the target image embedding. However, the ambiguity inherent in natural language descriptions and the diversity of possible image modifications suggest that a single point estimate is insufficient to capture the underlying distribution of the target image. In this work, we propose Probabilistic Compositional Embeddings (PCE), a framework that models the target image as a distribution in the embedding space. By representing the query and the target as Gaussian distributions, we can capture the uncertainty in the compositional process. We demonstrate that our approach achieves state-of-the-art performance on standard benchmarks for compositional image retrieval, while providing a measure of uncertainty that is useful for downstream tasks.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {{IEEE}/{CVF} {Conference} on {Computer} {Vision} and {Pattern} {Recognition} {Workshops} ({CVPRW})},
	publisher = {IEEE},
	author = {Neculai, Andrei and Chen, Yongqin and Akata, Zeynep},
	month = jun,
	year = {2022},
	keywords = {Computer science, Probabilistic logic, Embedding, Image retrieval, Benchmark (surveying), Divergence-from-randomness model, Information retrieval, Semantics (computer science), Image (mathematics), ENCODE, Artificial intelligence, Visual Word, Pattern recognition (psychology), Code (set theory), Statistical model, CVPRW},
}
