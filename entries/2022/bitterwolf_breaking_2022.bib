@misc{bitterwolf_breaking_2022,
	title = {Breaking {Down} {Out}-of-{Distribution} {Detection}: {Many} {Methods} {Based} on {OOD} {Training} {Data} {Estimate} a {Combination} of the {Same} {Core} {Quantities}},
	shorttitle = {Breaking {Down} {Out}-of-{Distribution} {Detection}},
	url = {https://arxiv.org/abs/2206.09880},
	doi = {10.48550/arXiv.2206.09880},
	abstract = {Out-of-distribution (OOD) detection is a crucial task for the safe deployment of machine learning models. A large class of OOD detection methods relies on training a model on both in-distribution (ID) and OOD data. In this paper, we show that many of these methods, despite their different motivations and architectures, are essentially estimating the same core quantities: the ID-class conditional densities and the OOD density. We demonstrate that these methods can be decomposed into a combination of these densities and a classifier. This perspective allows us to unify a wide range of existing approaches, explain their performance, and derive a simple yet powerful baseline that outperforms many complex state-of-the-art methods. We provide extensive experiments on standard benchmarks to support our theoretical findings.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Bitterwolf, Julian and Meinke, Alexander and Augustin, Maximilian and Hein, Matthias},
	year = {2022},
	keywords = {Discriminator, Binary classification, Outlier, Computer science, Artificial intelligence, Anomaly detection, Machine learning, Classifier (UML), Training set, Binary number, Pattern recognition (psychology), Data mining, Detector, Mathematics, ICML},
}
