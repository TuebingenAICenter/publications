@misc{behrens_retinal_2022,
	title = {Retinal horizontal cells use different synaptic sites for global feedforward and local feedback signaling},
	shorttitle = {Retinal horizontal cells use different synaptic sites},
	url = {https://doi.org/10.1016/j.cub.2021.11.055},
	doi = {10.1016/j.cub.2021.11.055},
	abstract = {Horizontal cells (HCs) are interneurons in the vertebrate retina that provide feedback to photoreceptors and feedforward signaling to bipolar cells. While the feedback mechanism has been debated for decades, the structural basis for these two distinct signaling pathways remains elusive. Here, we show that mouse horizontal cells use different synaptic sites for these two functions. Using serial block-face scanning electron microscopy (SBEM), we reconstructed the entire axonal arbor of individual HCs and mapped all synaptic contacts. We found that HCs form two distinct types of synaptic contacts: (1) large, complex terminals that contact photoreceptors and (2) small, simple terminals that contact bipolar cells. The large terminals are located on the HC axon terminals and are specialized for feedback signaling to photoreceptors. The small terminals are located on the HC dendrites and are specialized for feedforward signaling to bipolar cells. Our results provide a structural basis for the dual role of HCs in retinal processing and suggest that these two signaling pathways are spatially segregated.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Elsevier},
	author = {Behrens, Christian and Yadav, Shubhash Chandra and Korympidou, Maria M. and Zhang, Yue and Haverkamp, Silke and Irsen, Stephan and Schaedler, Anna and Dedek, Karin and Smith, Robert G. and Euler, Thomas and Berens, Philipp and Schubert, Timm},
	month = feb,
	year = {2022},
	keywords = {Immunolabeling, Axon, Neuroscience, Outer plexiform layer, Retina, Inner plexiform layer, Biology, Dendrite (mathematics), Axon terminal, Feed forward, Biophysics, Cell biology, Geometry},
}
