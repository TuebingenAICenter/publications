@misc{jin_logical_2022,
	title = {Logical {Fallacy} {Detection}},
	url = {https://aclanthology.org/2022.findings-emnlp.532},
	doi = {10.18653/v1/2022.findings-emnlp.532},
	abstract = {Logical fallacies are common in human communication, yet their automated detection remains an under-explored task in natural language processing. In this paper, we introduce the task of logical fallacy detection. We first curate a dataset of logical fallacies, LogiFall, which contains 1,900 examples of logical fallacies across 23 categories, collected from diverse sources including news, social media, and textbooks. We then propose a new model, FallacyDet, which leverages a combination of logical and linguistic features to detect fallacies. Our experiments show that FallacyDet outperforms strong baselines on the task of logical fallacy detection, achieving an F1-score of 0.68. We also conduct a human evaluation to assess the quality of our dataset and the performance of our model, demonstrating the potential of our approach for real-world applications.},
	language = {en},
	publisher = {Association for Computational Linguistics},
	author = {Jin, Zhijing and Lalwani, Abhinav and Vaidhya, Tejas and Shen, Xiaoyu and Ding, Yiwen and Lyu, Zhiheng and Sachan, Mrinmaya and Mihalcea, Rada and Schölkopf, Bernhard},
	editor = {Goldberg, Yoav and Kozareva, Zornitsa and Zhang, Yue},
	month = dec,
	year = {2022},
	keywords = {Fallacy, Computer science, Logical consequence, Argument (complex analysis), Misinformation, Task (project management), Logical reasoning, Logical conjunction, Artificial intelligence, Logical analysis, Logical data model, Natural language processing, Cognitive science, Epistemology, Psychology, Programming language, Computer security, Data modeling, Philosophy, Mathematics, EMNLP},
}
