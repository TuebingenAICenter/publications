@article{muller_generative_2022,
	title = {A {Generative} {Model} {Reveals} the {Influence} of {Patient} {Attributes} on {Fundus} {Images}},
	url = {https://openreview.net/forum?id=u9idZRTwmWR},
	abstract = {Deep learning models have achieved impressive performance in medical image analysis. However, their reliance on potentially biased datasets and the lack of interpretability of their decisions remain major hurdles for clinical adoption. In this work, we propose a generative model based on a conditional variational autoencoder to disentangle the influence of patient attributes from fundus images. We show that our model can learn a latent representation that captures the variation in fundus images due to patient attributes such as age, sex, and ethnicity. We demonstrate that our model can be used to generate synthetic images that reflect these attributes, and that it can be used to analyze the influence of these attributes on the model's predictions. Our results suggest that generative models can provide valuable insights into the factors that influence medical image analysis models and help to identify potential biases.},
	language = {en},
	urldate = {2025-01-24},
	journal = {Medical Imaging with Deep Learning},
	publisher = {OpenReview},
	author = {Müller, Samuel and Koch, Lukas M. and Lensch, Hendrik and Berens, Philipp},
	month = may,
	year = {2022},
	keywords = {MIDL},
}
