@article{xian_generalized_2022,
	title = {Generalized {Few}-{Shot} {Video} {Classification} {With} {Video} {Retrieval} and {Feature} {Generation}},
	issn = {0162-8828},
	shorttitle = {Generalized {Few}-{Shot} {Video} {Classification}},
	url = {https://ieeexplore.ieee.org/document/9576609},
	doi = {10.1109/TPAMI.2021.3120550},
	abstract = {Few-shot learning aims to recognize novel classes from only a few labeled examples. While most existing methods focus on image classification, few-shot video classification remains under-explored. In this paper, we propose a novel framework for generalized few-shot video classification, where the model is required to classify both base classes (with many training examples) and novel classes (with few training examples). Our approach leverages video retrieval to find relevant videos from a large unlabeled pool, which are then used to generate synthetic features for the novel classes. We show that this combination of retrieval and feature generation significantly improves the performance on few-shot video classification tasks. Extensive experiments on several benchmarks demonstrate the effectiveness of our method compared to state-of-the-art approaches.},
	language = {en},
	urldate = {2024-05-23},
	journal = {IEEE Transactions on Pattern Analysis and Machine Intelligence},
	publisher = {IEEE},
	author = {Xian, Yongqin and Korbar, Bruno and Douze, Matthijs and Torresani, Lorenzo and Schiele, Bernt and Akata, Zeynep},
	month = dec,
	year = {2022},
	keywords = {Computer science, Leverage (statistics), Artificial intelligence, Shot (pellet), Feature (linguistics), Machine learning, Pattern recognition (psychology), Focus (optics), Generative grammar, One shot, Generative adversarial network, Baseline (sea), Adversarial system, Deep learning, TPAMI},
}
