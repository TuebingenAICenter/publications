@inproceedings{kramer_probabilistic_2022-1,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Probabilistic {Numerical} {Method} of {Lines} for {Time}-{Dependent} {Partial} {Differential} {Equations}},
	shorttitle = {Probabilistic {Numerical} {Method} of {Lines}},
	url = {https://proceedings.mlr.press/v151/kramer22a.html},
	doi = {10.48550/arxiv.2110.11847},
	abstract = {The method of lines (MOL) is a standard approach for solving time-dependent partial differential equations (PDEs) by discretizing the spatial domain to transform the PDE into a system of ordinary differential equations (ODEs). In this work, we propose a probabilistic numerical method of lines (PN-MOL). By replacing the deterministic ODE solver with a probabilistic one, we obtain a posterior distribution over the solution of the PDE that quantifies the uncertainty arising from the temporal discretization. We demonstrate that the PN-MOL is computationally efficient, provides well-calibrated uncertainty estimates, and allows for the integration of prior knowledge about the solution.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 25th {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Krämer, N. and Schmidt, J. and Hennig, P.},
	editor = {Camps-Valls, Gustau and Ruiz, Francisco J. R. and Valera, Isabel},
	month = mar,
	year = {2022},
	keywords = {Probabilistic logic, Ode, Partial differential equation, Nonlinear system, Applied mathematics, Computer science, Algorithm, Mathematics, Mathematical optimization, Stochastic partial differential equation, Inference, Mathematical analysis, Artificial intelligence, AISTATS},
}
