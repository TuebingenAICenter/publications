@misc{croce_sparse-rs_2022,
	title = {Sparse-{RS}: a versatile framework for query-efficient sparse black-box adversarial attacks},
	shorttitle = {Sparse-{RS}},
	url = {https://arxiv.org/abs/2006.12834},
	doi = {10.48550/arxiv.2006.12834},
	abstract = {We propose Sparse-RS, a framework for sparse black-box adversarial attacks. Our method is based on random search and is designed to be query-efficient, i.e., it requires a small number of queries to the target model to find an adversarial example. We show that Sparse-RS outperforms existing sparse black-box attacks on several datasets and models, including those trained with adversarial training. Moreover, we demonstrate that our method can be used to evaluate the robustness of models against sparse perturbations in a more reliable way than previous approaches.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {AAAI},
	author = {Croce, Francesco and Andriushchenko, Maksym and Singh, Naman Deep and Flammarion, Nicolas and Hein, Matthias},
	year = {2022},
	keywords = {MNIST database, Adversarial system, Computer science, Black box, Image (mathematics), Code (set theory), Sparse approximation, Artificial intelligence, Algorithm, Theoretical computer science, Pattern recognition (psychology), Deep learning, Programming language, AAAI},
}
