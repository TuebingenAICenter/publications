@inproceedings{bosch_pick-and-mix_2022,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Pick-and-{Mix} {Information} {Operators} for {Probabilistic} {ODE} {Solvers}},
	shorttitle = {Pick-and-{Mix} {Information} {Operators}},
	url = {https://proceedings.mlr.press/v151/bosch22a.html},
	doi = {10.48550/arxiv.2110.10770},
	abstract = {Probabilistic numerical methods for ordinary differential equations (ODEs) quantify the uncertainty arising from the discretization of the continuous-time problem. These methods typically rely on a specific information operator, such as function evaluations or Taylor coefficients, to update the belief about the solution. In this paper, we propose a framework that allows for the flexible combination of different information operators within a single probabilistic ODE solver. We show that this 'pick-and-mix' approach allows for the construction of solvers that are more efficient and robust than those relying on a single type of information. We demonstrate the effectiveness of our approach on a range of numerical experiments.},
	language = {en},
	booktitle = {Proceedings of the 25th {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Bosch, N. and Tronarp, F. and Hennig, P.},
	editor = {Camps-Valls, Gustau and Ruiz, Francisco J. R. and Valera, Isabel},
	month = mar,
	year = {2022},
	keywords = {Probabilistic logic, Ode, Leverage (statistics), Solver, Computer science, Inference, Ordinary differential equation, Applied mathematics, Mathematical optimization, Mathematics, Differential equation, Theoretical computer science, Mathematical analysis, Artificial intelligence, AISTATS},
}
