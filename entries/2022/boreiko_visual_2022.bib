@misc{boreiko_visual_2022,
	title = {Visual explanations for the detection of diabetic retinopathy from retinal fundus images},
	shorttitle = {Visual explanations for the detection of diabetic retinopathy},
	url = {https://link.springer.com/chapter/10.1007/978-3-031-16434-7_52},
	doi = {10.1007/978-3-031-16434-7_52},
	abstract = {Deep learning models have achieved high performance in the automated detection of diabetic retinopathy (DR) from retinal fundus images. However, their lack of interpretability remains a major barrier for clinical adoption. In this work, we investigate the use of visual explanations to provide insights into the decision-making process of these models. We evaluate several attribution methods on a large-scale dataset and propose a novel approach that combines pixel-level explanations with anatomical knowledge. Our results demonstrate that the proposed method provides more faithful and clinically relevant explanations compared to existing techniques, potentially increasing trust in automated DR screening systems.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Springer Nature Switzerland},
	author = {Boreiko, Valentyn and Ilanchezian, Indu and Ayhan, Murat Seçkin and Müller, Sarah and Koch, Lisa M. and Faber, Hanna and Berens, Philipp and Hein, Matthias},
	month = feb,
	year = {2022},
	keywords = {Fundus (uterus), Computer science, Diabetic retinopathy, Artificial intelligence, Code (set theory), Retinal, Deep neural networks, Image (mathematics), Computer vision, Pattern recognition (psychology), Optometry, Deep learning, Ophthalmology, Medicine, Diabetes mellitus, MICCAI},
}
