@misc{eastwood_source-free_2022,
	title = {Source-{Free} {Adaptation} to {Measurement} {Shift} via {Bottom}-{Up} {Feature} {Restoration}},
	shorttitle = {Source-{Free} {Adaptation} to {Measurement} {Shift}},
	url = {https://openreview.net/forum?id=1JDiK_TbV4S},
	doi = {10.48550/arxiv.2107.05446},
	abstract = {We consider the problem of source-free domain adaptation under measurement shift, where a model trained on a source domain must be adapted to a target domain without access to source data. Measurement shift occurs when the input features are corrupted by a known or estimable transformation, such as noise, blur, or downsampling. We propose a bottom-up approach to feature restoration that leverages the causal structure of the data generation process. By inverting the measurement process, we can recover the underlying features and adapt the model to the target domain. We demonstrate the effectiveness of our approach on several benchmarks, showing that it outperforms existing methods for source-free domain adaptation.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {International Conference on Learning Representations},
	author = {Eastwood, Cian and Mason, Ian and Williams, Christopher K. I. and Schölkopf, Bernhard},
	month = apr,
	year = {2022},
	keywords = {Computer science, Leverage (statistics), Feature (linguistics), Artificial intelligence, Domain (mathematical analysis), Domain adaptation, Pattern recognition (psychology), Data mining, Classifier (UML), Mathematics, ICLR},
}
