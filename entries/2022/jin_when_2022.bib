@misc{jin_when_2022,
	title = {When to {Make} {Exceptions}: {Exploring} {Language} {Models} as {Accounts} of {Human} {Moral} {Judgment}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2022/hash/b654d6150630a5ba5df7a55621390daf-Abstract-Conference.html},
	doi = {10.48550/arxiv.2210.01478},
	abstract = {Moral judgment is a cornerstone of human social interaction, yet it is notoriously difficult to formalize. While many theories of moral judgment exist, they often struggle to account for the nuance and flexibility of human moral reasoning, particularly in cases where exceptions to general rules are made. In this paper, we explore the potential of large language models (LLMs) to serve as accounts of human moral judgment. We introduce a new dataset of moral scenarios that require reasoning about exceptions, and we evaluate the performance of several state-of-the-art LLMs on this task. We find that while LLMs are capable of capturing some aspects of human moral judgment, they still struggle with the nuanced reasoning required to identify and justify exceptions. We discuss the implications of these findings for the development of more robust and interpretable moral reasoning systems.},
	language = {en},
	publisher = {Curran Associates, Inc.},
	author = {Jin, Zhijing and Levine, Sydney and González, Fernando and Kamal, Ojasv and Sap, Maarten and Sachan, Mrinmaya and Mihalcea, Rada and Tenenbaum, Josh and Schölkopf, Bernhard},
	editor = {Koyejo, S. and Mohamed, S. and Agarwal, A. and Belgrave, D. and Cho, K. and Oh, A.},
	month = dec,
	year = {2022},
	keywords = {Flexibility (engineering), Set (abstract data type), Moral disengagement, Moral reasoning, Computer science, Cognition, Cognitive flexibility, Psychology, Epistemology, Social psychology, Cognitive science, NEURIPS},
}
