@misc{reizinger_embrace_2022,
	title = {Embrace the {Gap}: {VAEs} {Perform} {Independent} {Mechanism} {Analysis}},
	shorttitle = {Embrace the {Gap}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2022/hash/4eb91efe090f72f7cf42c69aab03fe85-Abstract-Conference.html},
	doi = {10.48550/arxiv.2206.02416},
	abstract = {Independent Mechanism Analysis (IMA) is a framework for causal representation learning that aims to recover the independent causal mechanisms of a data-generating process from observations. While recent work has established identifiability results for IMA, practical algorithms for this task remain scarce. In this work, we show that standard Variational Autoencoders (VAEs) can perform IMA when trained on data from different environments. We provide a theoretical analysis showing that the VAE objective encourages the latent variables to align with the independent mechanisms of the data-generating process. We further demonstrate that this alignment is robust to the choice of the encoder and decoder architectures and that it can be leveraged to perform causal discovery. We validate our findings on synthetic and real-world datasets, showing that VAEs can recover the underlying causal structure and mechanisms in a variety of settings.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Reizinger, Patrik and Gresele, Luigi and Brady, Jack and von Kügelgen, Julius and Zietlow, Dominik and Schölkopf, Bernhard and Martius, Georg and Brendel, Wieland and Besserve, Michel},
	month = dec,
	year = {2022},
	keywords = {Inference, Consistency (knowledge bases), Computer science, Representation (politics), Latent variable, Encoder, Process (computing), Algorithm, Artificial intelligence, Law, NEURIPS},
}
