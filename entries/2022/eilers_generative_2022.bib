@misc{eilers_generative_2022,
	title = {A {Generative} {Model} for {Quasar} {Spectra}},
	url = {https://is.mpg.de/ei/publications/eilersetal22},
	doi = {10.3847/1538-4357/ac8ead},
	abstract = {We present a generative model for quasar spectra that is designed to be flexible, interpretable, and physically motivated. Our model is based on a latent variable approach, where the latent space is learned from a large sample of quasar spectra from the Sloan Digital Sky Survey (SDSS). We use a Gaussian process to model the continuum and a set of basis functions to model the emission lines. The model is able to generate realistic quasar spectra that capture the diversity of the quasar population, including variations in continuum slope, emission line strength, and line width. We demonstrate the utility of our model by applying it to the problem of quasar redshift estimation and by using it to generate synthetic spectra for testing quasar selection algorithms.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {The American Astronomical Society},
	author = {Eilers, Anna-Christina and Hogg, David W. and Schölkopf, Bernhard and Foreman-Mackey, Daniel and Davies, Frederick B. and Schindler, Jan-Torge},
	month = oct,
	year = {2022},
	keywords = {Quasar, Reverberation mapping, Physics, Heteroscedasticity, Black hole (networking), Astrophysics, Statistical physics, Computer science, Galaxy, Machine learning, APJ},
}
