@article{shahrokhshahi_sample-efficient_2022,
	title = {Sample-{Efficient} {Policy} {Adaptation} for {Exoskeletons} {Under} {Variations} in the {Users} and the {Environment}},
	shorttitle = {Sample-{Efficient} {Policy} {Adaptation} for {Exoskeletons}},
	url = {https://is.mpg.de/ei/publications/shahrokhshahi22},
	doi = {10.1109/LRA.2022.3187262},
	abstract = {Exoskeletons are typically controlled by policies trained in simulation. However, the discrepancy between the simulation and the real-world environment, as well as the variations in the users' physical characteristics and gait patterns, often lead to performance degradation. To address this, we propose a sample-efficient policy adaptation framework that enables an exoskeleton to adapt its control policy to a new user or environment with minimal interaction. Our approach leverages a meta-learning framework that learns a prior policy, which can be quickly adapted to new tasks using a small amount of data. We evaluate our method on a lower-limb exoskeleton in simulation and demonstrate that it achieves superior adaptation performance compared to baseline methods with significantly fewer samples.},
	language = {en},
	urldate = {2024-05-22},
	journal = {IEEE Robotics and Automation Letters},
	publisher = {IEEE},
	author = {Shahrokhshahi, A. and Khadiv, M. and Taherifar, A. and Mansouri, S. and Park, E. J. and Arzanpour, S.},
	month = oct,
	year = {2022},
	keywords = {RAL},
}
