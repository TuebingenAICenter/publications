@inproceedings{li_revisiting_2022,
	title = {Revisiting {Random} {Channel} {Pruning} for {Neural} {Network} {Compression}},
	shorttitle = {Revisiting {Random} {Channel} {Pruning}},
	url = {https://openaccess.thecvf.com/content/CVPR2022/papers/Li_Revisiting_Random_Channel_Pruning_for_Neural_Network_Compression_CVPR_2022_paper.pdf},
	doi = {10.1109/CVPR52688.2022.00029},
	abstract = {Channel pruning is a popular technique for compressing deep neural networks. While many sophisticated methods have been proposed to select important channels, recent studies suggest that simple pruning strategies can perform surprisingly well. In this paper, we revisit random channel pruning. We show that, contrary to common belief, random pruning can achieve competitive performance compared to state-of-the-art methods, provided that the pruned network is retrained properly. We conduct extensive experiments on various architectures and datasets, and demonstrate that random pruning is a strong baseline that should be considered in future research.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {2022 {IEEE}/{CVF} {Conference} on {Computer} {Vision} and {Pattern} {Recognition} ({CVPR})},
	publisher = {IEEE},
	author = {Li, Y. and Adamczewski, K. and Li, W. and Gu, S. and Timofte, R. and Van Gool, L.},
	month = jun,
	year = {2022},
	keywords = {CVPR},
}
