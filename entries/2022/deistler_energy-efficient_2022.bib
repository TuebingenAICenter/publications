@article{deistler_energy-efficient_2022,
	title = {Energy-efficient network activity from disparate circuit parameters},
	issn = {0027-8424},
	shorttitle = {Energy-efficient network activity},
	url = {https://doi.org/10.1073/pnas.2207632119},
	doi = {10.1073/pnas.2207632119},
	abstract = {Biological neural networks are remarkably robust: they can maintain stable function despite significant variability in their underlying circuit parameters. While this phenomenon is well-documented, the functional consequences of such variability remain poorly understood. Here, we show that this variability is not merely a nuisance but a feature that allows networks to achieve energy-efficient information processing. We use a simulation-based inference framework to identify the manifold of circuit parameters that produce a specific target activity pattern in a recurrent neural network model. We find that this manifold is high-dimensional and that networks with disparate circuit parameters can produce nearly identical activity. Crucially, we show that these networks differ significantly in their metabolic cost, with some parameter combinations being much more energy-efficient than others. Our results suggest that biological systems may exploit this parameter variability to optimize for energy efficiency, providing a potential explanation for the observed heterogeneity in neural circuit parameters.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Proceedings of the National Academy of Sciences},
	publisher = {National Academy of Sciences},
	author = {Deistler, Michael and Macke, Jakob H. and Gonçalves, Pedro J.},
	month = sep,
	year = {2022},
	keywords = {Robustness (evolution), Electronic circuit, Computer science, Artificial neural network, Biological neural network, Efficient energy use, Biological system, Artificial intelligence, Machine learning, Chemistry, Biology, Engineering, Ecology, Electrical engineering, PNAS},
}
