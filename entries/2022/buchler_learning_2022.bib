@misc{buchler_learning_2022,
	title = {Learning to {Play} {Table} {Tennis} {From} {Scratch} using {Muscular} {Robots}},
	url = {https://doi.org/10.1109/TRO.2022.3176207},
	doi = {10.1109/TRO.2022.3176207},
	abstract = {Learning complex motor skills with robots is a challenging task, especially when the robot is actuated by non-linear, compliant actuators such as pneumatic artificial muscles. These actuators are difficult to control due to their non-linear dynamics, hysteresis, and time-varying properties. In this paper, we present a framework for learning to play table tennis from scratch with a robot actuated by pneumatic artificial muscles. We combine a model-based approach for low-level control with a model-free reinforcement learning approach for high-level task learning. We demonstrate that our approach allows the robot to learn to play table tennis in a real-world setting, starting from scratch, without any prior knowledge of the robot's dynamics or the task. We evaluate our approach in a series of experiments, showing that the robot can learn to hit the ball consistently and accurately, and that it can adapt to changes in the environment.},
	language = {en},
	urldate = {2025-02-07},
	publisher = {IEEE},
	author = {Büchler, Dieter and Guist, Simon and Calandra, Roberto and Berenz, Vincent and Schölkopf, Bernhard and Peters, Jan},
	year = {2022},
	keywords = {Reinforcement learning, Robot, Scratch, Computer science, Ball (mathematics), Artificial intelligence, Task (project management), State space, Simulation, Engineering, T-RO},
}
