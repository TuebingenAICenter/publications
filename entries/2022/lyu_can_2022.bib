@article{lyu_can_2022,
	title = {Can {Large} {Language} {Models} {Distinguish} {Cause} from {Effect}?},
	shorttitle = {Can {Large} {Language} {Models} {Distinguish} {Cause} from {Effect}?},
	url = {https://openreview.net/pdf?id=ucHh-ytUkOH},
	abstract = {Large language models (LLMs) have demonstrated remarkable performance on a wide range of natural language processing tasks. However, it remains unclear whether they can perform causal reasoning, a fundamental aspect of human intelligence. In this paper, we investigate whether LLMs can distinguish cause from effect. We propose a set of causal reasoning tasks and evaluate several state-of-the-art LLMs on these tasks. Our results show that while LLMs can perform well on some tasks, they struggle with others, suggesting that they do not yet possess a robust understanding of causality.},
	language = {en},
	urldate = {2025-05-14},
	journal = {UAI 2022 Workshop on Causal Representation Learning},
	author = {Lyu, Zhiheng and Jin, Zhijing and Mihalcea, Rada and Sachan, Mrinmaya and Schölkopf, Bernhard},
	month = aug,
	year = {2022},
	keywords = {UAI},
}
