@inproceedings{chaudhuri_relational_2022,
	title = {Relational {Proxies}: {Emergent} {Relationships} as {Fine}-{Grained} {Discriminators}},
	shorttitle = {Relational {Proxies}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2022/hash/c9f95e9ec39fa5ad3d0a562b993b92aa-Abstract-Conference.html},
	doi = {10.48550/arxiv.2210.02149},
	abstract = {Fine-grained classification requires models to learn subtle discriminative features that distinguish between visually similar classes. While existing methods often rely on part-based localization or attention mechanisms, they frequently struggle to capture the complex relationships between parts that define fine-grained categories. In this paper, we propose Relational Proxies, a novel approach that learns to represent fine-grained categories by modeling the emergent relationships between their constituent parts. We introduce a relational module that captures pairwise interactions between part features, which are then aggregated into a relational proxy for each class. These proxies serve as discriminative representations that capture the structural configuration of parts, enabling the model to distinguish between visually similar classes more effectively. We demonstrate the effectiveness of our approach on several fine-grained classification benchmarks, where it achieves state-of-the-art performance, outperforming existing methods by a significant margin.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 35 ({NeurIPS} 2022)},
	publisher = {Curran Associates, Inc.},
	author = {Chaudhuri, A. and Mancini, M. and Akata, Z. and Dutta, A.},
	month = dec,
	year = {2022},
	keywords = {Computer science, Benchmark (surveying), Margin (machine learning), Set (abstract data type), Object (grammar), Relational database, Relational model, Data mining, Theoretical computer science, Artificial intelligence, Machine learning, Programming language, Cartography, NEURIPS},
}
