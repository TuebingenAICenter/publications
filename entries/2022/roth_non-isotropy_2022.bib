@inproceedings{roth_non-isotropy_2022,
	title = {Non-isotropy {Regularization} for {Proxy}-based {Deep} {Metric} {Learning}},
	shorttitle = {Non-isotropy {Regularization}},
	url = {https://openaccess.thecvf.com/content/CVPR2022/papers/Roth_Non-Isotropy_Regularization_for_Proxy-Based_Deep_Metric_Learning_CVPR_2022_paper.pdf},
	doi = {10.1109/CVPR52688.2022.00727},
	abstract = {Deep Metric Learning (DML) aims to learn an embedding space where similar data points are close and dissimilar ones are far apart. While proxy-based methods have recently achieved state-of-the-art performance, they often suffer from the "collapsing" of embeddings, where the learned representations occupy only a small subspace of the available hypersphere. This phenomenon, often referred to as the "isotropy problem", limits the discriminative power of the learned embeddings. In this paper, we propose a novel regularization technique, Non-isotropy Regularization (NIR), that explicitly encourages the learned embeddings to be non-isotropic, thereby preventing collapse and improving the quality of the learned representations. We demonstrate the effectiveness of our approach on several standard DML benchmarks, where it consistently outperforms existing proxy-based methods.},
	language = {en},
	booktitle = {Proceedings of the {IEEE}/{CVF} {Conference} on {Computer} {Vision} and {Pattern} {Recognition} ({CVPR})},
	publisher = {IEEE},
	author = {Roth, Karsten and Vinyals, Oriol and Akata, Zeynep},
	month = jun,
	year = {2022},
	keywords = {Proxy (statistics), Leverage (statistics), Computer science, Isotropy, Regularization (linguistics), Artificial intelligence, Theoretical computer science, Mathematics, Machine learning, Mathematical optimization, Physics, CVPR},
}
