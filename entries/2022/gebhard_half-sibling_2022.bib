@article{gebhard_half-sibling_2022,
	title = {Half-sibling regression meets exoplanet imaging: {PSF} modeling and subtraction using a flexible, domain knowledge-driven, causal framework},
	copyright = {© ESO 2022},
	issn = {0004-6361},
	shorttitle = {Half-sibling regression meets exoplanet imaging},
	url = {https://www.aanda.org/articles/aa/full_html/2022/10/aa42529-21/aa42529-21.html},
	doi = {10.1051/0004-6361/202142529},
	abstract = {High-contrast imaging is the primary technique for directly detecting exoplanets. However, the signal of a potential planet is typically buried under the much brighter light of the host star and the complex, time-varying speckle noise caused by the instrument and the atmosphere. To detect planets, one must model and subtract this noise. We propose a new approach to point spread function (PSF) modeling and subtraction based on half-sibling regression, a causal machine learning framework for removing noise from data. Our method, which we call half-sibling regression for exoplanet imaging (HSR-EI), is flexible, interpretable, and can incorporate domain knowledge about the imaging process. We demonstrate that HSR-EI is competitive with state-of-the-art PSF subtraction algorithms on real data from the VLT/SPHERE instrument, while offering a more principled approach to noise modeling. We also show that HSR-EI can be used to improve the performance of existing algorithms by providing a better estimate of the PSF.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Astronomy \& Astrophysics},
	publisher = {EDP Sciences},
	author = {Gebhard, Timothy D. and Bonse, Markus J. and Quanz, Sascha P. and Schölkopf, Bernhard},
	month = oct,
	year = {2022},
	keywords = {Exoplanet, Computer science, Pixel, Artificial intelligence, Background subtraction, Noise (video), Contrast (vision), Machine learning, Algorithm, Regression, Data mining, Pattern recognition (psychology), Computer vision, Mathematics, Image (mathematics), Statistics, A\&A},
}
