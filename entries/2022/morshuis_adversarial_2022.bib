@inproceedings{morshuis_adversarial_2022,
	series = {Lecture {Notes} in {Computer} {Science}},
	title = {Adversarial {Robustness} of {MR} {Image} {Reconstruction} {Under} {Realistic} {Perturbations}},
	isbn = {978-3-031-17247-2},
	shorttitle = {Adversarial {Robustness} of {MR} {Image} {Reconstruction}},
	url = {https://is.mpg.de/ei/publications/morgatheibau22},
	doi = {10.1007/978-3-031-17247-2_3},
	abstract = {Deep learning-based reconstruction methods have recently achieved state-of-the-art performance in Magnetic Resonance (MR) imaging. However, their susceptibility to adversarial perturbations raises concerns regarding their reliability in clinical practice. In this work, we investigate the adversarial robustness of several state-of-the-art MR reconstruction models. We propose a novel threat model that considers realistic perturbations, such as k-space noise and undersampling artifacts, in addition to standard adversarial attacks. We find that while models are robust to small perturbations, they are highly vulnerable to structured adversarial attacks that exploit the specific geometry of the reconstruction process. Furthermore, we demonstrate that adversarial training can significantly improve robustness without compromising reconstruction quality on clean data.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Machine {Learning} for {Medical} {Image} {Reconstruction}},
	publisher = {Springer International Publishing},
	author = {Morshuis, J. N. and Gatidis, S. and Hein, M. and Baumgartner, C. F.},
	month = sep,
	year = {2022},
	keywords = {Adversarial system, Robustness (evolution), Computer science, Artificial intelligence, Iterative reconstruction, Image (mathematics), Reliability (semiconductor), Algorithm, Inverse problem, Noise (video), Machine learning, Computer vision, Mathematics, MICCAI, MLMIR},
}
