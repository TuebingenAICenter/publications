@inproceedings{keidar_slangvolution_2022,
	title = {Slangvolution: {A} {Causal} {Analysis} of {Semantic} {Change} and {Frequency} {Dynamics} in {Slang}},
	shorttitle = {Slangvolution},
	url = {https://aclanthology.org/2022.acl-long.101},
	doi = {10.18653/v1/2022.acl-long.101},
	abstract = {Slang is a dynamic linguistic phenomenon, characterized by rapid changes in both meaning and usage frequency. While previous work has studied semantic change and frequency dynamics in isolation, the causal relationship between them remains poorly understood. In this work, we propose a causal framework to investigate the interplay between semantic change and frequency dynamics in slang. We introduce a novel dataset of slang terms and their usage over time, and leverage causal inference techniques to disentangle the effects of semantic shift on frequency and vice versa. Our results reveal that semantic change is a significant driver of frequency dynamics, and that frequency changes can also influence the evolution of slang meanings. We further demonstrate the utility of our framework in predicting the future trajectory of slang terms.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Proceedings of the 60th {Annual} {Meeting} of the {Association} for {Computational} {Linguistics} ({ACL})},
	publisher = {Association for Computational Linguistics},
	author = {Keidar, D. and Opedal, A. and Jin, Z. and Sachan, M.},
	editor = {Muresan, Smaranda and Nakov, Preslav and Villavicencio, Aline},
	month = may,
	year = {2022},
	keywords = {ACL},
}
