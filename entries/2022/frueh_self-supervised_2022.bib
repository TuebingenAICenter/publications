@article{frueh_self-supervised_2022,
	title = {Self-supervised learning for automated anatomical tracking in medical image data with minimal human labeling effort},
	issn = {0169-2607},
	shorttitle = {Self-supervised learning for automated anatomical tracking},
	url = {https://is.mpg.de/ei/publications/fruehetal22},
	doi = {10.1016/j.cmpb.2022.107085},
	abstract = {Anatomical tracking in medical image data is a fundamental task for many clinical applications. While deep learning-based approaches have shown great potential, they typically require large amounts of manually annotated data, which is time-consuming and expensive to obtain. In this work, we propose a self-supervised learning framework for automated anatomical tracking that minimizes the need for human labeling. Our approach leverages the temporal consistency of anatomical structures in image sequences to learn robust representations without explicit supervision. We demonstrate the effectiveness of our method on multiple datasets, showing that it achieves competitive performance compared to fully supervised approaches while requiring only a fraction of the labeled data.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Computer Methods and Programs in Biomedicine},
	publisher = {Elsevier},
	author = {Frueh, M. and Kuestner, T. and Nachbar, M. and Thorwarth, D. and Schilling, A. and Gatidis, S.},
	month = oct,
	year = {2022},
	keywords = {CMPB},
}
