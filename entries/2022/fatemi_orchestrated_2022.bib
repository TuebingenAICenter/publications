@inproceedings{fatemi_orchestrated_2022,
	title = {Orchestrated {Value} {Mapping} for {Reinforcement} {Learning}},
	shorttitle = {Orchestrated {Value} {Mapping}},
	url = {https://openreview.net/forum?id=c87d0TS4yX},
	abstract = {Value-based reinforcement learning (RL) methods often rely on a single value function to estimate the expected return. However, in many environments, the distribution of returns can be complex, multimodal, or heavy-tailed, making a single scalar estimate insufficient. Distributional RL addresses this by modeling the full distribution of returns. In this paper, we propose Orchestrated Value Mapping (OVM), a novel framework that learns a set of value functions, each specialized to a different aspect of the return distribution. By orchestrating these value functions, OVM can capture complex return distributions more effectively than existing methods. We demonstrate the effectiveness of OVM on a variety of challenging RL benchmarks, showing that it consistently outperforms state-of-the-art distributional RL algorithms.},
	language = {en},
	booktitle = {International {Conference} on {Learning} {Representations}},
	author = {Fatemi, Mehdi and Tavakoli, Arash},
	month = apr,
	year = {2022},
	keywords = {ICLR},
}
