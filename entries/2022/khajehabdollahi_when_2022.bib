@article{khajehabdollahi_when_2022,
	title = {When to {Be} {Critical}? {Performance} and {Evolvability} in {Different} {Regimes} of {Neural} {Ising} {Agents}},
	issn = {1064-5462},
	shorttitle = {When to {Be} {Critical}?},
	url = {https://doi.org/10.1162/artl_a_00383},
	doi = {10.1162/artl_a_00383},
	abstract = {The hypothesis that biological systems operate near a critical point between order and chaos has been a subject of intense debate. While criticality is often associated with optimal information processing, its role in evolution remains unclear. Here, we investigate the relationship between criticality, performance, and evolvability in a class of neural agents based on the Ising model. We show that the agents' performance on a set of tasks is maximized in the critical regime, whereas their evolvability—the ability to adapt to new tasks—is highest in the subcritical regime. Our results suggest that the optimal operating point of a system depends on the trade-off between immediate performance and long-term adaptability, providing a potential explanation for the diversity of dynamical regimes observed in biological systems.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Artificial Life},
	publisher = {MIT Press},
	author = {Khajehabdollahi, Sina and Prosi, Jan and Giannakakis, Emmanouil and Martius, Georg and Levina, Anna},
	year = {2022},
	keywords = {Evolvability, Criticality, Computer science, Task (project management), Artificial life, Simple (philosophy), Resilience (materials science), Cellular automaton, Fitness landscape, Artificial neural network, Initialization, Benchmark (surveying), Evolutionary algorithm, Artificial intelligence, Biology, Evolutionary biology, Physics, Population, ALIFE},
}
