@misc{kapoor_multiscale_2022,
	title = {Multiscale {Metamorphic} {VAE} for 3D {Brain} {MRI} {Synthesis}},
	shorttitle = {Multiscale {Metamorphic} {VAE}},
	url = {https://arxiv.org/abs/2301.03588},
	doi = {10.48550/arxiv.2301.03588},
	abstract = {Generative models for 3D medical images are essential for data augmentation and privacy-preserving data sharing. However, generating high-resolution 3D volumes remains computationally challenging. In this work, we propose the Multiscale Metamorphic Variational Autoencoder (MM-VAE), a generative model that synthesizes 3D brain MRI volumes by learning a multiscale representation of the data. Our model decomposes the image generation process into a sequence of metamorphic transformations, allowing for the synthesis of high-fidelity 3D volumes at multiple scales. We demonstrate that our approach achieves state-of-the-art performance on 3D brain MRI synthesis, producing images with high anatomical fidelity and diversity.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Kapoor, Jaivardhan and Macke, Jakob H. and Baumgartner, Christian F.},
	year = {2022},
	keywords = {Computer science, Autoencoder, Generative grammar, Artificial intelligence, Generative model, Fidelity, Image (mathematics), Pattern recognition (psychology), Deep learning, NEURIPS},
}
