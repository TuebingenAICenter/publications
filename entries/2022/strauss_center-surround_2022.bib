@article{strauss_center-surround_2022,
	title = {Center-surround interactions underlie bipolar cell motion sensitivity in the mouse retina},
	copyright = {© The Author(s) 2022},
	issn = {2041-1723},
	url = {https://www.nature.com/articles/s41467-022-32762-7},
	doi = {10.1038/s41467-022-32762-7},
	abstract = {Motion sensitivity is a hallmark of visual processing. In the retina, it is generally thought to emerge in the inner plexiform layer, where ganglion cells receive input from direction-selective circuits. Here, we show that motion sensitivity is already present at the level of bipolar cells, the primary excitatory interneurons of the retina. Using two-photon calcium imaging in the mouse retina, we find that many bipolar cell types respond more strongly to moving than to stationary stimuli. This motion sensitivity is not inherited from upstream photoreceptors but is shaped by inhibitory input from amacrine cells. We show that this inhibition is spatially offset, creating a center-surround structure that is asymmetric in many bipolar cell types. Our results suggest that the retina performs motion-sensitive computations much earlier in the visual pathway than previously thought, providing a foundation for downstream motion-processing circuits.},
	language = {en},
	journal = {Nature Communications},
	publisher = {Nature Portfolio},
	author = {Strauss, Sarah and Korympidou, Maria M. and Ran, Yanli and Franke, Katrin and Schubert, Timm and Baden, Tom and Berens, Philipp and Euler, Thomas and Vlasits, Anna L.},
	month = sep,
	year = {2022},
	keywords = {Receptive field, Retina, Neuroscience, Motion (physics), Amacrine cell, Physics, Biology, Connectomics, Connectome, NATCOMM},
}
