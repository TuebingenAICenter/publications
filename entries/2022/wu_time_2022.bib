@misc{wu_time_2022,
	title = {Time pressure changes how people explore and respond to uncertainty},
	copyright = {CC BY 4.0},
	shorttitle = {Time pressure changes how people explore and respond to uncertainty},
	url = {https://doi.org/10.1038/s41598-022-07901-1},
	doi = {10.1038/s41598-022-07901-1},
	abstract = {Time pressure is a ubiquitous constraint in decision-making, yet its effect on the exploration-exploitation trade-off remains poorly understood. We investigate how time pressure influences human exploration in a multi-armed bandit task. Using a computational model of human behavior, we show that time pressure leads to a decrease in directed exploration (uncertainty-directed search) while leaving undirected exploration (random search) largely unaffected. This shift is driven by a reduction in the cognitive resources allocated to planning, as time pressure forces individuals to rely on simpler, more heuristic-based strategies. Our results provide a mechanistic account of how time pressure alters the exploration-exploitation trade-off and suggest that the impact of time pressure on decision-making is mediated by the cognitive costs of exploration.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Nature Portfolio},
	author = {Wu, Charley M. and Schulz, Eric and Pleskac, Timothy J. and Speekenbrink, Maarten},
	year = {2022},
	keywords = {Value (mathematics), Cognition, Reinforcement learning, Balance (ability), Resource (disambiguation), Rational planning model, Computer science, Cognitive psychology, Psychology, Economics, Artificial intelligence, Machine learning},
}
