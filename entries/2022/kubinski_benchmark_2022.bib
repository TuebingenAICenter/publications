@article{kubinski_benchmark_2022,
	title = {Benchmark of {Data} {Processing} {Methods} and {Machine} {Learning} {Models} for {Gut} {Microbiome}-{Based} {Diagnosis} of {Inflammatory} {Bowel} {Disease}},
	copyright = {CC BY 4.0},
	issn = {1664-8021},
	shorttitle = {Benchmark of {Data} {Processing} {Methods} and {Machine} {Learning} {Models}},
	url = {https://doi.org/10.3389/fgene.2022.784397},
	doi = {10.3389/fgene.2022.784397},
	abstract = {The gut microbiome has been extensively studied in the context of inflammatory bowel disease (IBD). While many studies have reported microbiome signatures associated with IBD, the reproducibility of these findings remains a challenge. This is partly due to the heterogeneity in data processing pipelines and machine learning (ML) models used across studies. In this study, we performed a comprehensive benchmark of data processing methods and ML models for IBD diagnosis using gut microbiome data. We evaluated the performance of various taxonomic profiling methods, normalization techniques, and ML algorithms on multiple publicly available datasets. Our results demonstrate that the choice of data processing pipeline significantly impacts the performance of ML models. We also found that ensemble methods generally outperform individual models. Furthermore, we provide recommendations for best practices in microbiome-based diagnostic model development.},
	language = {en},
	journal = {Frontiers in Genetics},
	publisher = {Frontiers Media S.A.},
	author = {Kubinski, R. and Djamen-Kepaou, J.-Y. and Zhanabaev, T. and Hernandez-Garcia, A. and Bauer, S. and Hildebrand, F. and Korcsmaros, T. and Karam, S. and Jantchou, P. and Kafi, K. and Martin, R. D.},
	month = feb,
	year = {2022},
	keywords = {Frontiers in Genetics},
}
