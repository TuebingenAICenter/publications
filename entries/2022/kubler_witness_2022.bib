@misc{kubler_witness_2022,
	title = {A {Witness} {Two}-{Sample} {Test}},
	url = {https://proceedings.mlr.press/v151/kubler22a.html},
	doi = {10.48550/arxiv.2102.05573},
	abstract = {We propose a new two-sample test based on the witness function of the Maximum Mean Discrepancy (MMD). While the MMD is a powerful kernel-based test statistic for the two-sample problem, it is often difficult to interpret because it is a single scalar value. By contrast, the witness function provides a localized view of the differences between two distributions. We show that the witness function can be used to construct a powerful two-sample test that is not only interpretable but also competitive with the state-of-the-art. Our test statistic is defined as the supremum of the witness function over a set of functions. We provide a theoretical analysis of the test, including its consistency and asymptotic distribution. We also demonstrate the effectiveness of our test on a variety of synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Kübler, Jonas M. and Jitkrittum, Wittawat and Schölkopf, Bernhard and Muandet, Krikamol},
	editor = {Camps-Valls, Gustau and Ruiz, Francisco J. R. and Valera, Isabel},
	month = mar,
	year = {2022},
	keywords = {Overfitting, Reproducing kernel Hilbert space, Kernel (algebra), Variable kernel density estimation, Mathematics, Test statistic, Kernel method, Test set, Nonparametric statistics, Algorithm, Computer science, Statistics, Artificial intelligence, Statistical hypothesis testing, Hilbert space, Support vector machine, Artificial neural network, Discrete mathematics, AISTATS},
}
