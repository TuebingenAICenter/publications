@article{cogliati_dezza_drive_2022,
	title = {The {Drive} for {Knowledge}: {The} {Science} of {Human} {Information}-{Seeking}},
	shorttitle = {The {Drive} for {Knowledge}},
	url = {https://www.cambridge.org/core/books/drive-for-knowledge/B7D7B75B7C1021D2F90089CC1B4C1DBF},
	doi = {10.1017/9781009026949},
	abstract = {Information-seeking is a fundamental human activity. From the curiosity that drives scientific discovery to the everyday search for news, entertainment, or social connection, we are constantly looking for information. This book provides a comprehensive overview of the science of human information-seeking, bringing together perspectives from psychology, neuroscience, computer science, and economics. The chapters cover the cognitive and neural mechanisms of curiosity, the computational models of active learning and exploration, and the social and developmental aspects of information-seeking. By integrating these diverse fields, the book offers a unified framework for understanding how we decide what to learn, how we learn it, and why we are driven to do so.},
	language = {en},
	urldate = {2024-05-23},
