@inproceedings{shaj_hidden_2022,
	title = {Hidden {Parameter} {Recurrent} {State} {Space} {Models} {For} {Changing} {Dynamics} {Scenarios}},
	shorttitle = {{HiP}-{RSSMs}},
	url = {https://openreview.net/forum?id=ds8yZOUsea},
	abstract = {Recurrent State Space Models (RSSMs) have shown great success in learning world models for complex control tasks. However, they typically assume that the environment dynamics are stationary. In many real-world scenarios, the dynamics change over time, e.g., due to wear and tear or changing environmental conditions. In this paper, we propose Hidden Parameter Recurrent State Space Models (HiP-RSSMs), which extend RSSMs to handle changing dynamics by inferring a latent context variable that captures the current dynamics parameters. We show that HiP-RSSMs can effectively adapt to changing dynamics in various simulated control tasks and outperform existing methods in terms of sample efficiency and final performance.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {10th {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Shaj, V. and Büchler, D. and Sonker, R. and Becker, P. and Neumann, G.},
	month = apr,
	year = {2022},
	keywords = {ICLR},
}
