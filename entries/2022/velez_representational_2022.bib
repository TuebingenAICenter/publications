@article{velez_representational_2022,
	title = {Representational exchange in social learning: {Blurring} the lines between the ritual and instrumental},
	issn = {0140-525X},
	shorttitle = {Representational exchange in social learning},
	url = {https://doi.org/10.1017/S0140525X22001339},
	doi = {10.1017/S0140525X22001339},
	abstract = {Humans are uniquely capable of high-fidelity cultural transmission, yet we also exhibit a puzzling tendency to copy causally opaque, ritualistic actions. We propose that this behavior is not a byproduct of a specialized mechanism for ritual, but rather a consequence of a general-purpose social learning system that treats all actions as potentially instrumental. We argue that learners represent actions as having both instrumental and social functions, and that these representations are dynamically updated through a process of representational exchange. This framework explains why humans are both highly flexible and highly ritualistic, and provides a unified account of social learning that bridges the gap between instrumental and ritual behavior.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Behavioral and Brain Sciences},
	publisher = {Cambridge University Press},
	author = {Vélez, Natalia and Wu, Charley M. and Cushman, Fiery},
	year = {2022},
	keywords = {Imitation, Fidelity, Flexibility (engineering), Social learning, Action (physics), Mechanism (biology), Cultural learning, Cognitive science, Through-the-lens metering, Cognitive psychology, Psychology, Computer science, Social psychology, Epistemology, Lens (geology), Economics, BBS},
}
