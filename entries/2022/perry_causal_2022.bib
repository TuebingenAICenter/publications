@misc{perry_causal_2022,
	title = {Causal {Discovery} in {Heterogeneous} {Environments} {Under} the {Sparse} {Mechanism} {Shift} {Hypothesis}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2022/hash/46a126492ea6fb87410e55a58df2e189-Abstract-Conference.html},
	doi = {10.48550/arxiv.2206.02013},
	abstract = {We consider the problem of causal discovery from data collected in heterogeneous environments, where the underlying causal mechanisms may change across environments. We formalize this setting using the Sparse Mechanism Shift (SMS) hypothesis, which posits that changes in the data distribution are caused by sparse interventions on the causal mechanisms. We propose a novel method for causal discovery that leverages these shifts to identify the causal structure. Our approach is based on the observation that the causal mechanisms are invariant across environments, while the non-causal mechanisms are not. We show that our method is consistent under certain conditions and demonstrate its effectiveness on synthetic and real-world data.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Perry, Ronan and von Kügelgen, Julius and Schölkopf, Bernhard},
	editor = {Koyejo, S. and Mohamed, S. and Agarwal, A. and Belgrave, D. and Cho, K. and Oh, A.},
	year = {2022},
	keywords = {Causality (physics), Causal structure, Causal model, Computer science, Estimator, Mechanism (biology), Artificial intelligence, Machine learning, Causal inference, Independent and identically distributed random variables, Equivalence (formal languages), Econometrics, Theoretical computer science, Mathematics, Statistics, Random variable, Epistemology, NEURIPS},
}
