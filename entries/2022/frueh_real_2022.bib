@article{frueh_real_2022,
	title = {Real {Time} {Landmark} {Detection} for {Within}- and {Cross} {Subject} {Tracking} {With} {Minimal} {Human} {Supervision}},
	copyright = {© 2022 IEEE},
	issn = {2169-3536},
	shorttitle = {Real {Time} {Landmark} {Detection}},
	url = {https://is.mpg.de/ei/publications/fruschgatkue22},
	doi = {10.1109/ACCESS.2022.3195211},
	abstract = {Landmark detection is a fundamental task in medical image analysis, serving as a prerequisite for registration, segmentation, and motion compensation. While deep learning-based approaches have achieved state-of-the-art performance, they typically require large amounts of manually annotated data, which is time-consuming and expensive to acquire. In this work, we propose a novel framework for real-time landmark detection that requires minimal human supervision. Our approach leverages a self-supervised learning strategy combined with a small amount of labeled data to achieve robust performance. We demonstrate the effectiveness of our method on both within-subject and cross-subject tracking tasks, showing that it can generalize well to unseen subjects and imaging conditions. Our framework achieves real-time performance, making it suitable for clinical applications where fast and accurate landmark detection is required.},
	language = {en},
	urldate = {2024-05-22},
	journal = {IEEE Access},
	publisher = {IEEE},
	author = {Frueh, M. and Schilling, A. and Gatidis, S. and Kuestner, T.},
	month = aug,
	year = {2022},
	keywords = {IEEE ACCESS},
}
