@inproceedings{wenger_preconditioning_2022,
	title = {Preconditioning for {Scalable} {Gaussian} {Process} {Hyperparameter} {Optimization}},
	shorttitle = {Preconditioning for {Scalable} {Gaussian} {Process} {Hyperparameter} {Optimization}},
	url = {https://proceedings.mlr.press/v162/wenger22a.html},
	doi = {10.48550/arxiv.2107.00243},
	abstract = {Gaussian process (GP) hyperparameter optimization is typically performed by maximizing the marginal likelihood, which requires computing the log-determinant and the inverse of the kernel matrix. For large datasets, these operations are computationally prohibitive, necessitating the use of iterative methods like conjugate gradients (CG). However, CG convergence is often slow, especially when the kernel matrix is ill-conditioned. In this paper, we propose a preconditioning strategy for GP hyperparameter optimization that significantly accelerates CG convergence. Our approach leverages the structure of the kernel matrix to construct a preconditioner that is both efficient to compute and effective at reducing the condition number. We demonstrate the effectiveness of our method on a variety of large-scale regression tasks, showing that it leads to substantial speedups in hyperparameter optimization compared to standard CG and other existing preconditioning techniques.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 39th {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Wenger, J. and Pleiss, G. and Hennig, P. and Cunningham, J. and Gardner, J.},
	month = jul,
	year = {2022},
	keywords = {Hyperparameter, Preconditioner, Kernel (algebra), Gaussian process, Computer science, Mathematical optimization, Stochastic gradient descent, Convergence (economics), Range (aeronautics), Mathematics, Algorithm, Computation, Applied mathematics, Gaussian, Iterative method, Machine learning, Artificial neural network, ICML},
}
