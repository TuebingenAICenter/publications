@misc{singh_phenomenology_2022,
	title = {Phenomenology of {Double} {Descent} in {Finite}-{Width} {Neural} {Networks}},
	url = {https://openreview.net/forum?id=lTqGXfn9Tv},
	doi = {10.48550/arxiv.2203.07337},
	abstract = {The double descent phenomenon, where test error decreases, increases, and then decreases again as model capacity increases, has been a subject of intense study. While it is well-understood in linear models and kernel regression, its manifestation in neural networks remains elusive. In this paper, we provide a comprehensive empirical study of double descent in finite-width neural networks. We show that the phenomenon is not universal and depends on the interplay between the model architecture, the optimization algorithm, and the data distribution. We further demonstrate that the peak in test error is associated with the interpolation threshold, where the model begins to fit the training data perfectly. Our results suggest that the double descent phenomenon is a consequence of the transition from an under-parameterized to an over-parameterized regime, and that it can be mitigated by appropriate regularization.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {OpenReview},
	author = {Singh, Sidak Pal and Lucchi, Aurélien and Hofmann, Thomas and Schölkopf, Bernhard},
	month = apr,
	year = {2022},
	keywords = {Hessian matrix, Artificial neural network, Applied mathematics, Gradient descent, Mathematics, Phenomenology (philosophy), Computer science, Interpolation (computer graphics), Parametric statistics, Kernel (algebra), Tangent, Parameterized complexity, Algorithm, Artificial intelligence, Pure mathematics, Statistics, Geometry, ICLR},
}
