@article{schmidt_impact_2022,
	title = {The impact of neuronal structure on cortical network architecture},
	issn = {2211-1247},
	shorttitle = {The impact of neuronal structure on cortical network architecture},
	url = {https://pure.mpg.de/rest/items/item_3278103/component/file_3325196/content},
	doi = {10.1016/j.celrep.2022.110685},
	abstract = {The architecture of cortical networks is constrained by the physical structure of neurons. However, the extent to which neuronal morphology determines the connectivity of cortical circuits remains unclear. Here, we use a generative model of cortical connectivity to show that the spatial distribution of dendrites and axons is a primary determinant of the connectivity of local cortical circuits. We find that the model, which is based on the overlap of neuronal processes, accurately predicts the connectivity of the mouse primary visual cortex. Our results suggest that the spatial arrangement of neurons and their processes is a fundamental principle of cortical organization, providing a parsimonious explanation for the observed connectivity patterns in the cortex.},
	language = {en},
	urldate = {2024-05-23},
	journal = {Cell Reports},
	publisher = {Cell Press},
	author = {Schmidt, Hannes and Macke, Jakob},
	month = apr,
	year = {2022},
	keywords = {Neuropil, Neuroscience, Biology, Synapse, Cerebral cortex, Cortex (anatomy), Neuron, Network topology, Cell type, Topology (electrical circuits), Nerve net, Computer science, Cell, Central nervous system, Computer network, CELL REPORTS},
}
