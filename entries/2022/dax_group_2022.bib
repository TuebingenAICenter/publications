@misc{dax_group_2022,
	title = {Group equivariant neural posterior estimation},
	shorttitle = {{GNPE}},
	url = {https://openreview.net/forum?id=u6s8dSporO8},
	doi = {10.48550/arxiv.2111.13139},
	abstract = {Simulation-based inference (SBI) allows for Bayesian inference in models where the likelihood is intractable but data can be simulated. Neural posterior estimation (NPE) is a popular SBI method that uses deep learning to learn the posterior distribution. However, standard NPE architectures do not exploit symmetries in the data or parameters, which can lead to inefficient use of data and poor generalization. In this paper, we introduce group equivariant neural posterior estimation (GNPE), a framework for incorporating group symmetries into NPE. We show that GNPE can be implemented by augmenting the input data with group-transformed versions of the data and using an equivariant neural network architecture. We demonstrate the effectiveness of GNPE on several synthetic and real-world problems, including gravitational-wave inference, where it significantly improves performance over standard NPE.},
	language = {en},
	urldate = {2025-02-11},
	author = {Dax, M. and Green, S. R. and Gair, J. and Deistler, M. and Schölkopf, B. and Macke, J. H.},
	month = apr,
	year = {2022},
	keywords = {Inference, Equivariant map, Estimator, Computer science, Artificial neural network, Exploit, Black box, Algorithm, Mathematics, Artificial intelligence, Statistics, ICLR},
}
