@article{bogdanovic_model-free_2022,
	title = {Model-free reinforcement learning for robust locomotion using demonstrations from trajectory optimization},
	copyright = {© 2022 Bogdanovic, Khadiv and Righetti. This is an open-access article distributed under the terms of the Creative Commons Attribution License (CC BY).},
	issn = {2296-9144},
	shorttitle = {Model-free reinforcement learning for robust locomotion},
	url = {https://www.frontiersin.org/articles/10.3389/frobt.2022.854212/full},
	doi = {10.3389/frobt.2022.854212},
	abstract = {Legged robots are capable of traversing complex terrains, but achieving robust locomotion remains a challenge. Model-based control methods, such as trajectory optimization (TO) and model predictive control (MPC), can generate high-quality motions but are often sensitive to model inaccuracies and external disturbances. Reinforcement learning (RL) has shown promise in learning robust control policies, but training from scratch is often sample-inefficient and requires careful reward engineering. In this work, we propose a framework that combines the strengths of TO and RL. We use TO to generate a set of optimal trajectories for a variety of tasks and terrains, and then use these trajectories to guide the RL training process. We show that our approach, which we call TO-guided RL, can learn robust locomotion policies that outperform both pure TO and pure RL methods in terms of success rate and robustness to disturbances. We evaluate our approach on a quadruped robot in simulation and show that it can traverse challenging terrains, including slopes, stairs, and uneven ground, with high success rates.},
	language = {en},
	urldate = {2024-05-23},
	journal = {Frontiers in Robotics and AI},
	publisher = {Frontiers Media S.A.},
	author = {Bogdanovic, Marko and Khadiv, Majid and Righetti, Ludovic},
	month = aug,
	year = {2022},
	keywords = {FRONTIERS},
}
