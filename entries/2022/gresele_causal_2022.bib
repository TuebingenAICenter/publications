@misc{gresele_causal_2022,
	title = {Causal {Inference} {Through} the {Structural} {Causal} {Marginal} {Problem}},
	url = {https://proceedings.mlr.press/v162/gresele22a.html},
	doi = {10.48550/arxiv.2202.01300},
	abstract = {We introduce the Structural Causal Marginal Problem (SCMP): given a set of marginal distributions of a structural causal model (SCM) under different interventions, can we identify the causal graph or the interventional distributions? We show that the SCMP is a powerful framework that encompasses several existing causal inference problems, such as causal discovery from interventional data, transportability, and causal effect estimation. We provide a general identifiability criterion for the SCMP and show that it can be solved using a variety of methods, including constraint-based, score-based, and continuous optimization approaches. We demonstrate the effectiveness of our framework on synthetic and real-world data.},
	language = {en},
	publisher = {PMLR},
	author = {Gresele, Luigi and von Kügelgen, Julius and Kübler, Jonas M. and Kirschbaum, Elke and Schölkopf, Bernhard and Janzing, Dominik},
	editor = {Chaudhuri, Kamalika and Jegelka, Stefanie and Song, Le and Szepesvari, Csaba and Niu, Gang and Sabato, Sivan},
	month = jul,
	year = {2022},
	keywords = {Marginal structural model, Categorical variable, Counterfactual thinking, Inference, Causal inference, Marginal model, Marginal distribution, Computer science, Statistical inference, Contrast (vision), Econometrics, Set (abstract data type), Mathematics, Machine learning, Artificial intelligence, Statistics, Regression analysis, Random variable, Psychology, ICML},
}
