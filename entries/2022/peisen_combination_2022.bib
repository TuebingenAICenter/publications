@article{peisen_combination_2022,
	title = {Combination of {Whole}-{Body} {Baseline} {CT} {Radiomics} and {Clinical} {Parameters} to {Predict} {Response} and {Survival} in a {Stage}-{IV} {Melanoma} {Cohort} {Undergoing} {Immunotherapy}},
	copyright = {CC BY 4.0},
	issn = {2072-6694},
	shorttitle = {Combination of {Whole}-{Body} {Baseline} {CT} {Radiomics} and {Clinical} {Parameters}},
	url = {https://doi.org/10.3390/cancers14122992},
	doi = {10.3390/cancers14122992},
	abstract = {The aim of this study was to investigate the predictive value of whole-body baseline CT radiomics combined with clinical parameters for response and survival in patients with stage-IV melanoma undergoing immunotherapy. In this retrospective study, 108 patients with stage-IV melanoma who underwent baseline CT imaging before starting immunotherapy were included. Radiomic features were extracted from all measurable lesions. A radiomics score was developed using a random forest classifier. Clinical parameters were combined with the radiomics score to predict response (RECIST 1.1) and overall survival (OS). The radiomics score showed a significant association with response (AUC = 0.78) and OS (p 0.001). The combination of the radiomics score and clinical parameters improved the prediction of response (AUC = 0.84) and OS (p 0.001). Whole-body baseline CT radiomics, especially when combined with clinical parameters, can predict response and survival in patients with stage-IV melanoma undergoing immunotherapy.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Cancers},
	publisher = {MDPI},
	author = {Peisen, Florian and Hänsch, Alexander and Hering, Amanda and Brendlin, Anja S. and Afat, Sami and Nikolaou, Konstantin and Gatidis, Sergios and Eigentler, Thomas and Amaral, Tiago and Moltz, Jan H. and Othman, Ahmed E.},
	month = jun,
	year = {2022},
	keywords = {Radiomics, Melanoma, Immunotherapy, CT},
}
