@misc{kremer_functional_2022,
	title = {Functional {Generalized} {Empirical} {Likelihood} {Estimation} for {Conditional} {Moment} {Restrictions}},
	url = {https://proceedings.mlr.press/v162/kremer22a.html},
	doi = {10.48550/arxiv.2207.04771},
	abstract = {We propose a functional generalized empirical likelihood (FGEL) estimator for conditional moment restrictions. By leveraging the framework of reproducing kernel Hilbert spaces (RKHS), we transform the infinite-dimensional conditional moment restrictions into a finite-dimensional problem. We show that the proposed estimator is consistent and asymptotically normal under mild regularity conditions. Furthermore, we demonstrate that the FGEL estimator is more robust than the generalized method of moments (GMM) estimator in the presence of heavy-tailed errors and outliers. We provide empirical evidence on both synthetic and real-world datasets to support our theoretical findings.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Kremer, H. and Zhu, J.-J. and Muandet, K. and Schölkopf, B.},
	editor = {Chaudhuri, Kamalika and Jegelka, Stefanie and Song, Le and Szepesvari, Csaba and Niu, Gang and Sabato, Sivan},
	month = jul,
	year = {2022},
	keywords = {Empirical likelihood, Estimator, Moment (physics), Inference, Generalized method of moments, Kernel (algebra), Computer science, Causal inference, Mathematical optimization, Mathematics, Applied mathematics, Econometrics, Machine learning, Artificial intelligence, Statistics, ICML},
}
