@article{bing_conditional_2022,
	title = {Conditional {Generation} of {Medical} {Time} {Series} for {Extrapolation} to {Underrepresented} {Populations}},
	copyright = {CC BY 4.0},
	issn = {2767-3170},
	shorttitle = {Conditional {Generation} of {Medical} {Time} {Series}},
	url = {https://is.mpg.de/ei/publications/binditbausch22},
	doi = {10.1371/journal.pdig.0000074},
	abstract = {Medical machine learning models often perform poorly on underrepresented populations due to a lack of sufficient training data. Generative models have been proposed as a solution to this data scarcity problem by synthesizing realistic medical data. However, existing generative models often fail to capture the complex temporal dependencies in medical time series or to provide the necessary control to generate data for specific underrepresented subgroups. In this work, we propose a conditional generative model for medical time series that allows for the generation of synthetic data for underrepresented populations. Our model, based on a conditional variational autoencoder, learns to disentangle the underlying factors of variation in medical time series, enabling the generation of data conditioned on specific patient characteristics. We demonstrate the effectiveness of our approach on two real-world medical datasets, showing that our model can generate high-quality synthetic data that improves the performance of downstream predictive models on underrepresented populations.},
	language = {en},
	urldate = {2024-05-23},
	journal = {PLOS Digital Health},
	publisher = {Public Library of Science},
	author = {Bing, S. and Dittadi, A. and Bauer, S. and Schwab, P.},
	month = jul,
	year = {2022},
	keywords = {Medical Time Series, Generative Models, Underrepresented Populations},
}
