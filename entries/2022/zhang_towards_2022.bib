@misc{zhang_towards_2022,
	title = {Towards {Principled} {Disentanglement} for {Domain} {Generalization}},
	shorttitle = {Towards {Principled} {Disentanglement}},
	url = {https://openaccess.thecvf.com/content/CVPR2022/papers/Zhang_Towards_Principled_Disentanglement_for_Domain_Generalization_CVPR_2022_paper.pdf},
	doi = {10.1109/CVPR52688.2022.00787},
	abstract = {Domain generalization (DG) aims to learn a model that generalizes to unseen target domains by exploiting data from multiple source domains. A common strategy is to learn disentangled representations that separate domain-invariant features from domain-specific ones. However, existing methods often lack a principled way to achieve this separation, leading to suboptimal performance. In this paper, we propose a principled framework for disentanglement in DG. We show that under certain conditions, the domain-invariant features can be identified by maximizing the mutual information between the representation and the label, while minimizing the mutual information between the representation and the domain index. We further propose a practical algorithm, named Disentangled Domain Generalization (DDG), to implement this framework. Extensive experiments on several benchmark datasets demonstrate that our method achieves state-of-the-art performance, outperforming existing DG methods by a significant margin.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {IEEE},
	author = {Zhang, Hanlin and Zhang, Yifan and Liu, Weiyang and Weller, Adrian and Schölkopf, Bernhard and Xing, Eric},
	year = {2022},
	keywords = {Computer science, Generalization, Spurious relationship, Invariant (physics), Domain (mathematical analysis), Artificial intelligence, Representation (politics), Salient, Theoretical computer science, Encoder, Transformation (genetics), Algorithm, Machine learning, Mathematics, CVPR},
}
