@article{schwetlick_deepgaze_2022,
	title = {{DeepGaze} vs {SceneWalk}: what can {DNNs} and biological scan path models teach each other?},
	issn = {1534-7362},
	shorttitle = {{DeepGaze} vs {SceneWalk}},
	url = {https://jov.arvojournals.org/article.aspx?articleid=2784484},
	doi = {10.1167/jov.22.14.3986},
	abstract = {Scan path models aim to predict the sequence of fixations during scene viewing. Two prominent approaches are DeepGaze, a deep neural network (DNN) based model, and SceneWalk, a cognitive model based on the idea of a guidance map. While DeepGaze achieves state-of-the-art performance in predicting fixation locations, SceneWalk provides a more interpretable framework for the underlying cognitive processes. In this paper, we compare these two approaches and investigate what they can learn from each other. We find that DeepGaze can be improved by incorporating a mechanism for inhibition of return, a key feature of SceneWalk. Conversely, SceneWalk can be improved by using the feature representations learned by DeepGaze. Our results suggest that combining the strengths of both approaches leads to better scan path predictions and a deeper understanding of the mechanisms underlying human eye movement control.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Vision},
	publisher = {Association for Research in Vision and Ophthalmology},
	author = {Schwetlick, Lisa and Kümmerer, Matthias and Engbert, Ralf and Bethge, Matthias},
	year = {2022},
	keywords = {Computer science, Predictability, Saccade, Artificial intelligence, Variance (accounting), Fixation (population genetics), Eye movement, Artificial neural network, Path (computing), Likelihood function, Divergence (linguistics), Machine learning, Pattern recognition (psychology), Algorithm, Statistics, Mathematics, Biology, Estimation theory, JOV},
}
