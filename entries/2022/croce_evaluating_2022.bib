@misc{croce_evaluating_2022,
	title = {Evaluating the {Adversarial} {Robustness} of {Adaptive} {Test}-time {Defenses}},
	shorttitle = {Evaluating the {Adversarial} {Robustness} of {Adaptive} {Test}-time {Defenses}},
	url = {https://arxiv.org/abs/2202.13711},
	doi = {10.48550/arXiv.2202.13711},
	abstract = {Test-time adaptation (TTA) aims to improve the performance of a pre-trained model on a target domain by adapting it to test data. Recently, several works have proposed TTA methods as a defense against adversarial attacks. In this paper, we show that these defenses are often evaluated against weak, non-adaptive attacks, leading to an overestimation of their robustness. We propose a framework for evaluating the adversarial robustness of TTA methods, which includes a set of adaptive attacks that account for the adaptation process. We evaluate several state-of-the-art TTA methods and show that they are significantly less robust than previously reported when evaluated against our adaptive attacks. Our results highlight the importance of evaluating TTA defenses against adaptive adversaries and provide a benchmark for future research in this area.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Croce, Francesco and Gowal, Sven and Brunner, Thomas and Shelhamer, Evan and Hein, Matthias and Cemgil, Taylan},
	year = {2022},
	keywords = {Robustness (evolution), Adversarial system, Categorization, Computer science, Inference, Machine learning, Computation, Artificial intelligence, Algorithm, Biology, ICML},
}
