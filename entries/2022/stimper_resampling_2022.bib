@misc{stimper_resampling_2022,
	title = {Resampling {Base} {Distributions} of {Normalizing} {Flows}},
	url = {https://proceedings.mlr.press/v151/stimper22a.html},
	doi = {10.48550/arxiv.2110.15828},
	abstract = {Normalizing flows are powerful generative models that learn a transformation from a simple base distribution to a complex target distribution. The expressivity of these models is limited by the choice of the base distribution, which is typically fixed to a simple unimodal distribution like a Gaussian. We propose to replace this fixed base distribution with a learnable, more flexible distribution. To this end, we introduce a resampling mechanism that allows the base distribution to be adapted to the target distribution during training. Our method is easy to implement, computationally efficient, and can be combined with any existing normalizing flow architecture. We demonstrate the effectiveness of our approach on a variety of density estimation and generative modeling tasks, showing that it consistently improves the performance of normalizing flows.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Stimper, Vincent and Schölkopf, Bernhard and Hernández-Lobato, José Miguel},
	editor = {Camps-Valls, Gustau and Ruiz, Francisco J. R. and Valera, Isabel},
	month = mar,
	year = {2022},
	keywords = {Resampling, Divergence (linguistics), Invertible matrix, Base (topology), Mathematics, Applied mathematics, Computer science, Sampling (signal processing), Algorithm, Density estimation, Flow (mathematics), Probability distribution, Distribution (mathematics), Net (polyhedron), Mathematical optimization, Statistics, Mathematical analysis, Pure mathematics, AISTATS},
}
