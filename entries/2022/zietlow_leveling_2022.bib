@misc{zietlow_leveling_2022,
	title = {Leveling {Down} in {Computer} {Vision}: {Pareto} {Inefficiencies} in {Fair} {Deep} {Classifiers}},
	shorttitle = {Leveling {Down} in {Computer} {Vision}},
	url = {https://openaccess.thecvf.com/content/CVPR2022/papers/Zietlow_Leveling_Down_in_Computer_Vision_Pareto_Inefficiencies_in_Fair_Deep_CVPR_2022_paper.pdf},
	doi = {10.1109/CVPR52688.2022.01017},
	abstract = {Fairness in machine learning is often equated with equalizing performance across groups. However, this can lead to 'leveling down', where the performance of advantaged groups is degraded to match the performance of disadvantaged groups, even when it is possible to improve the performance of the disadvantaged group without harming the advantaged one. We show that this phenomenon is common in deep learning classifiers for computer vision. We formalize this as a Pareto inefficiency and propose a simple method to identify and mitigate it. Our approach allows us to find models that are Pareto optimal, providing better performance for all groups compared to standard fairness-constrained models.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {IEEE},
	author = {Zietlow, Dominik and Lohaus, Michael and Balakrishnan, Guha and Kleindessner, Matthäus and Locatello, Francesco and Schölkopf, Bernhard and Russell, Chris},
	month = jun,
	year = {2022},
	keywords = {Disadvantaged, Heuristics, Computer science, Variance (accounting), Pareto principle, Artificial intelligence, Decomposition, Machine learning, Computer experiment, Mathematical optimization, Mathematics, Simulation, Economics, CVPR},
}
