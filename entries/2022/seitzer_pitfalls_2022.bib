@misc{seitzer_pitfalls_2022,
	title = {On the {Pitfalls} of {Heteroscedastic} {Uncertainty} {Estimation} with {Probabilistic} {Neural} {Networks}},
	url = {https://openreview.net/forum?id=aPOpXlnV1T},
	doi = {10.48550/arxiv.2203.09168},
	abstract = {Probabilistic neural networks are a popular tool for estimating heteroscedastic aleatoric uncertainty. They are typically trained by maximizing the log-likelihood of a Gaussian distribution with a variance predicted by the network. In this work, we identify a common failure mode of this approach: if the network is not sufficiently expressive or the training data is noisy, the predicted variance can collapse to zero or explode, leading to poor uncertainty estimates. We analyze the causes of this behavior and propose a simple and effective solution: a lower bound on the predicted variance. We demonstrate that this simple fix significantly improves the quality of uncertainty estimates on a variety of regression tasks.},
	language = {en},
	urldate = {2025-05-14},
	author = {Seitzer, Maximilian and Tavakoli, Arash and Antic, Dimitrije and Martius, Georg},
	month = apr,
	year = {2022},
	keywords = {Heteroscedasticity, Hyperparameter, Computer science, Artificial neural network, Logarithm, Probabilistic logic, Artificial intelligence, Variance (accounting), Machine learning, Range (aeronautics), Gaussian, Likelihood function, Interpretability, Point estimation, Function (biology), Econometrics, Statistics, Mathematics, Estimation theory, Algorithm, ICLR},
}
