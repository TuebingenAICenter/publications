@article{kunstle_estimating_2022,
	title = {Estimating the perceived dimension of psychophysical stimuli using triplet accuracy and hypothesis testing},
	issn = {1534-7362},
	url = {https://doi.org/10.1167/jov.22.13.5},
	doi = {10.1167/jov.22.13.5},
	abstract = {In many psychophysical experiments, observers are asked to judge the similarity of stimuli. A common way to analyze such data is to embed the stimuli into a low-dimensional Euclidean space, a technique known as multidimensional scaling (MDS). A crucial, yet often overlooked, question is how many dimensions are actually needed to represent the perceived similarity structure. If the chosen dimension is too low, the embedding will be inaccurate; if it is too high, the model will overfit. In this paper, we propose a novel method to estimate the intrinsic dimension of the perceived stimulus space. Our approach is based on triplet comparisons, which are a robust and common way to collect similarity data. We use the accuracy of triplet predictions as a measure of model fit and develop a hypothesis test to determine the minimum number of dimensions required to explain the data. We demonstrate the effectiveness of our method on both synthetic and real-world psychophysical data, showing that it provides a reliable estimate of the perceived dimension and helps to avoid overfitting.},
	language = {en},
	journal = {Journal of Vision},
	publisher = {Association for Research in Vision and Ophthalmology},
	author = {Künstle, David and von Luxburg, Ulrike and Wichmann, Felix},
	year = {2022},
	keywords = {Curse of dimensionality, Psychophysics, Overfitting, Multidimensional scaling, Artificial intelligence, Scaling, Computer science, Pattern recognition (psychology), Embedding, Perception, Pairwise comparison, Mathematics, Machine learning, Psychology, Artificial neural network, Dimension (graph theory), Observer (physics), Scale (ratio), Representation (politics), Similarity (geometry), Statistics, JOV},
}
