@inproceedings{rateike_dont_2022,
	title = {Don’t {Throw} it {Away}! {The} {Utility} of {Unlabeled} {Data} in {Fair} {Decision} {Making}},
	shorttitle = {Don’t {Throw} it {Away}!},
	url = {https://is.mpg.de/ei/publications/rateikem_2022},
	doi = {10.1145/3531146.3533199},
	abstract = {Fairness in machine learning is often studied in settings where sensitive attributes are available for all training samples. However, in many real-world scenarios, sensitive attributes are only available for a small subset of the data, while the majority of the data remains unlabeled with respect to these attributes. In this paper, we investigate the utility of such unlabeled data for fair decision making. We propose a framework that leverages unlabeled data to improve fairness-accuracy trade-offs. Our approach is based on the observation that unlabeled data can be used to learn a better representation of the data, which in turn can be used to improve fairness. We demonstrate the effectiveness of our approach on several real-world datasets and show that it consistently outperforms existing methods that either ignore unlabeled data or use it in a limited way.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {{FAccT} '22: 2022 {ACM} {Conference} on {Fairness}, {Accountability}, and {Transparency}},
	publisher = {ACM},
	author = {Rateike, M. and Majumdar, A. and Mineeva, O. and Gummadi, K. P. and Valera, I.},
	month = jun,
	year = {2022},
	keywords = {FACCT},
}
