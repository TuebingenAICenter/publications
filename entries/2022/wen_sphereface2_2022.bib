@inproceedings{wen_sphereface2_2022,
	title = {{SphereFace2}: {Binary} {Classification} is {All} {You} {Need} for {Deep} {Face} {Recognition}},
	shorttitle = {{SphereFace2}},
	url = {https://openreview.net/forum?id=l3SDgUh7qZO},
	abstract = {Deep face recognition has been dominated by margin-based softmax loss functions. While effective, these losses are often complex to design and optimize, requiring careful hyperparameter tuning. In this paper, we revisit the fundamental objective of face recognition and show that it can be effectively solved as a binary classification problem. We propose SphereFace2, a simple yet powerful framework that learns discriminative face representations by treating face recognition as a binary classification task. SphereFace2 eliminates the need for complex margin-based losses and achieves state-of-the-art performance on standard benchmarks. We provide theoretical analysis to justify our approach and demonstrate its effectiveness through extensive experiments.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {10th {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Wen, Yandong and Liu, Weiyang and Weller, Adrian and Raj, Bhiksha and Singh, Rita},
	month = apr,
	year = {2022},
	keywords = {ICLR},
}
