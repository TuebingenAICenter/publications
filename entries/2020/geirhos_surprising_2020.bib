@misc{geirhos_surprising_2020,
	title = {On the surprising similarities between supervised and self-supervised models},
	url = {https://arxiv.org/abs/2010.08377},
	doi = {10.48550/arxiv.2010.08377},
	abstract = {Self-supervised learning has recently emerged as a powerful alternative to supervised learning, with some models even matching supervised performance on ImageNet. But how similar are the representations learned by these two paradigms? We perform a large-scale comparison of supervised and self-supervised models across a wide range of architectures and datasets. We find that self-supervised models are surprisingly similar to their supervised counterparts: they exhibit similar error patterns, similar shape-bias, and similar robustness to common corruptions. Furthermore, we show that self-supervised models can be used as drop-in replacements for supervised models in downstream tasks with little to no loss in performance. Our results suggest that the representations learned by self-supervised models are not fundamentally different from those learned by supervised models, but rather that they capture similar features of the data.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Geirhos, Robert and Narayanappa, Kantharaju and Mitzkus, Benjamin and Bethge, Matthias and Wichmann, Felix A. and Brendel, Wieland},
	year = {2020},
	keywords = {Computer science, Artificial intelligence, Psychology, Machine learning, NEURIPS},
}
