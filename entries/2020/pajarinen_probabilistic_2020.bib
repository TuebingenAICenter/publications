@article{pajarinen_probabilistic_2020,
	title = {Probabilistic {Approach} to {Physical} {Object} {Disentangling}},
	url = {https://is.mpg.de/ei/publications/pajarepetneu20},
	doi = {10.1109/LRA.2020.3006789},
	abstract = {Disentangling objects from a pile is a fundamental task for autonomous robots. Existing approaches often rely on deep learning to predict grasping points or segmentation masks, which requires large amounts of labeled data and often fails to generalize to novel objects or configurations. In this paper, we propose a probabilistic approach to physical object disentangling that models the interaction between the robot and the objects as a latent variable model. Our approach learns to disentangle objects by interacting with the environment, without requiring any manual labels. We demonstrate that our method can effectively disentangle objects in a variety of scenarios, including piles of objects with different shapes and sizes, and that it outperforms existing baselines in terms of success rate and efficiency.},
	language = {en},
	urldate = {2024-05-22},
	journal = {IEEE Robotics and Automation Letters},
	publisher = {IEEE},
	author = {Pajarinen, J. and Arenz, O. and Peters, J. and Neumann, G.},
	year = {2020},
	keywords = {RAL},
}
