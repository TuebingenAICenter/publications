@inproceedings{negiar_stochastic_2020,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Stochastic {Frank}-{Wolfe} for {Constrained} {Finite}-{Sum} {Minimization}},
	shorttitle = {Stochastic {Frank}-{Wolfe}},
	url = {http://proceedings.mlr.press/v119/negiar20a/negiar20a.pdf},
	abstract = {We consider the problem of minimizing a finite sum of smooth convex functions over a convex compact set. The Frank-Wolfe (FW) algorithm is a popular choice for this problem as it only requires solving a linear subproblem at each iteration. However, standard FW requires a full gradient evaluation, which is computationally prohibitive in the large-scale setting. We propose a stochastic Frank-Wolfe algorithm that uses variance reduction to achieve a faster convergence rate than existing stochastic FW variants. We provide a convergence analysis for our algorithm and show that it achieves a linear convergence rate for strongly convex functions and a sublinear rate for general convex functions. We also provide empirical evidence on several machine learning problems demonstrating the effectiveness of our approach.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Proceedings of the 37th {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Negiar, Geoffrey and Dresdner, Gilles and Tsai, A. Y.-T. and El Ghaoui, Laurent and Locatello, Francesco and Freund, Robert M. and Pedregosa, Fabian},
	editor = {Daumé III, Hal and Singh, Aarti},
	month = jul,
	year = {2020},
	keywords = {ICML},
}
