@inproceedings{shaj_action-conditional_2020,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Action-{Conditional} {Recurrent} {Kalman} {Networks} {For} {Forward} and {Inverse} {Dynamics} {Learning}},
	shorttitle = {Action-{Conditional} {Recurrent} {Kalman} {Networks}},
	url = {https://proceedings.mlr.press/v155/shaj21a.html},
	abstract = {Learning accurate forward and inverse dynamics models is a fundamental challenge in robotics. While deep learning approaches have shown great success in learning complex dynamics, they often struggle with long-term stability and data efficiency. In this paper, we propose Action-Conditional Recurrent Kalman Networks (AC-RKNs), a novel architecture that combines the structural benefits of Kalman Filters with the representational power of deep neural networks. AC-RKNs are designed to learn forward and inverse dynamics models in a unified framework. By incorporating a latent state space that is updated via a Kalman filter-like mechanism, our model is able to capture long-term dependencies and maintain stability over long horizons. We demonstrate the effectiveness of our approach on a variety of robotic manipulation tasks, showing that AC-RKNs outperform state-of-the-art methods in terms of both prediction accuracy and data efficiency.},
	language = {en},
	booktitle = {Proceedings of the 4th {Conference} on {Robot} {Learning}},
	publisher = {PMLR},
	author = {Shaj, V. and Becker, P. and Büchler, D. and Pandya, H. and van Duijkeren, N. and Taylor, C. J. and Hanheide, M. and Neumann, G.},
	editor = {Kober, Jens and Ramos, Fabio and Tomlin, Claire J.},
	month = nov,
	year = {2020},
	keywords = {CORL},
}
