@misc{locatello_disentangling_2020,
	title = {Disentangling {Factors} of {Variations} {Using} {Few} {Labels}},
	shorttitle = {Disentangling {Factors} of {Variations} {Using} {Few} {Labels}},
	url = {https://openreview.net/forum?id=SygagpEKwB},
	doi = {10.48550/arxiv.1905.01258},
	abstract = {Unsupervised disentanglement learning aims to separate the independent factors of variation in data without access to ground-truth labels. Recent theoretical results show that this is impossible without inductive biases on both the models and the data. In this paper, we investigate the setting where a small number of labeled data is available. We show that even a few labeled examples can be used to identify the factors of variation and significantly improve disentanglement performance. We propose a simple yet effective semi-supervised approach that leverages these labels to learn a disentangled representation. We empirically demonstrate that our method outperforms state-of-the-art unsupervised approaches on several datasets and that it is robust to the choice of the few labeled examples.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {International Conference on Learning Representations},
	author = {Locatello, Francesco and Tschannen, Michael and Bauer, Stefan and Rätsch, Gunnar and Schölkopf, Bernhard and Bachem, Olivier},
	month = apr,
	year = {2020},
	keywords = {Variation (astronomy), Statistics, Mathematics, Physics, ICLR},
}
