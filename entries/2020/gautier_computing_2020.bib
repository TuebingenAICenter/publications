@misc{gautier_computing_2020,
	title = {Computing the norm of nonnegative matrices and the log-{Sobolev} constant of {Markov} chains},
	shorttitle = {Computing the norm of nonnegative matrices},
	url = {https://arxiv.org/abs/2002.02447},
	doi = {10.48550/arXiv.2002.02447},
	abstract = {We study the problem of computing the p-norm of a nonnegative matrix A, defined as the maximum of the ratio Ax\_p / x\_p over all non-zero nonnegative vectors x. While this problem is NP-hard for general matrices, we show that for nonnegative matrices it can be solved in polynomial time for any p = 1. We provide a simple iterative algorithm that converges to the optimal value and show that it is related to the power method. We then apply this result to the problem of computing the log-Sobolev constant of a Markov chain, which is a key quantity for determining the rate of convergence to stationarity. We show that the log-Sobolev constant can be computed by solving a sequence of norm problems for nonnegative matrices, and we provide an efficient algorithm for this task.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Gautier, Antoine and Hein, Matthias and Tudisco, Francesco},
	year = {2020},
	keywords = {Mathematics, Markov chain, Iterated function, Norm (philosophy), Constant (computer programming), Nonnegative matrix, Matrix (chemical analysis), Sobolev space, Pure mathematics, Convergence (economics), Logarithm, Discrete mathematics, Combinatorics, Eigenvalues and eigenvectors, Symmetric matrix, Mathematical analysis, Computer science},
}
