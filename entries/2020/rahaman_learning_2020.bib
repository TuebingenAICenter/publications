@inproceedings{rahaman_learning_2020,
	title = {Learning the {Arrow} of {Time} for {Problems} in {Reinforcement} {Learning}},
	shorttitle = {Learning the {Arrow} of {Time}},
	url = {https://openreview.net/pdf?id=rylJkpEtwS},
	abstract = {The ability to distinguish between the past and the future is a fundamental property of physical systems. In this work, we propose a method to learn the arrow of time from observations of dynamical systems. We show that this can be formulated as a self-supervised learning task, where a neural network is trained to predict the temporal order of a sequence of observations. We demonstrate that this learned representation is useful for reinforcement learning, where it can be used to improve sample efficiency and performance in environments with sparse rewards. We evaluate our method on a variety of tasks, including navigation and manipulation, and show that it outperforms existing methods for learning representations in reinforcement learning.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {8th {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Rahaman, Nasim and Wolf, Sebastian and Goyal, Anirudh and Remme, Roman and Bengio, Yoshua},
	month = apr,
	year = {2020},
	keywords = {ICLR},
}
