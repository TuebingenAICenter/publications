@article{motokura_plucking_2020,
	title = {Plucking {Motions} for {Tea} {Harvesting} {Robots} {Using} {Probabilistic} {Movement} {Primitives}},
	issn = {2377-3766},
	shorttitle = {Plucking {Motions} for {Tea} {Harvesting} {Robots}},
	url = {https://is.mpg.de/ei/publications/mottakewepet20},
	doi = {10.1109/LRA.2020.2976314},
	abstract = {Tea harvesting is a labor-intensive task that requires high dexterity and adaptability to the environment. While automated tea harvesting machines exist, they often damage the tea bushes or harvest low-quality leaves. In this paper, we propose a method for tea plucking using a robotic manipulator. We model the plucking motion using Probabilistic Movement Primitives (ProMPs), which allow for the representation of a distribution over trajectories. This representation enables the robot to adapt its motion to the varying positions of tea leaves and to handle the uncertainty inherent in the environment. We evaluate our approach in a simulated environment and demonstrate that it can successfully pluck tea leaves with high precision and adaptability.},
	language = {en},
	urldate = {2024-05-23},
	journal = {IEEE Robotics and Automation Letters},
	publisher = {IEEE},
	author = {Motokura, K. and Takahashi, M. and Ewerton, M. and Peters, J.},
	year = {2020},
	keywords = {RAL},
}
