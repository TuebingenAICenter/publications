@misc{rauber_eagerpy_2020,
	title = {{EagerPy}: {Writing} code that works natively with {PyTorch}, {TensorFlow}, {JAX}, and {NumPy}},
	shorttitle = {{EagerPy}},
	url = {https://arxiv.org/abs/2008.04175},
	doi = {10.48550/arxiv.2008.04175},
	abstract = {Modern deep learning research is fragmented across multiple frameworks, most notably PyTorch, TensorFlow, and JAX. This fragmentation makes it difficult to write code that is portable across frameworks, which is a major hurdle for research reproducibility and the development of framework-agnostic libraries. We introduce EagerPy, a library that provides a unified interface for PyTorch, TensorFlow, JAX, and NumPy. EagerPy allows researchers to write code that works natively with all these frameworks, while still allowing them to leverage framework-specific features when needed. EagerPy is designed to be lightweight, easy to use, and to have minimal overhead.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Rauber, Jonas and Bethge, Matthias and Brendel, Wieland},
	year = {2020},
	keywords = {Python (programming language), Chaining, Computer science, Documentation, Programming language, Code (set theory), Source code, Software engineering, World Wide Web},
}
