@article{goncalves_training_2020,
	title = {Training deep neural density estimators to identify mechanistic models of neural dynamics},
	copyright = {© 2020, Goncalves et al.},
	issn = {2050-084X},
	shorttitle = {Training deep neural density estimators},
	url = {https://doi.org/10.7554/eLife.56261},
	doi = {10.7554/eLife.56261},
	abstract = {Mechanistic models are essential for understanding neural dynamics, but fitting them to experimental data is often computationally prohibitive. We present a simulation-based inference framework that uses deep neural density estimators to perform likelihood-free inference. Our approach, which we call sequential neural posterior estimation (SNPE), enables the identification of parameters of mechanistic models by learning the posterior distribution of parameters given observed data. We demonstrate that SNPE can identify parameters of complex, high-dimensional models of neural dynamics, including models of single neurons and recurrent neural networks, with high accuracy and efficiency. Our framework is flexible, scalable, and can be applied to a wide range of mechanistic models, providing a powerful tool for bridging the gap between theory and experiment in neuroscience.},
	language = {en},
	urldate = {2024-05-23},
	journal = {eLife},
	publisher = {eLife Sciences Publications, Ltd},
	author = {Gonçalves, P. J. and Lueckmann, J.-M. and Deistler, M. and Nonnenmacher, M. and Öcal, K. and Bassetto, G. and Chintaluri, C. and Podlaski, W. F. and Haddad, S. A. and Vogels, T. P. and Greenberg, D. S. and Macke, J. H.},
	editor = {Huguenard, John R. and O'Leary, Timothy and Goldman, Mark S.},
	year = {2020},
	keywords = {Computer science, Artificial intelligence, Estimator, Artificial neural network, Machine learning, Bayesian probability, Inference, Bayesian inference, Flexibility (engineering), Mathematics, ELIFE},
}
