@article{park_variational_2020,
	title = {Variational {Bayes} {In} {Private} {Settings} ({VIPS})},
	issn = {1076-9757},
	shorttitle = {{VIPS}},
	url = {https://www.jair.org/index.php/jair/article/view/11763/26582},
	doi = {10.1613/jair.1.11763},
	abstract = {We present Variational Bayes in Private Settings (VIPS), a framework for performing variational Bayesian inference while preserving differential privacy. Our approach is based on the observation that the variational objective function can be optimized using stochastic gradient descent, and that differential privacy can be maintained by injecting noise into the gradients. We provide a theoretical analysis of the privacy guarantees of VIPS, and demonstrate its effectiveness on a variety of models and datasets, showing that it can achieve good predictive performance while providing strong privacy guarantees.},
	language = {en},
	journal = {Journal of Artificial Intelligence Research},
	publisher = {AI Access Foundation},
	author = {Park, M. and Foulds, J. and Chaudhuri, K. and Welling, M.},
	month = may,
	year = {2020},
	keywords = {JAIR},
}
