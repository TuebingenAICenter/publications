@article{cadwell_cell_2020,
	title = {Cell type composition and circuit organization of clonally related excitatory neurons in the juvenile mouse neocortex},
	issn = {2050-084X},
	url = {https://elifesciences.org/articles/52951},
	doi = {10.7554/elife.52951},
	abstract = {The neocortex is composed of a diverse array of excitatory neuron types that are generated from radial glial progenitors during development. Whether clonally related neurons, which share a common progenitor, are more likely to be of the same cell type or to form specific synaptic connections remains debated. Here, we used a combination of retroviral lineage tracing, Patch-seq, and multi-neuron patch-clamp recordings in the juvenile mouse visual cortex to address this question. We found that clonally related excitatory neurons are not more likely to be of the same transcriptomic cell type than non-related neurons. Furthermore, we found that clonally related neurons do not exhibit increased connectivity compared to non-related neurons. Our results suggest that the lineage of excitatory neurons in the juvenile mouse neocortex does not strongly constrain their cell type identity or their local circuit connectivity.},
	language = {en},
	journal = {eLife},
	publisher = {eLife Sciences Publications, Ltd},
	author = {Cadwell, Cathryn R. and Scala, Federico and Fahey, Paul G. and Kobak, Dmitry and Mulherkar, Shalaka and Sinz, Fabian H. and Papadopoulos, Stelios and Tan, Zheng Huan and Johnsson, Per and Hartmanis, Leonard and Li, Shuang and Cotton, R. and Tolias, Kimberley F. and Sandberg, Rickard and Berens, Philipp and Jiang, Xiaolong and Tolias, Andreas S.},
	month = mar,
	year = {2020},
	keywords = {Neocortex, Biology, Excitatory postsynaptic potential, Neuroscience, Subplate, Cell type, Progenitor cell, Nerve net, Embryonic stem cell, Neuron, Cerebral cortex, Cell, Stem cell, Cell biology, Genetics, Inhibitory postsynaptic potential, Gene, ELIFE},
}
