@article{lioutikov_learning_2020,
	title = {Learning {Attribute} {Grammars} for {Movement} {Primitive} {Sequencing}},
	shorttitle = {Learning {Attribute} {Grammars}},
	url = {https://is.mpg.de/ei/publications/lioutikovetal20},
	doi = {10.1177/0278364919868279},
	abstract = {Movement primitives are a powerful tool for representing complex robot behaviors. However, sequencing these primitives to achieve long-term goals remains a challenge. In this paper, we propose a framework for learning attribute grammars that can represent the hierarchical structure of complex tasks and the dependencies between movement primitives. Our approach combines the structural flexibility of context-free grammars with the continuous state representation of attribute grammars. We demonstrate the effectiveness of our method on a variety of robotic manipulation tasks, showing that it can learn to sequence movement primitives to achieve complex goals while maintaining robustness to variations in the environment.},
	language = {en},
	journal = {The International Journal of Robotics Research},
	publisher = {SAGE Publications},
	author = {Lioutikov, Rudolf and Maeda, Guilherme and Veiga, Felipe F. and Kersting, Kristian and Peters, Jan},
	year = {2020},
	keywords = {IJRR},
}
