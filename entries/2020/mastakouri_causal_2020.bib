@misc{mastakouri_causal_2020,
	title = {Causal analysis of {Covid}-19 {Spread} in {Germany}},
	shorttitle = {Causal analysis of {Covid}-19 {Spread} in {Germany}},
	url = {https://proceedings.neurips.cc/paper/2020/file/205e73579f21c2ed134dbd6ce7e4a1ea-Paper.pdf},
	doi = {10.48550/arxiv.2007.11896},
	abstract = {We study the spread of Covid-19 in Germany using causal discovery methods. We aim to identify the causal structure between the number of infected individuals and various interventions, such as school closures, contact bans, and the closure of non-essential shops. We use the LiNGAM algorithm to estimate the causal structure from time series data. Our results suggest that the interventions had a significant causal effect on the spread of the virus, and that the order of interventions matters. We also discuss the limitations of our approach and the potential for future work.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Mastakouri, Atalanti and Schölkopf, Bernhard},
	editor = {Larochelle, H. and Ranzato, M. and Hadsell, R. and Balcan, M. F. and Lin, H.},
	month = dec,
	year = {2020},
	keywords = {Coronavirus disease 2019 (COVID-19), 2019-20 coronavirus outbreak, Severe acute respiratory syndrome coronavirus 2 (SARS-CoV-2), Virology, Medicine, Outbreak, Infectious disease (medical specialty), NEURIPS},
}
