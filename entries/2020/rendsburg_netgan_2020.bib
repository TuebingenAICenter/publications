@article{rendsburg_netgan_2020,
	title = {{NetGAN} without {GAN}: {From} {Random} {Walks} to {Low}-{Rank} {Approximations}},
	shorttitle = {{NetGAN} without {GAN}},
	url = {http://tml.cs.uni-tuebingen.de/team/luxburg/publications/RensburgLuxburg_Netgan_without_Gan2020.pdf},
	abstract = {NetGAN is a popular generative model for graphs that learns to generate new graphs by performing random walks on the input graph and training a GAN to mimic these walks. In this paper, we show that the GAN component is not necessary to achieve the performance of NetGAN. We prove that the random walk distribution of a graph is closely related to the transition matrix of the graph, and that the generator of NetGAN essentially learns a low-rank approximation of this transition matrix. Based on this insight, we propose a simple, non-generative alternative to NetGAN that directly computes a low-rank approximation of the transition matrix. Our method is faster to train, easier to tune, and achieves competitive or better performance than NetGAN on a variety of graph generation tasks.},
	language = {en},
	journal = {Proceedings of the 37th International Conference on Machine Learning},
	publisher = {PMLR},
	author = {Rendsburg, Luca and Heidrich, Holger and von Luxburg, Ulrike},
	year = {2020},
	keywords = {Random walk, Rank (graph theory), Approximations of π, Mathematics, Computer science, Statistics, Combinatorics, Applied mathematics, ICML},
}
