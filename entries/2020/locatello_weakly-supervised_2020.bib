@misc{locatello_weakly-supervised_2020,
	title = {Weakly-{Supervised} {Disentanglement} {Without} {Compromises}},
	url = {http://proceedings.mlr.press/v119/locatello20a/locatello20a.pdf},
	doi = {10.48550/arxiv.2002.02886},
	abstract = {Disentanglement learning aims to separate the independent factors of variation in data. Recent theoretical results show that unsupervised disentanglement is impossible without inductive biases on both the models and the data. In this paper, we investigate the role of weak supervision in the form of data pairs that share a subset of their factors of variation. We show that this form of supervision is sufficient to identify the independent factors of variation for a broad range of models. We propose a simple and effective approach to leverage such data pairs and demonstrate that it leads to state-of-the-art disentanglement performance on several benchmarks. Our results suggest that weak supervision is a powerful and practical tool for disentanglement learning.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Locatello, Francesco and Poole, Ben and Rätsch, Gunnar and Schölkopf, Bernhard and Bachem, Olivier and Tschannen, Michael},
	month = jul,
	year = {2020},
	keywords = {Computer science, ICML},
}
