@inproceedings{schwab_learning_2020,
	title = {Learning {Counterfactual} {Representations} for {Estimating} {Individual} {Dose}-{Response} {Curves}},
	shorttitle = {Learning {Counterfactual} {Representations}},
	url = {https://aaai.org/ojs/index.php/AAAI/article/view/6014},
	doi = {10.1609/aaai.v34i04.6014},
	abstract = {Estimating the effect of a continuous-valued treatment on an outcome is a fundamental problem in many fields, including medicine and economics. While most existing methods for causal inference focus on binary treatments, many real-world interventions are continuous. In this paper, we propose the Counterfactual Regression for Dose-Response (CFRDR) model, a novel framework for estimating individual dose-response curves. Our approach learns a balanced representation of the input features that is independent of the treatment dose, while simultaneously predicting the potential outcomes. We demonstrate that our method achieves state-of-the-art performance on several benchmark datasets and provides a robust estimation of individual dose-response curves.},
	language = {en},
	booktitle = {Proceedings of the 34th {Conference} on {Artificial} {Intelligence} ({AAAI})},
	publisher = {AAAI Press},
	author = {Schwab, Patrick and Linhardt, Lorenz and Bauer, Stefan and Buhmann, Joachim M. and Karlen, Walter},
	month = feb,
	year = {2020},
	keywords = {AAAI},
}
