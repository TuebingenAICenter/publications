@article{schneider_generalized_2020,
	title = {Generalized {Invariant} {Risk} {Minimization}: relating adaptation and invariant representation learning},
	shorttitle = {Generalized {Invariant} {Risk} {Minimization}},
	url = {https://brendel-group.github.io/publication/2020_01_schneider123/},
	abstract = {Invariant Risk Minimization (IRM) aims to learn representations that are invariant across different environments to improve out-of-distribution generalization. However, IRM is often difficult to optimize and can be unstable. In this paper, we propose Generalized Invariant Risk Minimization (G-IRM), a framework that relates adaptation and invariant representation learning. We show that G-IRM can be interpreted as a form of domain adaptation, and we provide a theoretical analysis of its properties. We demonstrate that G-IRM achieves state-of-the-art performance on several benchmark datasets.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Advances in Neural Information Processing Systems},
	publisher = {NeurIPS},
	author = {Schneider, Steffen and Krishna, Shubham and Eck, Luisa and Brendel, Wieland and Mathis, Mackenzie W. and Bethge, Matthias},
	year = {2020},
	keywords = {NEURIPS},
}
