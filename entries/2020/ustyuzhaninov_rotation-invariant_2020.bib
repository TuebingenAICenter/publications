@article{ustyuzhaninov_rotation-invariant_2020,
	title = {Rotation-invariant clustering of neuronal responses in primary visual cortex},
	shorttitle = {Rotation-invariant clustering},
	url = {https://openreview.net/forum?id=rklr9kHFDB},
	abstract = {The functional organization of the primary visual cortex (V1) is often described in terms of simple and complex cells. While simple cells are sensitive to the phase of a stimulus, complex cells are phase-invariant. This distinction is often formalized as a hierarchy where complex cells pool the responses of simple cells. However, it is unclear whether this hierarchy is sufficient to explain the full diversity of neuronal responses in V1. Here, we propose a new approach to characterize neuronal responses based on rotation-invariant clustering. We show that this approach can identify distinct functional cell types in V1 that are not captured by the simple/complex cell dichotomy. Our results suggest that the functional organization of V1 is more complex than previously thought and that rotation-invariant representations are a key feature of neuronal responses in the visual cortex.},
	language = {en},
	urldate = {2025-05-14},
	journal = {International Conference on Learning Representations},
	publisher = {OpenReview},
	author = {Ustyuzhaninov, Ivan and Cadena, Santiago A. and Froudarakis, Emmanouil and Fahey, Paul G. and Walker, Edgar Y. and Cobos, Erick and Reimer, Jacob and Sinz, Fabian H. and Tolias, Andreas S. and Bethge, Matthias and Ecker, Alexander S.},
	year = {2020},
	keywords = {Equivariant map, Computer science, Pattern recognition (psychology), Visual cortex, Artificial intelligence, Receptive field, Cluster analysis, Convolutional neural network, Invariant (physics), Computer vision, Neuroscience, Mathematics, Biology, Pure mathematics, ICLR},
}
