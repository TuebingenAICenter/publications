@article{mathis_imagenet_2020,
	title = {{ImageNet} performance correlates with pose estimation robustness and generalization on out-of-domain data},
	shorttitle = {{ImageNet} performance correlates with pose estimation},
	url = {http://www.gatsby.ucl.ac.uk/~balaji/udl2020/accepted-papers/UDL2020-paper-047.pdf},
	abstract = {Deep learning has revolutionized pose estimation, yet the factors that contribute to robust and generalizable models remain poorly understood. Here, we investigate the relationship between ImageNet classification performance and pose estimation performance. We find that models with higher ImageNet top-1 accuracy consistently perform better on pose estimation tasks, both in terms of robustness to image corruptions and generalization to out-of-domain data. Our results suggest that ImageNet pre-training is a powerful proxy for pose estimation performance and that the features learned for classification are highly transferable to pose estimation.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Workshop on Uncertainty and Robustness in Deep Learning},
	author = {Mathis, Alexander and Biasi, Thomas and Yüksekgönül, Mert and Rogers, Byron and Bethge, Matthias and Mathis, Mackenzie Weygandt},
	year = {2020},
	keywords = {Robustness (evolution), Computer science, Artificial intelligence, Generalization, Pose, Machine learning, Data modeling, Pattern recognition (psychology), Data mining, Mathematics},
}
