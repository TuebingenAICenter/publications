@misc{brandle_what_2020,
	title = {What are we curious about?},
	shorttitle = {What are we curious about?},
	url = {https://doi.org/10.1016/j.tics.2020.05.010},
	doi = {10.1016/j.tics.2020.05.010},
	abstract = {Curiosity is a fundamental driver of human learning and discovery. However, what exactly makes something curious remains a subject of intense debate. Here, we review recent computational and behavioral approaches to curiosity, highlighting a shift from viewing curiosity as a drive for novelty to viewing it as a drive for information gain. We discuss how these approaches can be integrated into a unified framework of curiosity, and we outline future directions for research in this field.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Elsevier},
	author = {Brändle, Franziska and Wu, Charley M. and Schulz, Eric},
	month = jul,
	year = {2020},
	keywords = {Curiosity, Novelty, Epistemology, Computer science, Cognitive science, Psychology, Philosophy, Social psychology, TICS},
}
