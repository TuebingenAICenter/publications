@misc{michaelis_closing_2020,
	title = {Closing the {Generalization} {Gap} in {One}-{Shot} {Object} {Detection}},
	shorttitle = {Closing the {Generalization} {Gap}},
	url = {https://bethgelab.org/publication/2020_11_michaelis/},
	doi = {10.48550/arXiv.2011.04267},
	abstract = {One-shot object detection aims to detect objects of classes for which only a single example is available at test time. While recent methods have achieved impressive performance on standard benchmarks, we find that they often fail to generalize to novel object classes in more challenging settings. In this paper, we analyze the causes of this generalization gap and show that it is largely due to the models' reliance on class-specific features that do not transfer well to new classes. We propose a simple yet effective approach to close this gap by leveraging a large-scale pre-trained model and fine-tuning it on a small set of novel classes. Our method achieves state-of-the-art performance on several one-shot object detection benchmarks, demonstrating the importance of feature transferability in this task.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Michaelis, Claudio and Bethge, Matthias and Ecker, Alexander S.},
	year = {2020},
	keywords = {Generalization, Metric (unit), Object (grammar), Computer science, Artificial intelligence, Shot (pellet), Set (abstract data type), Object detection, Annotation, Focus (optics), Machine learning, One shot, Single shot, Training set, Pattern recognition (psychology), Mathematics, Closing (real estate), Classifier (UML), ARXIV},
}
