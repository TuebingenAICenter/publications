@article{lohaus_too_2020,
	title = {Too {Relaxed} to {Be} {Fair}},
	url = {http://tml.cs.uni-tuebingen.de/team/luxburg/publications/LohausPerrotLuxburg2020.pdf},
	doi = {10.48550/arXiv.2006.16566},
	abstract = {Fairness in machine learning is often formulated as a constraint optimization problem. In many cases, these constraints are relaxed to make the problem tractable. In this paper, we show that such relaxations can lead to unfair solutions that are far from the intended fairness guarantees. We analyze the behavior of common relaxations for fairness constraints and show that they can be easily manipulated. We propose a new framework for fairness that is robust to such relaxations and demonstrate its effectiveness on several benchmarks.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 37th International Conference on Machine Learning},
	publisher = {PMLR},
	author = {Lohaus, Michael and Perrot, Michaël and von Luxburg, Ulrike},
	year = {2020},
	keywords = {Computer science, ICML},
}
