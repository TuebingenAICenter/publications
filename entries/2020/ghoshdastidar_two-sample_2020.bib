@article{ghoshdastidar_two-sample_2020,
	title = {Two-sample hypothesis testing for inhomogeneous random graphs},
	issn = {0090-5364},
	url = {http://tml.cs.uni-tuebingen.de/team/luxburg/publications/GhoshdastidarGutzeitCarpentierLuxburg20.pdf},
	doi = {10.1214/19-AOS1897},
	abstract = {We consider the problem of two-sample hypothesis testing for inhomogeneous random graphs. Given two independent samples of graphs, each generated from an inhomogeneous random graph model with connection probabilities defined by a latent kernel, we want to test whether the two underlying kernels are equal. We propose a test statistic based on the difference between the empirical adjacency matrices of the two samples. We analyze the power of the test and show that it is minimax optimal under certain conditions on the latent kernels. We also provide a consistent estimator for the power of the test.},
	language = {en},
	urldate = {2025-05-14},
	journal = {The Annals of Statistics},
	publisher = {Institute of Mathematical Statistics},
	author = {Ghoshdastidar, Debarghya and Gutzeit, Maurilio and Carpentier, Alexandra and von Luxburg, Ulrike},
	year = {2020},
	keywords = {AOS},
}
