@article{schroder_system_2020,
	title = {System identification with biophysical constraints: {A} circuit model of the inner retina},
	shorttitle = {System identification with biophysical constraints},
	url = {https://proceedings.neurips.cc/paper/2020/hash/b139e104214a08ae3f2ebcce149cdf6e-Abstract.html},
	doi = {10.48550/arXiv.2006.10539},
	abstract = {System identification in neuroscience often relies on black-box models, which are powerful at predicting neural responses but difficult to interpret. Here, we propose a framework for system identification that incorporates biophysical constraints into deep learning models. We apply this approach to the inner retina, where we model the transformation from bipolar cell inputs to ganglion cell outputs. By constraining the model architecture to reflect the known connectivity of the retinal circuit, we show that we can learn interpretable models that perform on par with unconstrained black-box models. Our approach allows us to infer the functional connectivity of the retinal circuit from large-scale calcium imaging data and provides a path towards building more interpretable models of neural systems.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Advances in Neural Information Processing Systems},
	publisher = {Curran Associates, Inc.},
	author = {Schröder, Cornelius and Klindt, David and Strauss, Sarah and Franke, Katrin and Bethge, Matthias and Euler, Thomas and Berens, Philipp},
	year = {2020},
	keywords = {Connectomics, Computer science, Biological neural network, Retina, Black box, Neuroscience, Computational model, Connectome, Benchmark (surveying), Artificial intelligence, Machine learning, Biology, Functional connectivity, NEURIPS},
}
