@misc{agudelo-espana_bayesian_2020,
	title = {Bayesian {Online} {Prediction} of {Change} {Points}},
	url = {http://proceedings.mlr.press/v124/agudelo-espana20a.html},
	doi = {10.48550/arxiv.1902.04524},
	abstract = {We consider the problem of online change point detection in time series. Most existing methods for this task are either computationally expensive or rely on strong assumptions about the data generating process. In this paper, we propose a novel Bayesian approach for online change point detection that is both computationally efficient and flexible. Our method is based on a generative model that assumes the data is generated by a sequence of independent and identically distributed segments. We derive an efficient recursive update rule for the posterior distribution of the current segment length, which allows for real-time inference. We demonstrate the effectiveness of our approach on both synthetic and real-world datasets, showing that it outperforms state-of-the-art methods in terms of both accuracy and computational efficiency.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Agudelo-España, D. and Gomez-Gonzalez, S. and Bauer, S. and Schölkopf, B. and Peters, J.},
	editor = {Peters, Jonas and Sontag, David},
	year = {2020},
	keywords = {Change detection, Inference, Computer science, Generative model, Bayesian probability, Residual, Bayesian inference, Data mining, Artificial intelligence, Generative grammar, Point (geometry), Sequence (biology), Process (computing), Algorithm, Machine learning, Pattern recognition (psychology), Mathematics, UAI},
}
