@article{meding_phenomenal_2020,
	title = {Phenomenal {Causality} and {Sensory} {Realism}},
	issn = {2041-6695},
	url = {https://journals.sagepub.com/doi/full/10.1177/2041669520927038},
	doi = {10.1177/2041669520927038},
	abstract = {Phenomenal causality refers to the perception of causal relations between objects, such as when one object appears to launch another. While phenomenal causality is often considered a robust, automatic, and modular process, recent research suggests that it is sensitive to the observer's expectations and the context of the scene. In this article, we investigate whether phenomenal causality is also sensitive to the sensory realism of the stimuli. We presented observers with animations of colliding objects that varied in their physical realism and asked them to judge whether they perceived a causal interaction. We found that phenomenal causality is indeed sensitive to sensory realism: observers were more likely to report a causal interaction when the stimuli were physically realistic. This suggests that phenomenal causality is not a purely modular process but is instead integrated with our knowledge of the physical world.},
	language = {en},
	journal = {i-Perception},
	publisher = {SAGE Publications},
	author = {Meding, Kristof and Bruijns, Sebastian A. and Schölkopf, Bernhard and Berens, Philipp and Wichmann, Felix A.},
	month = jun,
	year = {2020},
	keywords = {Perception, Causality (physics), Stimulus (psychology), Dynamical billiards, Psychology, Attribution, Cognitive psychology, Collision, Introspection, Realism, Computer science, Cognitive science, Physics, Epistemology, Social psychology, Philosophy, Neuroscience, I-PERCEPTION},
}
