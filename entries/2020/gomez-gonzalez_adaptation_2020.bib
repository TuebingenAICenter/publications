@misc{gomez-gonzalez_adaptation_2020,
	title = {Adaptation and {Robust} {Learning} of {Probabilistic} {Movement} {Primitives}},
	shorttitle = {Adaptation and {Robust} {Learning} of {Probabilistic} {Movement} {Primitives}},
	url = {https://doi.org/10.1109/TRO.2019.2937010},
	doi = {10.1109/TRO.2019.2937010},
	abstract = {Probabilistic movement primitives (ProMPs) have become a popular framework for representing, learning, and generalizing motor skills in robotics. They allow for the representation of a distribution over trajectories, which can be used to adapt to new task constraints or to generalize to new situations. However, the original formulation of ProMPs has limitations in terms of robustness to outliers and the ability to adapt to new tasks. In this article, we propose a new framework for ProMPs that addresses these limitations. We introduce a robust learning approach that is based on the use of a robust loss function, which allows the ProMP to learn from demonstrations that contain outliers. Furthermore, we propose a new adaptation framework that allows the ProMP to adapt to new task constraints by solving a constrained optimization problem. We evaluate our approach on a variety of simulated and real-world robotic tasks, showing that it outperforms the original ProMP formulation in terms of robustness and adaptation performance.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {IEEE},
	author = {Gómez-González, Sebastián and Neumann, Gerhard and Schölkopf, Bernhard and Peters, Jan},
	month = mar,
	year = {2020},
	keywords = {Probabilistic logic, Computer science, Task (project management), Artificial intelligence, Robot, Adaptation (eye), Heuristics, Generalization, Movement (music), Machine learning, Robotics, Probability distribution, Mathematics, Engineering, TRO},
}
