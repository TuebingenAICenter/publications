@article{wahl_analytical_2020,
	title = {Analytical probabilistic modeling of dose-volume histograms},
	shorttitle = {Analytical probabilistic modeling of dose-volume histograms},
	url = {https://is.mpg.de/ei/publications/wahhenwieban20},
	doi = {10.1002/mp.14414},
	abstract = {Purpose: Dose-volume histograms (DVHs) are the standard tool for evaluating dose distributions in radiotherapy. However, they are typically computed from a single, deterministic dose distribution, ignoring the inherent uncertainties in the treatment planning process. We propose an analytical framework for probabilistic DVH modeling that accounts for these uncertainties. Methods: We model the dose distribution as a Gaussian process (GP) and derive an analytical expression for the probability distribution of the DVH. This allows us to compute the expected DVH and its variance without the need for computationally expensive Monte Carlo simulations. We validate our approach on clinical treatment plans and demonstrate its efficiency and accuracy. Results: Our method provides a fast and accurate way to quantify the impact of dose uncertainties on DVH metrics. It enables the identification of robust treatment plans and provides a basis for uncertainty-aware plan optimization. Conclusions: The proposed analytical framework for probabilistic DVH modeling is a powerful tool for uncertainty quantification in radiotherapy. It is computationally efficient and provides valuable insights into the robustness of treatment plans.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Medical Physics},
	publisher = {Wiley},
	author = {Wahl, N. and Hennig, P. and Wieser, H.-P. and Bangert, M.},
	year = {2020},
	keywords = {particle therapy, dose-volume histograms, uncertainty quantification, uncertainty propagation, analytical probabilistic modeling, Medical Physics},
}
