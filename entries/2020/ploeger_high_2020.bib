@inproceedings{ploeger_high_2020,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {High {Acceleration} {Reinforcement} {Learning} for {Real}-{World} {Juggling} with {Binary} {Rewards}},
	shorttitle = {High {Acceleration} {Reinforcement} {Learning} for {Real}-{World} {Juggling} with {Binary} {Rewards}},
	url = {https://proceedings.mlr.press/v155/ploeger21a.html},
	abstract = {Reinforcement learning (RL) has shown impressive results in simulation, but transferring these policies to real-world robots remains challenging. A major bottleneck is the sample efficiency of RL algorithms, especially when the reward signal is sparse, such as binary success/failure signals. In this paper, we propose a high acceleration reinforcement learning approach that combines a model-based trajectory optimizer with a model-free policy search. We demonstrate that our approach can learn to juggle a ball with a real-world robot arm using only binary rewards. Our method achieves this by using the trajectory optimizer to generate high-quality demonstrations, which are then used to initialize the policy, and by using the model-free policy search to refine the policy in the real world. We show that our approach is significantly more sample-efficient than state-of-the-art model-free RL algorithms and can learn to juggle in a few hundred trials.},
	language = {en},
	booktitle = {Proceedings of the 4th {Conference} on {Robot} {Learning}},
	publisher = {PMLR},
	author = {Ploeger, K. and Lutter, M. and Peters, J.},
	editor = {Kober, Jens and Ramos, Fabio and Tomlin, Claire J.},
	month = nov,
	year = {2020},
	keywords = {CORL},
}
