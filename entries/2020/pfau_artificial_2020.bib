@article{pfau_artificial_2020,
	title = {Artificial intelligence in ophthalmology: {Guidelines} for physicians for the critical evaluation of studies},
	issn = {0941-293X},
	shorttitle = {Artificial intelligence in ophthalmology},
	url = {https://link.springer.com/article/10.1007/s00347-020-01209-z},
	doi = {10.1007/s00347-020-01209-z},
	abstract = {Artificial intelligence (AI) is increasingly being used in ophthalmology. While many studies report high diagnostic accuracy, the clinical utility of these algorithms is often unclear. This article provides guidelines for physicians to critically evaluate AI studies in ophthalmology. We discuss the key components of AI studies, including data quality, model development, validation, and reporting. We also provide a checklist for clinicians to assess the quality and clinical relevance of AI studies.},
	language = {German},
	urldate = {2025-05-14},
	journal = {Der Ophthalmologe},
	publisher = {Springer Nature},
	author = {Pfau, Maximilian and Walther, G and von der Emde, L and Berens, Philipp and Faes, L and Fleckenstein, M and Holz, F G},
	month = aug,
	year = {2020},
	keywords = {OPHTHALMOLOGE},
}
