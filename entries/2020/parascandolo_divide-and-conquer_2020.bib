@inproceedings{parascandolo_divide-and-conquer_2020,
	title = {Divide-and-{Conquer} {Monte} {Carlo} {Tree} {Search} for goal directed planning},
	shorttitle = {Divide-and-{Conquer} {Monte} {Carlo} {Tree} {Search}},
	url = {https://arxiv.org/pdf/2004.11410.pdf},
	abstract = {Planning in complex environments with sparse rewards is a major challenge in reinforcement learning. Monte Carlo Tree Search (MCTS) is a powerful tool for planning, but its performance degrades in long-horizon tasks. We propose Divide-and-Conquer MCTS (DC-MCTS), a hierarchical planning algorithm that decomposes a long-horizon goal-directed task into a sequence of subgoals. DC-MCTS learns a goal-conditioned policy and a value function to guide the search, and uses a divide-and-conquer strategy to recursively break down the planning problem. We evaluate DC-MCTS on a set of challenging navigation and manipulation tasks, and show that it significantly outperforms standard MCTS and other baselines.},
	language = {en},
	urldate = {2024-05-23},
	author = {Parascandolo, Giambattista and Buesing, Lars and Merel, Josh and Hasenclever, Leonard and Aslanides, John and Hamrick, Jessica B. and Heess, Nicolas and Neitz, Alexander and Weber, Theophane},
	year = {2020},
	keywords = {ICLR},
}
