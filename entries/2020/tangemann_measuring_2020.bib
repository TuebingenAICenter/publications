@incollection{tangemann_measuring_2020,
	series = {Lecture {Notes} in {Computer} {Science}},
	title = {Measuring the {Importance} of {Temporal} {Features} in {Video} {Saliency}},
	isbn = {978-3-030-58604-1},
	shorttitle = {Measuring the {Importance} of {Temporal} {Features} in {Video} {Saliency}},
	url = {https://link.springer.com/chapter/10.1007/978-3-030-58604-1_40},
	doi = {10.1007/978-3-030-58604-1_40},
	abstract = {Video saliency models have improved significantly in recent years, largely due to the use of deep neural networks. However, it remains unclear to what extent these models rely on temporal information versus static features. In this paper, we investigate the importance of temporal features in video saliency by systematically ablating temporal information from a state-of-the-art video saliency model. We find that while temporal features provide a performance boost, static features are surprisingly strong and account for the majority of the model's predictive power. Our results suggest that current video saliency models are still heavily biased towards static image features and that there is significant room for improvement in modeling temporal dynamics.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Computer {Vision} – {ECCV} 2020},
	publisher = {Springer},
	author = {Tangemann, Matthias and Kümmerer, Matthias and Wallis, Thomas S. A. and Bethge, Matthias},
	year = {2020},
	keywords = {Gaze, Computer science, Artificial intelligence, Computer vision, Frame (networking), Motion (physics), Pattern recognition (psychology), Baseline (sea), Construct (python library), Focus (optics), Machine learning, ECCV},
