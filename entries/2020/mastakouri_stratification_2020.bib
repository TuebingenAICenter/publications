@misc{mastakouri_stratification_2020,
	title = {Stratification of behavioral response to transcranial current stimulation by resting-state electrophysiology},
	shorttitle = {Stratification of behavioral response to transcranial current stimulation},
	url = {https://www.biorxiv.org/content/10.1101/2020.01.27.921668v3},
	doi = {10.1101/2020.01.27.921668},
	abstract = {Transcranial current stimulation (tCS) is a promising tool for non-invasive brain modulation, yet its efficacy is highly variable across individuals. Here, we show that resting-state electroencephalography (EEG) can be used to stratify individuals based on their behavioral response to tCS. We recorded resting-state EEG from 30 healthy participants before they performed a visual detection task under tCS. We found that the individual alpha frequency (IAF) and the power of the alpha rhythm were predictive of the behavioral response to tCS. Specifically, participants with higher IAF showed a stronger behavioral response to tCS. Our results suggest that resting-state EEG can be used to identify individuals who are more likely to benefit from tCS, which could improve the efficacy of tCS-based interventions.},
	language = {en},
	urldate = {2024-05-23},
	publisher = {Cold Spring Harbor Laboratory},
	author = {Mastakouri, A. A.},
	year = {2020},
}
