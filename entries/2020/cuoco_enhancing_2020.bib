@article{cuoco_enhancing_2020,
	title = {Enhancing gravitational-wave science with machine learning},
	issn = {2632-2153},
	shorttitle = {Enhancing gravitational-wave science with machine learning},
	url = {https://doi.org/10.1088/2632-2153/abb93a},
	doi = {10.1088/2632-2153/abb93a},
	abstract = {The field of gravitational-wave (GW) astronomy has matured rapidly since the first direct detection of GWs in 2015. As the sensitivity of GW detectors improves and the number of detections grows, the computational cost of data analysis is becoming a bottleneck. Machine learning (ML) offers a powerful set of tools to address these challenges, with the potential to significantly accelerate data analysis, improve the sensitivity of searches, and enable new scientific discoveries. In this review, we provide an overview of the current state of ML applications in GW science, covering topics such as signal detection, parameter estimation, and detector characterization. We also discuss the challenges and future directions for the field, highlighting the potential for ML to play a transformative role in the era of multi-messenger astronomy.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Machine Learning: Science and Technology},
	publisher = {IOP Publishing},
	author = {Cuoco, Elena and Powell, Jade and Cavaglià, Marco and Ackley, Kendall and Bejger, Michał and Chatterjee, Chayan and Coughlin, Michael and Coughlin, Scott and Easter, Patrick and Essick, Reed and Gabbard, Hunter and Gebhard, Timothy and Ghosh, Shaon and Haegel, Léa and Iess, Alessandro and Keitel, David and Márka, Zsuzsa and Márka, Szabolcs and Morawski, Filip and Nguyen, Tuan and Ormiston, Richard and Pürrer, Michael and Razzano, Massimiliano and Staats, Karl and Vajente, Gabriele and Williams, Daniel},
	year = {2020},
	keywords = {MLST},
}
