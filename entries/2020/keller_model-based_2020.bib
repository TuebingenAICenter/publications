@inproceedings{keller_model-based_2020,
	title = {Model-{Based} {Quality}-{Diversity} {Search} for {Efficient} {Robot} {Learning}},
	shorttitle = {Model-{Based} {Quality}-{Diversity} {Search}},
	url = {https://is.mpg.de/ei/publications/keltanstapet20},
	doi = {10.1109/IROS45743.2020.9340794},
	abstract = {Quality-Diversity (QD) algorithms have recently emerged as a powerful tool for finding a diverse set of high-performing solutions. However, their application to real-world robotics is often hindered by the high sample complexity of the underlying evolutionary search. In this paper, we propose a model-based approach to QD search that leverages learned forward models to accelerate the discovery of diverse and high-performing behaviors. By using the model to perform imaginary rollouts, we can evaluate candidate solutions without the need for costly real-world interactions. We demonstrate the effectiveness of our approach on a variety of simulated robotic tasks, showing that it significantly improves sample efficiency compared to model-free QD methods.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {International {Conference} on {Intelligent} {Robots} and {Systems} ({IROS})},
	publisher = {IEEE},
	author = {Keller, L. and Tanneberg, D. and Stark, S. and Peters, J.},
	year = {2020},
	keywords = {IROS},
}
