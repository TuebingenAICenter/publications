@article{yoshimatsu_fovea-like_2020,
	title = {Fovea-like photoreceptor specializations underlie single {UV} cone driven prey-capture behavior in zebrafish},
	issn = {0896-6273},
	shorttitle = {Fovea-like photoreceptor specializations},
	url = {https://www.cell.com/neuron/pdf/S0896-6273(20)30313-5.pdf},
	doi = {10.1016/j.neuron.2020.06.005},
	abstract = {The vertebrate fovea is a specialized retinal region that supports high-acuity vision. While foveae are common in primates and some birds, they are generally considered absent in teleost fish. Here, we show that the zebrafish retina features a specialized area of high cone density in the ventro-temporal retina that shares key structural and functional features with the primate fovea. This area is characterized by a local increase in cone density, a specialized cone mosaic, and a reduction in the number of rods. We show that this area is essential for prey-capture behavior, as it is the primary site for the detection of small, UV-rich prey. Our results suggest that fovea-like specializations are a conserved feature of the vertebrate retina and that they may have evolved independently in different lineages to support high-acuity vision.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Neuron},
	publisher = {Elsevier},
	author = {Yoshimatsu, Takeshi and Schröder, Cornelius and Nevala, Noora E. and Berens, Philipp and Baden, Tom},
	month = jul,
	year = {2020},
	keywords = {Zebrafish, Foveal, Visual phototransduction, Biology, Neuroscience, Retina, Retinal, Gene, Genetics, NEURON},
}
