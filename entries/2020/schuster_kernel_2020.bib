@inproceedings{schuster_kernel_2020,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Kernel {Conditional} {Density} {Operators}},
	url = {http://proceedings.mlr.press/v108/schuster20a.html},
	abstract = {We propose a novel framework for conditional density estimation based on kernel mean embeddings. By representing conditional distributions as operators in reproducing kernel Hilbert spaces, we avoid the need for density estimation in the traditional sense. We show that the proposed kernel conditional density operator (KCDO) can be estimated from finite samples and provide a theoretical analysis of its convergence properties. Furthermore, we demonstrate that the KCDO can be used to perform various conditional inference tasks, such as conditional sampling, conditional expectation, and conditional mode estimation. We illustrate the effectiveness of our approach on several synthetic and real-world datasets.},
	language = {en},
	booktitle = {Proceedings of the 23rd {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Schuster, Ilja and Mollenhauer, Maximilian and Klus, Stefan and Muandet, Krikamol},
	editor = {Chiappa, Silvia and Calandra, Roberto},
	month = jun,
	year = {2020},
	keywords = {AISTATS},
}
