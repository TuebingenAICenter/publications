@inproceedings{gorham_stochastic_2020,
	title = {Stochastic {Stein} {Discrepancies}},
	url = {https://proceedings.neurips.cc/paper/2020/file/d03a857a23b5285736c4d55e0bb067c8-Paper.pdf},
	abstract = {Stein discrepancies are powerful tools for assessing the quality of a probability distribution approximation, with applications ranging from goodness-of-fit testing to variational inference. However, existing Stein discrepancies require the evaluation of the target distribution's score function (the gradient of the log-density) at every sample point, which is computationally prohibitive for large datasets or complex models. We introduce stochastic Stein discrepancies (SSDs), a new class of Stein discrepancies that replace the exact score function with a stochastic approximation. We prove that SSDs are valid discrepancies, provide conditions under which they can be used to consistently estimate the distance between distributions, and demonstrate their utility for scalable goodness-of-fit testing and parameter estimation.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 33 ({NeurIPS} 2020)},
	publisher = {Curran Associates, Inc.},
	author = {Gorham, Jeff and Raj, Anant and Mackey, Lester},
	month = dec,
	year = {2020},
	keywords = {NEURIPS},
}
