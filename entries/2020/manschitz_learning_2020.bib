@article{manschitz_learning_2020,
	title = {Learning {Sequential} {Force} {Interaction} {Skills}},
	copyright = {CC BY 4.0},
	issn = {2218-6581},
	shorttitle = {Learning {Sequential} {Force} {Interaction} {Skills}},
	url = {https://doi.org/10.3390/robotics9020045},
	doi = {10.3390/robotics9020045},
	abstract = {Robotic manipulation tasks often require the execution of sequential force interaction skills, such as picking up an object, placing it, and pushing it. Learning such skills from demonstrations is challenging because the force profiles are highly dependent on the object properties and the environment. In this paper, we propose a framework for learning sequential force interaction skills from human demonstrations. We represent the skills as a sequence of dynamic movement primitives, which are augmented with force profiles. We use a hidden semi-Markov model to segment the demonstrations into individual skills and to learn the transition probabilities between them. We evaluate our approach on a robotic platform, demonstrating that it can learn to perform complex sequential force interaction tasks from a small number of demonstrations.},
	language = {en},
	urldate = {2024-05-23},
	journal = {Robotics},
	publisher = {MDPI},
	author = {Manschitz, Stefan and Gienger, Michael and Kober, Jens and Peters, Jan},
	year = {2020},
	keywords = {ROBOTICS},
}
