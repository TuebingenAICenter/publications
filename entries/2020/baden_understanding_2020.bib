@article{baden_understanding_2020,
	title = {Understanding the retinal basis of vision across species},
	issn = {1471-0048},
	shorttitle = {Understanding the retinal basis of vision},
	url = {https://www.nature.com/articles/s41583-019-0242-1},
	doi = {10.1038/s41583-019-0242-1},
	abstract = {The retina is the first stage of visual processing in vertebrates. Over the past decade, our understanding of retinal function has been transformed by the application of large-scale functional imaging and molecular profiling, which have revealed a much higher degree of cell-type diversity and functional complexity than previously appreciated. In this Review, we discuss how these new insights are reshaping our view of the retina as a sophisticated signal-processing device. We highlight how the retina's functional architecture is conserved across species, yet also adapted to the specific ecological niches of different animals, and we discuss how these findings provide a blueprint for understanding the principles of neural circuit computation.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Nature Reviews Neuroscience},
	publisher = {Nature Portfolio},
	author = {Baden, Tom and Euler, Thomas and Berens, Philipp},
	month = jan,
	year = {2020},
	keywords = {Retinal, Vertebrate, Retina, Biology, Neuroscience, Function (biology), Evolutionary biology, Cognitive science, Psychology, Gene, Genetics},
}
