@article{ewerton_assisted_2020,
	title = {Assisted teleoperation in changing environments with a mixture of virtual guides},
	issn = {0169-1864},
	shorttitle = {Assisted teleoperation in changing environments},
	url = {https://is.mpg.de/ei/publications/ewearepet},
	doi = {10.1080/01691864.2020.1785326},
	abstract = {Teleoperation is a key technology for enabling robots to perform tasks in remote or hazardous environments. However, the high dimensionality of robot control and the lack of force feedback often make teleoperation challenging for human operators. Virtual guides have been proposed to assist the operator by constraining the robot's motion to task-relevant manifolds. Existing approaches often rely on a single, static model of the task, which limits their applicability in changing environments. In this paper, we propose a novel approach to assisted teleoperation that uses a mixture of virtual guides to adapt to changing task requirements. Our approach learns a set of virtual guides from demonstrations and uses a gating mechanism to combine them based on the current state of the environment. We evaluate our approach in a simulated teleoperation task and show that it significantly improves performance compared to existing methods.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Advanced Robotics},
	publisher = {Taylor \& Francis},
	author = {Ewerton, M. and Arenz, O. and Peters, J.},
	year = {2020},
	keywords = {ROBOTICS},
}
