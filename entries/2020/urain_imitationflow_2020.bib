@inproceedings{urain_imitationflow_2020,
	title = {{ImitationFlow}: {Learning} {Deep} {Stable} {Stochastic} {Dynamic} {Systems} by {Normalizing} {Flows}},
	shorttitle = {{ImitationFlow}},
	url = {https://is.mpg.de/ei/publications/uragintatpet20},
	doi = {10.1109/IROS45743.2020.9341035},
	abstract = {Learning stable dynamic systems from demonstrations is a fundamental problem in robot learning. While many approaches focus on deterministic systems, stochasticity is often required to represent the variability in human demonstrations. In this paper, we propose ImitationFlow, a novel framework for learning stable stochastic dynamic systems. We leverage normalizing flows to learn a transformation from a simple base distribution to a complex, multi-modal distribution of velocities. By enforcing a contraction constraint on the flow, we guarantee the stability of the learned system. We evaluate our approach on several synthetic and real-world robot manipulation tasks, demonstrating that ImitationFlow outperforms existing methods in terms of both accuracy and stability.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {International {Conference} on {Intelligent} {Robots} and {Systems} ({IROS})},
	publisher = {IEEE},
	author = {Urain, Julen and Ginesi, Matteo and Tateo, Domenico and Peters, Jan},
	year = {2020},
	keywords = {IROS},
}
