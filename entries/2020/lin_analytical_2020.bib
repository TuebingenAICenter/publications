@article{lin_analytical_2020,
	title = {Analytical classical density functionals from an equation learning network},
	issn = {0021-9606},
	url = {https://doi.org/10.1063/1.5135919},
	doi = {10.1063/1.5135919},
	abstract = {We propose a machine learning approach to construct analytical classical density functionals for inhomogeneous fluids. We use an equation learning network (ELN) to learn the functional from simulation data of the density profiles of a fluid in external potentials. The ELN is a neural network architecture that is constrained to represent the functional as a sum of basis functions, which allows for the extraction of an analytical expression. We demonstrate the method for a one-dimensional hard-rod fluid and a three-dimensional hard-sphere fluid. The learned functionals are accurate and can be used to predict the density profiles of the fluids in new external potentials.},
	language = {en},
	urldate = {2025-05-14},
	journal = {The Journal of Chemical Physics},
	publisher = {AIP Publishing},
	author = {Lin, Shang-Chun and Martius, Georg and Oettel, Martin},
	year = {2020},
	keywords = {JCP},
}
