@misc{hohmann_mynd_2020,
	title = {{MYND}: {Unsupervised} {Evaluation} of {Novel} {BCI} {Control} {Strategies} on {Consumer} {Hardware}},
	shorttitle = {{MYND}},
	url = {https://doi.org/10.1145/3379337.3415844},
	doi = {10.1145/3379337.3415844},
	abstract = {Brain-computer interfaces (BCIs) have the potential to revolutionize human-computer interaction. However, their widespread adoption is hindered by the need for extensive calibration and the reliance on expensive, specialized hardware. In this paper, we present MYND, a framework for the unsupervised evaluation of novel BCI control strategies on consumer-grade hardware. We demonstrate that our approach allows for the rapid development and testing of BCI applications without the need for time-consuming calibration sessions. Our results show that MYND achieves performance comparable to state-of-the-art supervised methods while significantly reducing the burden on the user.},
	language = {en},
	publisher = {Association for Computing Machinery},
	author = {Hohmann, Matthias R. and Konieczny, Lisa and Hackl, Michelle and Wirth, Brian and Zaman, Talha and Enficiaud, Raffi and Grosse-Wentrup, Moritz and Schölkopf, Bernhard},
	month = oct,
	year = {2020},
	keywords = {Computer science, Upload, Headset, Brain–computer interface, Generalizability theory, Scalability, Electroencephalography, Computer hardware, Channel (broadcasting), Control (management), Artificial intelligence, Psychology, Database, Neuroscience, Computer network, UIST},
}
