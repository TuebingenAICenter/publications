@misc{lu_sample-efficient_2020,
	title = {Sample-{Efficient} {Reinforcement} {Learning} via {Counterfactual}-{Based} {Data} {Augmentation}},
	shorttitle = {Sample-{Efficient} {Reinforcement} {Learning}},
	url = {https://offline-rl-neurips.github.io/pdf/34.pdf},
	doi = {10.48550/arxiv.2012.09092},
	abstract = {Reinforcement learning (RL) is often sample-inefficient, especially in environments with sparse rewards. In this paper, we propose a counterfactual-based data augmentation method to improve the sample efficiency of RL. Specifically, we learn a causal model of the environment and use it to generate counterfactual experiences, which are then used to augment the training data. We show that our method can significantly improve the sample efficiency of RL in various environments, including those with sparse rewards.},
	language = {en},
	urldate = {2025-05-14},
	author = {Lu, Chaochao and Huang, Biwei and Wang, Ke and Hernández-Lobato, José Miguel and Zhang, Kun and Schölkopf, Bernhard},
	year = {2020},
	keywords = {Counterfactual thinking, Reinforcement learning, Computer science, Sample (material), Exploit, Scarcity, Machine learning, Artificial intelligence, Set (abstract data type), Function (biology), Population, Data set, Psychology, NEURIPS},
}
