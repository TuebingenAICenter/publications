@misc{gresele_relative_2020,
	title = {Relative gradient optimization of the {Jacobian} term in unsupervised deep learning},
	url = {https://proceedings.neurips.cc/paper/2020/file/c10f48884c9c7fdbd9a7959c59eebea8-Paper.pdf},
	doi = {10.48550/arxiv.2006.15090},
	abstract = {Many unsupervised learning methods, such as normalizing flows and independent component analysis, require the computation of the Jacobian determinant of a transformation. This is computationally expensive, typically scaling as O(dˆ3) where d is the dimension of the data. In this paper, we propose a method to optimize the Jacobian term using relative gradients. This approach allows us to compute the gradient of the log-determinant of the Jacobian in O(dˆ2) time, which is a significant improvement over the standard O(dˆ3) approach. We demonstrate the effectiveness of our method on several unsupervised learning tasks, including density estimation and independent component analysis.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Gresele, Luigi and Fissore, Giancarlo and Javaloy, Adrián and Schölkopf, Bernhard and Hyvärinen, Aapo},
	editor = {Larochelle, H. and Ranzato, M. and Hadsell, R. and Balcan, M. F. and Lin, H.},
	month = dec,
	year = {2020},
	keywords = {Jacobian matrix and determinant, Computer science, Probabilistic logic, Representation (politics), Artificial neural network, Computation, Artificial intelligence, Contrast (vision), Deep learning, Quadratic equation, Term (time), Field (mathematics), Algorithm, Machine learning, Theoretical computer science, Mathematical optimization, Mathematics, Applied mathematics, NEURIPS},
}
