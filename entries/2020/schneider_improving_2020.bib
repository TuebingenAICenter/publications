@misc{schneider_improving_2020,
	title = {Improving robustness against common corruptions by covariate shift adaptation},
	shorttitle = {Improving robustness against common corruptions},
	url = {https://proceedings.neurips.cc/paper/2020/hash/85690f81aadc1749175c187784afc9ee-Abstract.html},
	doi = {10.48550/arxiv.2006.16971},
	abstract = {Deep neural networks are known to be vulnerable to distribution shifts, such as common corruptions (e.g., noise, blur, weather effects). While many methods have been proposed to improve robustness, they often require retraining the model or access to the original training data. In this paper, we propose a simple yet effective method to improve the robustness of pre-trained models against common corruptions without any retraining. Our method, which we call Test-Time Batch Statistics (TTBS), adapts the batch normalization statistics of a pre-trained model to the test data distribution. We show that TTBS significantly improves the robustness of various architectures on the ImageNet-C benchmark, often outperforming more complex methods. Furthermore, we demonstrate that our method is complementary to other robustness techniques and can be easily integrated into existing pipelines.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Schneider, Steffen and Rusak, Evgenia and Eck, Luisa and Bringmann, Oliver and Brendel, Wieland and Bethge, Matthias},
	year = {2020},
	keywords = {Robustness (evolution), Computer science, Covariate, Artificial intelligence, Normalization (sociology), Machine learning, Pattern recognition (psychology), NEURIPS},
}
