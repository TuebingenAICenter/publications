@article{lockel_probabilistic_2020,
	title = {A {Probabilistic} {Framework} for {Imitating} {Human} {Race} {Driver} {Behavior}},
	shorttitle = {A {Probabilistic} {Framework} for {Imitating} {Human} {Race} {Driver} {Behavior}},
	url = {https://is.mpg.de/ei/publications/locpetvli20},
	doi = {10.1109/LRA.2020.2970620},
	abstract = {Imitating human driving behavior is a challenging task due to the high-dimensional state space, the non-linear dynamics of the vehicle, and the multi-modal nature of human decision-making. In this paper, we propose a probabilistic framework for imitating human race driver behavior. Our approach is based on a mixture of experts model that learns to predict the driver's steering and acceleration commands from the vehicle's state. We evaluate our method on a real-world race track dataset and show that it outperforms state-of-the-art imitation learning methods in terms of lap time and driving performance.},
	language = {en},
	urldate = {2024-05-23},
	journal = {IEEE Robotics and Automation Letters},
	publisher = {IEEE},
	author = {Löckel, S. and Peters, J. and van Vliet, P.},
	year = {2020},
	keywords = {RAL},
}
