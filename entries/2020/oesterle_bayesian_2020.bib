@misc{oesterle_bayesian_2020,
	title = {Bayesian inference for biophysical neuron models enables stimulus optimization for retinal neuroprosthetics},
	copyright = {CC BY 4.0},
	shorttitle = {Bayesian inference for biophysical neuron models},
	url = {https://elifesciences.org/articles/54997},
	doi = {10.7554/eLife.54997},
	abstract = {Retinal neuroprosthetics aim to restore vision by electrically stimulating retinal ganglion cells (RGCs). However, the efficacy of current devices is limited by the lack of precise control over the activity of individual cells. Here, we present a framework for optimizing electrical stimulation patterns based on biophysical neuron models. We use Bayesian inference to fit multi-compartment models of RGCs to extracellular recordings. This approach allows us to account for the uncertainty in model parameters and to predict the response of RGCs to arbitrary stimulation patterns. We demonstrate that our framework can be used to optimize stimulation patterns to achieve specific target activity patterns in RGCs, both in simulations and in ex vivo recordings. Our results suggest that Bayesian inference for biophysical models is a powerful tool for the development of next-generation retinal neuroprosthetics.},
	language = {en},
	type = {{journalArticle}},
	urldate = {2025-05-14},
	publisher = {eLife Sciences Publications, Ltd},
	author = {Oesterle, Jonathan and Behrens, Christian and Schröder, Cornelius and Herrmann, Thoralf and Euler, Thomas and Franke, Katrin and Smith, Robert G. and Zeck, Günther and Berens, Philipp},
	month = oct,
	year = {2020},
	keywords = {Neuroprosthetics, Inference, Computer science, Stimulus (psychology), Bayesian probability, Bayesian inference, Neuroscience, Retinal, Neuron, Artificial intelligence, Psychology, Biology, Cognitive psychology},
}
