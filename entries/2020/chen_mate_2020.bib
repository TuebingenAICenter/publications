@inproceedings{chen_mate_2020,
	title = {{MATE}: {Plugging} in {Model} {Awareness} to {Task} {Embedding} for {Meta} {Learning}},
	shorttitle = {{MATE}},
	url = {https://proceedings.neurips.cc/paper/2020/file/8989e07fc124e7a9bcbdebcc8ace2bc0-Paper.pdf},
	abstract = {Meta-learning aims to learn a prior that can be quickly adapted to new tasks. A common approach is to learn a task embedding that captures the task-specific information. However, existing methods often ignore the model's own capacity and inductive bias when learning the task embedding. In this paper, we propose MATE, a Model-Aware Task Embedding framework for meta-learning. MATE explicitly incorporates the model's parameters into the task embedding process, allowing the task embedding to be aware of the model's current state. We show that MATE can be integrated into various meta-learning algorithms and consistently improves their performance on several benchmarks.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 33},
	publisher = {Curran Associates, Inc.},
	author = {Chen, X. and Wang, Z. and Tang, S. and Muandet, K.},
	month = dec,
	year = {2020},
	keywords = {NEURIPS},
}
