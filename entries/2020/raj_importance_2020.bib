@inproceedings{raj_importance_2020,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Importance {Sampling} via {Local} {Sensitivity}},
	shorttitle = {Importance {Sampling} via {Local} {Sensitivity}},
	url = {http://proceedings.mlr.press/v108/raj20a.html},
	abstract = {Importance sampling is a fundamental technique for variance reduction in Monte Carlo estimation. A key challenge is designing a proposal distribution that is close to the target distribution while being easy to sample from. We propose a new approach to importance sampling based on local sensitivity, a measure of how much the importance weight of a sample changes in a local neighborhood. We show that local sensitivity can be used to construct proposal distributions that are provably close to the optimal proposal distribution. We provide theoretical guarantees on the variance of our estimator and demonstrate its effectiveness on a variety of tasks, including estimating the partition function of graphical models and training deep generative models.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {Proceedings of the 23rd {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Raj, Anant and Musco, Cameron and Mackey, Lester},
	editor = {Chiappa, Silvia and Calandra, Roberto},
	month = aug,
	year = {2020},
	keywords = {AISTATS},
}
