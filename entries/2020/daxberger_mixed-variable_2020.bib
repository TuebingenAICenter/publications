@inproceedings{daxberger_mixed-variable_2020,
	title = {Mixed-{Variable} {Bayesian} {Optimization}},
	url = {https://doi.org/10.24963/ijcai.2020/365},
	doi = {10.24963/ijcai.2020/365},
	abstract = {Bayesian Optimization (BO) is a powerful framework for global optimization of expensive-to-evaluate black-box functions. While standard BO assumes continuous input spaces, many real-world problems involve mixed-variable spaces, containing continuous, discrete, and categorical variables. Existing approaches for mixed-variable BO often rely on simple heuristics or are limited to specific variable types. In this paper, we propose a novel approach for mixed-variable BO that leverages a latent space representation. We map the mixed-variable space into a continuous latent space using a variational autoencoder (VAE) and perform BO in this latent space. We demonstrate that our approach outperforms existing methods on a variety of synthetic and real-world benchmarks.},
	language = {en},
	publisher = {International Joint Conferences on Artificial Intelligence Organization},
	author = {Daxberger, E. and Makarova, A. and Turchetta, M. and Krause, A.},
	editor = {Bessiere, Christian},
	month = jul,
	year = {2020},
	keywords = {IJCAI},
}
