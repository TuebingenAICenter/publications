@inproceedings{joulani_simpler_2020,
	title = {A simpler approach to accelerated optimization: iterative averaging meets optimism},
	shorttitle = {A simpler approach to accelerated optimization},
	url = {http://proceedings.mlr.press/v119/joulani20a.html},
	doi = {http://proceedings.mlr.press/v119/joulani20a.html},
	abstract = {We propose a new approach to accelerated optimization that combines iterative averaging with optimism. Our method is simpler than existing accelerated methods, yet it achieves the same optimal convergence rates for smooth convex optimization. We show that our approach can be interpreted as a form of mirror descent with a specific choice of the mirror map, and we provide a unified analysis that covers both deterministic and stochastic settings. We also demonstrate the effectiveness of our method on several standard optimization problems.},
	language = {en},
	booktitle = {Proceedings of the 37th {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Joulani, Pooria and Raj, Anant and Gyoergy, Andras and Szepesvari, Csaba},
	month = jul,
	year = {2020},
	keywords = {ICML},
}
