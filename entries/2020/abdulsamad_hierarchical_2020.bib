@inproceedings{abdulsamad_hierarchical_2020,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Hierarchical {Decomposition} of {Nonlinear} {Dynamics} and {Control} for {System} {Identification} and {Policy} {Distillation}},
	url = {http://proceedings.mlr.press/v120/abdulsamad20a.html},
	abstract = {In this paper, we propose a hierarchical decomposition of nonlinear dynamics and control. We decompose the system dynamics into a linear time-invariant (LTI) base model and a nonlinear residual model. This decomposition allows us to use well-established linear control techniques for the base model and to learn the residual dynamics using Gaussian processes. We show that this approach leads to a more sample-efficient system identification and allows for a hierarchical policy distillation, where a complex policy is distilled into a simpler, more interpretable one. We demonstrate the effectiveness of our approach on several simulated and real-world robotic systems.},
	language = {en},
	booktitle = {Proceedings of the 2nd {Conference} on {Learning} for {Dynamics} and {Control}},
	publisher = {PMLR},
	author = {Abdulsamad, H. and Peters, J.},
	editor = {Bayen, Alexandre M. and Jadbabaie, Ali and Pappas, George and Parrilo, Pablo A. and Recht, Benjamin and Tomlin, Claire and Zeilinger, Melanie},
	month = jun,
	year = {2020},
	keywords = {L4DC},
}
