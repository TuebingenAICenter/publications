@article{borowski_natural_2020,
	title = {Natural images are more informative for interpreting cnn activations than state-of-the-art synthetic feature visualizations},
	shorttitle = {Natural images are more informative},
	url = {https://openreview.net/forum?id=-vhO2VPjbVa},
	abstract = {Feature visualization is a popular technique to interpret the internal representations of convolutional neural networks (CNNs). It typically involves generating synthetic images that maximize the activation of specific neurons. However, it remains unclear whether these synthetic visualizations are representative of the features that neurons actually respond to in natural images. In this work, we systematically compare synthetic feature visualizations with natural images that maximize neuron activations. We find that natural images are more informative for interpreting CNN activations than state-of-the-art synthetic feature visualizations. Our results suggest that synthetic visualizations may be biased towards features that are not representative of the natural image statistics that CNNs are trained on.},
	language = {en},
	urldate = {2025-05-14},
	journal = {NeurIPS 2020 Workshop SVRHM},
	author = {Borowski, Judy and Zimmermann, Roland Simon and Schepers, Judith and Geirhos, Robert and Wallis, Thomas S. A. and Bethge, Matthias and Brendel, Wieland},
	year = {2020},
	keywords = {Feature (linguistics), Artificial intelligence, Computer science, Natural (archaeology), Pattern recognition (psychology), Natural language processing, Computer vision, Geography, Linguistics, NEURIPS},
}
