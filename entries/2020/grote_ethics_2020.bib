@article{grote_ethics_2020,
	title = {On the ethics of algorithmic decision-making in healthcare},
	issn = {0306-6800},
	url = {https://jme.bmj.com/content/46/3/205.abstract},
	doi = {10.1136/medethics-2019-105586},
	abstract = {Algorithmic decision-making (ADM) is increasingly used in healthcare. While its potential to improve clinical outcomes is widely acknowledged, it also raises significant ethical concerns. In this paper, we provide a systematic overview of the ethical challenges associated with ADM in healthcare. We argue that these challenges can be structured along three dimensions: (1) the epistemic dimension, which concerns the quality and reliability of the data and the algorithms; (2) the normative dimension, which concerns the values and principles that should guide the development and deployment of ADM; and (3) the social dimension, which concerns the impact of ADM on the doctor-patient relationship and the broader healthcare system. We conclude by outlining a research agenda for the ethical development and implementation of ADM in healthcare.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Medical Ethics},
	publisher = {BMJ Publishing Group Ltd},
	author = {Grote, Thomas and Berens, Philipp},
	month = feb,
	year = {2020},
	keywords = {Paternalism, Normative, Health care, Artificial intelligence, Computer science, Machine learning, Psychology, Political science, Law},
}
