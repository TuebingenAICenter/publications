@misc{hofling_probing_2020,
	title = {Probing and predicting ganglion cell responses to smooth electrical stimulation in healthy and blind mouse retina},
	copyright = {© The Author(s) 2020},
	shorttitle = {Probing and predicting ganglion cell responses},
	url = {https://www.nature.com/articles/s41598-020-61899-y},
	doi = {10.1038/s41598-020-61899-y},
	abstract = {Retinal implants aim to restore vision in blind patients by electrically stimulating retinal ganglion cells (RGCs). However, the elicited visual percepts are often distorted, likely due to the complex transformation of electrical stimuli into RGC activity. Here, we probed RGC responses to smooth electrical stimulation in healthy and blind mouse retina using high-density multielectrode arrays. We found that RGCs in the blind retina show increased spontaneous activity and altered response properties to electrical stimulation compared to the healthy retina. We developed a generalized linear model (GLM) that accurately predicts RGC responses to arbitrary electrical stimuli in both healthy and blind retina. Our model reveals that the transformation of electrical stimuli into RGC activity is non-linear and depends on the stimulus history. These findings provide a framework for optimizing stimulation strategies for retinal prostheses.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Nature Research},
	author = {Höfling, Larissa and Oesterle, Johannes and Berens, Philipp and Zeck, Günther},
	month = mar,
	year = {2020},
	keywords = {Retinal implant, Neuroscience, Retina, Retinitis pigmentosa, Retinal, Stimulus (psychology), Stimulation, Multielectrode array, Phosphene, Retinal ganglion cell, Visual prosthesis, Photic Stimulation, Visual space, Biology, Microelectrode, Visual perception, Medicine, Ophthalmology, Psychology, Chemistry, Perception},
}
