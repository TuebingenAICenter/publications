@article{bitterwolf_certifiably_2020,
	title = {Certifiably {Adversarially} {Robust} {Detection} of {Out}-of-{Distribution} {Data}},
	shorttitle = {Certifiably {Adversarially} {Robust} {Detection}},
	url = {https://arxiv.org/abs/2007.08473},
	doi = {10.48550/arxiv.2007.08473},
	abstract = {Out-of-distribution (OOD) detection is a crucial task for the safe deployment of machine learning models. However, standard OOD detectors are vulnerable to adversarial attacks: an adversary can generate small perturbations that make OOD data appear as in-distribution (ID) data. In this paper, we propose a method for certifiably adversarially robust OOD detection. We derive a certified lower bound on the OOD score for a given input, which allows us to guarantee that an input is detected as OOD even under adversarial perturbations. We show that our method provides meaningful robustness guarantees on standard benchmarks and outperforms existing approaches in terms of certified OOD detection performance.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Advances in Neural Information Processing Systems},
	publisher = {Curran Associates, Inc.},
	author = {Bitterwolf, Julian and Meinke, Alexander and Hein, Matthias},
	year = {2020},
	keywords = {Robustness (evolution), Upper and lower bounds, Computer science, Low Confidence, Classifier (UML), Training set, Confidence interval, Certification, Artificial intelligence, Machine learning, Algorithm, Mathematics, Statistics, Overconfidence effect, Artificial neural network, Data mining, NEURIPS},
}
