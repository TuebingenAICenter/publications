@misc{zhao_temporal_2020,
	title = {The temporal structure of the inner retina at a single glance},
	copyright = {© The Author(s) 2020},
	url = {https://doi.org/10.1038/s41598-020-60214-z},
	doi = {10.1038/s41598-020-60214-z},
	abstract = {The inner retina is a complex neural circuit that processes visual information in parallel channels. While the functional diversity of retinal ganglion cells is well-studied, the temporal organization of the inner plexiform layer (IPL), where ganglion cells receive their synaptic input, remains poorly understood. Here, we used two-photon calcium imaging to record the activity of thousands of synaptic terminals in the mouse IPL. We show that the temporal structure of the IPL is highly organized: synaptic terminals are clustered into functional groups that tile the IPL in a stereotypical manner. This organization is preserved across animals and is robust to changes in stimulus statistics. Our results suggest that the IPL is organized into a set of temporal channels that are matched to the statistics of natural scenes, providing a framework for understanding how the retina processes visual information.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Nature Research},
	author = {Zhao, Zhijian and Klindt, David A. and Maia Chagas, Andrè and Szatko, Klaudia P. and Rogerson, Luke and Protti, Dario A. and Behrens, Christian and Dalkara, Deniz and Schubert, Timm and Bethge, Matthias and Franke, Katrin and Berens, Philipp and Ecker, Alexander S. and Euler, Thomas},
	year = {2020},
	keywords = {Inner plexiform layer, Retina, Neuropil, Neuroscience, Computer science, Excitatory postsynaptic potential, Physics, Optics, Biology, Inhibitory postsynaptic potential},
}
