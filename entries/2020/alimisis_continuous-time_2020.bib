@inproceedings{alimisis_continuous-time_2020,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {A {Continuous}-time {Perspective} for {Modeling} {Acceleration} in {Riemannian} {Optimization}},
	shorttitle = {A {Continuous}-time {Perspective} for {Modeling} {Acceleration} in {Riemannian} {Optimization}},
	url = {http://proceedings.mlr.press/v108/alimisis20a.html},
	abstract = {We study the acceleration of first-order optimization methods on Riemannian manifolds from a continuous-time perspective. We derive a class of second-order ordinary differential equations (ODEs) that model accelerated gradient descent on manifolds, generalizing the Euclidean Nesterov acceleration. We show that these ODEs can be discretized to obtain practical algorithms, and we provide convergence guarantees for the resulting methods. Our approach provides a unified framework for understanding and designing accelerated Riemannian optimization algorithms.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Proceedings of the 23rd {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Alimisis, F. and Orvieto, A. and Becigneul, G. and Lucchi, A.},
	editor = {Chiappa, Silvia and Calandra, Roberto},
	month = aug,
	year = {2020},
	keywords = {AISTATS},
}
