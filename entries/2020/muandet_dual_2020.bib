@inproceedings{muandet_dual_2020,
	title = {Dual {Instrumental} {Variable} {Regression}},
	shorttitle = {{DualIV}},
	url = {https://proceedings.neurips.cc/paper/2020/file/1c383cd30b7c298ab50293adfecb7b18-Paper.pdf},
	abstract = {Instrumental variable (IV) regression is a standard approach for estimating causal effects in the presence of unobserved confounders. Most existing methods rely on two-stage least squares or its kernelized extensions, which often suffer from high computational complexity and sensitivity to the choice of instruments. In this paper, we propose a novel framework for IV regression, called Dual Instrumental Variable (DualIV) regression, which reformulates the IV problem as a dual optimization problem. By leveraging the Fenchel-Rockafellar duality, we derive a computationally efficient estimator that avoids the need for explicit two-stage estimation. We provide theoretical guarantees for the proposed estimator and demonstrate its superior performance on both synthetic and real-world datasets compared to existing state-of-the-art methods.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 33},
	publisher = {Curran Associates, Inc.},
	author = {Muandet, Krikamol and Mehrjou, Arash and Lee, Si-Kwan and Raj, Anant},
	editor = {Larochelle, H. and Ranzato, M. and Hadsell, R. and Balcan, M. F. and Lin, H.},
	month = dec,
	year = {2020},
	keywords = {NEURIPS},
}
