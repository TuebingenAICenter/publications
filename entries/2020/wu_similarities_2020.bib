@misc{wu_similarities_2020,
	title = {Similarities and differences in spatial and non-spatial cognitive maps},
	copyright = {CC BY 4.0},
	shorttitle = {Similarities and differences in spatial and non-spatial cognitive maps},
	url = {https://doi.org/10.1371/journal.pcbi.1008149},
	doi = {10.1371/journal.pcbi.1008149},
	abstract = {The cognitive map theory suggests that the brain represents information in a structured, map-like format. While this theory was originally developed to explain spatial navigation, it has recently been extended to non-spatial domains. However, it remains unclear whether the same mechanisms support spatial and non-spatial cognitive maps. Here, we compare human performance in a spatial navigation task and a non-spatial function learning task, both of which require learning a latent structure. We find that participants use similar strategies to explore and generalize in both domains, and that their performance is well-described by a Gaussian process model. However, we also find differences in the way participants represent the two types of information, with spatial maps being more rigid and non-spatial maps being more flexible. These results suggest that while there are common principles underlying cognitive maps, the specific implementation depends on the domain.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Public Library of Science},
	author = {Wu, Charley M. and Schulz, Eric and Garvert, Mona M. and Meder, Björn and Schuck, Nicolas W.},
	year = {2020},
	keywords = {Leverage (statistics), Generalization, Artificial intelligence, Task (project management), Computer science, Concept learning, Spatial cognition, Machine learning, Bayesian probability, Gaussian process, Kriging, Function (biology), Spatial intelligence, Cognition, Gaussian, Psychology, Mathematics},
}
