@inproceedings{park_measure-theoretic_2020,
	title = {A {Measure}-{Theoretic} {Approach} to {Kernel} {Conditional} {Mean} {Embeddings}},
	url = {https://proceedings.neurips.cc/paper/2020/file/f340f1b1f65b6df5b5e3f94d95b11daf-Paper.pdf},
	abstract = {Kernel conditional mean embeddings (KCME) have become a powerful tool for representing conditional distributions in reproducing kernel Hilbert spaces (RKHS). Despite their popularity, the theoretical foundation of KCME remains largely restricted to the setting where the conditional distribution is defined via the disintegration theorem, which requires the existence of a regular conditional probability. In this paper, we provide a measure-theoretic foundation for KCME that does not rely on the existence of a regular conditional probability. We show that the conditional mean embedding can be defined as a unique element in an RKHS that satisfies a specific integral equation. This approach allows us to define KCME for a much broader class of conditional distributions, including those that do not admit a regular conditional probability. We also provide a consistent estimator for the proposed KCME and analyze its convergence rate.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 33},
	publisher = {Curran Associates, Inc.},
	author = {Park, J. and Muandet, K.},
	month = dec,
	year = {2020},
	keywords = {NEURIPS},
}
