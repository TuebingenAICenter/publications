@misc{ayhan_expert-validated_2020,
	title = {Expert-validated estimation of diagnostic uncertainty for deep neural networks in diabetic retinopathy detection},
	url = {https://www.sciencedirect.com/science/article/abs/pii/S1361841520300888},
	doi = {10.1016/j.media.2020.101724},
	abstract = {Deep learning models have achieved expert-level performance in the automated detection of diabetic retinopathy (DR) from fundus images. However, their clinical adoption is hindered by a lack of reliable uncertainty estimates, which are crucial for safety-critical applications. In this work, we propose a framework for estimating diagnostic uncertainty in deep neural networks for DR detection. We evaluate several uncertainty estimation methods, including Monte Carlo dropout and deep ensembles, and validate them against expert-provided uncertainty labels. Our results demonstrate that these methods can effectively identify images where the model is likely to be incorrect, providing a mechanism for human-in-the-loop decision making. We show that uncertainty-aware models can significantly improve the safety and reliability of automated DR screening systems.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Elsevier},
	author = {Ayhan, Murat Seckin and Kuhlewein, Laura and Aliyeva, Gulnar and Inhoffen, W. and Ziemssen, Focke and Berens, Philipp},
	month = aug,
	year = {2020},
	keywords = {Computer science, Probabilistic logic, Artificial intelligence, Diabetic retinopathy, Artificial neural network, Machine learning, Deep neural networks, Variety (cybernetics), Deep learning, Medicine, Diabetes mellitus},
}
