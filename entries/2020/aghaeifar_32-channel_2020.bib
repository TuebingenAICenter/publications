@article{aghaeifar_32-channel_2020,
	title = {A 32-channel multi-coil setup optimized for human brain shimming at 9.4T},
	issn = {0740-3194},
	shorttitle = {A 32-channel multi-coil setup},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/mrm.27929},
	doi = {10.1002/mrm.27929},
	abstract = {Purpose: To design and construct a 32-channel multi-coil setup for dynamic B0 shimming of the human brain at 9.4T. Methods: The multi-coil array consists of 32 circular coils arranged on a cylindrical former. The coil geometry was optimized using a genetic algorithm to maximize the shimming performance over the human brain volume. The coils were driven by a custom-built multi-channel current source. The performance of the multi-coil setup was evaluated in phantom and in vivo experiments at 9.4T. Results: The multi-coil setup provides a significant improvement in B0 homogeneity compared to the standard spherical harmonic shimming. The in vivo results demonstrate that the multi-coil setup can effectively compensate for B0 field inhomogeneities induced by the human brain. Conclusion: The 32-channel multi-coil setup is a promising tool for high-field MRI, enabling improved B0 shimming and potentially enhancing the quality of high-field MRI applications.},
	language = {en},
	journal = {Magnetic Resonance in Medicine},
	publisher = {Wiley},
	author = {Aghaeifar, Ali and Zhou, Jiazheng and Heule, Rahel and Tabibian, Behzad and Schölkopf, Bernhard and Jia, Feng and Zaitsev, Maxim and Scheffler, Klaus},
	year = {2020},
	keywords = {Electromagnetic coil, Human brain, Computer science, Channel (broadcasting), Nuclear magnetic resonance, Radiofrequency coil, Physics, Neuroscience, Electrical engineering, Telecommunications, Engineering, Psychology, MRM},
}
