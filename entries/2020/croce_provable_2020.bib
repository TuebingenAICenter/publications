@misc{croce_provable_2020,
	title = {Provable robustness against all adversarial lp-perturbations for p=1},
	shorttitle = {Provable robustness against all adversarial lp-perturbations},
	url = {https://openreview.net/forum?id=rklk_ySYPB},
	doi = {10.48550/arxiv.1905.11213},
	abstract = {We consider the problem of certifying the robustness of a neural network against adversarial perturbations. While most existing work focuses on a specific lp-norm, we propose a method to certify robustness against all lp-norms for p = 1 simultaneously. Our approach is based on the observation that for a fixed lp-norm, the minimal perturbation is related to the dual norm. We derive a convex relaxation of the robust classification problem that provides a lower bound on the minimal perturbation for any lp-norm with p = 1. We show that our method is computationally efficient and provides tight bounds on several benchmark datasets.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {OpenReview},
	author = {Croce, Francesco and Hein, Matthias},
	year = {2020},
	keywords = {Robustness (evolution), Adversarial system, Computer science, Perturbation (astronomy), Dilemma, Norm (philosophy), Mathematical optimization, Mathematics, Artificial intelligence, Physics, Philosophy, ICLR},
}
