@misc{weis_unmasking_2020,
	title = {Unmasking the {Inductive} {Biases} of {Unsupervised} {Object} {Representations} for {Video} {Sequences}},
	shorttitle = {Unmasking the {Inductive} {Biases}},
	url = {https://brendel-group.github.io/publication/2020_06_weis/},
	doi = {10.48550/arxiv.2006.07034},
	abstract = {Unsupervised object-centric representation learning aims to decompose scenes into individual objects without manual supervision. While recent models have shown impressive results on static images, their performance on video sequences remains less understood. In this paper, we systematically evaluate the inductive biases of state-of-the-art unsupervised object-centric models on video data. We find that most models rely heavily on simple low-level cues such as motion and spatial proximity rather than learning a robust notion of objects. We propose a new benchmark for evaluating object-centric representations in video, which includes tasks such as object tracking and segmentation. Our results reveal that current models struggle to maintain object identity over time and often fail to generalize to unseen object shapes and motions. We hope that our findings will guide future research towards more robust and generalizable object-centric representations.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Weis, Marissa A. and Chitta, Kashyap and Sharma, Yash and Brendel, Wieland and Bethge, Matthias and Geiger, Andreas and Ecker, Alexander S.},
	year = {2020},
	keywords = {Computer science, Artificial intelligence, Video tracking, Unsupervised learning, Segmentation, Benchmark (surveying), Cluster analysis, Object (grammar), Object detection, Computer vision, Feature learning, Machine learning, Pattern recognition (psychology), Benchmarking, Transformer, Exploit, CVPR},
}
