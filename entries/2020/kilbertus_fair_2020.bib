@misc{kilbertus_fair_2020,
	title = {Fair {Decisions} {Despite} {Imperfect} {Predictions}},
	url = {http://proceedings.mlr.press/v108/kilbertus20a.html},
	doi = {10.48550/arxiv.1902.02979},
	abstract = {We consider the problem of making fair decisions based on imperfect predictions. In many real-world applications, such as loan granting or hiring, a decision maker uses a predictive model to estimate a target variable and then makes a decision based on this estimate. Often, the predictive model is imperfect, i.e., it does not perfectly predict the target variable. We show that even if the predictive model is fair with respect to a sensitive attribute, the resulting decisions may be unfair. Conversely, we show that even if the predictive model is unfair, it is possible to make fair decisions. We propose a framework to achieve fairness in decision making by adjusting the decision threshold based on the sensitive attribute and the predictive model's error distribution. We provide theoretical guarantees for our approach and demonstrate its effectiveness on synthetic and real-world datasets.},
	language = {en},
	publisher = {PMLR},
	author = {Kilbertus, N. and Gomez Rodriguez, M. and Schölkopf, B. and Muandet, K. and Valera, I.},
	editor = {Chiappa, Silvia and Calandra, Roberto},
	month = aug,
	year = {2020},
	keywords = {Computer science, Exploit, Context (archaeology), Inference, Machine learning, Reinforcement learning, Imperfect, Artificial intelligence, Loan, Space (punctuation), Neglect, Economics, Psychology, Computer security, AISTATS},
}
