@inproceedings{gessner_integrals_2020,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Integrals over {Gaussians} under {Linear} {Domain} {Constraints}},
	url = {http://proceedings.mlr.press/v108/gessner20a.html},
	doi = {10.48550/arxiv.1910.09328},
	abstract = {We consider the problem of computing the integral of a Gaussian probability density function over a domain defined by a set of linear inequality constraints. This problem is equivalent to computing the cumulative distribution function of a multivariate Gaussian distribution. While this is a well-studied problem, existing methods often struggle with high-dimensional domains or require expensive numerical integration. We propose a new approach based on the observation that the integral can be expressed as a sequence of one-dimensional integrals. We show that this approach is computationally efficient and provides accurate results even in high dimensions. We demonstrate the effectiveness of our method on a range of synthetic and real-world problems.},
	language = {en},
	booktitle = {Proceedings of the 23rd {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Gessner, A. and Kanjilal, O. and Hennig, P.},
	editor = {Chiappa, Silvia and Calandra, Roberto},
	month = aug,
	year = {2020},
	keywords = {Computation, Gaussian, Mathematics, Algorithm, Volume integral, Logarithm, Ellipse, Bayesian optimization, Applied mathematics, Mathematical optimization, Computer science, Mathematical analysis, Geometry, Integral equation, AISTATS},
}
