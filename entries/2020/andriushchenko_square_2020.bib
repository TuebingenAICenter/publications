@misc{andriushchenko_square_2020,
	title = {Square {Attack}: a query-efficient black-box adversarial attack via random search},
	shorttitle = {Square {Attack}},
	url = {https://arxiv.org/abs/1912.00049},
	doi = {10.1007/978-3-030-58595-2_40},
	abstract = {We propose Square Attack, a score-based black-box adversarial attack. It is a randomized search scheme which selects at each iteration a square of a certain size to be perturbed. Square Attack is query-efficient, does not rely on local gradient information, and is thus robust to gradient masking. We show that it outperforms existing black-box attacks on several standard benchmarks for \${\textbackslash}ell\_p\$ threat models, while requiring significantly fewer queries. Moreover, we show that it can be used to evaluate the robustness of models trained with different defenses, including those that are known to be resistant to gradient-based attacks.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Springer},
	author = {Andriushchenko, Maksym and Croce, Francesco and Flammarion, Nicolas and Hein, Matthias},
	year = {2020},
	keywords = {Computer science, Square (algebra), Set (abstract data type), Masking (illustration), Algorithm, Theoretical computer science, Mathematics, Geometry, ECCV},
}
