@article{wuthrich_trifinger_2020,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {{TriFinger}: {An} {Open}-{Source} {Robot} for {Learning} {Dexterity}},
	shorttitle = {{TriFinger}},
