@article{vlastelica_differentiation_2020,
	series = {{ICLR}'20},
	title = {Differentiation of {Blackbox} {Combinatorial} {Solvers}},
	url = {https://openreview.net/forum?id=BkevoJSYPB},
	abstract = {We propose a method to differentiate through blackbox combinatorial solvers. Our approach allows for the integration of combinatorial algorithms (e.g., shortest path, max-flow, or even TSP solvers) into deep learning architectures as layers. The method is based on a local linear interpolation of the solver's solution surface, which is constructed using the solver's output at the forward pass and a perturbed version of the input at the backward pass. We demonstrate the effectiveness of our approach on several tasks, including image-based shortest path prediction and a challenging task of learning to solve the Traveling Salesperson Problem.},
	language = {en},
	urldate = {2025-05-14},
	journal = {International Conference on Learning Representations},
	author = {Vlastelica, Marin and Paulus, Anselm and Musil, Vít and Martius, Georg and Rolínek, Michal},
	month = may,
	year = {2020},
	keywords = {ICLR},
}
