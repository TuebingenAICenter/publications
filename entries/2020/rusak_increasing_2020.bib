@article{rusak_increasing_2020,
	title = {Increasing the robustness of {DNNs} against image corruptions by playing the {Game} of {Noise}},
	shorttitle = {Increasing the robustness of {DNNs}},
	url = {https://brendel-group.github.io/publication/2020_01_rusaka/},
	doi = {10.48550/arXiv.2001.06057},
	abstract = {Deep neural networks (DNNs) are known to be vulnerable to small, adversarial perturbations. However, they are also surprisingly fragile to common image corruptions such as noise, blur, or weather effects. While adversarial training has been shown to improve robustness against adversarial perturbations, it often fails to improve robustness against common corruptions. In this paper, we propose a new training objective, the Game of Noise, which improves the robustness of DNNs against a wide range of common image corruptions. Our approach is based on the observation that common corruptions can be modeled as a game between a noise generator and the classifier. We show that by training the classifier to be robust against the worst-case noise generated by the noise generator, we can significantly improve the robustness of the classifier against a variety of common corruptions. We evaluate our approach on the ImageNet-C and CIFAR-10-C benchmarks and show that it outperforms existing methods for improving robustness against common corruptions.},
	language = {en},
	urldate = {2025-05-14},
	journal = {International Conference on Learning Representations},
	publisher = {arXiv},
	author = {Rusak, Evgenia and Schott, Lukas and Zimmermann, Roland and Bitterwolf, Julian and Bringmann, Oliver and Bethge, Matthias and Brendel, Wieland},
	year = {2020},
	keywords = {Robustness (evolution), Computer science, Artificial intelligence, MNIST database, Gaussian, Adversarial system, Uncorrelated, Benchmark (surveying), Pattern recognition (psychology), Machine learning, Mathematics, Deep learning, Statistics, Physics, Geography, ICLR},
}
