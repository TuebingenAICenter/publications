@misc{zhu_new_2020,
	title = {A {New} {Distribution}-{Free} {Concept} for {Representing}, {Comparing}, and {Propagating} {Uncertainty} in {Dynamical} {Systems} with {Kernel} {Probabilistic} {Programming}},
	shorttitle = {A {New} {Distribution}-{Free} {Concept}},
	url = {https://doi.org/10.1016/j.ifacol.2020.12.557},
	doi = {10.1016/j.ifacol.2020.12.557},
	abstract = {In this paper, we propose a new distribution-free concept for representing, comparing, and propagating uncertainty in dynamical systems. Our approach is based on kernel probabilistic programming, which allows us to represent probability distributions as elements in a reproducing kernel Hilbert space (RKHS). This representation enables us to compare distributions using the maximum mean discrepancy (MMD) and to propagate uncertainty through dynamical systems using kernel-based operators. We demonstrate the effectiveness of our approach on several benchmark problems, including a nonlinear dynamical system and a robotic arm control task.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Elsevier},
	author = {Zhu, Jia-Jie and Muandet, Krikamol and Diehl, Moritz and Schölkopf, Bernhard},
	month = jul,
	year = {2020},
	keywords = {Probabilistic logic, Embedding, Computer science, Kernel (algebra), Dynamical systems theory, Theoretical computer science, Context (archaeology), Mathematical optimization, Mathematics, Artificial intelligence, Discrete mathematics, IFAC},
}
