@misc{laturnus_systematic_2020,
	title = {A systematic evaluation of interneuron morphology representations for cell type discrimination},
	shorttitle = {A systematic evaluation of interneuron morphology representations},
	url = {https://link.springer.com/article/10.1007/s12021-020-09461-z},
	doi = {10.1007/s12021-020-09461-z},
	abstract = {The classification of neurons into cell types is a fundamental task in neuroscience. With the increasing availability of digital reconstructions of neuronal morphologies, quantitative methods for comparing and clustering these morphologies have become essential. However, it is unclear which representation of morphology is most suitable for cell type discrimination. Here, we systematically evaluate a wide range of morphological representations, including classical morphometric features, graph-based representations, and representations derived from deep learning models. We compare these representations on a large dataset of interneuron morphologies from the mouse visual cortex. We find that while classical morphometric features perform well, they are outperformed by representations that capture the spatial arrangement of the dendritic tree. Furthermore, we show that deep learning-based representations can learn informative features directly from the raw morphology, providing a promising avenue for future research.},
	language = {en},
	type = {{journalArticle}},
	urldate = {2025-05-14},
	publisher = {Springer Nature},
	author = {Laturnus, Sophie and Kobak, Dmitry and Berens, Philipp},
	month = may,
	year = {2020},
	keywords = {Interneuron, Morphology (biology), Neuroscience, Communication, Biology, Psychology, Zoology},
}
