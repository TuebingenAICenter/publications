@misc{rene_inference_2020,
	title = {Inference of a mesoscopic population model from population spike trains},
	shorttitle = {Inference of a mesoscopic population model},
	url = {https://doi.org/10.1162/neco_a_01295},
	doi = {10.1162/neco_a_01295},
	abstract = {We present a method for inferring the parameters of a mesoscopic population model from population spike trains. Our model is based on a stochastic differential equation for the population firing rate, which is coupled to the observed spike trains via a point process. We use a Bayesian framework to infer the parameters of the model, and we develop an efficient Markov chain Monte Carlo (MCMC) algorithm for sampling from the posterior distribution. We demonstrate the performance of our method on synthetic data and on recordings from the primary visual cortex of anesthetized mice.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {MIT Press},
	author = {René, Alexandre and Longtin, André and Macke, Jakob H.},
	year = {2020},
	keywords = {Markov chain Monte Carlo, Inference, Population, Computer science, Bayesian inference, Mesoscopic physics, Bayesian probability, Sampling (signal processing), Algorithm, Statistical physics, Artificial intelligence, Physics},
}
