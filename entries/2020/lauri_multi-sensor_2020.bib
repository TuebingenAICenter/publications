@article{lauri_multi-sensor_2020,
	title = {Multi-{Sensor} {Next}-{Best}-{View} {Planning} as {Matroid}-{Constrained} {Submodular} {Maximization}},
	issn = {2377-3766},
	shorttitle = {Multi-{Sensor} {Next}-{Best}-{View} {Planning}},
	url = {https://is.mpg.de/ei/publications/laupajpetfri20},
	doi = {10.1109/LRA.2020.3007445},
	abstract = {Next-Best-View (NBV) planning is a fundamental problem in robotics, where the goal is to select a sequence of sensing actions to minimize uncertainty about the environment. In this paper, we consider the problem of multi-sensor NBV planning, where a robot can choose between different sensors at each step. We show that the multi-sensor NBV problem can be formulated as the maximization of a submodular set function subject to a matroid constraint. This formulation allows us to use a greedy algorithm with a provable approximation guarantee of 1-1/e. We evaluate our approach in simulation and on a real robot, showing that it outperforms existing methods in terms of both information gain and computational efficiency.},
	language = {en},
	urldate = {2024-05-23},
	journal = {IEEE Robotics and Automation Letters},
	publisher = {IEEE},
	author = {Lauri, Mikko and Pajarinen, Joni and Peters, Jan and Frintrop, Simone},
	year = {2020},
	keywords = {RAL},
}
