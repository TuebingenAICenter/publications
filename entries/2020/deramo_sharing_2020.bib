@inproceedings{deramo_sharing_2020,
	title = {Sharing {Knowledge} in {Multi}-{Task} {Deep} {Reinforcement} {Learning}},
	shorttitle = {Sharing {Knowledge} in {Multi}-{Task} {Deep} {Reinforcement} {Learning}},
	url = {https://openreview.net/forum?id=rkgpv2VFvr},
	abstract = {Multi-task reinforcement learning aims to improve the learning efficiency of an agent by leveraging knowledge across multiple tasks. A common approach is to share parameters among tasks, but this often leads to negative transfer when tasks are not sufficiently related. In this paper, we propose a novel approach to multi-task deep reinforcement learning that learns to share knowledge by dynamically selecting which parameters to share. We introduce a gating mechanism that learns to mask the weights of the neural network, allowing the agent to selectively share information across tasks. We evaluate our approach on a variety of multi-task reinforcement learning benchmarks and show that it outperforms existing methods in terms of both learning speed and final performance.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {8th {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {D'Eramo, Carlo and Tateo, Davide and Bonarini, Andrea and Restelli, Marcello and Peters, Jan},
	month = apr,
	year = {2020},
	keywords = {ICLR},
}
