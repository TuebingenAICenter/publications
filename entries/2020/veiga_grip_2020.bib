@article{veiga_grip_2020,
	title = {Grip {Stabilization} through {Independent} {Finger} {Tactile} {Feedback} {Control}},
	copyright = {CC BY 4.0},
	issn = {1424-8220},
	shorttitle = {Grip {Stabilization} through {Independent} {Finger} {Tactile} {Feedback} {Control}},
	url = {https://www.mdpi.com/1424-8220/20/6/1748},
	doi = {10.3390/s20061748},
	abstract = {Tactile feedback is essential for human manipulation, particularly for grip stabilization. While the role of tactile feedback in grip force control has been extensively studied in humans, its application to robotic manipulation remains limited. In this paper, we propose a novel control framework for grip stabilization based on independent finger tactile feedback. We use a tactile sensor that provides information about the contact state and the slip of each finger. The proposed controller uses this information to adjust the grip force of each finger independently, ensuring that the object is held securely while minimizing the grip force. We evaluate the proposed controller in a series of experiments with a robotic hand, demonstrating its effectiveness in stabilizing objects under various conditions, including unexpected perturbations and object slippage. Our results show that the proposed controller outperforms a baseline controller that uses a constant grip force, and that it is able to adapt to different object properties and manipulation tasks.},
	language = {en},
	urldate = {2024-05-23},
	journal = {Sensors},
	publisher = {MDPI},
	author = {Veiga, F. and Edin, B. and Peters, J.},
	month = mar,
	year = {2020},
	keywords = {SENSORS},
}
