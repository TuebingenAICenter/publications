@misc{gomez-gonzalez_real_2020,
	title = {Real {Time} {Trajectory} {Prediction} {Using} {Deep} {Conditional} {Generative} {Models}},
	shorttitle = {Real {Time} {Trajectory} {Prediction}},
	url = {https://doi.org/10.1109/LRA.2020.2966390},
	doi = {10.1109/LRA.2020.2966390},
	abstract = {Trajectory prediction is a fundamental problem in robotics, essential for safe and efficient navigation in dynamic environments. While deep learning methods have achieved impressive results in this task, they often struggle with the inherent uncertainty of future trajectories and the requirement for real-time performance. In this paper, we propose a novel approach to trajectory prediction using deep conditional generative models. Our method learns a distribution over future trajectories conditioned on past observations, allowing for the generation of multiple plausible future paths. We demonstrate that our model can be trained efficiently and performs inference in real-time, making it suitable for online robotic applications. We evaluate our approach on several benchmark datasets and show that it outperforms existing state-of-the-art methods in terms of both accuracy and computational efficiency.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {IEEE},
	author = {Gómez-González, Sebastián and Prokudin, Sergey and Schölkopf, Bernhard and Peters, Jan},
	month = apr,
	year = {2020},
	keywords = {Computer science, Artificial intelligence, Trajectory, Inference, Deep learning, Generative model, Machine learning, Artificial neural network, Robot, Generative grammar, LRA},
}
