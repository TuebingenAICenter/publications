@inproceedings{dangel_modular_2020,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Modular {Block}-diagonal {Curvature} {Approximations} for {Feedforward} {Architectures}},
	url = {http://proceedings.mlr.press/v108/dangel20a.html},
	doi = {10.48550/arxiv.1902.01813},
	abstract = {Second-order optimization methods for deep learning require approximations of the curvature matrix, such as the Fisher information matrix or the Hessian. A common strategy is to use block-diagonal approximations, where blocks correspond to layers or even individual parameters. We propose a modular framework for constructing such approximations. It decomposes the curvature of a feedforward network into local contributions from individual layers and activation functions. This modularity allows for a systematic derivation of various existing approximations, such as K-FAC, and facilitates the development of new ones. We demonstrate the flexibility of our framework by deriving a novel block-diagonal approximation that accounts for correlations between weights and biases, and show that it improves upon standard K-FAC on small-scale problems.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 23rd {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Dangel, Felix and Harmeling, Stefan and Hennig, Philipp},
	editor = {Chiappa, Silvia and Calandra, Roberto},
	month = aug,
	year = {2020},
	keywords = {Hessian matrix, Curvature, Diagonal, Block matrix, Block (permutation group theory), Modular design, Computation, Feed forward, Matrix (chemical analysis), Computer science, Algebra over a field, Algorithm, Mathematics, Applied mathematics, Geometry, Pure mathematics, Backpropagation, Artificial neural network, Artificial intelligence, AISTATS},
}
