@misc{rusak_simple_2020,
	title = {A simple way to make neural networks robust against diverse image corruptions},
	shorttitle = {A simple way to make neural networks robust},
	url = {https://brendel-group.github.io/publication/2020_01_rusak/},
	doi = {10.1007/978-3-030-58580-8_4},
	abstract = {Deep neural networks are known to be vulnerable to small, adversarial perturbations. However, they are also surprisingly fragile to common image corruptions such as noise, blur, or weather effects. While adversarial training has been shown to improve robustness against adversarial perturbations, it often fails to generalize to common corruptions. In this paper, we propose a simple, yet effective, approach to improve the robustness of neural networks against a wide range of common image corruptions. Our method, which we call AugMix, involves augmenting the training data with a mixture of diverse image corruptions. We show that AugMix significantly improves the robustness of various architectures on several benchmarks, including ImageNet-C and CIFAR-10-C, while maintaining high accuracy on clean images.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Springer},
	author = {Rusak, Evgenia and Schott, Lukas and Zimmermann, Roland S. and Bitterwolf, Julian and Bringmann, Oliver and Bethge, Matthias and Brendel, Wieland},
	year = {2020},
	keywords = {MNIST database, Artificial intelligence, Computer science, Gaussian, Deep neural networks, Benchmark (surveying), Adversarial system, Uncorrelated, Image (mathematics), Artificial neural network, Simple (philosophy), Pattern recognition (psychology), Machine learning, Algorithm, Mathematics, Geography, Statistics, Physics, ECCV},
}
