@article{agudelo-espana_real-robot_2020,
	title = {A {Real}-{Robot} {Dataset} for {Assessing} {Transferability} of {Learned} {Dynamics} {Models}},
	url = {https://doi.org/10.1109/ICRA40945.2020.9197392},
	doi = {10.1109/ICRA40945.2020.9197392},
	abstract = {We present a dataset of real-robot trajectories for the purpose of benchmarking the transferability of learned dynamics models. The dataset consists of trajectories from a 7-DOF manipulator (KUKA LBR iiwa) performing reaching tasks under different conditions, such as varying payloads and friction settings. We provide the data in a standardized format and include baseline results for several state-of-the-art dynamics learning methods. Our goal is to facilitate research in transfer learning and robust control by providing a common benchmark for evaluating how well learned models generalize to unseen dynamics.},
	language = {en},
	journal = {IEEE International Conference on Robotics and Automation (ICRA)},
	publisher = {IEEE},
	author = {Agudelo-España, Diego and Zadaianchuk, Andrii and Wenk, Philippe and Garg, Aditya and Akpo, Joel and Grimminger, Felix and Viereck, Julian and Naveau, Maximilien and Righetti, Ludovic and Martius, Georg and Krause, Andreas and Schölkopf, Bernhard and Bauer, Stefan and Wüthrich, Manuel},
	year = {2020},
	keywords = {Computer science, Benchmark (surveying), Machine learning, Context (archaeology), Artificial intelligence, Dynamics (music), Reinforcement learning, Robot, Control (management), Set (abstract data type), Transfer of learning, ICRA},
}
