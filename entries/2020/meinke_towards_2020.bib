@misc{meinke_towards_2020,
	title = {Towards neural networks that provably know when they don't know},
	shorttitle = {Towards neural networks that provably know when they don't know},
	url = {https://openreview.net/forum?id=ByxGkySKwH},
	doi = {10.48550/arxiv.1909.12180},
	abstract = {Deep neural networks are known to be overconfident on out-of-distribution data. While many heuristic methods have been proposed to detect such data, they often fail on adversarial examples. In this paper, we propose a method to train neural networks that are provably certain on a given set of training data and have a guaranteed uncertainty on the complement of the training data. We achieve this by training the network to be constant on the training data and to have a high uncertainty on the complement. We show that our method is effective in detecting out-of-distribution data and is robust to adversarial attacks.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {OpenReview},
	author = {Meinke, Alexander and Hein, Matthias},
	year = {2020},
	keywords = {Computer science, Property (philosophy), Need to know, Point (geometry), Context (archaeology), Training set, Artificial neural network, State (computer science), Artificial intelligence, Machine learning, Theoretical computer science, Computer security, Algorithm, Mathematics, Epistemology, ICLR},
}
