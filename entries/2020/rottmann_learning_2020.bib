@inproceedings{rottmann_learning_2020,
	title = {Learning {Hierarchical} {Acquisition} {Functions} for {Bayesian} {Optimization}},
	shorttitle = {Learning {Hierarchical} {Acquisition} {Functions}},
	url = {https://is.mpg.de/ei/publications/rottmannetal20},
	doi = {10.1109/IROS45743.2020.9341335},
	abstract = {Bayesian Optimization (BO) is a powerful framework for global optimization of expensive-to-evaluate black-box functions. A key component of BO is the acquisition function, which determines the next query point by balancing exploration and exploitation. While standard acquisition functions like Expected Improvement or Upper Confidence Bound are widely used, they are often hand-crafted and may not be optimal for all problems. In this paper, we propose a novel approach to learn hierarchical acquisition functions for BO. Our method leverages a hierarchical structure to adaptively select or combine multiple acquisition functions, allowing the optimizer to switch between different exploration-exploitation strategies based on the current state of the optimization process. We demonstrate the effectiveness of our approach on a variety of synthetic and real-world benchmark problems, showing that it outperforms standard BO methods in terms of convergence speed and final solution quality.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {International {Conference} on {Intelligent} {Robots} and {Systems} ({IROS})},
	publisher = {IEEE},
	author = {Rottmann, N. and Kunavar, T. and Babic, J. and Peters, J. and Rueckert, E.},
	year = {2020},
	keywords = {IROS},
}
