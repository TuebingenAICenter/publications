@misc{sandbrink_task-driven_2020,
	title = {Task-driven hierarchical deep neural network models of the proprioceptive pathway},
	shorttitle = {Task-driven hierarchical deep neural network models},
	url = {https://bethgelab.org/publication/2020_05_sandbrink/},
	doi = {10.1101/2020.05.06.081372},
	abstract = {Proprioception, the sense of self-movement and body position, is essential for motor control. While the peripheral components of the proprioceptive pathway are well-characterized, the central processing of proprioceptive information remains poorly understood. Here, we propose a task-driven modeling approach to study the proprioceptive pathway. We train hierarchical deep neural networks to perform a proprioceptive task: estimating the pose of a simulated musculoskeletal arm from muscle spindle afferent activity. We find that these models develop representations that are remarkably similar to those observed in the cuneate nucleus and primary somatosensory cortex. Our results suggest that the proprioceptive pathway is optimized for extracting task-relevant information about body state, and that task-driven models can provide a powerful framework for understanding sensory processing in the brain.},
	language = {en},
	urldate = {2024-05-22},
	publisher = {bioRxiv},
	author = {Sandbrink, Kai J and Mamidanna, Pranav and Michaelis, Claudio and Mathis, Mackenzie Weygandt and Bethge, Matthias and Mathis, Alexander},
	year = {2020},
	keywords = {BIORXIV},
}
