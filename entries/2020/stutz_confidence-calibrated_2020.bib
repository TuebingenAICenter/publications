@misc{stutz_confidence-calibrated_2020,
	title = {Confidence-{Calibrated} {Adversarial} {Training}: {Generalizing} to {Unseen} {Attacks}},
	shorttitle = {Confidence-{Calibrated} {Adversarial} {Training}},
	url = {https://arxiv.org/abs/1910.06259},
	doi = {10.48550/arxiv.1910.06259},
	abstract = {Adversarial training is the state-of-the-art defense against adversarial attacks. However, it is known to be specific to the threat model used during training, i.e., models are vulnerable to unseen attacks. In this paper, we argue that this is due to the fact that adversarial training does not explicitly encourage the model to be confident only on the data manifold. We propose Confidence-Calibrated Adversarial Training (CCAT) which encourages the model to predict low confidence for adversarial examples. We show that this allows the model to generalize to unseen attacks, including different threat models and even unseen attack types. Our approach achieves state-of-the-art results on CIFAR-10 and SVHN in terms of robustness to unseen attacks while maintaining high accuracy on clean data.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Stutz, David and Hein, Matthias and Schiele, Bernt},
	year = {2020},
	keywords = {Adversarial system, Robustness (evolution), Computer science, Training set, Artificial intelligence, Low Confidence, Confidence interval, Threat model, Algorithm, Machine learning, Mathematics, Statistics, Computer security, Psychology, Training (meteorology), Geography, ICML},
}
