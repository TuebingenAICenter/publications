@inproceedings{trauble_is_2020,
	title = {Is {Independence} all you need? {On} the {Generalization} of {Representations} {Learned} from {Correlated} {Data}},
	shorttitle = {Is {Independence} all you need?},
	url = {https://is.mpg.de/ei/publications/traubleetal20},
	abstract = {Deep learning models often fail to generalize to new environments because they rely on spurious correlations in the training data. A common strategy to mitigate this is to learn representations that are independent of the environment or other nuisance variables. In this paper, we investigate whether independence is sufficient for generalization. We show that, while independence is a necessary condition for causal models, it is not sufficient for generalization in the presence of correlated data. We provide a theoretical analysis of the conditions under which independence-based representations fail to generalize and propose a new approach that leverages causal structure to learn more robust representations.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems}},
	author = {Träuble, Frederik and Creager, Elliot and Kilbertus, Niki and Goyal, Anirudh and Locatello, Francesco and Schölkopf, Bernhard and Bauer, Stefan},
	year = {2020},
	keywords = {NEURIPS},
}
