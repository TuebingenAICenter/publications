@article{tanneberg_evolutionary_2020,
	title = {Evolutionary training and abstraction yields algorithmic generalization of neural computers},
	issn = {2522-5839},
	shorttitle = {Evolutionary training and abstraction},
	url = {https://www.nature.com/articles/s42256-020-00255-1},
	doi = {10.1038/s42256-020-00255-1},
	abstract = {Neural computers, such as neural Turing machines and differentiable neural computers, have been proposed to overcome the limitations of standard neural networks in tasks requiring algorithmic reasoning. However, these models often struggle to generalize to problem instances that are significantly larger than those seen during training. Here we show that evolutionary training combined with a novel abstraction mechanism allows neural computers to learn algorithms that generalize to problem instances of arbitrary size. We demonstrate this on a range of algorithmic tasks, including sorting, graph traversal and pathfinding, where our approach outperforms existing gradient-based methods in terms of both generalization performance and sample efficiency.},
	language = {en},
	urldate = {2024-05-23},
	journal = {Nature Machine Intelligence},
	publisher = {Nature Research},
	author = {Tanneberg, Daniel and Rueckert, Elmar and Peters, Jan},
	month = dec,
	year = {2020},
	keywords = {NMI},
}
