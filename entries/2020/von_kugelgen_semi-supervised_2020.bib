@misc{von_kugelgen_semi-supervised_2020,
	title = {Semi-supervised learning, causality, and the conditional cluster assumption},
	url = {http://proceedings.mlr.press/v124/kugelgen20a.html},
	doi = {10.48550/arxiv.1905.12081},
	abstract = {Semi-supervised learning (SSL) aims to improve predictive performance by leveraging unlabeled data. A common assumption in SSL is the cluster assumption, which states that the decision boundary should lie in low-density regions of the marginal distribution of the input. In this paper, we investigate the cluster assumption from a causal perspective. We show that the validity of the cluster assumption depends on the causal direction between the input and the target variable. Specifically, we argue that the cluster assumption is more likely to hold when the causal direction is from the input to the target, and less likely when it is from the target to the input. We formalize this intuition by introducing the conditional cluster assumption, which relates the cluster assumption to the causal structure of the data-generating process. We provide theoretical and empirical evidence supporting our claims.},
	language = {en},
	publisher = {PMLR},
	author = {von Kügelgen, Julius and Mey, Alexander and Loog, Marco and Schölkopf, Bernhard},
	editor = {Peters, Jonas and Sontag, David},
	month = aug,
	year = {2020},
	keywords = {Causality (physics), Computer science, Exploit, Conditional probability distribution, Machine learning, Artificial intelligence, Distribution (mathematics), Marginal distribution, Econometrics, Mathematics, Random variable, Statistics, UAI},
}
