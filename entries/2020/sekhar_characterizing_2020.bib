@article{sekhar_characterizing_2020,
	title = {Characterizing {Retinal} {Ganglion} {Cell} {Responses} to {Electrical} {Stimulation} {Using} {Generalized} {Linear} {Models}},
	copyright = {© 2020 Sekhar, Ramesh, Bassetto, Zrenner, Macke and Rathbun.},
	issn = {1662-453X},
	shorttitle = {Characterizing {RGC} {Responses} to {Electrical} {Stimulation}},
	url = {https://www.frontiersin.org/articles/10.3389/fnins.2020.00378/full},
	doi = {10.3389/fnins.2020.00378},
	abstract = {Electrical stimulation of the retina is a promising approach to restore vision in patients suffering from retinal degenerative diseases. However, the neural code of the retina is complex, and the responses of retinal ganglion cells (RGCs) to electrical stimulation are highly variable. To better understand and predict these responses, we used generalized linear models (GLMs) to characterize the responses of RGCs to electrical stimulation. We recorded the responses of RGCs in the isolated mouse retina to electrical stimulation using a multi-electrode array. We then fitted GLMs to the recorded spike trains, using the stimulus waveform and the history of the cell's own spiking activity as inputs. We found that the GLMs could accurately predict the responses of RGCs to electrical stimulation, capturing both the deterministic and stochastic components of the responses. Our results demonstrate that GLMs are a powerful tool for characterizing the responses of RGCs to electrical stimulation and could be used to optimize stimulation strategies for retinal prostheses.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Frontiers in Neuroscience},
	publisher = {Frontiers Media S.A.},
	author = {Sekhar, Sudarshan and Ramesh, Poornima and Bassetto, Giacomo and Zrenner, Eberhart and Macke, Jakob H. and Rathbun, Daniel L.},
	year = {2020},
	keywords = {Retinal ganglion cell, Stimulation, Neuroscience, Retinal, Computer science, Biology, Retina, Medicine, Ophthalmology, FRONTIERS},
}
