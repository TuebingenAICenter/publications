@article{grimminger_open_2020,
	title = {An {Open} {Torque}-{Controlled} {Modular} {Robot} {Architecture} for {Legged} {Locomotion} {Research}},
	shorttitle = {An {Open} {Torque}-{Controlled} {Modular} {Robot} {Architecture}},
	url = {https://arxiv.org/abs/1910.00093},
	doi = {10.1109/LRA.2020.2976639},
	abstract = {We present an open-source, modular, torque-controlled robot architecture designed for legged locomotion research. The architecture is based on a custom-designed actuator module that combines a high-torque brushless DC motor with a low-ratio planetary gear and a custom-designed motor controller. The modularity of the design allows for the rapid prototyping of different robot configurations, from simple 1-DOF test benches to complex quadrupedal robots. We demonstrate the capabilities of the architecture by building a quadrupedal robot and showing its performance in various locomotion tasks, including walking, trotting, and jumping. The entire design, including the mechanical parts, electronics, and software, is open-source and available to the research community.},
	language = {en},
	journal = {IEEE Robotics and Automation Letters},
	publisher = {IEEE},
	author = {Grimminger, Felix and Meduri, Avadesh and Khadiv, Majid and Viereck, Julian and Wüthrich, Manuel and Naveau, Maximilien and Berenz, Vincent and Heim, Steve and Widmaier, Felix and Flayols, Thomas and Fiene, Jonathan and Badri-Spröwitz, Alexander and Righetti, Ludovic},
	month = apr,
	year = {2020},
	keywords = {LRA},
}
