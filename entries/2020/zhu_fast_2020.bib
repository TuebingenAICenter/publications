@inproceedings{zhu_fast_2020,
	title = {Fast {Non}-{Parametric} {Learning} to {Accelerate} {Mixed}-{Integer} {Programming} for {Hybrid} {Model} {Predictive} {Control}},
	shorttitle = {Fast {Non}-{Parametric} {Learning} to {Accelerate} {Mixed}-{Integer} {Programming}},
	url = {https://www.sciencedirect.com/science/article/pii/S2405896320315950},
	doi = {10.1016/j.ifacol.2020.12.1200},
	abstract = {Mixed-integer programming (MIP) is a powerful tool for solving hybrid model predictive control (HMPC) problems. However, the computational complexity of MIP is NP-hard, which often prevents its application in real-time control. In this paper, we propose a fast non-parametric learning approach to accelerate the solution of HMPC problems. We learn a mapping from the state to the optimal integer sequence of the MIP problem. By predicting the optimal integer sequence, the MIP problem reduces to a convex quadratic program (QP), which can be solved very efficiently. We use a k-nearest neighbor (k-NN) classifier for the learning task, which is non-parametric and allows for fast training and inference. We demonstrate the effectiveness of our approach on a hybrid system benchmark problem, showing significant speedups compared to standard MIP solvers while maintaining high control performance.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {{IFAC}-{PapersOnLine}},
	publisher = {Elsevier},
	author = {Zhu, J.-J. and Martius, G.},
	month = jul,
	year = {2020},
	keywords = {Model predictive control, Computer science, Integer programming, Mathematical optimization, Simple (philosophy), Field (mathematics), Hybrid system, Parametric statistics, Integer (computer science), Piecewise, Algorithm, Control (management), Mathematics, Artificial intelligence, Machine learning, IFAC},
}
