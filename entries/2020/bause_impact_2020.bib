@article{bause_impact_2020,
	title = {Impact of prospective motion correction, distortion correction methods and large vein bias on the spatial accuracy of cortical laminar {fMRI} at 9.4 {Tesla}},
	issn = {1053-8119},
	shorttitle = {Impact of prospective motion correction},
	url = {https://doi.org/10.1016/j.neuroimage.2019.116434},
	doi = {10.1016/j.neuroimage.2019.116434},
	abstract = {Cortical laminar fMRI at ultra-high fields (UHF) promises to resolve the columnar and laminar organization of the human brain. However, the spatial accuracy of laminar fMRI is limited by several factors, including head motion, geometric distortions, and the large vein bias. In this study, we systematically investigated the impact of prospective motion correction (PMC), different distortion correction methods, and the large vein bias on the spatial accuracy of laminar fMRI at 9.4 T. We found that PMC significantly improved the spatial stability of the fMRI data, reducing motion-related artifacts and improving the alignment of the functional data with the anatomical reference. Distortion correction methods, including field map-based and point-spread function-based approaches, were effective in reducing geometric distortions, with the latter providing superior results in regions with high susceptibility gradients. The large vein bias, which is a major confound in laminar fMRI, was found to be significantly reduced by using a high-resolution acquisition and appropriate preprocessing steps. Our results demonstrate that a combination of PMC, advanced distortion correction, and careful handling of the large vein bias is essential for achieving high spatial accuracy in laminar fMRI at 9.4 T.},
	language = {en},
	urldate = {2024-05-23},
	journal = {Neuroimage},
	publisher = {Elsevier},
	author = {Bause, J. and Polimeni, J. R. and Stelzer, J. and In, M.-H. and Ehses, P. and Kraemer-Fernandez, P. and Aghaeifar, A. and Lacosse, E. and Pohmann, R. and Scheffler, K.},
	year = {2020},
	keywords = {NEUROIMAGE},
}
