@inproceedings{richard_modeling_2020,
	title = {Modeling {Shared} responses in {Neuroimaging} {Studies} through {MultiView} {ICA}},
	shorttitle = {Modeling {Shared} responses in {Neuroimaging} {Studies} through {MultiView} {ICA}},
	url = {https://proceedings.neurips.cc/paper/2020/file/de03beffeed9da5f3639a621bcab5dd4-Paper.pdf},
	abstract = {We propose a new method to analyze multi-subject neuroimaging data, such as fMRI recordings. Our approach, MultiView ICA, assumes that each subject's data is a linear mixture of some shared components and subject-specific noise. We show that under mild conditions, the shared components can be recovered by maximizing the independence of the estimated sources across subjects. We provide a fast algorithm to solve this problem, and demonstrate its effectiveness on both synthetic and real fMRI data, where it outperforms standard methods like Group ICA or Procrustes-based alignment.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 33 ({NeurIPS} 2020)},
	publisher = {Curran Associates, Inc.},
	author = {Richard, Hugo and Gresele, Luigi and Hyvärinen, Aapo and Thirion, Bertrand and Gramfort, Alexandre and Ablin, Pierre},
	month = dec,
	year = {2020},
	keywords = {NEURIPS},
}
