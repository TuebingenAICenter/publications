@article{kubler_adaptive_2020,
	title = {An {Adaptive} {Optimizer} for {Measurement}-{Frugal} {Variational} {Algorithms}},
	copyright = {CC BY 4.0},
	issn = {2521-327X},
	shorttitle = {An {Adaptive} {Optimizer} for {Measurement}-{Frugal} {Variational} {Algorithms}},
	url = {https://quantum-journal.org/papers/q-2020-05-11-263/},
	doi = {10.22331/q-2020-05-11-263},
	abstract = {Variational quantum algorithms (VQAs) are leading candidates for demonstrating quantum advantage on near-term quantum devices. A major bottleneck for VQAs is the measurement cost, i.e., the number of quantum measurements required to estimate the cost function. We introduce an adaptive optimizer, called SPSA-F (Simultaneous Perturbation Stochastic Approximation with Frugal measurements), that reduces the measurement cost of VQAs. SPSA-F is based on the SPSA algorithm but incorporates a measurement-frugal strategy that reuses measurement data to estimate the gradient. We prove that SPSA-F converges to a local minimum of the cost function under standard assumptions. We numerically demonstrate that SPSA-F significantly reduces the measurement cost compared to standard SPSA and other gradient-based optimizers for various VQA problems, including the Variational Quantum Eigensolver and the Quantum Approximate Optimization Algorithm.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Quantum},
	publisher = {Verein zur Förderung des Open Access Publizierens in den Quantenwissenschaften},
	author = {Kübler, J. M. and Arrasmith, A. and Cincio, L. and Coles, P. J.},
	month = may,
	year = {2020},
	keywords = {QUANTUM},
}
