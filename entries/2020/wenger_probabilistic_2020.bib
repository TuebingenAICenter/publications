@inproceedings{wenger_probabilistic_2020,
	title = {Probabilistic {Linear} {Solvers} for {Machine} {Learning}},
	shorttitle = {Probabilistic {Linear} {Solvers} for {Machine} {Learning}},
	url = {https://proceedings.neurips.cc/paper/2020/file/4afd521d77158e02aed37e2274b90c9c-Paper.pdf},
	doi = {10.48550/arxiv.2010.09691},
	abstract = {Many machine learning problems require the solution of large-scale linear systems. Standard iterative solvers provide a point estimate of the solution. However, in many settings, it is beneficial to quantify the uncertainty about the solution, for example, to inform subsequent decisions or to propagate errors. Probabilistic linear solvers treat the solution of a linear system as an inference problem, providing a posterior distribution over the solution. In this paper, we review the state of the art in probabilistic linear solvers, discuss their theoretical properties, and demonstrate their utility in machine learning applications, including Gaussian process regression and Bayesian optimization.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 33},
	publisher = {Curran Associates, Inc.},
	author = {Wenger, Jonathan and Hennig, Philipp},
	editor = {Larochelle, Hugo and Ranzato, Marc and Hadsell, Raia and Balcan, Maria-Florina and Lin, Hsuan-Tien},
	month = dec,
	year = {2020},
	keywords = {Computer science, Probabilistic logic, Computation, Set (abstract data type), Class (philosophy), Matrix (chemical analysis), Scale (ratio), Inverse, Algorithm, Artificial intelligence, Machine learning, Mathematical optimization, Theoretical computer science, Mathematics, probabilistic numerics, numerical linear algebra, machine learning, NEURIPS},
