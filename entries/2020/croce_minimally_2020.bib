@misc{croce_minimally_2020,
	title = {Minimally distorted {Adversarial} {Examples} with a {Fast} {Adaptive} {Boundary} {Attack}},
	shorttitle = {{FAB}-attack},
	url = {https://arxiv.org/abs/1907.02044},
	doi = {10.48550/arxiv.1907.02044},
	abstract = {We propose the Fast Adaptive Boundary (FAB) attack, a new attack to evaluate the robustness of classifiers. FAB is a first-order method that computes adversarial examples with small perturbations by linearizing the classifier's decision boundary. It is computationally efficient and can be used to find the distance to the decision boundary for different norms (L1, L2, Linf). We show that FAB is more effective than existing attacks in finding smaller adversarial perturbations, and it is particularly useful for evaluating the robustness of models trained with adversarial training.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Croce, Francesco and Hein, Matthias},
	year = {2020},
	keywords = {Adversarial system, Computer science, Computation, Robustness (evolution), Norm (philosophy), Perturbation (astronomy), Algorithm, Artificial intelligence, Mathematical optimization, Mathematics, Deep neural networks, Artificial neural network, ICML},
}
