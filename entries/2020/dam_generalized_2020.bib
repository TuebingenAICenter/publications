@inproceedings{dam_generalized_2020,
	title = {Generalized {Mean} {Estimation} in {Monte}-{Carlo} {Tree} {Search}},
	shorttitle = {Generalized {Mean} {Estimation} in {MCTS}},
	url = {https://www.ijcai.org/proceedings/2020/0332.pdf},
	doi = {10.24963/ijcai.2020/332},
	abstract = {Monte-Carlo Tree Search (MCTS) is a popular algorithm for sequential decision making. A core component of MCTS is the estimation of the value of a state-action pair, which is typically computed as the sample mean of the returns obtained from simulations. However, the sample mean is only optimal under the assumption that the returns are independent and identically distributed (i.i.d.) with a finite variance. In many MCTS applications, these assumptions are violated, for example, due to the non-stationary nature of the tree policy. In this paper, we propose to replace the sample mean with a generalized mean estimator. We show that this approach can be interpreted as a form of importance sampling, which allows us to correct for the bias introduced by the tree policy. We provide theoretical guarantees for the convergence of the proposed estimator and demonstrate its effectiveness in several challenging domains, including games and planning problems.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Proceedings of the {Twenty}-{Ninth} {International} {Joint} {Conference} on {Artificial} {Intelligence} ({IJCAI})},
	publisher = {International Joint Conferences on Artificial Intelligence Organization},
	author = {Dam, T. and Klink, P. and D'Eramo, C. and Peters, J. and Pajarinen, J.},
	editor = {Bessiere, Christian},
	month = jul,
	year = {2020},
	keywords = {IJCAI},
}
