@inproceedings{bradshaw_barking_2020,
	title = {Barking up the right tree: an approach to search over molecule synthesis {DAGs}},
	shorttitle = {Barking up the right tree},
	url = {https://proceedings.neurips.cc/paper/2020/file/4cc05b35c2f937c5bd9e7d41d3686fff-Paper.pdf},
	abstract = {We propose a new approach to search over the space of molecule synthesis directed acyclic graphs (DAGs). Our approach, which we call DAG-DQN, uses a deep Q-network to learn a policy for building synthesis DAGs. The state space is defined by the set of molecules currently available, and the action space consists of applying a reaction to a subset of these molecules. We show that DAG-DQN can be used to find synthesis DAGs for molecules that are difficult to synthesize, and that it outperforms existing methods on a range of benchmarks.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 33},
	publisher = {Curran Associates, Inc.},
	author = {Bradshaw, John and Paige, Brooks and Kusner, Matt and Segler, Marwin and Hernández-Lobato, José Miguel},
	month = dec,
	year = {2020},
	keywords = {NEURIPS},
}
