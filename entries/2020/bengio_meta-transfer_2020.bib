@inproceedings{bengio_meta-transfer_2020,
	title = {A meta-transfer objective for learning to disentangle causal mechanisms},
	shorttitle = {A meta-transfer objective for learning to disentangle causal mechanisms},
	url = {https://openreview.net/pdf?id=ryxWIgBFPS},
	abstract = {The goal of disentangling the underlying causal factors of data is a central challenge in machine learning. We propose a new objective for learning to disentangle causal mechanisms, based on the principle that a causal model should be robust to changes in the environment or task. We formulate this as a meta-learning problem, where the goal is to learn a representation that allows for fast adaptation to new tasks by leveraging the underlying causal structure. We demonstrate the effectiveness of our approach on several synthetic and real-world datasets, showing that it can learn to disentangle causal factors more effectively than existing methods.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {8th {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Bengio, Yoshua and Deleu, Tristan and Rahaman, Nasim and Ke, Nan Rosemary and Lachapelle, Sébastien and Bilaniuk, Olexa and Goyal, Anirudh and Pal, Christopher},
	month = apr,
	year = {2020},
	keywords = {ICLR},
}
