@article{wu_cognition_2020,
	title = {Cognition, {Collectives}, and {Human} {Culture}},
	shorttitle = {Cognition, {Collectives}, and {Human} {Culture}},
	url = {https://cognitivesciencesociety.org/cogsci20/papers/0002/0002.pdf},
	abstract = {Human culture is a collective phenomenon, emerging from the interactions of individual minds. While cognitive science has traditionally focused on the individual, there is a growing interest in how cognitive processes are shaped by, and in turn shape, the collective. This paper introduces the symposium on Cognition, Collectives, and Human Culture, which brings together researchers from across the cognitive sciences to discuss the interplay between individual cognition and collective behavior. We highlight three key themes: the role of social learning in cultural evolution, the cognitive mechanisms underlying collective intelligence, and the impact of cultural structures on individual cognition.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 42nd Annual Conference of the Cognitive Science Society},
	publisher = {Cognitive Science Society},
	author = {Wu, Charley M. and Vélez, Natalia and Ho, Mark K. and Goldstone, Robert L.},
	editor = {Denison, Stephanie and Mack, Michael and Xu, Yang and Armstrong, Blair C.},
	year = {2020},
	keywords = {Cognition, Cognitive science, Psychology, Neuroscience, COGSCI},
}
