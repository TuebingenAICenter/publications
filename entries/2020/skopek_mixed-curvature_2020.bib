@inproceedings{skopek_mixed-curvature_2020,
	title = {Mixed-curvature {Variational} {Autoencoders}},
	shorttitle = {Mixed-curvature {Variational} {Autoencoders}},
	url = {https://openreview.net/pdf?id=S1g6xeSKDS},
	abstract = {Variational Autoencoders (VAEs) are powerful generative models that rely on a latent space to represent data. While Euclidean space is the standard choice for the latent manifold, recent work has shown that hyperbolic space is better suited for hierarchical data. However, real-world data often exhibits a mixture of hierarchical and cyclic structures, which cannot be captured by a single constant curvature space. In this paper, we propose Mixed-Curvature Variational Autoencoders (MC-VAEs), a framework that learns a latent space with mixed curvature. We introduce a novel product manifold consisting of spherical, Euclidean, and hyperbolic components, and we derive the corresponding Riemannian geometry to perform variational inference. We demonstrate that MC-VAEs outperform their single-curvature counterparts on a variety of datasets, including those with complex hierarchical and cyclic structures.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {8th {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Skopek, Ondrej and Ganea, Octavian-Eugen and Becigneul, Gary},
	month = apr,
	year = {2020},
	keywords = {ICLR},
}
