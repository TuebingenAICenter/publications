@misc{besserve_assaying_2020,
	title = {Assaying {Large}-scale {Testing} {Models} to {Interpret} {Covid}-19 {Case} {Numbers}. {A} {Cross}-country {Study}},
	shorttitle = {Assaying {Large}-scale {Testing} {Models}},
	url = {https://arxiv.org/abs/2012.01912},
	doi = {10.48550/arXiv.2012.01912},
	abstract = {The number of confirmed COVID-19 cases is a key metric for monitoring the pandemic, but it is heavily influenced by the testing strategy and capacity of each country. We propose a model to estimate the true number of infections by accounting for the testing effort. We apply this model to data from several countries and show that it can explain a significant part of the variation in reported case numbers. Our results suggest that the true number of infections is often much higher than the number of confirmed cases, and that the testing effort is a crucial factor in interpreting the reported data.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Besserve, Michel and Buchholz, Simon and Schölkopf, Bernhard},
	year = {2020},
	keywords = {Coronavirus disease 2019 (COVID-19), Contrast (vision), Econometrics, Severe acute respiratory syndrome coronavirus 2 (SARS-CoV-2), Pandemic, Limiting, Scale (ratio), 2019-20 coronavirus outbreak, Statistical hypothesis testing, Statistics, Mathematics, Computer science, Geography, Medicine, Artificial intelligence, Virology, Engineering, Cartography, Pathology, Infectious disease (medical specialty), Outbreak},
}
