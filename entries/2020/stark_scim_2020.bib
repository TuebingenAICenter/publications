@article{stark_scim_2020,
	title = {{SCIM}: universal single-cell matching with unpaired feature sets},
	issn = {1367-4803},
	shorttitle = {{SCIM}},
	url = {https://academic.oup.com/bioinformatics/article/36/Supplement_2/i919/5936356},
	doi = {10.1093/bioinformatics/btaa843},
	abstract = {Motivation: Single-cell technologies allow for the characterization of cellular states at high resolution. However, different technologies often measure different features (e.g. RNA and protein) on different cells, making it difficult to integrate these data. Existing methods for single-cell data integration often rely on shared features or prior knowledge of cell types, which limits their applicability. Results: We present SCIM (Single-Cell Integration and Matching), a method for integrating single-cell data with unpaired feature sets. SCIM uses a variational autoencoder framework to learn a joint latent space that captures the shared biological information across different modalities. We demonstrate that SCIM outperforms existing methods in matching cells across different technologies and in identifying shared cell types, even when the feature sets are completely disjoint. SCIM is a flexible and scalable approach that can be applied to a wide range of single-cell integration tasks.},
	language = {en},
	urldate = {2024-05-23},
	journal = {Bioinformatics},
	publisher = {Oxford University Press},
	author = {Stark, S. G. and Ficek, J. and Locatello, F. and Bonilla, X. and Chevrier, S. and Singer, F. and Consortium, Tumor Profiler and Rätsch, G. and Lehmann, K.-V.},
	year = {2020},
	keywords = {BIOINFORMATICS},
}
