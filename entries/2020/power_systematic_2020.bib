@misc{power_systematic_2020,
	title = {Systematic spatiotemporal mapping reveals divergent cell death pathways in three mouse models of hereditary retinal degeneration},
	shorttitle = {Systematic spatiotemporal mapping},
	url = {https://onlinelibrary.wiley.com/doi/full/10.1002/cne.24807},
	doi = {10.1002/cne.24807},
	abstract = {Hereditary retinal degeneration (RD) is a group of clinically and genetically heterogeneous diseases that lead to blindness. Despite the diversity of the underlying genetic mutations, the final common pathway is the death of photoreceptors. To better understand the mechanisms of cell death, we performed a systematic spatiotemporal mapping of the retina in three mouse models of RD: the rd1, rd10, and VPP mice. We used a combination of immunohistochemistry, TUNEL staining, and live-cell imaging to track the progression of cell death and the activation of cell death pathways. We found that the spatiotemporal pattern of cell death was distinct in each model. In the rd1 mouse, cell death was rapid and occurred throughout the retina, whereas in the rd10 and VPP mice, cell death was slower and showed a distinct spatial progression. Furthermore, we identified divergent cell death pathways, with the rd1 mouse showing a predominance of parthanatos, while the rd10 and VPP mice showed a mix of apoptosis and other cell death mechanisms. Our results suggest that the mechanisms of cell death in RD are not uniform and that therapeutic strategies may need to be tailored to the specific genetic and spatiotemporal context of the disease.},
	language = {en},
	type = {{journalArticle}},
	urldate = {2025-05-14},
	publisher = {Wiley},
	author = {Power, Michael J. and Rogerson, Luke E. and Schubert, Timm and Berens, Philipp and Euler, Thomas and Paquet-Durand, François},
	month = mar,
	year = {2020},
	keywords = {Retinal degeneration, Degeneration (medical), Biology, Retinal, Neuroscience, Pathology, Retina, Medicine},
}
