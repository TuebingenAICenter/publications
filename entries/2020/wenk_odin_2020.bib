@misc{wenk_odin_2020,
	title = {{ODIN}: {ODE}-{Informed} {Regression} for {Parameter} and {State} {Inference} in {Time}-{Continuous} {Dynamical} {Systems}},
	shorttitle = {{ODIN}},
	url = {https://aaai.org/ojs/index.php/AAAI/article/view/6106},
	doi = {10.1609/aaai.v34i04.6106},
	abstract = {We consider the problem of inferring parameters and latent states of time-continuous dynamical systems from noisy, irregularly sampled observations. While Gaussian processes (GPs) are a powerful tool for regression, they do not naturally incorporate the structural knowledge provided by ordinary differential equations (ODEs). We propose ODIN, a novel framework that leverages the structure of ODEs to perform inference in dynamical systems. By using a GP prior on the derivative of the state, we can formulate the inference problem as a regression task that is informed by the ODE. We show that this approach allows for efficient and accurate parameter and state estimation, even in the presence of sparse and noisy data. We demonstrate the effectiveness of our method on several synthetic and real-world benchmarks.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {AAAI Press},
	author = {Wenk, Philippe and Abbati, Gabriele and Osborne, Michael A. and Schölkopf, Bernhard and Krause, Andreas and Bauer, Stefan},
	year = {2020},
	keywords = {Ode, Inference, Leverage (statistics), Computer science, Ordinary differential equation, Gaussian process, State (computer science), Gaussian, Mathematical optimization, Algorithm, Machine learning, Artificial intelligence, Applied mathematics, Mathematics, Differential equation, AAAI},
}
