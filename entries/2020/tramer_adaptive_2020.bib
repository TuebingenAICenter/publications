@misc{tramer_adaptive_2020,
	title = {On {Adaptive} {Attacks} to {Adversarial} {Example} {Defenses}},
	url = {https://proceedings.neurips.cc/paper/2020/hash/11f38f8ecd71867b42433548d1078e38-Abstract.html},
	doi = {10.48550/arxiv.2002.08347},
	abstract = {Many defenses against adversarial examples are proposed every year, but most are subsequently broken by stronger attacks. A common reason for this is the use of a non-adaptive attack: the attacker does not account for the specific mechanism of the defense. In this paper, we argue that evaluating a defense against non-adaptive attacks is insufficient and can lead to a false sense of security. We propose a framework for evaluating defenses against adaptive attacks, where the attacker is aware of the defense and adapts their attack accordingly. We demonstrate the effectiveness of our framework by evaluating several recent defenses and showing that they are vulnerable to adaptive attacks, even when they were previously thought to be robust.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Tramer, Florian and Carlini, Nicholas and Brendel, Wieland and Madry, Aleksander},
	year = {2020},
	keywords = {Adversarial system, Computer science, De facto, Computer security, Risk analysis (engineering), Artificial intelligence, Business, Political science, Law, NEURIPS},
}
