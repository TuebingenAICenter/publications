@misc{jitkrittum_testing_2020,
	title = {Testing {Goodness} of {Fit} of {Conditional} {Density} {Models} with {Kernels}},
	url = {http://proceedings.mlr.press/v124/jitkrittum20a.html},
	doi = {10.48550/arxiv.2002.10271},
	abstract = {We propose a kernel-based test for the goodness of fit of a conditional density model. Given a conditional density model p(yx) and a set of i.i.d. samples \{(xi, yi)\}i=1ˆn, we wish to test whether the model is correct, i.e., whether the true conditional density q(yx) is equal to p(yx). Our test statistic is based on the kernel conditional mean embedding of the difference between the true conditional distribution and the model. We show that the test statistic can be computed in O(nˆ2) time, and its asymptotic null distribution is a weighted sum of chi-square random variables. We further propose a wild bootstrap procedure to approximate the null distribution, which is shown to be consistent. Our test is powerful against general alternatives and does not require the density model to be normalized. We demonstrate the effectiveness of our test on synthetic and real-world data, including a conditional density estimation task for a complex physical system.},
	language = {en},
	publisher = {PMLR},
	author = {Jitkrittum, Wittawat and Kanagawa, Heishiro and Schölkopf, Bernhard},
	editor = {Peters, Jonas and Sontag, David},
	month = aug,
	year = {2020},
	keywords = {Conditional probability distribution, Goodness of fit, Mathematics, Interpretability, Statistics, Covariate, Conditional variance, Density estimation, Nonparametric statistics, Conditional expectation, Probability density function, Econometrics, Computer science, Artificial intelligence, UAI},
}
