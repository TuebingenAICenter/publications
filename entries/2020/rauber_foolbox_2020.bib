@article{rauber_foolbox_2020,
	title = {Foolbox {Native}: {Fast} adversarial attacks to benchmark the robustness of machine learning models in {PyTorch}, {TensorFlow}, and {JAX}},
	issn = {2475-9066},
	shorttitle = {Foolbox {Native}},
	url = {https://joss.theoj.org/papers/10.21105/joss.02607},
	doi = {10.21105/joss.02607},
	abstract = {Foolbox is a Python library that lets you easily benchmark the robustness of machine learning models. It provides access to a large number of adversarial attacks, which can be used to fool models and test their robustness. Foolbox Native is a complete rewrite of Foolbox that is designed to be fast and easy to use with PyTorch, TensorFlow, and JAX. It is built on top of eager execution and provides a unified interface for all three frameworks.},
	language = {en},
	urldate = {2025-05-14},
	journal = {The Journal of Open Source Software},
	publisher = {The Open Journal},
	author = {Rauber, Jonas and Zimmermann, Roland and Bethge, Matthias and Brendel, Wieland},
	year = {2020},
	keywords = {Robustness (evolution), Benchmark (surveying), Artificial intelligence, Computer science, Adversarial system, Machine learning, Deep learning, Cartography, Geography, Chemistry, JOSS},
}
