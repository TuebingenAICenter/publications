@misc{huang_causal_2020,
	title = {Causal {Discovery} from {Heterogeneous}/{Nonstationary} {Data}},
	url = {http://jmlr.org/papers/v21/19-232.html},
	abstract = {Causal discovery from observational data is a fundamental problem in science and engineering. Most existing methods assume that the data are generated from a single stationary distribution. However, in many real-world applications, data are collected from multiple domains or environments, or are nonstationary, which may contain rich information about the underlying causal structure. In this paper, we propose a framework for causal discovery from heterogeneous/nonstationary data. We show that the changes in the distribution of the data, which are often considered a nuisance in standard causal discovery, can be exploited to identify the causal structure. We propose a method to learn the causal structure by modeling the changes in the data distribution, and we provide theoretical results on the identifiability of the causal structure. We also demonstrate the effectiveness of our method on both synthetic and real-world data.},
	language = {en},
	publisher = {Journal of Machine Learning Research},
	author = {Huang, Biwei and Zhang, Kun and Zhang, Jiji and Ramsey, Joseph and Sánchez-Romero, Rubén and Glymour, Clark and Schölkopf, Bernhard},
	year = {2020},
	keywords = {Causal structure, Computer science, Causal model, Constraint (computer-aided design), Representation (politics), Data mining, Econometrics, Artificial intelligence, Machine learning, Mathematics, Statistics, JMLR},
}
