@inproceedings{kalatzis_variational_2020,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Variational {Autoencoders} with {Riemannian} {Brownian} {Motion} {Priors}},
	url = {http://proceedings.mlr.press/v119/kalatzis20a/kalatzis20a.pdf},
	abstract = {We propose a new class of priors for Variational Autoencoders (VAEs) based on Riemannian Brownian motion. By defining a diffusion process on a learned Riemannian manifold, we allow the latent space to capture the geometry of the data. This leads to a more flexible prior that can adapt to the underlying structure of the data, while still being computationally tractable. We demonstrate the effectiveness of our approach on several benchmarks, showing that it outperforms standard VAEs and other manifold-based models.},
	language = {en},
	booktitle = {Proceedings of the 37th {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Kalatzis, Dimitrios and Eklund, David and Arvanitidis, Georgios and Hauberg, Søren},
	editor = {Daumé III, Hal and Singh, Aarti},
	month = jul,
	year = {2020},
	keywords = {ICML},
}
