@article{tejero-cantero_sbi_2020,
	title = {sbi: {A} toolkit for simulation-based inference},
	issn = {2475-9066},
	shorttitle = {sbi},
	url = {https://doi.org/10.21105/joss.02505},
	doi = {10.21105/joss.02505},
	abstract = {Simulation-based inference (SBI) is a set of methods for performing Bayesian inference when the likelihood function is intractable but the model can be simulated. sbi is a Python package that provides a comprehensive, modular, and easy-to-use interface for modern SBI algorithms, including neural posterior estimation, neural likelihood estimation, and neural ratio estimation. It is designed to be flexible, allowing users to easily swap between different inference algorithms and models, and to be integrated into existing scientific workflows.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Open Source Software},
	publisher = {The Open Journal},
	author = {Tejero-Cantero, Alvaro and Boelts, Jan and Deistler, Michael and Lueckmann, Jan-Matthis and Durkan, Conor and Gonçalves, Pedro J. and Greenberg, David S. and Macke, Jakob H.},
	year = {2020},
	keywords = {Computer science, Generalization, Inference, Set (abstract data type), Bayesian probability, Contrast (vision), Statistical inference, Bayesian inference, Data mining, Parameter space, Machine learning, Algorithm, Black box, Artificial intelligence, Statistics, Mathematics, JOSS},
}
