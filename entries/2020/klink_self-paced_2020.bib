@inproceedings{klink_self-paced_2020,
	title = {Self-{Paced} {Deep} {Reinforcement} {Learning}},
	url = {https://proceedings.neurips.cc/paper/2020/file/68a9750337a418a86fe06c1991a1d64c-Paper.pdf},
	abstract = {Deep reinforcement learning (DRL) has achieved impressive results in many challenging tasks. However, training DRL agents often requires a large number of samples and is sensitive to the order in which samples are presented. Self-paced learning (SPL) is a paradigm that mimics the human learning process by starting with easy tasks and gradually increasing the difficulty. In this paper, we propose a novel self-paced deep reinforcement learning framework that automatically determines the difficulty of tasks and schedules the training process accordingly. We show that our approach significantly improves the sample efficiency and final performance of DRL agents in various environments.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 33},
	publisher = {Curran Associates, Inc.},
	author = {Klink, Pascal and D'Eramo, Carlo and Peters, Jan and Pajarinen, Joni},
	month = dec,
	year = {2020},
	keywords = {NEURIPS},
}
