@article{bartels_conjugate_2020,
	title = {Conjugate {Gradients} for {Kernel} {Machines}},
	issn = {1532-4435},
	url = {http://jmlr.org/papers/v21/18-473.html},
	doi = {10.48550/arxiv.1911.06048},
	abstract = {Kernel methods are a cornerstone of machine learning, but their computational cost is a major bottleneck. For a dataset of size n, they typically require O(nˆ3) time and O(nˆ2) memory. We propose a method to solve the kernel linear system using the conjugate gradient (CG) method, which reduces the complexity to O(nˆ2) time and O(n) memory. Our approach is based on a novel approximation of the kernel matrix-vector product, which we derive using a low-rank approximation of the kernel matrix. We show that our method is competitive with state-of-the-art approaches in terms of accuracy and significantly faster in terms of training time.},
	language = {en},
	journal = {Journal of Machine Learning Research},
	publisher = {Journal of Machine Learning Research},
	author = {Bartels, S. and Hennig, P.},
	year = {2020},
	keywords = {Variable kernel density estimation, Kernel (algebra), Conjugate prior, Kernel embedding of distributions, Mathematics, Gaussian process, Algorithm, Computation, Kernel principal component analysis, Kernel method, Computer science, Applied mathematics, Gaussian, Mathematical optimization, Artificial intelligence, Statistics, Posterior probability, Bayesian probability, Support vector machine, Combinatorics, JMLR},
}
