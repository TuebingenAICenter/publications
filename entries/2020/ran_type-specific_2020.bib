@misc{ran_type-specific_2020,
	title = {Type-specific dendritic integration in mouse retinal ganglion cells},
	copyright = {© The Author(s) 2020},
	shorttitle = {Type-specific dendritic integration},
	url = {https://www.nature.com/articles/s41467-020-15867-9},
	doi = {10.1038/s41467-020-15867-9},
	abstract = {Retinal ganglion cells (RGCs) are the output neurons of the retina. They integrate synaptic inputs from bipolar and amacrine cells in their dendrites to compute specific visual features. While it is known that RGC types differ in their morphology and light responses, it remains unclear how dendritic integration differs between RGC types. Here, we use two-photon calcium imaging to record the activity of dendrites in four types of mouse RGCs. We find that dendritic integration is type-specific: in some RGC types, dendrites act as independent integration units, while in others, they are strongly coupled. This type-specificity is linked to the morphology of the RGCs and the spatial distribution of their synaptic inputs. Our results suggest that dendritic integration is a key mechanism for the functional diversity of RGCs.},
	language = {en},
	type = {{journalArticle}},
	urldate = {2025-05-14},
	publisher = {Nature Portfolio},
	author = {Ran, Yanli and Huang, Ziwei and Baden, Tom and Schubert, Timm and Baayen, R. Harald and Berens, Philipp and Franke, Katrin and Euler, Thomas},
	month = apr,
	year = {2020},
	keywords = {Giant retinal ganglion cells, Retinal, Bistratified cell, Intrinsically photosensitive retinal ganglion cells, Cell biology, Retinal ganglion cell, Biology, Neuroscience, Retina, Chemistry, Anatomy, Botany},
}
