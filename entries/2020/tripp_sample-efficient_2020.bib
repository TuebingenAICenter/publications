@inproceedings{tripp_sample-efficient_2020,
	title = {Sample-{Efficient} {Optimization} in the {Latent} {Space} of {Deep} {Generative} {Models} via {Weighted} {Retraining}},
	shorttitle = {Sample-{Efficient} {Optimization} in the {Latent} {Space} of {Deep} {Generative} {Models} via {Weighted} {Retraining}},
	url = {https://proceedings.neurips.cc/paper/2020/file/81e3225c6ad49623167a4309eb4b2e75-Paper.pdf},
	abstract = {We consider the problem of optimizing a black-box function defined over the output space of a deep generative model. This is a challenging task because the function is typically expensive to evaluate and the generative model is complex. We propose a new method, Weighted Retraining (WR), which addresses this problem by iteratively retraining the generative model on a weighted dataset of samples that have high function values. We show that WR is sample-efficient and can be used to optimize functions in high-dimensional spaces. We demonstrate the effectiveness of our method on a variety of tasks, including optimizing the properties of molecules and generating images with specific attributes.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 33},
	publisher = {Curran Associates, Inc.},
	author = {Tripp, A. and Daxberger, E. and Hernández-Lobato, J. M.},
	editor = {Larochelle, H. and Ranzato, M. and Hadsell, R. and Balcan, M. F. and Lin, H.},
	month = dec,
	year = {2020},
	keywords = {NEURIPS},
}
