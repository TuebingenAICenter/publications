@misc{garreau_explaining_2020,
	title = {Explaining the {Explainer}: {A} {First} {Theoretical} {Analysis} of {LIME}},
	shorttitle = {Explaining the {Explainer}},
	url = {https://arxiv.org/abs/2001.03447},
	doi = {10.48550/arxiv.2001.03447},
	abstract = {LIME (Local Interpretable Model-agnostic Explanations) is a popular method to explain the predictions of complex machine learning models. Despite its empirical success, little is known about its theoretical properties. In this paper, we provide a first theoretical analysis of LIME. We show that, under mild assumptions, the LIME explanation converges to a specific ridge regression solution as the number of samples goes to infinity. We also analyze the stability of the LIME explanation and show that it can be highly unstable, in the sense that small changes in the input can lead to large changes in the explanation. Finally, we propose a modification of LIME that improves its stability.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Proceedings of the 23rd International Conference on Artificial Intelligence and Statistics},
	author = {Garreau, Damien and von Luxburg, Ulrike},
	year = {2020},
	keywords = {Interpretability, Lime, Function (biology), Computer science, Machine learning, Artificial intelligence, Geology, AISTATS},
}
