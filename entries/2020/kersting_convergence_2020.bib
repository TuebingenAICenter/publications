@article{kersting_convergence_2020,
	title = {Convergence rates of {Gaussian} {ODE} filters},
	issn = {0960-3174},
	shorttitle = {Convergence rates of {Gaussian} {ODE} filters},
	url = {https://is.mpg.de/ei/publications/kersulhen20},
	doi = {10.1007/s11222-020-09972-4},
	abstract = {Probabilistic numerical methods for ordinary differential equations (ODEs) provide not only a point estimate of the solution, but also a quantification of the uncertainty arising from the discretization. Gaussian ODE filters are a prominent class of such methods, which treat the ODE as a state-space model and perform Bayesian filtering to infer the solution. Despite their popularity, their convergence properties have remained largely unexplored. In this paper, we provide a rigorous analysis of the convergence rates of Gaussian ODE filters. We show that, under appropriate conditions, the posterior mean of the Gaussian ODE filter converges to the true solution of the ODE at a rate determined by the order of the underlying Taylor expansion and the regularity of the vector field. We also show that the posterior variance contracts at a rate consistent with the error in the posterior mean, which justifies the use of the posterior variance as a measure of uncertainty. Our theoretical results are supported by numerical experiments.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Statistics and Computing},
	publisher = {Springer},
	author = {Kersting, H. and Sullivan, T. J. and Hennig, P.},
	year = {2020},
	keywords = {Ode, Mathematics, Gaussian, Rate of convergence, Applied mathematics, Ordinary differential equation, Truncation (statistics), Brownian motion, Convergence (economics), Initial value problem, Gaussian process, Range (aeronautics), A priori and a posteriori, Mathematical analysis, Differential equation, Computer science, Statistics, Physics, STATCOMP},
}
