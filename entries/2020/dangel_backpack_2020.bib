@inproceedings{dangel_backpack_2020,
	title = {{BackPACK}: {Packing} more into {Backprop}},
	shorttitle = {{BackPACK}},
	url = {https://openreview.net/forum?id=BJlrF24twB},
	doi = {10.48550/arxiv.1912.10985},
	abstract = {Modern deep learning relies on the backpropagation algorithm to compute gradients. However, gradients are often not enough: second-order information, variances, or individual gradients are required for many advanced optimization methods, diagnostics, and analyses. We present BackPACK, an efficient framework built on top of PyTorch that extends backpropagation to extract this additional information. BackPACK is modular, easy to use, and computationally efficient, often requiring only a small overhead compared to standard backpropagation. We demonstrate its utility by implementing several second-order optimizers and diagnostic tools, showing that they can be used to train deep neural networks with minimal code changes.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {8th {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Dangel, Felix and Kunstner, Frederik and Hennig, Philipp},
	month = apr,
	year = {2020},
	keywords = {Hessian matrix, Computer science, Benchmark (surveying), Deep learning, Focus (optics), Artificial neural network, Backpropagation, Artificial intelligence, Code (set theory), Automatic differentiation, Replication (statistics), Deep neural networks, Software, Impossibility, Theoretical computer science, Machine learning, Mathematical optimization, Algorithm, Applied mathematics, Mathematics, Computation, Programming language, ICLR},
}
