@inproceedings{bachmann_constant_2020,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Constant {Curvature} {Graph} {Convolutional} {Networks}},
	shorttitle = {{CCGCN}},
	url = {http://proceedings.mlr.press/v119/bachmann20a/bachmann20a.pdf},
	abstract = {We introduce Constant Curvature Graph Convolutional Networks (CCGCNs), a framework for learning on graphs that generalizes Graph Convolutional Networks (GCNs) to spaces of constant curvature, namely spherical and hyperbolic spaces. We propose a novel approach to perform convolutions in these spaces by leveraging the exponential and logarithmic maps, which allow us to map graph data to and from the tangent space of a manifold. We demonstrate that our approach is effective for node classification and link prediction tasks on various datasets, outperforming Euclidean GCNs and other baselines.},
	language = {en},
	booktitle = {Proceedings of the 37th {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Bachmann, Gregor and Becigneul, Gary and Ganea, Octavian-Eugen},
	editor = {Daumé III, Hal and Singh, Aarti},
	month = jul,
	year = {2020},
	keywords = {ICML},
}
