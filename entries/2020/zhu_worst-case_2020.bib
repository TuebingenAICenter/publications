@misc{zhu_worst-case_2020,
	title = {Worst-{Case} {Risk} {Quantification} under {Distributional} {Ambiguity} using {Kernel} {Mean} {Embedding} in {Moment} {Problem}},
	url = {https://doi.org/10.1109/CDC42340.2020.9303938},
	doi = {10.1109/CDC42340.2020.9303938},
	abstract = {We consider the problem of quantifying the worst-case risk of a system under distributional ambiguity. The ambiguity is represented by a set of probability distributions that satisfy a set of moment constraints. We propose a novel approach to solve this problem by embedding the distributions into a reproducing kernel Hilbert space (RKHS). The moment constraints are then expressed as linear constraints on the kernel mean embeddings. This formulation leads to a convex optimization problem, which can be solved efficiently. We provide theoretical guarantees for the convergence of the proposed estimator and demonstrate its effectiveness on several numerical examples.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {IEEE},
	author = {Zhu, Jia-Jie and Jitkrittum, Wittawat and Diehl, Moritz and Schölkopf, Bernhard},
	month = dec,
	year = {2020},
	keywords = {Reproducing kernel Hilbert space, Kernel (algebra), Ambiguity, Moment problem, Constraint (computer-aided design), Moment (physics), Embedding, Mathematics, Context (archaeology), Kernel embedding of distributions, Kernel method, Applied mathematics, Variable kernel density estimation, Mathematical optimization, Hilbert space, Computer science, Discrete mathematics, Mathematical analysis, Statistics, Artificial intelligence, Support vector machine, CDC},
}
