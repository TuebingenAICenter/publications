@article{berens_potential_2020,
	title = {Potential of methods of artificial intelligence for quality assurance},
	issn = {0941-293X},
	shorttitle = {Potential of methods of artificial intelligence for quality assurance},
	url = {https://link.springer.com/article/10.1007/s00347-020-01063-z},
	doi = {10.1007/s00347-020-01063-z},
	abstract = {Die Qualitätssicherung in der Augenheilkunde ist ein zentrales Thema, um eine hohe Versorgungsqualität zu gewährleisten. Methoden der künstlichen Intelligenz (KI) bieten hierfür neue Möglichkeiten. In diesem Beitrag werden die Potenziale von KI-Methoden für die Qualitätssicherung in der Augenheilkunde diskutiert. Dabei werden sowohl die Möglichkeiten der automatisierten Bildanalyse als auch die Analyse von strukturierten Daten betrachtet. Zudem werden Herausforderungen und Limitationen bei der Implementierung von KI-Methoden in den klinischen Alltag aufgezeigt.},
	language = {de},
	urldate = {2025-05-14},
	journal = {Der Ophthalmologe},
	publisher = {Springer Nature},
	author = {Berens, Philipp and Waldstein, Sebastian M. and Ayhan, M. S. and Kuemmerle, L. and Agostini, H. and Stahl, A. and Ziemssen, F.},
	month = feb,
	year = {2020},
	keywords = {AI},
}
