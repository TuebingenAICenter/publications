@article{geirhos_shortcut_2020,
	title = {Shortcut learning in deep neural networks},
	issn = {2522-5839},
	shorttitle = {Shortcut learning in deep neural networks},
	url = {https://www.nature.com/articles/s42256-020-00257-z},
	doi = {10.1038/s42256-020-00257-z},
	abstract = {Deep neural networks are highly successful at many tasks, but they often rely on 'shortcuts'—decision rules that perform well on standard benchmarks but fail to generalize to more challenging testing conditions, such as real-world scenarios. Here we argue that shortcut learning is a common phenomenon in deep learning and that it is the primary reason for the surprising failures of deep neural networks when they are tested on data that differs even slightly from the training distribution. We provide a conceptual framework for understanding shortcut learning, review evidence for its existence across various domains and discuss how it can be mitigated.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Nature Machine Intelligence},
	publisher = {Nature Portfolio},
	author = {Geirhos, Robert and Jacobsen, Jörn-Henrik and Michaelis, Claudio and Zemel, Richard and Brendel, Wieland and Bethge, Matthias and Wichmann, Felix A.},
	month = nov,
	year = {2020},
	keywords = {Artificial intelligence, Computer science, Deep learning, Transferability, Benchmarking, Machine learning, Artificial neural network, Deep neural networks, Robustness (evolution), Perspective (graphical), Management},
}
