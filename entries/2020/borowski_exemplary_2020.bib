@misc{borowski_exemplary_2020,
	title = {Exemplary {Natural} {Images} {Explain} {CNN} {Activations} {Better} than {Feature} {Visualizations}},
	shorttitle = {Exemplary natural images},
	url = {https://brendel-group.github.io/publication/2020_10_borowski/},
	doi = {10.48550/arxiv.2010.12606},
	abstract = {Feature visualization is a popular technique to interpret the internal representations of convolutional neural networks (CNNs). However, it remains unclear whether these visualizations are faithful to the features that the network actually uses for its predictions. In this paper, we propose a new approach to interpret CNN activations: we identify exemplary natural images that maximally activate a given neuron or channel. We show that these natural images are more interpretable than standard feature visualizations (e.g., optimization-based visualizations) in a human-subject experiment. Furthermore, we find that natural images are more faithful to the network's internal representations, as they are better at predicting the network's behavior on unseen data. Our results suggest that natural images are a more suitable tool for interpreting CNNs than synthetic feature visualizations.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Borowski, Judy and Zimmermann, Roland S. and Schepers, Judith and Geirhos, Robert and Wallis, Thomas S. A. and Bethge, Matthias and Brendel, Wieland},
	year = {2020},
	keywords = {Interpretability, Computer science, Artificial intelligence, Feature (linguistics), Convolutional neural network, Visualization, Margin (machine learning), Pattern recognition (psychology), Synthetic data, Natural (archaeology), Image (mathematics), Computer vision, Machine learning, NEURIPS, ICLR},
}
