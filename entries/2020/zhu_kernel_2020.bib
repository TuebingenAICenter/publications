@misc{zhu_kernel_2020,
	title = {A {Kernel} {Mean} {Embedding} {Approach} to {Reducing} {Conservativeness} in {Stochastic} {Programming} and {Control}},
	url = {http://proceedings.mlr.press/v120/zhu20a.html},
	doi = {10.48550/arxiv.2001.10398},
	abstract = {Stochastic programming and control problems often involve chance constraints, which are typically difficult to solve due to the need for evaluating the probability of constraint violation. A common approach is to use conservative approximations, such as the Conditional Value-at-Risk (CVaR) or the Cantelli inequality, which can lead to overly conservative solutions. In this paper, we propose a new approach to reducing this conservativeness by using kernel mean embeddings of distributions. We show that the chance constraint can be reformulated as a deterministic constraint on the kernel mean embedding of the distribution of the constraint violation. This allows us to use convex optimization techniques to solve the problem. We demonstrate the effectiveness of our approach on several numerical examples, showing that it can significantly reduce the conservativeness of the solutions compared to existing methods.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Zhu, J.-J. and Diehl, M. and Schölkopf, B.},
	editor = {Bayen, Alexandre M. and Jadbabaie, Ali and Pappas, George and Parrilo, Pablo A. and Recht, Benjamin and Tomlin, Claire and Zeilinger, Melanie},
	month = jun,
	year = {2020},
	keywords = {Embedding, Mathematical optimization, Constraint (computer-aided design), Kernel (algebra), Stochastic optimization, Set (abstract data type), Stochastic programming, Control (management), Optimization problem, Mathematics, Computer science, Artificial intelligence, L4DC},
}
