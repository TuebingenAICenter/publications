@article{tabibian_design_2020,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {On the design of consequential ranking algorithms},
	url = {http://proceedings.mlr.press/v124/tabibian20a.html},
	abstract = {Ranking algorithms are ubiquitous in online platforms, where they are used to sort items such as news articles, products, or search results. However, most existing ranking algorithms are designed to maximize immediate user engagement, ignoring the long-term consequences of their decisions on the items being ranked. In this paper, we study the design of consequential ranking algorithms, which explicitly account for the long-term impact of ranking decisions on the items. We formulate the problem as a reinforcement learning task and propose a novel algorithm, which we call Consequential Ranking (CR). We show that CR can be learned efficiently and that it outperforms existing ranking algorithms in terms of long-term utility in both synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 36th International Conference on Uncertainty in Artificial Intelligence (UAI)},
	publisher = {PMLR},
	author = {Tabibian, Behzad and Gómez, Vicenç and De, Abir and Schölkopf, Bernhard and Gomez-Rodriguez, Manuel},
	editor = {Peters, Jonas and Sontag, David},
	month = aug,
	year = {2020},
	keywords = {Computer science, Ranking (information retrieval), Algorithm design, Artificial intelligence, Algorithm, UAI},
}
