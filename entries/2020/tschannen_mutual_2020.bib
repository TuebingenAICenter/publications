@inproceedings{tschannen_mutual_2020,
	title = {On {Mutual} {Information} {Maximization} for {Representation} {Learning}},
	shorttitle = {On {Mutual} {Information} {Maximization} for {Representation} {Learning}},
	url = {https://openreview.net/forum?id=rkxoh24FPH},
	abstract = {Mutual information (MI) maximization has become a popular objective for self-supervised representation learning. Many recent approaches maximize a lower bound on the MI between different views of the data. In this paper, we show that the success of these methods is not necessarily due to the properties of MI, but rather to the choice of the architecture and the data augmentation strategy. We demonstrate this by constructing a family of objectives that maximize a lower bound on the MI, but which can be optimized to yield representations that are completely independent of the input. We further show that these objectives can be interpreted as a form of contrastive learning, and that the performance of these methods is strongly correlated with the quality of the learned representations. Our results suggest that the success of MI maximization for representation learning is largely due to the inductive biases of the models and the data augmentation, rather than the MI objective itself.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {8th {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Tschannen, Michael and Djolonga, Josip and Rubenstein, Paul K. and Gelly, Sylvain and Lucic, Mario},
	month = apr,
	year = {2020},
	keywords = {ICLR},
}
