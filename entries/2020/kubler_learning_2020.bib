@misc{kubler_learning_2020,
	title = {Learning {Kernel} {Tests} {Without} {Data} {Splitting}},
	url = {https://papers.nips.cc/paper/2020/hash/44f683a84163b3523afe57c2e008bc8c-Abstract.html},
	doi = {10.48550/arxiv.2006.02286},
	abstract = {Kernel-based hypothesis tests are powerful tools for detecting differences between distributions. A common practice to ensure the validity of these tests is to split the data into two parts: one for learning the test statistic (e.g., optimizing kernel parameters) and one for performing the test. However, data splitting is sample-inefficient, especially in the small-sample regime. In this paper, we propose a framework to learn kernel tests without data splitting. We achieve this by formulating the test as a learning problem where the objective is to maximize the test power while controlling the Type-I error rate. We show that the proposed test is consistent and has a well-controlled Type-I error rate. Experimental results on various synthetic and real-world datasets demonstrate that our method consistently outperforms existing kernel tests that rely on data splitting.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Kübler, Jonas M. and Jitkrittum, Wittawat and Schölkopf, Bernhard and Muandet, Krikamol},
	editor = {Larochelle, H. and Ranzato, M. and Hadsell, R. and Balcan, M. F. and Lin, H.},
	month = dec,
	year = {2020},
	keywords = {Inference, Kernel (algebra), Hyperparameter, Computer science, Statistical hypothesis testing, Mathematics, Sample size determination, Null hypothesis, Algorithm, Statistics, Machine learning, Artificial intelligence, NEURIPS},
}
