@misc{szatko_neural_2020,
	title = {Neural circuits in the mouse retina support color vision in the upper visual field},
	copyright = {© The Author(s) 2020},
	shorttitle = {Neural circuits in the mouse retina},
	url = {https://www.nature.com/articles/s41467-020-17113-8},
	doi = {10.1038/s41467-020-17113-8},
	abstract = {The mouse retina is generally considered to be color-blind, despite the presence of two opsins (M- and S-opsin) in its cones. Here, we show that the mouse retina is capable of color processing. We find that the mouse retina is organized into two functional zones: a ventral region dominated by M-opsin and a dorsal region with a gradient of S-opsin. We show that this organization is reflected in the functional properties of retinal ganglion cells (RGCs). Specifically, we identify a population of RGCs in the dorsal retina that are sensitive to the ratio of M- and S-cone input, a prerequisite for color opponency. These cells are tuned to the spectral composition of the upper visual field, which is dominated by the sky. Our results suggest that the mouse retina is specialized for color vision in the upper visual field, likely to support the detection of aerial predators.},
	language = {en},
	type = {{journalArticle}},
	urldate = {2025-05-14},
	publisher = {Nature Portfolio},
	author = {Szatko, Klaudia P. and Korympidou, Maria M. and Ran, Yanli and Berens, Philipp and Dalkara, Deniz and Schubert, Timm and Euler, Thomas and Franke, Katrin},
	month = jul,
	year = {2020},
	keywords = {Retina, Color vision, Computer vision, Computer science, Artificial intelligence, Visual field, Neuroscience, Psychology},
}
