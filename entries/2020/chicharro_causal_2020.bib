@misc{chicharro_causal_2020,
	title = {Causal learning with sufficient statistics: an information bottleneck approach},
	shorttitle = {Causal learning with sufficient statistics},
	url = {https://arxiv.org/abs/2010.05375},
	abstract = {We propose a framework for causal discovery based on the principle of the Information Bottleneck (IB). We show that the causal structure of a system can be identified by finding a representation of the observed variables that is maximally informative about the future, while being minimally informative about the past, given the current state. This approach allows us to identify causal relationships without assuming any specific functional form for the underlying dynamics. We demonstrate the effectiveness of our method on synthetic and real-world data, showing that it outperforms existing methods in terms of accuracy and robustness.},
	language = {en},
	urldate = {2024-05-23},
	publisher = {arXiv},
	author = {Chicharro, Daniel and Besserve, Michel and Panzeri, Stefano},
	year = {2020},
	keywords = {ARXIV},
}
