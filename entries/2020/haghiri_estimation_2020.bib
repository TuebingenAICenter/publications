@misc{haghiri_estimation_2020,
	title = {Estimation of perceptual scales using ordinal embedding},
	shorttitle = {Estimation of perceptual scales},
	url = {https://doi.org/10.1167/jov.20.9.14},
	doi = {10.1167/jov.20.9.14},
	abstract = {Ordinal embedding is the problem of finding a low-dimensional Euclidean representation of a set of objects given only ordinal information about their distances (e.g., 'object A is closer to object B than to object C'). In this paper, we propose a new method for ordinal embedding that is specifically designed to estimate perceptual scales. Our method is based on a probabilistic model of the ordinal data, and it allows us to estimate the underlying perceptual scale even when the data are noisy or incomplete. We demonstrate the effectiveness of our method on both synthetic and real-world data, and we show that it outperforms existing methods in terms of both accuracy and robustness.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Association for Research in Vision and Ophthalmology},
	author = {Haghiri, Siavash and Wichmann, Felix A. and von Luxburg, Ulrike},
	year = {2020},
	keywords = {Embedding, Psychophysics, Scaling, Multidimensional scaling, Ordinal data, Perception, Mathematics, Computer science, Artificial intelligence, Stimulus (psychology), Algorithm, Statistics, Cognitive psychology, Psychology, Geometry, JOV},
}
