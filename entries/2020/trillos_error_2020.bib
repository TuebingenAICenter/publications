@article{trillos_error_2020,
	title = {Error {Estimates} for {Spectral} {Convergence} of the {Graph} {Laplacian} on {Random} {Geometric} {Graphs} {Toward} the {Laplace}–{Beltrami} {Operator}},
	issn = {1615-3375},
	url = {https://link.springer.com/article/10.1007/s10208-019-09436-w},
	doi = {10.1007/s10208-019-09436-w},
	abstract = {We study the spectral convergence of the graph Laplacian defined on a random geometric graph constructed from n i.i.d. samples of a probability distribution supported on a compact Riemannian manifold M. We show that the eigenvalues and eigenvectors of the graph Laplacian converge to the eigenvalues and eigenfunctions of the Laplace–Beltrami operator on M. We provide explicit rates of convergence for the eigenvalues and eigenvectors. The results are obtained by establishing a quantitative consistency of the graph Laplacian as an operator on L2(M) and by using spectral perturbation theory. Our results hold for a wide range of kernels and for the standard graph Laplacian as well as the normalized graph Laplacian.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Foundations of Computational Mathematics},
	publisher = {Springer Science and Business Media LLC},
	author = {Trillos, Nicolás García and Gerlach, Moritz and Hein, Matthias and Slepčev, Dejan},
	year = {2020},
	keywords = {Mathematics, Submanifold, Laplacian matrix, Laplace operator, Eigenvalues and eigenvectors, Combinatorics, Graph, Eigenfunction, Rate of convergence, Algebraic connectivity, Laplace–Beltrami operator, Random geometric graph, Spectral graph theory, Mathematical analysis, Discrete mathematics, p-Laplacian, Voltage graph, Line graph, Physics, FOCM},
}
