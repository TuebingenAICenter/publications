@inproceedings{oh_radial_2020,
	title = {Radial and {Directional} {Posteriors} for {Bayesian} {Deep} {Learning}},
	shorttitle = {Radial and {Directional} {Posteriors}},
	url = {https://aaai.org/ojs/index.php/AAAI/article/view/5976},
	doi = {10.1609/aaai.v34i04.5976},
	abstract = {Bayesian deep learning aims to capture model uncertainty by inferring a posterior distribution over the weights of a neural network. A common approach is variational inference, which approximates the true posterior with a simpler distribution. However, the choice of the variational family is often restricted to mean-field Gaussians for computational tractability, which fails to capture complex correlations between weights. In this paper, we propose a new variational family based on radial and directional distributions. Our approach allows for flexible posterior approximations that can capture dependencies between weights while remaining computationally efficient. We demonstrate the effectiveness of our method on various benchmarks, showing that it achieves competitive performance compared to existing methods while providing better uncertainty estimates.},
	language = {en},
	booktitle = {Proceedings of the 34th {Conference} on {Artificial} {Intelligence} ({AAAI})},
	publisher = {AAAI Press},
	author = {Oh, Changheon and Adamczewski, Krzysztof and Park, Mijung},
	month = feb,
	year = {2020},
	keywords = {AAAI},
}
