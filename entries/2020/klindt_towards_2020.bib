@misc{klindt_towards_2020,
	title = {Towards {Nonlinear} {Disentanglement} in {Natural} {Data} with {Temporal} {Sparse} {Coding}},
	shorttitle = {Towards {Nonlinear} {Disentanglement}},
	url = {https://arxiv.org/abs/2007.10930},
	doi = {10.48550/arXiv.2007.10930},
	abstract = {Learning disentangled representations of natural data is a central challenge in machine learning. While recent work has shown that disentanglement is possible in the presence of temporal structure, these approaches are often limited to linear mixing models. In this paper, we propose a novel framework for nonlinear disentanglement based on temporal sparse coding. We show that by leveraging the temporal structure of natural data, we can learn disentangled representations even in the presence of nonlinear mixing. We demonstrate the effectiveness of our approach on a variety of synthetic and natural datasets, showing that it outperforms existing methods in terms of disentanglement quality and reconstruction accuracy.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Klindt, David and Schott, Lukas and Sharma, Yash and Ustyuzhaninov, Ivan and Brendel, Wieland and Bethge, Matthias and Paiton, Dylan M.},
	year = {2020},
	keywords = {Computer science, Leverage (statistics), Neural coding, Identifiability, Artificial intelligence, Generative model, Machine learning, Property (philosophy), Generative grammar, Pattern recognition (psychology), ICLR},
}
