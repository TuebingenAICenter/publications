@article{franzke_exploring_2020,
	title = {Exploring the {Relationship} {Between} {EMG} {Feature} {Space} {Characteristics} and {Control} {Performance} in {Machine} {Learning} {Myoelectric} {Control}},
	shorttitle = {Exploring the {Relationship} {Between} {EMG} {Feature} {Space} {Characteristics}},
	url = {https://is.mpg.de/ei/publications/vinjay_etal_cd20},
	doi = {10.1109/TNSRE.2020.3029873},
	abstract = {Machine learning-based myoelectric control is a promising approach for controlling prosthetic limbs. However, the performance of these systems is often inconsistent. One potential reason for this inconsistency is the variability in the electromyographic (EMG) signal, which can lead to changes in the feature space. In this study, we investigate the relationship between EMG feature space characteristics and control performance. We analyze the feature space of EMG signals recorded from 10 able-bodied subjects during a series of isometric contractions. We extract a set of commonly used time-domain features and evaluate their performance in a classification task. We find that the separability of the feature space, as measured by the Davies-Bouldin index, is strongly correlated with the classification accuracy. Furthermore, we show that the feature space characteristics are influenced by the electrode placement and the level of muscle contraction. These findings provide insights into the factors that influence the performance of machine learning-based myoelectric control systems and suggest potential strategies for improving their robustness.},
	language = {en},
	journal = {IEEE Transactions on Neural Systems and Rehabilitation Engineering},
	publisher = {IEEE},
	author = {Franzke, Andreas W. and Kristoffersen, Morten B. and Jayaram, Vinay and van der Sluis, Corry K. and Murgia, Alessio and Bongers, Raoul M.},
	month = oct,
	year = {2020},
	keywords = {TNSRE},
}
