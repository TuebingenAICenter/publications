@misc{ortega_caro_local_2020,
	title = {Local {Convolutions} {Cause} an {Implicit} {Bias} towards {High} {Frequency} {Adversarial} {Examples}},
	url = {https://arxiv.org/abs/2006.11440},
	doi = {10.48550/arxiv.2006.11440},
	abstract = {Deep convolutional neural networks (CNNs) are known to be vulnerable to adversarial examples. While many defenses have been proposed, most are broken by stronger attacks. In this paper, we show that the vulnerability of CNNs to adversarial examples is partly due to an implicit bias of local convolutions towards high-frequency features. We demonstrate that this bias is a consequence of the local connectivity and weight sharing of convolutions, which effectively act as high-pass filters. We provide a theoretical analysis of this phenomenon and show that it leads to a higher sensitivity to high-frequency perturbations. Finally, we propose a simple modification to the convolution operation that mitigates this bias and improves the robustness of CNNs to adversarial examples.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Ortega Caro, Josue and Ju, Yilong and Pyle, Ryan and Dey, Sourav and Brendel, Wieland and Anselmi, Fabio and Patel, Ankit},
	year = {2020},
	keywords = {Frequency domain, Robustness (evolution), Computer science, Adversarial system, Nonlinear system, Convolution (computer science), Algorithm, Mathematics, Artificial intelligence, Artificial neural network, Physics, Computer vision, Convolutional neural network, Bounded function, Mathematical analysis},
}
