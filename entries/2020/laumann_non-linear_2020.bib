@inproceedings{laumann_non-linear_2020,
	title = {Non-linear interlinkages and key objectives amongst the {Paris} {Agreement} and the {Sustainable} {Development} {Goals}},
	shorttitle = {Non-linear interlinkages and key objectives},
	url = {https://arxiv.org/abs/2004.09318},
	abstract = {The Paris Agreement (PA) and the 2030 Agenda for Sustainable Development (SDGs) are the two most significant international policy frameworks for sustainable development. While they are often treated as separate agendas, they are deeply interconnected. Understanding these interlinkages is crucial for policy coherence and for identifying synergies and trade-offs. In this paper, we propose a data-driven approach to map the interlinkages between the PA and the SDGs. We use natural language processing to extract key objectives from the PA and the SDGs and construct a network of interlinkages based on semantic similarity. We then use community detection and network analysis to identify key objectives and clusters of interlinkages. Our results reveal a complex, non-linear structure of interlinkages, with several key objectives acting as bridges between the two agendas. We discuss the implications of our findings for policy coherence and the implementation of the PA and the SDGs.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {{ICLR} 2020 {Workshop} "{Tackling} {Climate} {Change} with {Machine} {Learning}"},
	author = {Laumann, Felix and von Kügelgen, Julius and Barahona, Mauricio},
	month = apr,
	year = {2020},
	keywords = {ICLR},
}
