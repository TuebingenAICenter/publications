@article{koert_multi-channel_2020,
	title = {Multi-{Channel} {Interactive} {Reinforcement} {Learning} for {Sequential} {Tasks}},
	copyright = {© 2020 Koert, Kircher, Salikutluk, D'Eramo and Peters. This is an open-access article distributed under the terms of the Creative Commons Attribution License (CC BY).},
	issn = {2296-9144},
	shorttitle = {Multi-{Channel} {Interactive} {Reinforcement} {Learning}},
	url = {https://www.frontiersin.org/articles/10.3389/frobt.2020.00097/full},
	doi = {10.3389/frobt.2020.00097},
	abstract = {Interactive Reinforcement Learning (IntRL) allows agents to learn from human feedback, which can significantly speed up the learning process. However, most existing approaches rely on a single feedback channel, such as scalar rewards or demonstrations. In this paper, we propose a multi-channel IntRL framework that allows an agent to learn from multiple types of human feedback, including scalar rewards, demonstrations, and corrections. We introduce a novel approach to combine these feedback channels by learning a shared representation of the human's intent. We evaluate our approach on a set of sequential tasks and show that it outperforms single-channel IntRL methods in terms of learning speed and final performance.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Frontiers in Robotics and AI},
	publisher = {Frontiers Media S.A.},
	author = {Koert, David and Kircher, Matthias and Salikutluk, Veli and D'Eramo, Carlo and Peters, Jan},
	month = sep,
	year = {2020},
	keywords = {Reinforcement Learning, Interactive Learning, Human-Robot Interaction},
}
