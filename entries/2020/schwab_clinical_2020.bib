@article{schwab_clinical_2020,
	title = {Clinical {Predictive} {Models} for {COVID}-19: {Systematic} {Study}},
	copyright = {© Patrick Schwab, Alexander DuMont Schütte, Bernhard Dietz, Stefan Bauer. Originally published in the Journal of Medical Internet Research (http://www.jmir.org), 21.10.2020.},
	issn = {1438-8871},
	shorttitle = {Clinical {Predictive} {Models} for {COVID}-19},
	url = {http://www.jmir.org/2020/10/e21439/},
	doi = {10.2196/21439},
	abstract = {Background: The COVID-19 pandemic has triggered a surge in the development of clinical predictive models for the diagnosis and prognosis of patients with COVID-19. However, the quality and clinical utility of these models remain unclear. Objective: This study aims to systematically review and evaluate the clinical predictive models developed for COVID-19 to provide a comprehensive overview of the current state of the field and identify potential pitfalls in model development. Methods: We performed a systematic search of the literature for clinical predictive models for COVID-19 published between January 1, 2020, and May 15, 2020. We extracted information on the study design, model development, and validation procedures. We assessed the risk of bias and the applicability of the models using the Prediction Model Risk of Bias Assessment Tool (PROBAST). Results: We identified 22 studies describing 31 predictive models. Most models were developed using small, nonrepresentative datasets and lacked external validation. The majority of models were at high risk of bias, primarily due to inappropriate exclusion of patients, lack of blinding, and overfitting. Conclusions: The current landscape of clinical predictive models for COVID-19 is characterized by a high risk of bias and limited clinical utility. Future research should prioritize the use of large, representative datasets, rigorous validation procedures, and transparent reporting to ensure the development of reliable and clinically useful models.},
	language = {en},
	journal = {Journal of Medical Internet Research},
	publisher = {JMIR Publications},
	author = {Schwab, Patrick and DuMont Schütte, Alexander and Dietz, Bernhard and Bauer, Stefan},
	month = oct,
	year = {2020},
	keywords = {COVID-19, JMIR},
}
