@inproceedings{kristiadi_being_2020,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Being {Bayesian}, {Even} {Just} a {Bit}, {Fixes} {Overconfidence} in {ReLU} {Networks}},
	shorttitle = {Being {Bayesian}, {Even} {Just} a {Bit}, {Fixes} {Overconfidence} in {ReLU} {Networks}},
	url = {http://proceedings.mlr.press/v119/kristiadi20a/kristiadi20a.pdf},
	doi = {10.48550/arxiv.2002.10118},
	abstract = {Deep ReLU networks are known to be overconfident: they often assign high probabilities to incorrect predictions, especially on out-of-distribution data. We show that this is partly due to the fact that standard training (maximum likelihood) ignores the uncertainty of the network's parameters. We propose a simple, scalable Bayesian approach that approximates the posterior of the last layer's weights using the Laplace approximation. This method is computationally efficient, easy to implement, and significantly improves the calibration of ReLU networks on both in-distribution and out-of-distribution data, while maintaining competitive predictive performance.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 37th {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Kristiadi, Augustin and Hein, Matthias and Hennig, Philipp},
	editor = {Daumé III, Hal and Singh, Aarti},
	month = jul,
	year = {2020},
	keywords = {Computer science, Bayesian probability, Inference, Artificial neural network, Artificial intelligence, Machine learning, Bayesian inference, Approximate inference, Range (aeronautics), Overconfidence effect, Bayesian network, Algorithm, ICML},
}
