@misc{von_kugelgen_towards_2020,
	title = {Towards causal generative scene models via competition of experts},
	shorttitle = {Towards causal generative scene models},
	url = {https://arxiv.org/abs/2004.12906},
	doi = {10.48550/arxiv.2004.12906},
	abstract = {We propose a framework for learning causal generative models of scenes. Our approach is based on the idea that a scene can be decomposed into a set of independent causal factors, which we model as a collection of experts. Each expert is responsible for generating a specific part of the scene, and the final scene is formed by a competition between these experts. We show that this framework can learn to disentangle causal factors from raw images and that it can be used for causal reasoning and intervention.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {von Kügelgen, Julius and Ustyuzhaninov, Ivan and Gehler, Peter and Bethge, Matthias and Schölkopf, Bernhard},
	month = apr,
	year = {2020},
	keywords = {Computer science, Generative model, Generative grammar, Artificial intelligence, Object (grammar), Representation (politics), Visual reasoning, Modularity (biology), Categorization, Modular design, Contrast (vision), Machine learning, ICLR},
}
