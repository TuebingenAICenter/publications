@inproceedings{almeida_santos_decentralized_2020,
	title = {Decentralized {Data}-{Driven} {Tuning} of {Droop} {Frequency} {Controllers}},
	shorttitle = {Decentralized {Data}-{Driven} {Tuning} of {Droop} {Frequency} {Controllers}},
	url = {https://is.mpg.de/ei/publications/almgilpetste20},
	doi = {10.1109/ISGT-Europe47291.2020.9248956},
	abstract = {Droop control is a standard method for frequency regulation in power systems with high penetration of inverter-based resources. However, the performance of droop controllers is highly sensitive to the choice of droop gains. In this paper, we propose a decentralized data-driven approach to tune droop gains. Our approach relies on the observation that the frequency response of a power system can be modeled as a linear system. We use this model to formulate a convex optimization problem that minimizes the frequency deviation following a disturbance. The proposed approach is decentralized, meaning that each inverter only requires local measurements to tune its droop gain. We demonstrate the effectiveness of our approach through simulations on the IEEE 39-bus system.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {{IEEE} {PES} {Innovative} {Smart} {Grid} {Technologies} {Europe} ({ISGT}-{Europe})},
	publisher = {IEEE},
	author = {Almeida Santos, A. and Gil, C.E.M. and Peters, J. and Steinke, F.},
	year = {2020},
	keywords = {ISGT},
}
