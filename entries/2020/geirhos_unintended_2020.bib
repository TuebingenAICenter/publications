@article{geirhos_unintended_2020,
	title = {Unintended cue learning: {Lessons} for deep learning from experimental psychology},
	issn = {1534-7362},
	shorttitle = {Unintended cue learning},
	url = {https://jov.arvojournals.org/article.aspx?articleid=2771702},
	doi = {10.1167/jov.20.11.652},
	abstract = {Deep learning models are often surprisingly successful at solving complex tasks, yet they frequently fail to generalize to new data distributions. A common explanation is that models rely on unintended cues—features that are predictive in the training set but do not generalize to other contexts. In this paper, we draw on the long history of experimental psychology to provide a structured overview of unintended cue learning. We show that many phenomena in deep learning have direct counterparts in psychology, such as the Clever Hans effect, the distinction between cue and category learning, and the role of stimulus salience. By synthesizing these insights, we argue that unintended cue learning is a fundamental challenge for machine learning that requires a shift in focus from purely data-driven approaches to incorporating inductive biases and causal reasoning.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Vision},
	publisher = {Association for Research in Vision and Ophthalmology},
	author = {Geirhos, Robert and Jacobsen, Jörn-Henrik and Michaelis, Claudio and Zemel, Richard and Brendel, Wieland and Bethge, Matthias and Wichmann, Felix A.},
	year = {2020},
	keywords = {Unintended consequences, Object (grammar), Context (archaeology), Psychology, Cognitive psychology, Artificial intelligence, Cognitive science, Computer science, Epistemology, JOV, Task (project management), Fixation (population genetics), Saccade, Eye movement, Artificial neural network, Visual search, Machine learning, Pattern recognition (psychology)},
}
