@misc{mineeva_deepmased_2020,
	title = {{DeepMAsED}: evaluating the quality of metagenomic assemblies},
	shorttitle = {{DeepMAsED}},
	url = {https://academic.oup.com/bioinformatics/article-pdf/36/10/3011/33204439/btaa124.pdf},
	doi = {10.1093/bioinformatics/btaa124},
	abstract = {Motivation: Metagenomic assembly is a critical step in the analysis of microbiome data. However, the quality of metagenomic assemblies is often poor, and existing tools for evaluating assembly quality are either reference-based or rely on simple heuristics. Results: We present DeepMAsED, a deep learning-based tool for evaluating the quality of metagenomic assemblies. DeepMAsED uses a convolutional neural network to classify contigs as either correctly or incorrectly assembled based on read coverage and k-mer composition. We show that DeepMAsED outperforms existing tools in identifying misassembled contigs and is robust to variations in sequencing depth and community composition.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Oxford University Press},
	author = {Mineeva, O. and Rojas-Carulla, M. and Ley, R. E. and Schölkopf, B. and Youngblut, N. D.},
	month = feb,
	year = {2020},
	keywords = {Metagenomics, Computer science, Quality (philosophy), Computational biology, Biochemical engineering, Biology, Engineering, Genetics, Gene, Physics, Contig, Pipeline (software), Genome, Data mining, Artificial intelligence, Data science},
}
