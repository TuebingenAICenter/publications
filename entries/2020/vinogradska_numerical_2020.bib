@article{vinogradska_numerical_2020,
	title = {Numerical {Quadrature} for {Probabilistic} {Policy} {Search}},
	shorttitle = {Numerical {Quadrature} for {Probabilistic} {Policy} {Search}},
	url = {https://is.mpg.de/ei/publications/8520758},
	doi = {10.1109/TPAMI.2018.2879335},
	abstract = {Probabilistic policy search is a powerful framework for reinforcement learning that accounts for model uncertainty by optimizing a policy with respect to a distribution over dynamics models. A key challenge in this framework is the computation of the expected return, which involves an intractable integral over the state-action space. Existing approaches typically rely on moment matching or sampling to approximate this integral. In this paper, we propose to use numerical quadrature to approximate the expected return. We show that numerical quadrature can provide more accurate approximations than moment matching and is more sample-efficient than sampling-based methods. We demonstrate the effectiveness of our approach on several benchmark tasks, showing that it outperforms existing probabilistic policy search methods.},
	language = {en},
	urldate = {2024-05-23},
	journal = {IEEE Transactions on Pattern Analysis and Machine Intelligence},
	publisher = {IEEE},
	author = {Vinogradska, J. and Bischoff, B. and Achterhold, J. and Koller, T. and Peters, J.},
	year = {2020},
	keywords = {TPAMI},
}
