@misc{augustin_adversarial_2020,
	title = {Adversarial {Robustness} on {In}- and {Out}-{Distribution} {Improves} {Explainability}},
	shorttitle = {Adversarial {Robustness} on {In}- and {Out}-{Distribution} {Improves} {Explainability}},
	url = {https://arxiv.org/abs/2003.09461},
	doi = {10.1007/978-3-030-58595-2_14},
	abstract = {It has been observed that explanations of standard deep neural networks are often noisy and do not align well with human perception. While adversarial training improves robustness, it has been shown that it also leads to more interpretable gradients. In this paper, we investigate the effect of adversarial training on the explainability of deep neural networks. We show that adversarial training on the in-distribution alone is not sufficient to obtain high-quality explanations. Instead, we propose to perform adversarial training on both in- and out-distribution data. We demonstrate that this approach leads to significantly more interpretable gradients and improves the robustness of the explanations. We evaluate our method on several datasets and show that it outperforms existing methods in terms of both robustness and explainability.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Springer},
	author = {Augustin, Maximilian and Meinke, Alexander and Hein, Matthias},
	year = {2020},
	keywords = {Adversarial system, Robustness (evolution), Computer science, Artificial intelligence, Deep neural networks, Generative grammar, Machine learning, Counterfactual conditional, Pattern recognition (psychology), Artificial neural network, Counterfactual thinking, Psychology, ECCV},
}
