@inproceedings{harder_interpretable_2020,
	title = {Interpretable and {Differentially} {Private} {Predictions}},
	shorttitle = {Interpretable and {Differentially} {Private} {Predictions}},
	url = {https://aaai.org/ojs/index.php/AAAI/article/view/5827},
	doi = {10.1609/aaai.v34i04.5827},
	abstract = {We propose a method for learning interpretable models that satisfy differential privacy. Our approach is based on the observation that many interpretable models, such as decision trees or rule lists, can be viewed as a sequence of partitions of the feature space. We show that by using a differentially private mechanism to select these partitions, we can learn models that are both interpretable and satisfy differential privacy. We demonstrate the effectiveness of our approach on several real-world datasets, showing that it achieves a good trade-off between interpretability, privacy, and accuracy.},
	language = {en},
	booktitle = {Proceedings of the 34th {Conference} on {Artificial} {Intelligence} ({AAAI})},
	publisher = {AAAI Press},
	author = {Harder, F. and Bauer, M. and Park, M.},
	month = feb,
	year = {2020},
	keywords = {AAAI},
}
