@misc{brendel_learning_2020,
	title = {Learning to represent signals spike by spike},
	copyright = {CC BY 4.0},
	url = {https://journals.plos.org/ploscompbiol/article?id=10.1371/journal.pcbi.1007692},
	doi = {10.1371/journal.pcbi.1007692},
	abstract = {How do neurons represent information in their spikes? A prominent hypothesis is that neural populations represent signals by minimizing the difference between the signal and its reconstruction from spikes. This framework, often called 'predictive coding' or 'efficient coding', has been successful in explaining neural responses in various sensory systems. However, it has been difficult to apply to complex, high-dimensional signals or to learn the optimal representation from data. Here, we propose a learning rule that allows a population of spiking neurons to learn to represent signals spike by spike. The learning rule is local, biologically plausible, and allows the network to adapt to the statistics of the input signal. We show that the network learns to represent signals efficiently, achieving a reconstruction error that is close to the theoretical limit. We also show that the learned representations are robust to noise and that the network can generalize to novel signals. Our results provide a new perspective on how neural populations can learn to represent information in a spike-based manner.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Public Library of Science},
	author = {Brendel, Wieland and Bourdoukan, Ralph and Vertechi, Pietro and Machens, Christian K. and Denéve, Sophie},
	year = {2020},
	keywords = {Spike (software development), Computer science, Artificial neural network, Population, Neural coding, Biological neural network, Neuroscience, Spike train, Code (set theory), Artificial intelligence, Neuron, Machine learning, Set (abstract data type), Psychology},
}
