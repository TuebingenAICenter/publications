@article{ke_learning_2020,
	title = {Learning {Neural} {Causal} {Models} from {Unknown} {Interventions}},
	shorttitle = {Learning {Neural} {Causal} {Models}},
	url = {https://arxiv.org/abs/1910.01075},
	abstract = {Causal discovery from observational data is a notoriously difficult problem, as the causal structure is generally not identifiable without strong assumptions. Interventional data can help, but in many real-world scenarios, the interventions are unknown or only partially known. In this paper, we propose a framework for learning causal models from data where the interventions are unknown. We introduce a latent variable model that jointly learns the causal structure and the intervention targets. We demonstrate that our approach can recover the true causal structure in synthetic data and outperforms existing methods on real-world benchmarks.},
	language = {en},
	urldate = {2025-05-14},
	journal = {arXiv preprint arXiv:1910.01075},
	publisher = {arXiv},
	author = {Ke, Nan Rosemary and Bilaniuk, Olexa and Goyal, Anirudh and Bauer, Stefan and Larochelle, Hugo and Schölkopf, Bernhard and Mozer, Michael C. and Pal, Christopher and Bengio, Yoshua},
	year = {2020},
	keywords = {arXiv},
}
