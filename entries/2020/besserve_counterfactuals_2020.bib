@inproceedings{besserve_counterfactuals_2020,
	title = {Counterfactuals uncover the modular structure of deep generative models},
	shorttitle = {Counterfactuals uncover the modular structure of deep generative models},
	url = {https://openreview.net/forum?id=SJxDDpEKvH},
	abstract = {Deep generative models are often criticized for being black boxes. While they can generate high-quality samples, it is often unclear how their internal representations relate to the causal structure of the data generating process. In this paper, we propose a framework to uncover the modular structure of deep generative models by leveraging counterfactual reasoning. We show that by intervening on the latent variables of a generative model, we can identify independent causal mechanisms that are learned by the model. We demonstrate the effectiveness of our approach on several synthetic and real-world datasets, showing that it can recover the underlying causal structure of the data and provide interpretable explanations for the model's predictions.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {8th {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Besserve, Michel and Mehrjou, Arash and Sun, Rui and Schölkopf, Bernhard},
	month = apr,
	year = {2020},
	keywords = {ICLR},
}
