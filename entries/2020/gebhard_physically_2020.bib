@misc{gebhard_physically_2020,
	title = {Physically constrained causal noise models for high-contrast imaging of exoplanets},
	shorttitle = {Physically constrained causal noise models},
	url = {https://arxiv.org/abs/2010.05591},
	doi = {10.48550/arxiv.2010.05591},
	abstract = {High-contrast imaging (HCI) is a key technique for the direct detection and characterization of exoplanets. However, the raw data is dominated by quasi-static speckle noise, which is several orders of magnitude brighter than the planetary signal. Current post-processing algorithms rely on the assumption that the planetary signal and the noise can be separated based on their different temporal evolution. In this work, we propose a novel approach to HCI post-processing based on causal inference. We model the noise as a causal process and use physical constraints to disentangle the planetary signal from the noise. We demonstrate that our approach outperforms state-of-the-art algorithms on both synthetic and real data.},
	language = {en},
	urldate = {2025-05-14},
	author = {Gebhard, Timothy D. and Bonse, Markus J. and Quanz, Sascha P. and Schölkopf, Bernhard},
	year = {2020},
	keywords = {Exoplanet, Contrast (vision), Noise (video), Computer science, Geology, Physics, Artificial intelligence, Planet, Astronomy, Image (mathematics), NEURIPS},
}
