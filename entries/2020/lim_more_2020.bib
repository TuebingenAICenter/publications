@inproceedings{lim_more_2020,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {More {Powerful} {Selective} {Kernel} {Tests} for {Feature} {Selection}},
	shorttitle = {More {Powerful} {Selective} {Kernel} {Tests} for {Feature} {Selection}},
	url = {http://proceedings.mlr.press/v108/lim20a.html},
	abstract = {Feature selection is a fundamental problem in machine learning. A recent approach, the selective kernel test, performs feature selection by testing the conditional independence of a target variable given a subset of features. However, the existing selective kernel test is often underpowered because it uses a fixed kernel that may not be suitable for the data. In this paper, we propose a more powerful selective kernel test by optimizing the kernel to maximize the test power. We show that the proposed test is more powerful than the existing one and can be used for feature selection in various settings, including high-dimensional data and non-linear relationships. We also provide a theoretical analysis of the proposed test and demonstrate its effectiveness through extensive experiments.},
	language = {en},
	booktitle = {Proceedings of the 23rd {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Lim, J. N. and Yamada, M. and Jitkrittum, W. and Terada, Y. and Matsui, S. and Shimodaira, H.},
	editor = {Chiappa, Silvia and Calandra, Roberto},
	month = aug,
	year = {2020},
	keywords = {AISTATS},
}
