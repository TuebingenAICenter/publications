@inproceedings{gondal_transfer_2019,
	title = {On the {Transfer} of {Inductive} {Bias} from {Simulation} to the {Real} {World}: a {New} {Disentanglement} {Dataset}},
	shorttitle = {On the {Transfer} of {Inductive} {Bias} from {Simulation} to the {Real} {World}},
	url = {https://papers.nips.cc/paper/9704-on-the-transfer-of-inductive-bias-from-simulation-to-the-real-world-a-new-disentanglement-dataset},
	doi = {10.48550/arxiv.1906.03292},
	abstract = {Disentangled representation learning aims to separate the independent factors of variation in data. While many methods have been proposed, their evaluation is often limited to synthetic datasets where the ground truth factors are known. In this work, we introduce a new dataset for the evaluation of disentanglement methods, consisting of both simulated and real-world images of the same objects. We use this dataset to investigate the transfer of inductive biases from simulation to the real world. Our results suggest that while some methods are able to learn disentangled representations in simulation, their performance on real-world data is often limited by the domain gap. We hope that this dataset will facilitate future research on the transfer of disentangled representations to real-world applications.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 32},
	publisher = {Curran Associates, Inc.},
	author = {Gondal, Muhammad Waleed and Wüthrich, Manuel and Miladinovic, Djordje and Locatello, Francesco and Breidt, Martin and Volchkov, Valentin and Akpo, Joel and Bachem, Olivier and Schölkopf, Bernhard and Bauer, Stefan},
	editor = {Wallach, H. and Larochelle, H. and Beygelzimer, A. and d'Alché-Buc, F. and Fox, E. and Garnett, R.},
	month = dec,
	year = {2019},
	keywords = {Computer science, Hyperparameter, Variation (astronomy), Representation (politics), Object (grammar), Artificial intelligence, Key (lock), Set (abstract data type), Machine learning, Transfer of learning, Inductive bias, Data set, Position (finance), Transfer (computing), Data mining, Multi-task learning, Task (project management), Engineering, Systems engineering, NEURIPS},
