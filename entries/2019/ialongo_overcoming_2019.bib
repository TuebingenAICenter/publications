@inproceedings{ialongo_overcoming_2019,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Overcoming {Mean}-{Field} {Approximations} in {Recurrent} {Gaussian} {Process} {Models}},
	shorttitle = {Overcoming {Mean}-{Field} {Approximations} in {Recurrent} {Gaussian} {Process} {Models}},
	url = {http://proceedings.mlr.press/v97/ialongo19a.html},
	abstract = {Recurrent Gaussian Process (RGP) models are a powerful class of models for time-series data. However, exact inference is intractable, and current approximate inference methods rely on mean-field assumptions that ignore the temporal correlations in the latent state. We propose a new variational inference framework for RGPs that allows for non-mean-field posterior approximations. We achieve this by using a structured variational distribution that captures the temporal dependencies in the latent state. We demonstrate that our approach leads to better predictive performance and more accurate uncertainty estimates on a range of time-series datasets.},
	language = {en},
	booktitle = {Proceedings of the 36th {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Ialongo, A. D. and Van Der Wilk, M. and Hensman, J. and Rasmussen, C. E.},
	editor = {Chaudhuri, Kamalika and Salakhutdinov, Ruslan},
	month = jun,
	year = {2019},
	keywords = {ICML},
}
