@misc{locatello_fairness_2019,
	title = {On the {Fairness} of {Disentangled} {Representations}},
	url = {https://papers.nips.cc/paper/9603-on-the-fairness-of-disentangled-representations},
	doi = {10.48550/arxiv.1905.13662},
	abstract = {Disentangled representations are often argued to be a key ingredient for fair machine learning. The intuition is that if a model can separate the underlying factors of variation in the data, it becomes easier to control for sensitive attributes and ensure fairness. In this paper, we investigate this claim by empirically evaluating the relationship between disentanglement and fairness on a variety of datasets and models. We find that, contrary to common intuition, disentanglement does not automatically lead to fairness. In fact, we show that even with perfectly disentangled representations, models can still exhibit significant unfairness. We further analyze the conditions under which disentanglement can be beneficial for fairness and provide insights into the limitations of current approaches.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Locatello, Francesco and Abbati, Gabriele and Rainforth, Tom and Bauer, Stefan and Schölkopf, Bernhard and Bachem, Olivier},
	editor = {Wallach, H. and Larochelle, H. and Beygelzimer, A. and d'Alché-Buc, F. and Fox, E. and Garnett, R.},
	month = dec,
	year = {2019},
	keywords = {Interpretability, Generalization, Variable (mathematics), Computer science, Representation (politics), Variables, Property (philosophy), Artificial intelligence, Machine learning, Econometrics, Mathematics, Epistemology, NEURIPS},
}
