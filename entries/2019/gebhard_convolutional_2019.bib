@article{gebhard_convolutional_2019,
	title = {Convolutional neural networks: {A} magic bullet for gravitational-wave detection?},
	issn = {2470-0010},
	shorttitle = {Convolutional neural networks},
	url = {https://link.aps.org/doi/10.1103/PhysRevD.100.063015},
	doi = {10.1103/PhysRevD.100.063015},
	abstract = {The detection of gravitational waves from compact binary coalescences is a challenging task due to the low signal-to-noise ratio of the signals and the non-Gaussian, nonstationary nature of the detector noise. Currently, matched-filter-based searches are the standard approach. However, these are computationally expensive and rely on accurate waveform templates. In this paper, we investigate the use of convolutional neural networks (CNNs) for gravitational-wave detection. We show that CNNs can be trained to detect signals from binary black hole mergers in real-time with high sensitivity and low false-alarm rates. We compare the performance of our CNN-based approach to a standard matched-filter search and find that it achieves comparable performance while being significantly faster. We also discuss the limitations of our approach and potential directions for future research.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Physical Review D},
	publisher = {American Physical Society},
	author = {Gebhard, Timothy and Kilbertus, Niki and Harry, Ian and Schölkopf, Bernhard},
	month = sep,
	year = {2019},
	keywords = {Magic bullet, Convolutional neural network, Gravitational wave, Computer science, MAGIC (telescope), Physics, Astronomy, Artificial intelligence, PRD},
}
