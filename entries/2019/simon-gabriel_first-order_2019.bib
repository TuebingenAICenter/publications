@article{simon-gabriel_first-order_2019,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {First-{Order} {Adversarial} {Vulnerability} of {Neural} {Networks} and {Input} {Dimension}},
	shorttitle = {First-{Order} {Adversarial} {Vulnerability}},
	url = {http://proceedings.mlr.press/v97/simon-gabriel19a.html},
	abstract = {We study the vulnerability of neural networks to small input perturbations, focusing on the first-order (gradient-based) adversarial vulnerability. We show that this vulnerability is closely related to the input dimension. Specifically, for a wide class of classifiers, the expected gradient norm is proportional to the square root of the input dimension. This result provides a theoretical explanation for why high-dimensional inputs are more susceptible to adversarial attacks. We also provide empirical evidence supporting our theoretical findings on several datasets and architectures.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 36th International Conference on Machine Learning},
	publisher = {PMLR},
	author = {Simon-Gabriel, C.-J. and Ollivier, Y. and Bottou, L. and Schölkopf, B. and Lopez-Paz, D.},
	editor = {Chaudhuri, Kamalika and Salakhutdinov, Ruslan},
	month = jun,
	year = {2019},
	keywords = {ICML},
}
