@article{lueckmann_likelihood-free_2019,
	title = {Likelihood-free inference with emulator networks},
	issn = {2640-3498},
	url = {http://proceedings.mlr.press/v96/lueckmann19a.html},
	abstract = {Likelihood-free inference (LFI) methods, such as approximate Bayesian computation (ABC), allow for Bayesian inference in models where the likelihood function is intractable but simulation is possible. However, standard LFI methods are often computationally expensive, requiring a large number of simulations. We propose a new approach to LFI that uses neural networks to emulate the simulator. Our emulator networks learn to approximate the simulator's output, allowing for fast and accurate inference. We demonstrate the effectiveness of our approach on several benchmark problems and show that it can significantly reduce the number of simulations required for accurate inference.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the Twenty-Second International Conference on Artificial Intelligence and Statistics},
	publisher = {PMLR},
	author = {Lueckmann, Jan-Matthis and Bassetto, Giacomo and Karaletsos, Theofanis and Macke, Jakob},
	year = {2019},
	keywords = {AISTATS},
}
