@inproceedings{arvanitidis_fast_2019,
	title = {Fast and {Robust} {Shortest} {Paths} on {Manifolds} {Learned} from {Data}},
	shorttitle = {Fast and {Robust} {Shortest} {Paths} on {Manifolds} {Learned} from {Data}},
	url = {http://proceedings.mlr.press/v89/arvanitidis19a/arvanitidis19a.html},
	abstract = {We consider the problem of computing shortest paths on a manifold that is learned from data. This is a fundamental task in manifold learning, with applications in dimensionality reduction, data visualization, and generative modeling. Existing approaches typically rely on graph-based approximations, which are computationally expensive and sensitive to noise. We propose a novel approach that learns a Riemannian metric on the manifold, which allows us to compute shortest paths by solving a simple ordinary differential equation. Our approach is fast, robust to noise, and can be applied to high-dimensional data. We demonstrate the effectiveness of our approach on several synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 22nd {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Arvanitidis, Georgios and Hauberg, Søren and Hennig, Philipp and Schober, Michael},
	editor = {Chaudhuri, Kamalika and Sugiyama, Masashi},
	month = apr,
	year = {2019},
	keywords = {Ode, Solver, Computer science, Ordinary differential equation, Stability (learning theory), Metric (unit), Simple (philosophy), Applied mathematics, Scheme (mathematics), Mathematical optimization, Mathematics, Differential equation, Mathematical analysis, Machine learning, AISTATS},
}
