@article{kummerer_selecting_2019,
	title = {Selecting {Maximally}-{Predictive} {Deep} {Features} to {Explain} {What} {Drives} {Fixations} in {Free}-{Viewing}},
	shorttitle = {Selecting {Maximally}-{Predictive} {Deep} {Features}},
	url = {https://bethgelab.org/publication/2019_01_kummerer/},
	abstract = {Deep neural networks have recently achieved state-of-the-art performance in predicting human eye fixations. However, it remains unclear which features of these networks are responsible for this success and whether they correspond to features used by the human visual system. Here, we propose a method to select a small subset of features from a deep neural network that are maximally predictive of human fixations. We show that this approach allows us to identify a small number of features that explain a large proportion of the variance in human fixation data. Our results suggest that the human visual system relies on a hierarchy of features that are well-represented in deep neural networks, and that our method can be used to gain insights into the mechanisms underlying human visual attention.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the Symposium on Applied Perception},
	publisher = {Purdue University},
	author = {Kümmerer, Matthias and Wallis, Thomas S. A. and Bethge, Matthias},
	year = {2019},
	keywords = {Artificial intelligence, Computer science, Computer vision, Cognitive psychology, Psychology, MODVIS},
}
