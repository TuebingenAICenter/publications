@misc{ozdenizci_neural_2019,
	title = {Neural {Signatures} of {Motor} {Skill} in the {Resting} {Brain}},
	shorttitle = {Neural {Signatures} of {Motor} {Skill}},
	url = {https://doi.org/10.1109/SMC.2019.8914252},
	doi = {10.1109/SMC.2019.8914252},
	abstract = {The ability to acquire and refine motor skills is a fundamental aspect of human behavior. While the neural correlates of motor skill acquisition have been extensively studied during task execution, the neural signatures of motor skill in the resting brain remain less understood. In this paper, we investigate whether motor skill levels can be predicted from resting-state electroencephalography (EEG) data. We analyze resting-state EEG recordings from subjects who have undergone a motor learning task. Using a machine learning approach, we demonstrate that motor skill levels can be decoded from resting-state brain activity. Our results suggest that motor skill is reflected in the intrinsic functional organization of the brain, providing new insights into the neural basis of motor learning and potential biomarkers for neurorehabilitation.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {IEEE},
	author = {Ozdenizci, Ozan and Meyer, Timm and Wichmann, Felix and Peters, Jan and Schölkopf, Bernhard and Cetin, Müjdat and Grosse-Wentrup, Moritz},
	month = oct,
	year = {2019},
	keywords = {Neurorehabilitation, Neurofeedback, Psychology, Motor learning, Sensorimotor rhythm, Rhythm, Physical medicine and rehabilitation, Electroencephalography, Brain activity and meditation, Neuroscience, Resting state fMRI, Motor skill, Stroke (engine), Cognitive psychology, Rehabilitation, Medicine, SMC},
}
