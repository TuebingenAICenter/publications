@inproceedings{van_steenkiste_are_2019,
	title = {Are {Disentangled} {Representations} {Helpful} for {Abstract} {Visual} {Reasoning}?},
	shorttitle = {Are {Disentangled} {Representations} {Helpful} for {Abstract} {Visual} {Reasoning}?},
	url = {https://papers.nips.cc/paper/9570-are-disentangled-representations-helpful-for-abstract-visual-reasoning},
	abstract = {Disentangled representations are often hypothesized to be a useful starting point for downstream tasks, such as abstract visual reasoning. In this paper, we investigate this hypothesis by evaluating a wide range of state-of-the-art disentanglement methods on the recently proposed Abstract Reasoning Dataset (RAVEN). We find that, contrary to common belief, there is no clear correlation between the disentanglement metrics and the performance on the reasoning task. Furthermore, we show that even the best-performing disentangled models do not consistently outperform simple baselines, suggesting that current disentanglement methods may not be capturing the structural information required for abstract visual reasoning.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 32},
	publisher = {Curran Associates, Inc.},
	author = {van Steenkiste, S. and Locatello, F. and Schmidhuber, J. and Bachem, O.},
	month = dec,
	year = {2019},
	keywords = {NEURIPS},
}
