@misc{mastakouri_beta_2019,
	title = {Beta {Power} {May} {Mediate} the {Effect} of {Gamma}-{TACS} on {Motor} {Performance}},
	shorttitle = {Beta {Power} {May} {Mediate} the {Effect} of {Gamma}-{TACS} on {Motor} {Performance}},
	url = {https://ieeexplore.ieee.org/abstract/document/8856416},
	doi = {10.1109/EMBC.2019.8856416},
	abstract = {Transcranial alternating current stimulation (tACS) is a non-invasive brain stimulation technique that can modulate brain oscillations. While it has been shown that tACS can influence motor performance, the underlying mechanisms remain poorly understood. In this study, we investigated whether the effect of gamma-tACS on motor performance is mediated by changes in beta power. We recorded EEG during a motor task while participants received gamma-tACS or sham stimulation. Our results suggest that gamma-tACS modulates motor performance and that this effect is mediated by changes in beta power, providing evidence for a potential mechanism of action for tACS.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {IEEE},
	author = {Mastakouri, Atalanti-Amalia and Schölkopf, Bernhard and Grosse-Wentrup, Moritz},
	month = jul,
	year = {2019},
	keywords = {Transcranial alternating current stimulation, Motor cortex, Neuroscience, Psychology, Stimulation, Electroencephalography, Transcranial magnetic stimulation, Computer science, EMBC},
}
