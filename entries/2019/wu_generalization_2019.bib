@inproceedings{wu_generalization_2019,
	title = {Generalization as diffusion: human function learning on graphs},
	shorttitle = {Generalization as diffusion},
	url = {https://mindmodeling.org/cogsci2019/papers/0525/0525.pdf},
	doi = {10.1037/0000158-001},
	abstract = {How do people generalize from observed data to unobserved states? We propose that human function learning can be modeled as a diffusion process on a graph. This framework assumes that people represent the structure of the environment as a graph and generalize by diffusing information from observed nodes to unobserved nodes. We test this model against human behavior in a function learning task on graphs, finding that it outperforms several alternative models of generalization. Our results suggest that human function learning is constrained by the underlying structure of the environment, and that this structure is represented as a graph.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {Proceedings of the 41st {Annual} {Conference} of the {Cognitive} {Science} {Society}},
	publisher = {Cognitive Science Society},
	author = {Wu, Charley M. and Schulz, Eric and Gershman, Samuel J.},
	editor = {Goel, Ashok K. and Seifert, Colleen M. and Freksa, Christian},
	year = {2019},
	keywords = {COGSCI},
}
