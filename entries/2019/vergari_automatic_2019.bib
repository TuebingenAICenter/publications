@inproceedings{vergari_automatic_2019,
	title = {Automatic {Bayesian} {Density} {Analysis}},
	shorttitle = {{ABDA}},
	url = {https://doi.org/10.1609/aaai.v33i01.33015207},
	doi = {10.1609/aaai.v33i01.33015207},
	abstract = {Density estimation is a fundamental task in machine learning. While many models exist, choosing the right one for a given dataset is often a manual, trial-and-error process. We propose Automatic Bayesian Density Analysis (ABDA), a framework that automates the selection and training of density estimators. ABDA leverages the properties of Sum-Product Networks (SPNs), a class of tractable probabilistic models, to perform Bayesian model selection. Specifically, we introduce a novel approach to learn the structure of SPNs that allows for efficient marginal likelihood estimation. We demonstrate that ABDA can automatically discover high-quality density models across a wide range of datasets, often outperforming manually tuned models.},
	language = {en},
	booktitle = {Proceedings of the {AAAI} {Conference} on {Artificial} {Intelligence}},
	publisher = {AAAI.org},
	author = {Vergari, Antonio and Molina, Alejandro and Peharz, Robert and Ghahramani, Zoubin and Kersting, Kristian and Valera, Isabel},
	month = jan,
	year = {2019},
	keywords = {AAAI},
}
