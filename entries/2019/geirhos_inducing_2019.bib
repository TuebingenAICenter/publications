@article{geirhos_inducing_2019,
	title = {Inducing a human-like shape bias leads to emergent human-level distortion robustness in {CNNs}},
	issn = {1534-7362},
	shorttitle = {Inducing a human-like shape bias},
	url = {https://jov.arvojournals.org/article.aspx?articleid=2750764},
	doi = {10.1167/19.10.209c},
	abstract = {Convolutional neural networks (CNNs) are often considered to be texture-based classifiers, whereas human object recognition is thought to be primarily shape-based. Here, we show that this difference in bias is a major reason for the discrepancy between human and machine robustness. By training CNNs on a stylized-ImageNet dataset, we induce a human-like shape bias. We find that these shape-biased models exhibit a significantly higher robustness to image distortions and corruptions, reaching human-level performance on some tasks. Our results suggest that the shape bias is a key factor for robust object recognition in both biological and artificial systems.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Vision},
	publisher = {Association for Research in Vision and Ophthalmology (ARVO)},
	author = {Geirhos, Robert and Rubisch, Patricia and Rauber, Jonas and Medina Temme, Carlos R. and Michaelis, Claudio and Brendel, Wieland and Bethge, Matthias and Wichmann, Felix A.},
	year = {2019},
	keywords = {Artificial intelligence, Convolutional neural network, Pattern recognition (psychology), Computer science, Robustness (evolution), Cognitive neuroscience of visual object recognition, Contrast (vision), Texture (cosmology), Object (grammar), Image (mathematics), Biology, JOV, Saccade, Fixation (population genetics), Eye movement, Computer vision, VSS},
}
