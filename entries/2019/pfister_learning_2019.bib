@article{pfister_learning_2019,
	title = {Learning stable and predictive structures in kinetic systems},
	shorttitle = {Learning stable and predictive structures in kinetic systems},
	url = {https://is.mpg.de/ei/publications/pfibaupet19},
	doi = {10.1073/pnas.1905688116},
	abstract = {We propose a method for learning the structure of kinetic systems from observational data. Our approach is based on the idea that the underlying physical mechanisms are stable across different environments or experimental conditions, while the specific dynamics may change. By exploiting this stability, we can identify the causal structure of the system, which is more predictive and robust than purely correlational models. We demonstrate the effectiveness of our method on both synthetic and real-world data, showing that it outperforms existing structure learning algorithms in terms of both predictive accuracy and structural recovery.},
	language = {en},
	journal = {Proceedings of the National Academy of Sciences},
	publisher = {National Academy of Sciences},
	author = {Pfister, Niklas and Bauer, Sebastian and Peters, Jonas},
	year = {2019},
	keywords = {PNAS},
}
