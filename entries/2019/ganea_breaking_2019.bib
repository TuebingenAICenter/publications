@inproceedings{ganea_breaking_2019,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Breaking the {Softmax} {Bottleneck} via {Learnable} {Monotonic} {Pointwise} {Non}-linearities},
	shorttitle = {Breaking the {Softmax} {Bottleneck}},
	url = {http://proceedings.mlr.press/v97/ganea19a.html},
	abstract = {The softmax function is the standard way to map a vector of real-valued scores to a probability distribution. However, it has been shown that the softmax bottleneck limits the expressivity of language models, as it restricts the rank of the output probability matrix to be at most the dimension of the hidden state. In this paper, we propose to break this bottleneck by introducing learnable monotonic pointwise non-linearities after the softmax layer. We show that this simple modification allows the model to represent a much larger class of probability distributions, while still being easy to train and efficient to evaluate. We demonstrate the effectiveness of our approach on several language modeling benchmarks, where it consistently outperforms the standard softmax.},
	language = {en},
	booktitle = {Proceedings of the 36th {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Ganea, Octavian-Eugen and Gelly, Sylvain and Becigneul, Gary and Severyn, Aliaksei},
	month = jun,
	year = {2019},
	keywords = {ICML},
}
