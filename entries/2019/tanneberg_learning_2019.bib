@misc{tanneberg_learning_2019,
	title = {Learning {Algorithmic} {Solutions} to {Symbolic} {Planning} {Tasks} with a {Neural} {Computer} {Architecture}},
	shorttitle = {Learning {Algorithmic} {Solutions} to {Symbolic} {Planning} {Tasks}},
	url = {https://arxiv.org/abs/1911.00926},
	abstract = {Symbolic planning is a core challenge in artificial intelligence, often requiring complex reasoning over long horizons. While classical planners are highly efficient, they rely on hand-crafted domain models. In contrast, deep reinforcement learning has shown promise in learning policies directly from raw observations, but often struggles with long-term planning and generalization. In this paper, we propose a neural computer architecture that learns to solve symbolic planning tasks by inducing algorithmic solutions. Our architecture combines a neural controller with an external memory, allowing it to learn to manipulate symbolic representations and perform multi-step reasoning. We demonstrate that our approach can learn to solve complex planning tasks, such as the Tower of Hanoi and Sokoban, and generalize to unseen problem instances. Furthermore, we show that our model can be trained using only sparse rewards, making it applicable to a wide range of planning problems.},
	language = {en},
	urldate = {2024-05-22},
	publisher = {arXiv},
	author = {Tanneberg, Daniel and Rueckert, Elmar and Peters, Jan},
	year = {2019},
	keywords = {ARXIV},
}
