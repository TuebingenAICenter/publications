@inproceedings{rubenstein_practical_2019,
	title = {Practical and {Consistent} {Estimation} of f-{Divergences}},
	shorttitle = {Practical and {Consistent} {Estimation} of f-{Divergences}},
	url = {https://papers.nips.cc/paper/8661-practical-and-consistent-estimation-of-f-divergences},
	abstract = {We consider the problem of estimating f-divergences between two distributions P and Q given samples from each. While many estimators exist, they often suffer from high variance, lack of consistency, or require density estimation. We propose a new class of estimators based on the variational representation of f-divergences. By using a kernel-based approach to parameterize the variational functions, we obtain estimators that are consistent, computationally efficient, and perform well in practice. We provide a theoretical analysis of the convergence rates of our estimators and demonstrate their effectiveness on a range of tasks, including two-sample testing and training generative models.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 32},
	publisher = {Curran Associates, Inc.},
	author = {Rubenstein, Paul K. and Bousquet, Olivier and Djolonga, Josip and Riquelme, Carlos and Tolstikhin, Ilya},
	editor = {Wallach, H. and Larochelle, H. and Beygelzimer, A. and d'Alche-Buc, F. and Fox, E. and Garnett, R.},
	month = dec,
	year = {2019},
	keywords = {NEURIPS},
}
