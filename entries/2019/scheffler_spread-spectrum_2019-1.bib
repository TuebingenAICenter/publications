@article{scheffler_spread-spectrum_2019-1,
	title = {Spread-spectrum magnetic resonance imaging},
	issn = {0740-3194},
	shorttitle = {Spread-spectrum magnetic resonance imaging},
	url = {https://doi.org/10.1002/mrm.27766},
	doi = {10.1002/mrm.27766},
	abstract = {Purpose: To introduce a novel method for magnetic resonance imaging (MRI) based on the concept of spread-spectrum (SS) communication. Methods: In SS-MRI, the radiofrequency (RF) excitation is modulated by a pseudo-random noise sequence, spreading the signal over a wide bandwidth. The image is reconstructed from the received signal using a matched filter or an iterative reconstruction algorithm. We demonstrate the feasibility of SS-MRI using numerical simulations and phantom experiments. Results: SS-MRI allows for high-speed imaging with reduced sensitivity to motion and susceptibility artifacts. The method is robust to noise and provides high-quality images even with low signal-to-noise ratios. Conclusion: SS-MRI is a promising technique for fast and robust MRI, with potential applications in clinical and research settings.},
	language = {en},
	journal = {Magnetic Resonance in Medicine},
	publisher = {Wiley},
	author = {Scheffler, Klaus and Loktyushin, Alexander and Bause, J and Aghaeifar, Ali and Steffen, Theodor and Schölkopf, Bernhard},
	year = {2019},
	keywords = {Acceleration, Modulation (music), Electromagnetic coil, Physics, Magnetic field, Frequency modulation, Iterative reconstruction, Amplifier, Sensitivity (control systems), Nuclear magnetic resonance, Range (aeronautics), Optics, Acoustics, Computer science, Radio frequency, Artificial intelligence, Electronic engineering, Materials science, Telecommunications},
}
