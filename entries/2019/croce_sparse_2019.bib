@misc{croce_sparse_2019,
	title = {Sparse and {Imperceivable} {Adversarial} {Attacks}},
	shorttitle = {Sparse and {Imperceivable} {Adversarial} {Attacks}},
	url = {https://arxiv.org/abs/1909.05040},
	doi = {10.1109/ICCV.2019.00482},
	abstract = {We propose a new class of adversarial attacks which are both sparse and imperceivable. While existing sparse attacks (e.g. pixel attacks) are often easily detectable due to large changes in individual pixels, we introduce a constraint on the maximum change per pixel, which we combine with an L0-norm constraint on the number of modified pixels. We show that our attack, which we call Sparse-RS, is able to find adversarial examples with very few modified pixels that are also imperceivable to the human eye. We evaluate our attack on several state-of-the-art defenses and show that it is more effective than existing sparse attacks, while also being computationally efficient.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {IEEE},
	author = {Croce, Francesco and Hein, Matthias},
	year = {2019},
	keywords = {Adversarial system, Computer science, Gradient descent, Robustness (evolution), Deep neural networks, Norm (philosophy), Artificial intelligence, Pixel, Perspective (graphical), Algorithm, Artificial neural network, ICCV},
}
