@article{parisi_td-regularized_2019,
	title = {{TD}-regularized actor-critic methods},
	issn = {0885-6125},
	shorttitle = {{TD}-regularized actor-critic methods},
	url = {https://is.mpg.de/ei/publications/partanpetkha19},
	doi = {10.1007/s10994-019-05788-0},
	abstract = {Actor-critic methods are a popular class of reinforcement learning algorithms that combine the benefits of policy-based and value-based methods. However, they often suffer from high variance and instability, especially when using function approximation. In this paper, we propose a new class of actor-critic methods that use temporal-difference (TD) regularization to improve the stability and performance of the learning process. We show that our proposed methods can be interpreted as a form of natural policy gradient, and we provide theoretical guarantees for their convergence. We also demonstrate the effectiveness of our methods on a variety of reinforcement learning benchmarks, showing that they outperform existing actor-critic methods in terms of both sample efficiency and final performance.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Machine Learning},
	publisher = {Springer},
	author = {Parisi, Simone and Tangkaratt, Voot and Peters, Jan and Khan, Mohammad Emtiyaz},
	year = {2019},
	keywords = {MLJ},
}
