@inproceedings{liu_fisher_2019,
	title = {Fisher {Efficient} {Inference} of {Intractable} {Models}},
	url = {https://papers.nips.cc/paper/9083-fisher-efficient-inference-of-intractable-models},
	abstract = {We propose a new method for parameter estimation in models where the likelihood function is intractable but the score function (the gradient of the log-likelihood) can be approximated. Our approach is based on the Fisher divergence, which measures the discrepancy between the score functions of the model and the data distribution. We show that our estimator is Fisher efficient, meaning it achieves the Cramér-Rao lower bound as the sample size increases. We also provide a kernel-based implementation that is computationally efficient and does not require MCMC sampling. Experimental results on several intractable models demonstrate the effectiveness of our method.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 32},
	publisher = {Curran Associates, Inc.},
	author = {Liu, S. and Kanamori, T. and Jitkrittum, W. and Chen, Y.},
	editor = {Wallach, H. and Larochelle, H. and Beygelzimer, A. and d'Alché-Buc, F. and Fox, E. and Garnett, R.},
	month = dec,
	year = {2019},
	keywords = {NEURIPS},
}
