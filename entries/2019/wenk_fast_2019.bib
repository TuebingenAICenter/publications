@inproceedings{wenk_fast_2019,
	title = {Fast {Gaussian} {Process} {Based} {Gradient} {Matching} for {Parameter} {Identification} in {Systems} of {Nonlinear} {ODEs}},
	shorttitle = {Fast {Gaussian} {Process} {Based} {Gradient} {Matching}},
	url = {http://proceedings.mlr.press/v89/wenk19a.html},
	abstract = {Parameter identification in systems of nonlinear ordinary differential equations (ODEs) is a fundamental problem in science and engineering. Gradient matching is a popular approach to avoid the computationally expensive numerical integration of the ODEs during parameter estimation. However, existing gradient matching methods often rely on Gaussian Process (GP) regression, which scales cubically with the number of observations, limiting their applicability to large datasets. In this paper, we propose a novel gradient matching framework that leverages sparse GP approximations to achieve linear scaling in the number of observations. We derive a closed-form objective function that allows for efficient optimization of the ODE parameters. We demonstrate the effectiveness of our approach on several synthetic and real-world benchmarks, showing that it achieves competitive accuracy while being significantly faster than existing methods.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Proceedings of the 22nd {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Wenk, Philipp and Gotovos, Andreas and Bauer, Stefan and Gorbach, Nina and Krause, Andreas and Buhmann, Joachim M.},
	editor = {Chaudhuri, Kamalika and Sugiyama, Masashi},
	month = apr,
	year = {2019},
	keywords = {AISTATS},
}
