@article{kobak_art_2019,
	title = {The art of using t-{SNE} for single-cell transcriptomics},
	issn = {2041-1723},
	shorttitle = {The art of using t-{SNE}},
	url = {https://www.nature.com/articles/s41467-019-13056-x},
	doi = {10.1038/s41467-019-13056-x},
	abstract = {t-distributed stochastic neighbor embedding (t-SNE) is widely used for visualization of single-cell RNA-seq data. However, it is often used as a black box, and its results can be misleading if the parameters are not chosen carefully. Here we discuss the effects of the perplexity and the early exaggeration parameters, and show that they can be used to reveal different aspects of the data structure. We also discuss the importance of the initialization and the distance metric. We provide a set of practical recommendations for using t-SNE in single-cell transcriptomics.},
	language = {en},
	journal = {Nature Communications},
	publisher = {Nature Research},
	author = {Kobak, Dmitry and Berens, Philipp},
	month = nov,
	year = {2019},
	keywords = {Computer science, Embedding, Pipeline (software), Dimensionality reduction, Protocol (science), Transcriptome, Upsampling, Data mining, Similarity (geometry), Computational biology, Artificial intelligence, Theoretical computer science, Biology, Gene, Gene expression, Genetics},
}
