@article{meding_perceiving_2019,
	title = {Perceiving the arrow of time in autoregressive motion},
	url = {https://papers.nips.cc/paper/8502-perceiving-the-arrow-of-time-in-autoregressive-motion},
	abstract = {The arrow of time is a fundamental concept in physics, yet its perception by humans remains poorly understood. We investigate whether humans can distinguish between forward and time-reversed autoregressive motion. We find that human observers are surprisingly good at this task, even when the motion is generated by simple linear autoregressive models. We propose a computational model based on the assumption that the human visual system performs causal inference to distinguish between forward and backward motion. Our model accounts for human performance across a range of conditions and suggests that the perception of the arrow of time is linked to the ability to infer the underlying causal structure of dynamic scenes.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Advances in Neural Information Processing Systems 32},
	publisher = {Curran Associates, Inc.},
	author = {Meding, Kristof and Janzing, Dominik and Schölkopf, Bernhard and Wichmann, Felix A.},
	month = dec,
	year = {2019},
	keywords = {Computer science, Observer (physics), Artificial intelligence, Autoregressive model, Heuristic, Machine learning, Inference, Noise (video), Causal structure, Algorithm, Bayesian probability, Mathematics, Econometrics, NEURIPS},
}
