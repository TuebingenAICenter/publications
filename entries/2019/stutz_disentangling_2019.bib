@inproceedings{stutz_disentangling_2019,
	title = {Disentangling {Adversarial} {Robustness} and {Generalization}},
	isbn = {978-1-7281-3293-8},
	shorttitle = {Disentangling {Adversarial} {Robustness} and {Generalization}},
	url = {https://arxiv.org/abs/1812.00740},
	doi = {10.1109/CVPR.2019.00705},
	abstract = {Adversarial training is currently the most effective defense against adversarial attacks. However, it is often observed that adversarial training leads to a significant drop in standard accuracy on clean data. This phenomenon is often referred to as the robustness-accuracy trade-off. In this paper, we investigate the relationship between adversarial robustness and generalization. We show that the robustness-accuracy trade-off is not inherent to adversarial training, but rather a consequence of the specific way adversarial training is formulated. We propose a new adversarial training objective that disentangles robustness and generalization, allowing us to improve robustness without sacrificing standard accuracy. We demonstrate the effectiveness of our approach on several benchmark datasets and show that it outperforms existing methods.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Proceedings of the {IEEE}/{CVF} {Conference} on {Computer} {Vision} and {Pattern} {Recognition} ({CVPR})},
	publisher = {IEEE},
	author = {Stutz, David and Hein, Matthias and Schiele, Bernt},
	year = {2019},
	keywords = {Adversarial system, MNIST database, Robustness (evolution), Generalization, Manifold (fluid mechanics), Computer science, Artificial intelligence, Mathematics, Deep learning, Engineering, CVPR},
}
