@inproceedings{klink_self-paced_2019,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Self-{Paced} {Contextual} {Reinforcement} {Learning}},
	shorttitle = {Self-{Paced} {Contextual} {Reinforcement} {Learning}},
	url = {http://proceedings.mlr.press/v100/klink20a.html},
	abstract = {Contextual reinforcement learning (CRL) aims at learning a policy that generalizes across different tasks or contexts. However, in many real-world scenarios, the agent is faced with a large variety of contexts, some of which might be too difficult to learn at the beginning of the training process. In this paper, we propose a self-paced learning approach for CRL that automatically selects the order in which contexts are presented to the agent. We formulate the problem as a joint optimization of the policy parameters and a weighting of the contexts, where the weights are determined by the agent's current performance. We show that our approach can be interpreted as a form of curriculum learning that adapts to the agent's learning progress. We evaluate our method on several simulated robotic tasks and show that it significantly improves the learning speed and final performance compared to standard CRL methods.},
	language = {en},
	booktitle = {Proceedings of the 3rd {Annual} {Conference} on {Robot} {Learning}},
	publisher = {PMLR},
	author = {Klink, P. and Abdulsamad, H. and Belousov, B. and Peters, J.},
	month = nov,
	year = {2019},
	keywords = {CORL},
}
