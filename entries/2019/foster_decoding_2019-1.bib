@article{foster_decoding_2019-1,
	title = {Decoding subcategories of human bodies from both body- and face-responsive cortical regions},
	url = {https://doi.org/10.1016/j.neuroimage.2019.116085},
	doi = {10.1016/j.neuroimage.2019.116085},
	abstract = {Our visual system can easily categorize objects (e.g. faces vs. bodies) and further differentiate them into subcategories (e.g. male vs. female). This ability is particularly important for objects of social significance, such as human faces and bodies. While many studies have demonstrated category selectivity to faces and bodies in the brain, how subcategories of faces and bodies are represented remains unclear. Here, we investigated how the brain encodes two prominent subcategories shared by both faces and bodies, sex and weight, and whether neural responses to these subcategories rely on low-level visual, high-level visual or semantic similarity. We recorded brain activity with fMRI while participants viewed faces and bodies that varied in sex, weight, and image size. The results showed that the sex of bodies can be decoded from both body- and face-responsive brain areas, with the former exhibiting more consistent size-invariant decoding than the latter. Body weight could also be decoded in face-responsive areas and in distributed body-responsive areas, and this decoding was also invariant to image size. The weight of faces could be decoded from the fusiform body area (FBA), and weight could be decoded across face and body stimuli in the extrastriate body area (EBA) and a distributed body-responsive area. The sex of well-controlled faces (e.g. excluding hairstyles) could not be decoded from face- or body-responsive regions. These results demonstrate that both face- and body-responsive brain regions encode information that can distinguish the sex and weight of bodies. Moreover, the neural patterns corresponding to sex and weight were invariant to image size and could sometimes generalize across face and body stimuli, suggesting that such subcategorical information is encoded with a high-level visual or semantic code.},
	language = {en},
	journal = {NeuroImage},
	publisher = {Elsevier},
	author = {Foster, Celia and Zhao, Mintao and Romero, Javier and Black, Michael J. and Mohler, Betty J. and Bartels, Andreas and Bülthoff, Isabelle},
	month = nov,
	year = {2019},
	keywords = {Categorization, Psychology, Face (sociological concept), Decoding methods, Cognitive psychology, Communication, Computer science, Artificial intelligence, NEUROIMAGE},
}
