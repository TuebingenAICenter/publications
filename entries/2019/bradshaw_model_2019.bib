@inproceedings{bradshaw_model_2019,
	title = {A {Model} to {Search} for {Synthesizable} {Molecules}},
	shorttitle = {A {Model} to {Search} for {Synthesizable} {Molecules}},
	url = {https://papers.nips.cc/paper/9007-a-model-to-search-for-synthesizable-molecules},
	abstract = {The discovery of new molecules with desirable properties is a fundamental problem in chemistry and drug design. Recent work has focused on using generative models to propose new molecular structures. However, many of these models propose molecules that are difficult or impossible to synthesize. We introduce a model that searches for molecules by navigating the space of chemical reactions, rather than the space of molecular graphs. This ensures that all generated molecules are synthesizable by construction. We demonstrate that our model can be used to optimize molecular properties, and that it outperforms existing methods in terms of the synthesizability of the generated molecules.},
	language = {en},
	urldate = {2024-05-23},
	publisher = {Curran Associates, Inc.},
	author = {Bradshaw, John and Paige, Brooks and Kusner, Matt J. and Segler, Marwin and Hernández-Lobato, José Miguel},
	editor = {Wallach, H. and Larochelle, H. and Beygelzimer, A. and d'Alché-Buc, F. and Fox, E. and Garnett, R.},
	month = dec,
	year = {2019},
	keywords = {NEURIPS},
}
