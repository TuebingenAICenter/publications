@inproceedings{bauer_resampled_2019,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Resampled {Priors} for {Variational} {Autoencoders}},
	shorttitle = {Resampled {Priors} for {Variational} {Autoencoders}},
	url = {http://proceedings.mlr.press/v89/bauer19a.html},
	abstract = {Variational autoencoders (VAEs) are typically trained by maximizing the evidence lower bound (ELBO) on the log-marginal likelihood of the data. The ELBO is derived using a simple prior, such as a standard Gaussian, which is often too restrictive to capture the true structure of the data. We propose a method for learning more flexible priors by using a resampling procedure. Our approach, which we call the resampled prior, allows for a wide range of complex, multi-modal prior distributions while remaining computationally efficient. We demonstrate that our method leads to improved generative performance on several standard benchmarks.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Proceedings of the 22nd {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Bauer, Matthias and Mnih, Andriy},
	editor = {Chaudhuri, Kamalika and Sugiyama, Masashi},
	month = apr,
	year = {2019},
	keywords = {AISTATS},
}
