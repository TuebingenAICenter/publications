@misc{gresele_incomplete_2019,
	title = {The {Incomplete} {Rosetta} {Stone} problem: {Identifiability} results for {Multi}-view {Nonlinear} {ICA}},
	shorttitle = {The {Incomplete} {Rosetta} {Stone} problem},
	url = {https://proceedings.mlr.press/v115/gresele20a.html},
	doi = {10.48550/arxiv.1905.06642},
	abstract = {We study the problem of identifying latent sources from multiple observed views, where each view is a nonlinear transformation of the same underlying sources. This is a generalization of Independent Component Analysis (ICA) to the nonlinear and multi-view setting. We show that, under certain conditions, the latent sources are identifiable up to a permutation and element-wise transformations. Our results provide a theoretical foundation for multi-view representation learning and suggest that the availability of multiple views can alleviate the fundamental non-identifiability of nonlinear ICA.},
	language = {en},
	publisher = {PMLR},
	author = {Gresele, Luigi and Rubenstein, Paul K. and Mehrjou, Arash and Locatello, Francesco and Schölkopf, Bernhard},
	editor = {Adams, Ryan P. and Gogate, Vibhav},
	month = jul,
	year = {2019},
	keywords = {Identifiability, Mixing (physics), Independent component analysis, Nonlinear system, Latent variable, Computer science, Representation (politics), Undo, Component (thermodynamics), Contrast (vision), Blind signal separation, Algorithm, Applied mathematics, Artificial intelligence, Mathematics, Machine learning, Law, Physics, UAI},
}
