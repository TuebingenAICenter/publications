@article{miladinovic_spindle_2019,
	title = {{SPINDLE}: {End}-to-end learning from {EEG}/{EMG} to extrapolate animal sleep scoring across experimental settings, labs and species},
	copyright = {CC BY 4.0},
	issn = {1553-7358},
	shorttitle = {{SPINDLE}},
	url = {https://doi.org/10.1371/journal.pcbi.1006968},
	doi = {10.1371/journal.pcbi.1006968},
	abstract = {Sleep scoring is a fundamental task in sleep research, yet it remains a time-consuming and subjective process. While automated methods exist, they often lack robustness when applied to data from different experimental settings, laboratories, or species. We present SPINDLE, an end-to-end deep learning framework for automated sleep scoring that addresses these challenges. SPINDLE uses a convolutional neural network to learn features directly from raw EEG and EMG signals, eliminating the need for manual feature engineering. We demonstrate that SPINDLE achieves high accuracy across diverse datasets, including different mouse strains, recording conditions, and even across species. Our results show that SPINDLE generalizes well to unseen data, making it a versatile tool for large-scale sleep studies.},
	language = {en},
	urldate = {2024-05-22},
	journal = {PLOS Computational Biology},
	publisher = {Public Library of Science},
	author = {Miladinovic, Dragana and Muheim, Cyril and Bauer, Sebastian and Spinnler, Anita and Noain, Daniela and Bandarabadi, Mohammad and Gallusser, Benoit and Krummenacher, Guido and Baumann, Christian and Adamantidis, Antoine and Brown, Steven A. and Buhmann, Joachim M.},
	month = apr,
	year = {2019},
	keywords = {PLOSCB},
}
