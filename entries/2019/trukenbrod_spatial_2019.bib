@article{trukenbrod_spatial_2019,
	title = {Spatial statistics for gaze patterns in scene viewing: {Effects} of repeated viewing},
	issn = {1534-7362},
	shorttitle = {Spatial statistics for gaze patterns in scene viewing},
	url = {https://is.mpg.de/ei/publications/trubarwiceng19},
	doi = {10.1167/19.6.5},
	abstract = {When viewing a scene repeatedly, gaze patterns become more similar across repetitions. However, it is unclear whether this similarity is due to a global increase in the consistency of gaze locations or a more specific, local refinement of gaze patterns. Here, we investigate the spatial statistics of gaze patterns in scene viewing using a large-scale eye-tracking dataset. We analyze the spatial distribution of fixations and the similarity of gaze patterns across repetitions using a spatial point process model. We find that gaze patterns become more similar across repetitions, and this similarity is driven by a global increase in the consistency of gaze locations, rather than a local refinement of gaze patterns. Our results suggest that repeated viewing leads to a more efficient exploration of the scene, with gaze patterns becoming more focused on informative regions.},
	language = {en},
	urldate = {2024-05-23},
	journal = {Journal of Vision},
	publisher = {Association for Research in Vision and Ophthalmology},
	author = {Trukenbrod, Hans A. and Barthelmé, Simon and Wichmann, Felix A. and Engbert, Ralf},
	year = {2019},
	keywords = {JOV},
}
