@article{blobaum_analysis_2019,
	title = {Analysis of cause-effect inference by comparing regression errors},
	copyright = {CC BY 4.0},
	issn = {2376-5992},
	url = {https://doi.org/10.7717/peerj-cs.169},
	doi = {10.7717/peerj-cs.169},
	abstract = {Distinguishing cause from effect is a fundamental problem in science. A popular approach is to assume that the cause X and the effect Y are related by Y = f(X) + N, where the noise N is independent of X. If this holds, the regression of Y on X should be 'simpler' than the regression of X on Y. We analyze this intuition by comparing the regression errors of both directions. We show that for a large class of models, the regression error is indeed smaller in the causal direction. We provide theoretical results for additive noise models and show that the difference in regression errors is related to the mutual information between cause and effect. Furthermore, we propose a new method for cause-effect inference based on these insights and demonstrate its performance on synthetic and real-world data.},
	language = {en},
	journal = {PeerJ Computer Science},
	publisher = {PeerJ},
	author = {Blöbaum, Patrick and Janzing, Dominik and Washio, Takashi and Shimizu, Shohei and Schölkopf, Bernhard},
	year = {2019},
	keywords = {Causal inference, Conditional independence, Independence (probability theory), Regression, Inference, Computer science, Statistics, Mathematics, Regression analysis, Algorithm, Econometrics, Artificial intelligence},
}
