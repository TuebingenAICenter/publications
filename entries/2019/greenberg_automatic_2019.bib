@article{greenberg_automatic_2019,
	title = {Automatic {Posterior} {Transformation} for {Likelihood}-{Free} {Inference}},
	shorttitle = {{APT}},
	url = {https://proceedings.mlr.press/v97/greenberg19a.html},
	doi = {10.48550/arxiv.1905.07488},
	abstract = {Likelihood-free inference (LFI) methods allow for Bayesian inference in models where the likelihood function is intractable but simulation is possible. Recent advances in LFI have focused on learning the posterior or likelihood using neural density estimators. We introduce Automatic Posterior Transformation (APT), a new method for LFI that learns the posterior by amortizing the inference process over a range of parameters. APT is based on a novel formulation of the posterior as a transformation of a base distribution, which allows for efficient and flexible density estimation. We demonstrate that APT achieves state-of-the-art performance on a range of benchmark problems and is highly scalable to high-dimensional parameter spaces.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 36th International Conference on Machine Learning},
	publisher = {PMLR},
	author = {Greenberg, David S. and Nonnenmacher, Marcel and Macke, Jakob H.},
	year = {2019},
	keywords = {Computer science, Inference, Posterior probability, Estimator, Artificial intelligence, Bayesian inference, Machine learning, Range (aeronautics), Transformation (genetics), Bayesian probability, Algorithm, Mathematics, Statistics, Engineering, ICML},
}
