@inproceedings{wu_under_2019,
	title = {Under pressure: {The} influence of time limits on human exploration},
	shorttitle = {Under pressure},
	url = {https://mindmodeling.org/cogsci2019/papers/0222/0222.pdf},
	doi = {10.31234/osf.io/tsxq9},
	abstract = {Time pressure is a ubiquitous feature of decision-making in the real world, yet its effect on exploration remains poorly understood. We investigate how time limits influence exploration in a multi-armed bandit task. Participants were given either a generous or a restrictive time limit to make a sequence of choices. We find that time pressure leads to more exploitative behavior, characterized by a reduction in the exploration of uncertain options. This effect is driven by a shift in the underlying decision strategy, with participants under time pressure relying more on simple heuristics rather than more complex, information-seeking strategies. Our results suggest that time pressure acts as a constraint on the cognitive resources available for exploration, leading to a more conservative and less adaptive decision-making process.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {Proceedings of the 41st {Annual} {Conference} of the {Cognitive} {Science} {Society}},
	publisher = {Cognitive Science Society},
	author = {Wu, Charley M. and Schulz, Eric and Gerbaulet, K. and Pleskac, Timothy J. and Speekenbrink, Maarten},
	editor = {Goel, Ashok K. and Seifert, Colleen M. and Freksa, Christian},
	year = {2019},
	keywords = {COGSCI},
}
