@inproceedings{kastner_bayesian_2019,
	title = {Bayesian inference for synaptic connectivity rules in anatomically realistic cortical connectomes},
	shorttitle = {Bayesian inference for synaptic connectivity rules},
	url = {https://pure.mpg.de/rest/items/item_3279605/component/file_3279606/content},
	abstract = {The structural connectivity of the brain is a key determinant of its function. However, mapping the full connectome of a mammalian brain remains a formidable challenge. Instead, we often rely on statistical models of connectivity, which describe the probability of a synapse between two neurons as a function of their cell types, spatial distance, and other features. While such models are useful, they are often fitted to incomplete data or rely on heuristic assumptions. Here, we propose a Bayesian framework for inferring synaptic connectivity rules from partial connectomic data. Our approach allows us to incorporate prior knowledge about cortical architecture and to quantify the uncertainty in the inferred connectivity rules. We demonstrate our method on a dataset of mouse visual cortex, showing that it can recover known connectivity motifs and provide new insights into the principles of cortical organization.},
	language = {en},
	urldate = {2024-05-22},
	author = {Kastner, J. and Macke, J. H.},
	year = {2019},
	keywords = {BERNSTEIN},
}
