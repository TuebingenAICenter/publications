@article{koc_optimizing_2019,
	title = {Optimizing the {Execution} of {Dynamic} {Robot} {Movements} {With} {Learning} {Control}},
	issn = {1552-3098},
	shorttitle = {Optimizing the {Execution} of {Dynamic} {Robot} {Movements}},
	url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?tp=&arnumber=8705679},
	doi = {10.1109/TRO.2019.2906558},
	abstract = {Dynamic robot movements, such as throwing, hitting, or catching, require high-precision control to succeed. While learning from demonstration (LfD) can provide a good initial policy, the resulting movements often lack the precision required for complex tasks. In this article, we propose a framework that optimizes the execution of dynamic robot movements by combining LfD with iterative learning control (ILC). We represent the robot movement as a dynamic movement primitive (DMP) and use LfD to learn the initial parameters. We then use ILC to refine the execution of the movement by iteratively updating the control parameters based on the tracking error. We demonstrate the effectiveness of our approach on a real robot platform, showing that it can significantly improve the performance of dynamic movements compared to LfD alone.},
	language = {en},
	journal = {IEEE Transactions on Robotics},
	publisher = {IEEE},
	author = {Koc, O. and Maeda, G. and Peters, J.},
	year = {2019},
	keywords = {TRO},
}
