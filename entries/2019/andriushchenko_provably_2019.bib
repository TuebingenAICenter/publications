@misc{andriushchenko_provably_2019,
	title = {Provably {Robust} {Boosted} {Decision} {Stumps} and {Trees} against {Adversarial} {Attacks}},
	shorttitle = {Provably {Robust} {Boosted} {Decision} {Stumps} and {Trees}},
	url = {https://arxiv.org/abs/1906.03526},
	doi = {10.48550/arXiv.1906.03526},
	abstract = {We propose a new approach to train provably robust boosted decision stumps and trees against adversarial attacks. Our method is based on a robust version of the exponential loss which allows us to derive a tight upper bound on the adversarial loss. We show that for decision stumps, the robust loss can be minimized efficiently. For decision trees, we propose a greedy training algorithm that minimizes the robust loss at each split. Our approach provides a certificate of robustness for the final model, meaning that for any input, we can guarantee that the prediction does not change within a given perturbation set. We evaluate our method on several datasets and show that it achieves state-of-the-art robust accuracy for tree-based models, while being significantly faster to train than existing methods.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Andriushchenko, Maksym and Hein, Matthias},
	year = {2019},
	keywords = {Interpretability, MNIST database, Robustness (evolution), Boosting (machine learning), Decision tree, Computer science, Deep neural networks, Mathematics, Upper and lower bounds, Artificial intelligence, Artificial neural network, Algorithm, Combinatorics, Discrete mathematics, NEURIPS},
}
