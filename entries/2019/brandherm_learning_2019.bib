@article{brandherm_learning_2019,
	title = {Learning {Replanning} {Policies} {With} {Direct} {Policy} {Search}},
	shorttitle = {Learning {Replanning} {Policies}},
	url = {https://is.mpg.de/ei/publications/brapetneuakr19},
	doi = {10.1109/LRA.2019.2901656},
	abstract = {In this paper, we propose a novel approach to learn replanning policies for complex robotic tasks. Instead of learning a single policy that maps states to actions, we learn a policy that maps states to a sequence of future actions, i.e., a plan. Our approach is based on direct policy search, which allows us to optimize the policy parameters directly with respect to the task objective. We show that our approach can learn effective replanning policies for a variety of robotic tasks, including reaching, pushing, and manipulation, in both simulation and on a real robot.},
	language = {en},
	urldate = {2024-05-23},
	journal = {IEEE Robotics and Automation Letters},
	publisher = {IEEE},
	author = {Brandherm, F. and Peters, J. and Neumann, G. and Akrour, R.},
	year = {2019},
	keywords = {RAL},
}
