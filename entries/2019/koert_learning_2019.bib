@article{koert_learning_2019,
	title = {Learning {Intention} {Aware} {Online} {Adaptation} of {Movement} {Primitives}},
	shorttitle = {Learning {Intention} {Aware} {Online} {Adaptation} of {Movement} {Primitives}},
	url = {https://is.mpg.de/ei/publications/koertetal19},
	doi = {10.1109/LRA.2019.2928760},
	abstract = {In many human-robot interaction scenarios, the robot needs to adapt its movement to the human's intent. For example, when handing over an object, the robot should adapt its trajectory to the human's reaching motion. In this paper, we propose a framework for learning intention-aware online adaptation of movement primitives. We model the human's intent as a latent variable and use a Bayesian approach to infer the intent from the observed human motion. Based on this inference, we adapt the robot's movement primitive online. We evaluate our approach in a simulated handover scenario and show that it outperforms a baseline approach that does not account for the human's intent.},
	language = {en},
	urldate = {2024-05-22},
	journal = {IEEE Robotics and Automation Letters},
	publisher = {IEEE},
	author = {Koert, D. and Pajarinen, J. and Schotschneider, A. and Trick, S. and Rothkopf, C. and Peters, J.},
	year = {2019},
	keywords = {IROS},
}
