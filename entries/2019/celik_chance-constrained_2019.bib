@inproceedings{celik_chance-constrained_2019,
	title = {Chance-{Constrained} {Trajectory} {Optimization} for {Non}-linear {Systems} with {Unknown} {Stochastic} {Dynamics}},
	shorttitle = {Chance-{Constrained} {Trajectory} {Optimization}},
	url = {https://is.mpg.de/ei/publications/celabdpet19},
	doi = {10.1109/IROS40897.2019.8967794},
	abstract = {Trajectory optimization for non-linear systems with stochastic dynamics is a challenging problem, especially when the dynamics are unknown. In this paper, we propose a chance-constrained trajectory optimization framework that can handle unknown stochastic dynamics. We use Gaussian Processes to learn the dynamics and their uncertainty from data. The chance constraints are then reformulated into deterministic constraints using the learned dynamics and uncertainty. We demonstrate the effectiveness of our approach on a simulated non-linear system.},
	language = {en},
	urldate = {2024-05-23},
	publisher = {IEEE},
	author = {Celik, O. and Abdulsamad, H. and Peters, J.},
	month = nov,
	year = {2019},
	keywords = {IROS},
}
