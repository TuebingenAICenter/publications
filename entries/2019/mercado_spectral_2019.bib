@article{mercado_spectral_2019,
	title = {Spectral {Clustering} of {Signed} {Graphs} via {Matrix} {Power} {Means}},
	shorttitle = {Spectral {Clustering} of {Signed} {Graphs}},
	url = {https://arxiv.org/abs/1905.06230},
	doi = {10.48550/arXiv.1905.06230},
	abstract = {We propose a new spectral clustering method for signed graphs based on matrix power means. Signed graphs contain both positive and negative edges, representing relations like trust/distrust or like/dislike. Standard spectral clustering methods for signed graphs are based on the signed Laplacian, which often fails to capture the structure of the graph when the graph is unbalanced. We introduce a family of Laplacians based on the matrix power mean of the positive and negative parts of the adjacency matrix. We show that our method is consistent in the context of the signed stochastic block model and outperforms existing methods on synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 36th International Conference on Machine Learning},
	publisher = {PMLR},
	author = {Mercado, Pedro and Tudisco, Francesco and Hein, Matthias},
	year = {2019},
	keywords = {Stochastic block model, Spectral clustering, Eigenvalues and eigenvectors, Mathematics, Laplace operator, Cluster analysis, Laplacian matrix, Block (permutation group theory), Matrix (chemical analysis), Combinatorics, Power iteration, Discrete mathematics, Applied mathematics, Algorithm, Statistics, Mathematical analysis, Physics, Iterative method, ICML},
}
