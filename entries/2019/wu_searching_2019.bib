@inproceedings{wu_searching_2019,
	title = {Searching for rewards in graph-structured spaces},
	shorttitle = {Searching for rewards in graph-structured spaces},
	url = {https://charleywu.github.io/downloads/wu2019searching.pdf},
	doi = {10.32470/CCN.2019.1041-0},
	abstract = {How do people search for rewards in environments where options are related by a graph structure? We propose a model of human search based on Gaussian process function learning over graphs. We test this model in a behavioral experiment where participants search for rewards on a graph. We find that participants' search behavior is well-described by a strategy that balances exploration and exploitation, and that they are able to leverage the graph structure to generalize rewards to unobserved nodes. Our results suggest that people use a combination of local and global information to guide their search in complex, structured environments.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Proceedings of the 2019 {Conference} on {Cognitive} {Computational} {Neuroscience}},
	author = {Wu, Charley M. and Schulz, Eric and Gershman, Samuel J.},
	year = {2019},
	keywords = {CCN},
}
