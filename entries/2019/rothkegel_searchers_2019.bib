@article{rothkegel_searchers_2019,
	title = {Searchers adjust their eye-movement dynamics to target characteristics in natural scenes},
	issn = {2045-2322},
	shorttitle = {Searchers adjust their eye-movement dynamics},
	url = {https://doi.org/10.1038/s41598-018-37548-w},
	doi = {10.1038/s41598-018-37548-w},
	abstract = {Visual search in natural scenes is a complex task that requires the coordination of eye movements to locate a target. While previous research has focused on the role of image features in guiding attention, the influence of target characteristics on eye-movement dynamics remains less understood. Here, we investigated how searchers adjust their eye-movement dynamics to target characteristics in natural scenes. We recorded eye movements of participants searching for targets of varying difficulty in natural images. We found that searchers adapt their saccade amplitudes and fixation durations to the target's characteristics. Specifically, when searching for more difficult targets, participants made smaller saccades and longer fixations. These findings suggest that searchers dynamically adjust their oculomotor behavior to optimize search performance based on the expected difficulty of the target.},
	language = {en},
	urldate = {2024-05-23},
	journal = {Scientific Reports},
	publisher = {Nature Portfolio},
	author = {Rothkegel, L.O.M. and Schütt, H.H. and Trukenbrod, H.A. and Wichmann, F. A. and Engbert, R.},
	year = {2019},
	keywords = {SCIREP},
}
