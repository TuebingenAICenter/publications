@misc{brendel_accurate_2019,
	title = {Accurate, reliable and fast robustness evaluation},
	url = {https://proceedings.neurips.cc/paper/2019/hash/885fe656777008c335ac96072a45be15-Abstract.html},
	doi = {10.48550/arxiv.1907.01003},
	abstract = {Robustness evaluation of neural networks against adversarial perturbations is a central problem in machine learning. However, current evaluation methods are either slow (e.g., iterative attacks) or unreliable (e.g., gradient-based attacks). In this paper, we propose a new approach to robustness evaluation that is both accurate and fast. We introduce the Boundary Attack, a simple yet effective decision-based attack that can be used to estimate the robustness of a model. We show that the Boundary Attack is more accurate than existing gradient-based attacks and significantly faster than iterative attacks. We also demonstrate that the Boundary Attack can be used to evaluate the robustness of models that are not differentiable, such as those with non-differentiable activation functions or those that are black-box.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Brendel, Wieland and Rauber, Jonas and Kümmerer, Matthias and Ustyuzhaninov, Ivan and Bethge, Matthias},
	year = {2019},
	keywords = {Robustness (evolution), Computer science, Reliability engineering, Engineering, Biology, NEURIPS},
}
