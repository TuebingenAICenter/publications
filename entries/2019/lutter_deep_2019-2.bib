@inproceedings{lutter_deep_2019-2,
	title = {Deep {Lagrangian} {Networks}: {Using} {Physics} as {Model} {Prior} for {Deep} {Learning}},
	shorttitle = {Deep {Lagrangian} {Networks}},
	url = {https://openreview.net/pdf?id=BklHpjCqKm},
	abstract = {Deep learning has achieved impressive results in many domains, but often requires large amounts of data and lacks interpretability. In robotics, we have a strong prior: the laws of physics. In this paper, we propose Deep Lagrangian Networks (DeLaN), a deep learning architecture that incorporates the Lagrangian formulation of physics. By learning the Lagrangian of a system, we can derive the equations of motion, which allows us to model the dynamics of a robot. Our approach is data-efficient, interpretable, and can be used for control. We demonstrate the effectiveness of our approach on a simulated robot arm and a real-world robot.},
	language = {en},
	urldate = {2024-05-22},
	publisher = {ICLR},
	author = {Lutter, Michael and Ritter, Christian and Peters, Jan},
	month = may,
	year = {2019},
	keywords = {ICLR},
}
