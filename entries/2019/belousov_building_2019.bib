@inproceedings{belousov_building_2019,
	title = {Building a {Library} of {Tactile} {Skills} {Based} on {FingerVision}},
	shorttitle = {Building a {Library} of {Tactile} {Skills} {Based} on {FingerVision}},
	url = {https://is.mpg.de/ei/publications/belousovetal19},
	doi = {10.1109/Humanoids43949.2019.9035000},
	abstract = {Tactile sensing is crucial for robots to perform dexterous manipulation tasks. However, the high dimensionality of tactile data and the difficulty of obtaining ground truth labels make learning tactile skills challenging. In this paper, we propose a framework for building a library of tactile skills based on FingerVision, a low-cost, high-resolution tactile sensor. We demonstrate that our framework can be used to learn a variety of tactile skills, including grasping, sliding, and pushing, in a sample-efficient manner. We also show that the learned skills can be transferred to new objects and tasks, demonstrating the potential of our approach for building general-purpose tactile manipulation systems.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {International {Conference} on {Humanoid} {Robots} ({Humanoids})},
	publisher = {IEEE},
	author = {Belousov, B. and Sadybakasov, A. and Wibranek, B. and Veiga, F. and Tessmann, O. and Peters, J.},
	month = oct,
	year = {2019},
	keywords = {HUMANOIDS},
}
