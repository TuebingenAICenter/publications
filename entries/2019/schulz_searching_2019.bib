@article{schulz_searching_2019,
	title = {Searching for {Rewards} {Like} a {Child} {Means} {Less} {Generalization} and {More} {Directed} {Exploration}},
	issn = {0956-7976},
	shorttitle = {Searching for {Rewards} {Like} a {Child}},
	url = {https://doi.org/10.1177/0956797619863663},
	doi = {10.1177/0956797619863663},
	abstract = {How do children explore the world to find rewards? We compared the exploration strategies of children (ages 6–10) and adults in a multi-armed bandit task. We found that children explore more than adults do, but their exploration is less directed toward high-potential options. Using a computational model of function learning, we show that this difference is driven by children's reduced ability to generalize from previous experiences. While adults use their knowledge of the environment to guide their exploration, children rely more on directed exploration—a strategy that is less efficient in structured environments. These results suggest that developmental differences in exploration are not just a matter of curiosity, but are rooted in fundamental differences in how children and adults learn and generalize.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Psychological Science},
	publisher = {SAGE Publications},
	author = {Schulz, Eric and Wu, Charley M. and Ruggeri, Azzurra and Meder, Björn},
	year = {2019},
	keywords = {Generalization, Psychology, Task (project management), Sampling (signal processing), Balance (ability), Developmental psychology, Dilemma, Cognitive psychology, Computer science, Mathematics},
}
