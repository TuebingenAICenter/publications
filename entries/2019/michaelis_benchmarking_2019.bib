@misc{michaelis_benchmarking_2019,
	title = {Benchmarking {Robustness} in {Object} {Detection}: {Autonomous} {Driving} when {Winter} is {Coming}},
	shorttitle = {Benchmarking {Robustness} in {Object} {Detection}},
	url = {https://arxiv.org/abs/1907.07484},
	doi = {10.48550/arXiv.1907.07484},
	abstract = {Deep neural networks have achieved impressive performance on object detection tasks. However, their robustness to common corruptions, such as weather conditions or sensor noise, remains largely unexplored. In this paper, we introduce a new benchmark for object detection robustness, which consists of a large-scale dataset of common corruptions applied to the Pascal VOC and COCO datasets. We evaluate a wide range of state-of-the-art object detectors on this benchmark and find that their performance drops significantly under corruption. We further analyze the impact of different types of corruptions and find that some are more challenging than others. Finally, we propose a simple data augmentation strategy that improves the robustness of object detectors to these corruptions.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Michaelis, Claudio and Mitzkus, Benjamin and Geirhos, Robert and Rusak, Evgenia and Bringmann, Oliver and Ecker, Alexander S. and Bethge, Matthias and Brendel, Wieland},
	year = {2019},
	keywords = {Robustness (evolution), Benchmarking, Benchmark (surveying), Object detection, Computer science, Artificial intelligence, Deep learning, Pascal (unit), Computer vision, Machine learning, Data mining, Pattern recognition (psychology), Cartography, Geography, ICCV},
}
