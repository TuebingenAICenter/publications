@article{sinz_engineering_2019,
	title = {Engineering a less artificial intelligence},
	issn = {0896-6273},
	url = {https://bethgelab.org/publication/2019_09_sinz/},
	doi = {10.1016/j.neuron.2019.08.034},
	abstract = {Artificial intelligence (AI) has made remarkable progress in recent years, yet it still falls short of human-level performance in many tasks. One reason for this is that current AI systems are often trained on static datasets and lack the ability to learn from experience in the same way that humans do. In this paper, we argue that to build more intelligent systems, we need to move beyond static datasets and towards systems that can learn from their own experiences in a more naturalistic way. We propose a framework for engineering such systems, which we call 'less artificial intelligence'. This framework emphasizes the importance of incorporating principles from neuroscience and cognitive science into the design of AI systems. We discuss the potential benefits of this approach and provide examples of how it can be applied to a range of tasks.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Neuron},
	publisher = {Elsevier},
	author = {Sinz, Fabian H and Pitkow, Xaq and Reimer, Jacob and Bethge, Matthias and Tolias, Andreas S},
	year = {2019},
	keywords = {Psychology, Artificial intelligence, Cognitive science, Computer science, Neuroscience, NEURON},
}
