@article{tabibian_enhancing_2019,
	title = {Enhancing {Human} {Learning} via {Spaced} {Repetition} {Optimization}},
	shorttitle = {Enhancing {Human} {Learning}},
	url = {https://www.pnas.org/content/116/10/3988},
	doi = {10.1073/pnas.1815156116},
	abstract = {Spaced repetition is a technique for efficient learning that involves repeating information at specifically spaced intervals. Despite its effectiveness, most existing spaced repetition systems rely on heuristic scheduling algorithms that are not optimized for individual learners. Here, we propose a framework to optimize spaced repetition schedules by combining a point process model of human memory with a reinforcement learning approach. We show that our framework can be used to derive optimal schedules for any given memory model and that it significantly outperforms existing heuristic-based and model-based scheduling algorithms in terms of both learning efficiency and retention. We also demonstrate that our framework is scalable and can be used to optimize schedules for thousands of items in real time.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the National Academy of Sciences},
	publisher = {National Academy of Sciences},
	author = {Tabibian, Behzad and Upadhyay, Utkarsh and De, Abir and Zarezade, Ali and Schölkopf, Bernhard and Gomez Rodriguez, Manuel},
	year = {2019},
	keywords = {Memorization, Repetition (rhetorical device), Computer science, Heuristics, Schedule, Discriminative model, Scalability, Point (geometry), Algorithm, Artificial intelligence, Machine learning, Speech recognition, Mathematics, PNAS},
}
