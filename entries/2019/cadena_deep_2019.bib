@article{cadena_deep_2019,
	title = {Deep convolutional models improve predictions of macaque {V1} responses to natural images},
	copyright = {CC BY 4.0},
	issn = {1553-7358},
	shorttitle = {Deep convolutional models improve predictions of macaque {V1} responses},
	url = {https://journals.plos.org/ploscompbiol/article?id=10.1371/journal.pcbi.1006897},
	doi = {10.1371/journal.pcbi.1006897},
	abstract = {The primary goal of sensory neuroscience is to build predictive models of neural responses to natural stimuli. While deep convolutional neural networks (CNNs) have recently achieved state-of-the-art performance in predicting responses of neurons in higher visual areas, their ability to predict responses in primary visual cortex (V1) has been less clear. Here, we show that deep CNNs, when trained on object recognition, can predict V1 responses to natural images significantly better than classical models. We find that the performance of these models depends on the architecture and the training objective. Specifically, we show that models with a larger receptive field and a more complex architecture perform better. Furthermore, we find that the internal representations of these models are more similar to V1 than those of classical models. Our results suggest that deep CNNs are a powerful tool for understanding the computations performed by the visual cortex.},
	language = {en},
	urldate = {2025-05-14},
	journal = {PLoS Computational Biology},
	publisher = {Public Library of Science},
	author = {Cadena, Santiago A. and Denfield, George H. and Walker, Edgar Y. and Gatys, Leon A. and Tolias, Andreas S. and Bethge, Matthias and Ecker, Alexander S.},
	year = {2019},
	keywords = {Artificial intelligence, Computer science, Convolutional neural network, Deep learning, Transfer of learning, Visual cortex, Pattern recognition (psychology), Feature (linguistics), Macaque, Machine learning, Cognitive neuroscience of visual object recognition, Set (abstract data type), Object (grammar), Neuroscience, Psychology, PLOSCB},
}
