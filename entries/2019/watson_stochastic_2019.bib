@inproceedings{watson_stochastic_2019,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Stochastic {Optimal} {Control} as {Approximate} {Input} {Inference}},
	shorttitle = {Stochastic {Optimal} {Control} as {Approximate} {Input} {Inference}},
	url = {http://proceedings.mlr.press/v100/watson20a.html},
	abstract = {Stochastic optimal control (SOC) is a powerful framework for decision making under uncertainty. However, solving SOC problems is often computationally demanding. In this paper, we propose a novel perspective on SOC by framing it as an approximate input inference problem. We show that the optimal control policy can be interpreted as a posterior distribution over control inputs, conditioned on the goal of minimizing a cost function. By leveraging this connection, we derive a new class of algorithms that approximate the optimal control policy using variational inference. We demonstrate the effectiveness of our approach on several challenging control tasks, showing that it achieves competitive performance while being more computationally efficient than traditional methods.},
	language = {en},
	booktitle = {Proceedings of the 3rd {Annual} {Conference} on {Robot} {Learning}},
	publisher = {PMLR},
	author = {Watson, J. and Abdulsamad, H. and Peters, J.},
	editor = {Kaelbling, Leslie Pack and Kragic, Danica and Sugiura, Komei},
	month = nov,
	year = {2019},
	keywords = {CORL},
}
