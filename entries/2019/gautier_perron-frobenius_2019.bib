@article{gautier_perron-frobenius_2019,
	title = {The {Perron}-{Frobenius} {Theorem} for {Multihomogeneous} {Mappings}},
	issn = {0895-4798},
	shorttitle = {The {Perron}-{Frobenius} {Theorem} for {Multihomogeneous} {Mappings}},
	url = {https://doi.org/10.1137/18m1165037},
	doi = {10.1137/18m1165037},
	abstract = {We study the spectral theory of multihomogeneous mappings, which are a generalization of linear operators and homogeneous polynomials. We show that for a large class of such mappings, which we call cone-preserving, a Perron-Frobenius theorem holds. In particular, we prove the existence of a positive eigenvector and a corresponding eigenvalue, which is the spectral radius of the mapping. We also provide conditions for the uniqueness of the eigenvector and the convergence of the power iteration. Our results generalize the classical Perron-Frobenius theorem for non-negative matrices and the results for homogeneous mappings of degree m.},
	language = {en},
	urldate = {2025-05-14},
	journal = {SIAM Journal on Matrix Analysis and Applications},
	publisher = {Society for Industrial and Applied Mathematics},
	author = {Gautier, Antoine and Tudisco, Francesco and Hein, Matthias},
	year = {2019},
	keywords = {Mathematics, Multilinear map, Uniqueness, Spectral radius, Iterated function, Eigenvalues and eigenvectors, Pure mathematics, Nonlinear system, Spectral theory, Order (exchange), Matrix norm, Applied mathematics, Mathematical analysis, Hilbert space, SIMAX},
}
