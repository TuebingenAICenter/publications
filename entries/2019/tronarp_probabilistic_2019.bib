@article{tronarp_probabilistic_2019,
	title = {Probabilistic solutions to ordinary differential equations as nonlinear {Bayesian} filtering: a new perspective},
	issn = {0960-3174},
	shorttitle = {Probabilistic solutions to ordinary differential equations},
	url = {https://is.mpg.de/ei/publications/trokersarhen19},
	doi = {10.1007/s11222-019-09900-1},
	abstract = {We propose a new perspective on probabilistic numerical methods for ordinary differential equations (ODEs). We show that a large class of existing probabilistic ODE solvers can be interpreted as nonlinear Bayesian filtering problems. This interpretation allows us to leverage the extensive literature on Bayesian filtering to derive new solvers, analyze existing ones, and provide a unified framework for probabilistic numerical integration. We demonstrate the utility of this perspective by deriving a new class of solvers based on the extended Kalman filter and the unscented Kalman filter, and by providing a rigorous convergence analysis for a class of linear ODE solvers.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Statistics and Computing},
	publisher = {Springer},
	author = {Tronarp, Filip and Kersting, Hans and Särkkä, Simo and Hennig, Philipp},
	year = {2019},
	keywords = {Ode, Mathematics, Applied mathematics, Filtering problem, Gaussian process, Gaussian, Probabilistic logic, Smoothing, Ordinary differential equation, Particle filter, Bayesian probability, Mathematical optimization, Algorithm, Differential equation, Kalman filter, Mathematical analysis, Extended Kalman filter, STATCOMP},
}
