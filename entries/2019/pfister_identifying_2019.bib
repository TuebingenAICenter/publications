@misc{pfister_identifying_2019,
	title = {Identifying {Causal} {Structure} in {Large}-{Scale} {Kinetic} {Systems}},
	url = {https://is.mpg.de/ei/publications/pfibaupet19b},
	abstract = {We consider the problem of learning the causal structure of a kinetic system from observational time series data. Kinetic systems are often described by systems of ordinary differential equations (ODEs). In many applications, such as gene regulatory networks or chemical reaction networks, the number of variables is large, but the underlying causal structure is sparse. We propose a method that exploits the structure of kinetic equations to identify the causal graph. Our approach is based on a regularized regression framework and is computationally efficient, allowing us to handle systems with hundreds of variables. We provide theoretical guarantees for the consistency of our estimator and demonstrate its performance on synthetic and real-world data.},
	language = {en},
	urldate = {2024-05-22},
	author = {Pfister, Niklas and Bauer, Sebastian and Peters, Jonas},
	year = {2019},
}
