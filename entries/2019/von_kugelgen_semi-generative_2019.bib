@inproceedings{von_kugelgen_semi-generative_2019,
	title = {Semi-{Generative} {Modelling}: {Covariate}-{Shift} {Adaptation} with {Cause} and {Effect} {Features}},
	shorttitle = {Semi-{Generative} {Modelling}},
	url = {https://proceedings.mlr.press/v89/kugelgen19a.html},
	abstract = {We consider the problem of covariate shift, where the distribution of the input features changes between training and test time, while the conditional distribution of the target given the features remains invariant. Standard approaches to this problem typically rely on importance weighting, which can be unstable and often ignores the causal structure of the data. We propose a novel framework, Semi-Generative Modelling (SGM), which leverages causal knowledge to perform covariate-shift adaptation. By explicitly modelling the causal direction between features and target, SGM allows for a more robust and flexible adaptation to covariate shift. We demonstrate the effectiveness of our approach on both synthetic and real-world datasets, showing that it outperforms existing methods in various scenarios.},
	language = {en},
	booktitle = {Proceedings of the 22nd {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {von Kügelgen, Julius and Mey, Alexander and Loog, Marco},
	editor = {Chaudhuri, Kamalika and Sugiyama, Masashi},
	month = apr,
	year = {2019},
	keywords = {AISTATS},
}
