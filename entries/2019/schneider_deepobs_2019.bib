@inproceedings{schneider_deepobs_2019,
	title = {{DeepOBS}: {A} {Deep} {Learning} {Optimizer} {Benchmark} {Suite}},
	shorttitle = {{DeepOBS}},
	url = {https://openreview.net/pdf?id=rJg6ssC5Y7},
	doi = {10.48550/arxiv.1903.05499},
	abstract = {The development of new optimization algorithms for deep learning is a central topic in machine learning research. However, comparing new methods to the state-of-the-art is difficult because results are often reported on different tasks, with different hyperparameter tuning budgets, and different software frameworks. To address this, we introduce DeepOBS, a Deep Learning Optimizer Benchmark Suite. DeepOBS provides a standardized collection of deep learning problems, including data sets, models, and loss functions, that are representative of modern deep learning research. It is built on top of TensorFlow and provides a unified interface for benchmarking optimizers. We demonstrate the utility of DeepOBS by benchmarking several popular optimizers on a variety of tasks.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {7th {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Schneider, Frank and Balles, Lukas and Hennig, Philipp},
	month = may,
	year = {2019},
	keywords = {Benchmarking, MNIST database, Computer science, Deep learning, Artificial intelligence, Machine learning, Suite, Python (programming language), Benchmark (surveying), Programming language, ICLR},
}
