@article{croce_provable_2019,
	title = {Provable {Robustness} of {ReLU} {Networks} via {Maximization} of {Linear} {Regions}},
	shorttitle = {Provable {Robustness} of {ReLU} {Networks}},
	url = {https://arxiv.org/abs/1810.07481},
	doi = {10.48550/arXiv.1810.07481},
	abstract = {We propose a new approach to improve the provable robustness of ReLU networks. We show that the robustness of a ReLU network is related to the number of linear regions it creates. Specifically, we prove that a higher number of linear regions can lead to a larger robust radius. Based on this insight, we propose a regularization method that encourages the network to create more linear regions. We evaluate our method on several datasets and show that it improves the provable robustness of ReLU networks compared to existing methods.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 22nd International Conference on Artificial Intelligence and Statistics},
	publisher = {PMLR},
	author = {Croce, Francesco and Andriushchenko, Maksym and Hein, Matthias},
	year = {2019},
	keywords = {AISTATS},
}
