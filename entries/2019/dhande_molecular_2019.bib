@article{dhande_molecular_2019,
	title = {Molecular fingerprinting of on–off direction-selective retinal ganglion cells across species and relevance to primate visual circuits.},
	issn = {0270-6474},
	shorttitle = {Molecular fingerprinting of on–off direction-selective retinal ganglion cells},
	url = {https://www.jneurosci.org/content/39/1/78},
	doi = {10.1523/JNEUROSCI.1413-18.2018},
	abstract = {Direction-selective retinal ganglion cells (DSGCs) are a classic model for studying how neural circuits compute visual motion. In mice, ON–OFF DSGCs are well characterized, but their counterparts in other species, including primates, remain poorly understood. Here, we show that the transcription factor Satb2 is expressed by ON–OFF DSGCs in the mouse retina. We find that Satb2 is also expressed by a subset of RGCs in the macaque retina that are morphologically and physiologically similar to mouse ON–OFF DSGCs. These findings suggest that the molecular identity of ON–OFF DSGCs is conserved across species and provide a new tool for studying these cells in primates.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Neuroscience},
	publisher = {Society for Neuroscience},
	author = {Dhande, Onkar S. and Stafford, Benjamin K. and Franke, Katrin and El-Danaf, Rami and Percival, Kelly A. and Phan, Anh H. and Berens, Philipp and Huberman, Andrew D.},
	month = jan,
	year = {2019},
	keywords = {JNEUROSCI},
}
