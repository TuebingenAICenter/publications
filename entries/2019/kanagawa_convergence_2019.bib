@inproceedings{kanagawa_convergence_2019,
	title = {Convergence {Guarantees} for {Adaptive} {Bayesian} {Quadrature} {Methods}},
	shorttitle = {Convergence {Guarantees} for {Adaptive} {Bayesian} {Quadrature} {Methods}},
	url = {https://papers.nips.cc/paper/8854-convergence-guarantees-for-adaptive-bayesian-quadrature-methods},
	doi = {10.48550/arxiv.1905.10271},
	abstract = {Bayesian quadrature (BQ) is a framework for numerical integration that treats the integral as a latent value to be inferred. While BQ is often used with adaptive designs to select evaluation points, theoretical guarantees for such adaptive methods are limited. This paper provides convergence guarantees for adaptive BQ methods. We show that, under mild conditions on the integrand and the kernel, the BQ posterior mean converges to the true integral value at a rate determined by the fill distance of the design points. We also provide a convergence rate for the BQ posterior variance, which serves as a measure of uncertainty. Our results cover a wide range of adaptive strategies, including those based on the BQ posterior variance and those based on information-theoretic criteria.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 32},
	publisher = {Curran Associates, Inc.},
	author = {Kanagawa, M. and Hennig, P.},
	editor = {Wallach, H. and Larochelle, H. and Beygelzimer, A. and d'Alche-Buc, F. and Fox, E. and Garnett, R.},
	month = dec,
	year = {2019},
	keywords = {Convergence (economics), Quadrature (astronomy), Bayesian probability, Adaptive quadrature, Computer science, Mathematical optimization, Econometrics, Applied mathematics, Mathematics, Artificial intelligence, Economics, Control theory (sociology), Engineering, Electronic engineering, Macroeconomics, NEURIPS},
}
