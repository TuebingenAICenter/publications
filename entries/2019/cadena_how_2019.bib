@article{cadena_how_2019,
	title = {How well do deep neural networks trained on object recognition characterize the mouse visual system?},
	shorttitle = {How well do deep neural networks trained on object recognition characterize the mouse visual system?},
	url = {https://openreview.net/forum?id=rkxcXmtUUS},
	doi = {10.48550/arXiv.1902.01416},
	abstract = {Deep neural networks (DNNs) have recently emerged as the state-of-the-art models for predicting neural responses in the primate visual system. However, it remains unclear whether these models are also suitable for describing the mouse visual system, which differs from the primate system in several fundamental ways, such as the lack of a clear hierarchical organization and the absence of foveal vision. Here, we systematically evaluate how well DNNs trained on object recognition characterize the mouse primary visual cortex (V1). We find that while these models can predict neural responses in mouse V1, they do not outperform simpler models that are specifically designed to capture the properties of the mouse visual system. Furthermore, we show that the performance of DNNs is largely driven by low-level image features, suggesting that they do not capture the higher-level representations that are characteristic of the primate visual system. Our results suggest that while DNNs are powerful tools for modeling neural responses, they may not be the most appropriate models for the mouse visual system.},
	language = {en},
	urldate = {2025-05-14},
	journal = {International Conference on Learning Representations},
	publisher = {OpenReview},
	author = {Cadena, Santiago A. and Sinz, Fabian H. and Muhammad, Taliah and Froudarakis, Emmanouil and Cobos, Erick and Walker, Edgar Y. and Reimer, Jake and Bethge, Matthias and Tolias, Andreas and Ecker, Alexander S.},
	year = {2019},
	keywords = {Artificial intelligence, Computer science, Artificial neural network, Cognitive neuroscience of visual object recognition, Object (grammar), Computer vision, Pattern recognition (psychology), ICLR},
}
