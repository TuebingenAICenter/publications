@article{li_learning_2019,
	title = {Learning from brains how to regularize machines},
	shorttitle = {Learning from brains},
	url = {https://proceedings.neurips.cc/paper/2019/hash/70117ee3c0b15a2950f1e82a215e812b-Abstract.html},
	doi = {10.48550/arxiv.1911.05072},
	abstract = {Deep neural networks are powerful function approximators, but they often fail to generalize to out-of-distribution data. In contrast, biological visual systems are remarkably robust to image distortions. Here, we show that the internal representations of biological visual systems can be used to regularize deep neural networks. We propose a novel regularization method, Neural Taskonomy, which encourages neural networks to learn representations that are similar to those found in the primary visual cortex of mice. We demonstrate that our method improves the robustness of deep neural networks to image distortions and adversarial attacks, while maintaining high performance on standard benchmarks.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Advances in Neural Information Processing Systems},
	publisher = {Curran Associates, Inc.},
	author = {Li, Zhe and Brendel, Wieland and Walker, Edgar and Cobos, Erick and Muhammad, Taliah and Reimer, Jacob and Bethge, Matthias and Sinz, Fabian and Pitkow, Zachary and Tolias, Andreas},
	year = {2019},
	keywords = {Robustness (evolution), Artificial intelligence, Computer science, Convolutional neural network, Inference, Similarity (geometry), Pattern recognition (psychology), Artificial neural network, Machine learning, Representation (politics), Image (mathematics), NEURIPS},
}
