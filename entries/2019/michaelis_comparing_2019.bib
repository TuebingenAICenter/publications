@article{michaelis_comparing_2019,
	title = {Comparing {Search} {Strategies} of {Humans} and {Machines} in {Clutter}},
	issn = {1534-7362},
	url = {https://jov.arvojournals.org/article.aspx?articleid=2751187},
	doi = {10.1167/19.10.309c},
	abstract = {Visual search in cluttered scenes is a fundamental task for both biological and artificial vision systems. While deep neural networks (DNNs) have achieved human-level performance on object recognition, it remains unclear whether they employ similar search strategies to humans. We compared the search behavior of humans and state-of-the-art object detectors (Faster R-CNN, RetinaNet) in cluttered scenes. We generated synthetic images of varying clutter levels and measured search performance and eye movements. We found that while both humans and machines show a decrease in performance with increasing clutter, their search strategies differ significantly. Humans exhibit a systematic search pattern, whereas machines rely on global image features and are less affected by the spatial arrangement of distractors. Our results suggest that current object detectors do not yet capture the human-like search strategy in cluttered environments.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Vision},
	publisher = {Association for Research in Vision and Ophthalmology},
	author = {Michaelis, Claudio and Weller, Marlene and Funke, Christina and Ecker, Alexander S. and Wallis, Thomas S. A. and Bethge, Matthias},
	year = {2019},
	keywords = {Clutter, Artificial intelligence, Computer science, Computer vision, Image processing, Segmentation, Pattern recognition (psychology), Process (computing), Object (grammar), Position (finance), Task (project management), Perception, Set (abstract data type), Cognitive neuroscience of visual object recognition, Ranging, Object detection, Image (mathematics), Radar, Psychology, JOV},
}
