@article{babbar_data_2019,
	title = {Data scarcity, robustness and extreme multi-label classification},
	issn = {0885-6125},
	url = {https://doi.org/10.1007/s10994-019-05791-5},
	doi = {10.1007/s10994-019-05791-5},
	abstract = {Extreme multi-label classification (XML) involves learning a classifier that can tag a data point with the most relevant subset of labels from an extremely large label set. A key challenge in XML is the extreme sparsity of training data for the vast majority of labels. In this paper, we study the robustness of XML algorithms to such data scarcity. We show that for a large class of XML algorithms, the prediction error is bounded by the label-wise training data size. We propose a robust XML algorithm, DiSMEC, which is based on learning a multi-label classifier with a large number of labels. We show that DiSMEC is robust to data scarcity and achieves state-of-the-art performance on several benchmark datasets.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Machine Learning},
	publisher = {Springer},
	author = {Babbar, Rohit and Schölkopf, Bernhard},
	month = sep,
	year = {2019},
	keywords = {Hamming distance, Artificial intelligence, Robustness (evolution), Computer science, Classifier (UML), Pattern recognition (psychology), Hamming code, Mahalanobis distance, Mathematics, Upper and lower bounds, Machine learning, Algorithm, ML},
}
