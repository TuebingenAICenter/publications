@inproceedings{perrot_boosting_2019,
	title = {Boosting for {Comparison}-{Based} {Learning}},
	shorttitle = {Boosting for {Comparison}-{Based} {Learning}},
	url = {https://arxiv.org/abs/1810.13333},
	doi = {10.24963/ijcai.2019/436},
	abstract = {In comparison-based learning, the goal is to learn a representation or a classifier from triplet comparisons of the form 'object A is more similar to object B than to object C'. While many algorithms have been proposed for this setting, most of them are batch algorithms that do not scale well to large datasets. In this paper, we propose a boosting approach for comparison-based learning. Our algorithm, TripletBoost, iteratively learns a linear combination of simple comparison-based base learners. We provide a theoretical analysis of the convergence of the algorithm and show that it is consistent under mild conditions. Furthermore, we demonstrate that TripletBoost achieves state-of-the-art performance on several benchmark datasets while being significantly faster than existing methods.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the {Twenty}-{Eighth} {International} {Joint} {Conference} on {Artificial} {Intelligence}},
	publisher = {International Joint Conferences on Artificial Intelligence Organization},
	author = {Perrot, Michael and von Luxburg, Ulrike},
	year = {2019},
	keywords = {IJCAI},
}
