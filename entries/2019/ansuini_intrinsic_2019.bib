@misc{ansuini_intrinsic_2019,
	title = {Intrinsic dimension of data representations in deep neural networks},
	url = {https://proceedings.neurips.cc/paper/2019/hash/cfcce0621b49c983991ead4c3d4d3b6b-Abstract.html},
	doi = {10.48550/arxiv.1905.12784},
	abstract = {Deep neural networks have achieved remarkable success in many machine learning tasks. However, the nature of the representations they learn remains poorly understood. Here, we study the intrinsic dimension (ID) of the data representations in deep neural networks. We use a local intrinsic dimension estimator to analyze the ID of the representations of several state-of-the-art deep networks trained on image classification tasks. We find that the ID of the representations is much lower than the number of units in the layers, and that it decreases along the hierarchy of layers. We also find that the ID of the representations is correlated with the performance of the network, and that it can be used to predict the generalization error. Our results suggest that deep networks learn low-dimensional representations of the data, and that the dimensionality of these representations is a key factor in their performance.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Ansuini, Alessio and Laio, Alessandro and Macke, Jakob H. and Zoccolan, Davide},
	year = {2019},
	keywords = {Curse of dimensionality, Artificial neural network, Dimension (graph theory), Set (abstract data type), Representation (politics), Principal component analysis, Data set, Pattern recognition (psychology), Artificial intelligence, Layer (electronics), Intrinsic dimension, Computer science, Dimensionality reduction, Mathematics, Algorithm, Combinatorics, NEURIPS},
}
