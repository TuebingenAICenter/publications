@article{ghoshdastidar_foundations_2019,
	title = {Foundations of {Comparison}-{Based} {Hierarchical} {Clustering}},
	shorttitle = {Foundations of {Comparison}-{Based} {Hierarchical} {Clustering}},
	url = {https://arxiv.org/abs/1811.00928},
	doi = {10.48550/arXiv.1811.00928},
	abstract = {Hierarchical clustering is a fundamental task in data analysis. While most existing algorithms require numerical data (e.g., Euclidean distances), in many applications only comparison queries of the form "is object x closer to y than to z?" are available. In this paper, we provide the first theoretical foundations for comparison-based hierarchical clustering. We propose a general framework that allows us to analyze the sample complexity and recovery guarantees of such algorithms. We show that under a standard model of comparison queries, it is possible to recover the true hierarchical structure of the data with high probability. We also provide a concrete algorithm, prove its consistency, and demonstrate its performance on synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Advances in Neural Information Processing Systems 32},
	publisher = {Curran Associates, Inc.},
	author = {Ghoshdastidar, Debarghya and Perrot, Michael and von Luxburg, Ulrike},
	year = {2019},
	keywords = {NEURIPS},
}
