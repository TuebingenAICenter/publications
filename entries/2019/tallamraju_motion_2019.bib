@inproceedings{tallamraju_motion_2019,
	title = {Motion {Planning} for {Multi}-{Mobile}-{Manipulator} {Payload} {Transport} {Systems}},
	shorttitle = {Motion {Planning} for {Multi}-{Mobile}-{Manipulator} {Payload} {Transport} {Systems}},
	url = {https://is.mpg.de/ps/publications/rahul_case_2019},
	doi = {10.1109/COASE.2019.8842840},
	abstract = {Cooperative transport of a payload by multiple mobile manipulators is a complex task due to the high dimensionality of the state space and the non-holonomic constraints of the mobile bases. In this paper, we propose a motion planning framework for a team of mobile manipulators transporting a common payload. We model the system as a single kinematic chain with a closed-loop structure. We use a sampling-based motion planner to find a collision-free path for the payload in the workspace. The motion of the mobile bases and the manipulators is then derived using the inverse kinematics of the closed-loop system. We validate our approach through simulations and experiments with a team of two mobile manipulators.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {15th {IEEE} {International} {Conference} on {Automation} {Science} and {Engineering}},
	publisher = {IEEE},
	author = {Tallamraju, Rahul and Salunkhe, Durgesh and Rajappa, Sujit and Ahmad, Aamir and Karlapalem, Kamalakar and Shah, Suril Vijaykumar},
	month = aug,
	year = {2019},
	keywords = {CASE},
}
