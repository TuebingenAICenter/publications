@article{stimper_multidimensional_2019,
	title = {Multidimensional {Contrast} {Limited} {Adaptive} {Histogram} {Equalization}},
	issn = {2169-3536},
	shorttitle = {M-{CLAHE}},
	url = {https://ieeexplore.ieee.org/document/8895993},
	doi = {10.1109/ACCESS.2019.2952899},
	abstract = {Contrast Limited Adaptive Histogram Equalization (CLAHE) is a popular method for contrast enhancement in image processing. It operates on 2D images by computing local histograms and redistributing them to improve local contrast while limiting noise amplification. However, modern scientific imaging often produces multidimensional data, such as 3D volumes or time-series data, for which standard 2D CLAHE is not directly applicable. In this paper, we propose a multidimensional generalization of CLAHE, which we call M-CLAHE. Our method extends the concept of local histogram equalization to arbitrary dimensions by using a multidimensional grid of tiles and multilinear interpolation. We demonstrate the effectiveness of M-CLAHE on various types of multidimensional data, including 3D medical images and time-resolved electron microscopy data, and show that it provides superior contrast enhancement compared to existing methods.},
	language = {en},
	urldate = {2025-05-14},
	journal = {IEEE Access},
	publisher = {IEEE},
	author = {Stimper, Vincent and Bauer, Stefan and Ernstorfer, Ralph and Schölkopf, Bernhard and Xian, R. Patrick},
	year = {2019},
	keywords = {Adaptive histogram equalization, Computer science, Histogram equalization, Histogram, Contrast (vision), Artificial intelligence, Preprocessor, Visualization, Image processing, Computer vision, Pattern recognition (psychology), Image (mathematics)},
}
