@article{mastakouri_selecting_2019,
	title = {Selecting causal brain features with a single conditional independence test per feature},
	url = {https://papers.nips.cc/paper/9419-selecting-causal-brain-features-with-a-single-conditional-independence-test-per-feature},
	abstract = {We address the problem of selecting features that have a causal influence on a target variable. In many applications, such as neuroimaging, the number of features is large, while the number of samples is small. We propose a method that selects causal features by performing a single conditional independence test per feature. Our approach is based on the assumption that the target variable is a cause of the features, or that there is a common cause. We show that under certain conditions, our method is consistent and can recover the causal features. We demonstrate the effectiveness of our method on synthetic data and on real-world neuroimaging data.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Advances in Neural Information Processing Systems 32},
	publisher = {Curran Associates, Inc.},
	author = {Mastakouri, Atalanti-Anastasia and Schölkopf, Bernhard and Janzing, Dominik},
	editor = {Wallach, H. and Larochelle, H. and Beygelzimer, A. and d'Alché-Buc, F. and Fox, E. and Garnett, R.},
	month = dec,
	year = {2019},
	keywords = {Conditional independence, Constraint (computer-aided design), Independence (probability theory), Computer science, Artificial intelligence, Feature selection, Machine learning, Set (abstract data type), Neurophysiology, Variable (mathematics), Causality (physics), Feature (linguistics), Statistical hypothesis testing, Causal model, Psychology, Mathematics, Statistics, Neuroscience, NEURIPS},
}
