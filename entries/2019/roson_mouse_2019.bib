@article{roson_mouse_2019,
	title = {Mouse {dLGN} {Receives} {Functional} {Input} from a {Diverse} {Population} of {Retinal} {Ganglion} {Cells} with {Limited} {Convergence}},
	issn = {0896-6273},
	url = {https://doi.org/10.1016/j.neuron.2019.01.040},
	doi = {10.1016/j.neuron.2019.01.040},
	abstract = {The dorsal lateral geniculate nucleus (dLGN) is the primary thalamic relay for visual information to the cortex. While the dLGN is known to receive input from many types of retinal ganglion cells (RGCs), the functional organization of this input remains poorly understood. Here, we used two-photon calcium imaging to record the activity of RGC axons in the mouse dLGN and of dLGN neurons. We found that the dLGN receives functional input from a diverse population of RGCs, including many types that are not typically associated with the dLGN. Furthermore, we found that individual dLGN neurons receive input from a limited number of RGCs, and that this convergence is highly specific. Our results suggest that the dLGN is not merely a passive relay, but a sophisticated processing center that selectively filters and integrates visual information.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Neuron},
	publisher = {Elsevier},
	author = {Rosón, Miroslav Román and Bauer, Yannik and Kotkat, Ann H. and Berens, Philipp and Euler, Thomas and Busse, Laura},
	month = apr,
	year = {2019},
	keywords = {Neuroscience, Visual cortex, Biology, Population, Retina, Thalamus, Retinal, Retinal ganglion cell, Medicine, NEURON},
}
