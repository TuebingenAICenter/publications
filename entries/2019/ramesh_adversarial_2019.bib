@article{ramesh_adversarial_2019,
	title = {Adversarial {Training} of {Neural} {Encoding} {Models} on {Population} {Spike} {Trains}},
	url = {https://doi.org/10.32470/ccn.2019.1263-0},
	doi = {10.32470/ccn.2019.1263-0},
	abstract = {Neural encoding models aim to predict the activity of neurons in response to sensory stimuli. While deep learning models have achieved state-of-the-art performance in predicting neural responses, they often fail to capture the full statistical structure of population spike trains, such as noise correlations. Here, we propose an adversarial training framework to train neural encoding models. We show that our approach leads to models that better capture the statistical properties of population spike trains compared to standard maximum likelihood estimation.},
	language = {en},
	urldate = {2025-05-14},
	journal = {2019 Conference on Cognitive Computational Neuroscience},
	publisher = {Cognitive Computational Neuroscience},
	author = {Ramesh, Poornima and Atayi, Mohamad and Macke, Jakob H.},
	year = {2019},
	keywords = {Spike (software development), Train, Encoding (memory), Computer science, Training (meteorology), Speech recognition, Spike train, Population, Adversarial system, Artificial intelligence, Artificial neural network, Machine learning, Pattern recognition (psychology), Geography, Cartography, CCN},
}
