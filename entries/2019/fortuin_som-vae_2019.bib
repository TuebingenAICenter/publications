@inproceedings{fortuin_som-vae_2019,
	title = {{SOM}-{VAE}: {Interpretable} {Discrete} {Representation} {Learning} on {Time} {Series}},
	shorttitle = {{SOM}-{VAE}},
	url = {https://openreview.net/pdf?id=rygjcsR9Y7},
	abstract = {Learning meaningful representations of time series data is a challenging task, especially when the data is high-dimensional and contains complex temporal dependencies. We propose the SOM-VAE, a deep learning model that combines the structural properties of Self-Organizing Maps (SOMs) with the generative capabilities of Variational Autoencoders (VAEs). The SOM-VAE learns a discrete latent representation that is organized in a grid, which allows for the visualization and interpretation of the learned representations. We demonstrate the effectiveness of our model on several time series datasets, showing that it learns interpretable representations while achieving competitive performance on downstream tasks.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {7th {International} {Conference} on {Learning} {Representations} ({ICLR})},
	publisher = {ICLR},
	author = {Fortuin, Vincent and Hüser, Matthias and Locatello, Francesco and Strathmann, Heiko and Rätsch, Gunnar},
	month = may,
	year = {2019},
	keywords = {ICLR},
}
