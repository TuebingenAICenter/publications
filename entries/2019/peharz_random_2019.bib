@inproceedings{peharz_random_2019,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Random {Sum}-{Product} {Networks}: {A} {Simple} and {Effective} {Approach} to {Probabilistic} {Deep} {Learning}},
	shorttitle = {Random {Sum}-{Product} {Networks}},
	url = {https://proceedings.mlr.press/v115/peharz20a.html},
	abstract = {Sum-Product Networks (SPNs) are a class of deep probabilistic models that allow for exact and efficient inference. However, learning the structure of SPNs is a challenging task, often requiring complex heuristics. In this paper, we propose Random Sum-Product Networks (RSPNs), a simple and effective approach to learn SPNs. RSPNs are constructed by randomly sampling the structure of the network, and then learning the parameters. We show that RSPNs can be learned very efficiently, and that they achieve competitive performance on a wide range of density estimation tasks. Furthermore, we show that RSPNs can be used as a building block for more complex probabilistic models, such as deep generative models.},
	language = {en},
	booktitle = {Proceedings of the 35th {Conference} on {Uncertainty} in {Artificial} {Intelligence} ({UAI})},
	publisher = {PMLR},
	author = {Peharz, Robert and Vergari, Antonio and Stelzner, Karl and Molina, Alejandro and Shao, Xiaoting and Trapp, Martin and Kersting, Kristian and Ghahramani, Zoubin},
	month = jul,
	year = {2019},
	keywords = {UAI},
}
