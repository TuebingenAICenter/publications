@phdthesis{buchler_robot_2019,
	title = {Robot {Learning} for {Muscular} {Systems}},
	shorttitle = {Robot {Learning} for {Muscular} {Systems}},
	url = {https://tuprints.ulb.tu-darmstadt.de/17210/1/phdthesis_buechler.pdf},
	abstract = {Muscular systems are characterized by their high degree of redundancy, non-linear dynamics, and the ability to change their mechanical properties. These properties make them highly versatile but also difficult to control. In this thesis, we investigate how robot learning can be used to control muscular systems. We focus on two main aspects: the learning of forward models and the learning of control policies. We show that by using these methods, we can achieve robust and efficient control of muscular systems in simulation and on real hardware.},
	language = {en},
	type = {Ph.{D}. {Thesis}},
	urldate = {2024-05-22},
	school = {Technical University Darmstadt},
	author = {Büchler, D.},
	month = dec,
	year = {2019},
}
