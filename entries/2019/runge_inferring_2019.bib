@article{runge_inferring_2019,
	title = {Inferring causation from time series with perspectives in {Earth} system sciences},
	issn = {2041-1723},
	shorttitle = {Inferring causation from time series},
	url = {https://doi.org/10.1038/s41467-019-10105-3},
	doi = {10.1038/s41467-019-10105-3},
	abstract = {Inferring causal relationships from time series is a fundamental challenge in many scientific disciplines. In Earth system sciences, the complexity of the system, the presence of non-linearities, and the limited length of observational records make this task particularly difficult. Here, we review the state-of-the-art in causal inference from time series, focusing on methods that are applicable to Earth system data. We discuss the assumptions, strengths, and limitations of different approaches, including Granger causality, convergent cross mapping, and constraint-based causal discovery algorithms. We also highlight the importance of incorporating domain knowledge and the potential of machine learning-based approaches. Finally, we provide a roadmap for future research, emphasizing the need for interdisciplinary collaboration and the development of robust, scalable, and interpretable causal inference methods.},
	language = {en},
	urldate = {2024-05-23},
	journal = {Nature Communications},
	publisher = {Nature Portfolio},
	author = {Runge, Jakob and Bathiany, Sebastian and Bollt, Erik and Camps-Valls, Gustau and Coumou, Dim and Deyle, Ethan and Glymour, Clark and Kretschmer, Marlene and Mahecha, Miguel D. and Munoz-Mari, Jordi and van Nes, Egbert H. and Peters, Jonas and Quax, Rick and Reichstein, Markus and Scheffer, Marten and Schölkopf, Bernhard and Spirtes, Peter and Sugihara, George and Sun, Jian and Zhang, Kun and Zscheischler, Jakob},
	year = {2019},
	keywords = {Causation, Series (stratigraphy), Time series, Data science, Computer science, Computational biology, Biology, Epistemology, Paleontology, Philosophy, Machine learning, NATURE},
}
