@article{klus_eigendecompositions_2019,
	title = {Eigendecompositions of {Transfer} {Operators} in {Reproducing} {Kernel} {Hilbert} {Spaces}},
	issn = {0938-8974},
	shorttitle = {Eigendecompositions of {Transfer} {Operators}},
	url = {https://is.mpg.de/ei/publications/kluschmua19},
	doi = {10.1007/s00332-019-09574-z},
	abstract = {Transfer operators, such as the Perron-Frobenius and Koopman operators, are powerful tools for analyzing the global dynamics of nonlinear systems. Since these operators are infinite-dimensional, they are typically approximated using finite-dimensional matrices. In this paper, we propose a framework for approximating transfer operators using reproducing kernel Hilbert spaces (RKHS). We show that the eigendecomposition of the transfer operator can be computed by solving a regularized kernel eigenvalue problem. This approach is closely related to kernel principal component analysis and kernel canonical correlation analysis. We demonstrate the effectiveness of our method on several examples, including the identification of metastable sets and the computation of Koopman eigenfunctions.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Journal of Nonlinear Science},
	publisher = {Springer Nature},
	author = {Klus, Stefan and Schuster, Ingmar and Muandet, Krikamol},
	year = {2019},
	keywords = {JNS},
}
