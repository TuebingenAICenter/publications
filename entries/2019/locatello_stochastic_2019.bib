@inproceedings{locatello_stochastic_2019,
	title = {Stochastic {Frank}-{Wolfe} for {Composite} {Convex} {Minimization}},
	shorttitle = {Stochastic {Frank}-{Wolfe} for {Composite} {Convex} {Minimization}},
	url = {https://papers.nips.cc/paper/9572-stochastic-frank-wolfe-for-composite-convex-minimization},
	abstract = {We propose a novel stochastic Frank-Wolfe (SFW) algorithm for composite convex minimization problems. Our algorithm uses a variance-reduced gradient estimator and a specific step-size strategy to achieve a convergence rate of O(1/k) for general convex functions and O(1/kˆ2) for strongly convex functions, where k is the number of iterations. We also provide a theoretical analysis of the algorithm's convergence properties and demonstrate its effectiveness on several machine learning problems.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 32},
	publisher = {Curran Associates, Inc.},
	author = {Locatello, Francesco and Yurtsever, Alp and Fercoq, Olivier and Cevher, Volkan},
	month = dec,
	year = {2019},
	keywords = {NEURIPS},
}
