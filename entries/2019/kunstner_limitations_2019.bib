@inproceedings{kunstner_limitations_2019,
	title = {Limitations of the empirical {Fisher} approximation for natural gradient descent},
	shorttitle = {Limitations of the empirical {Fisher} approximation},
	url = {https://papers.nips.cc/paper/8669-limitations-of-the-empirical-fisher-approximation-for-natural-gradient-descent},
	doi = {10.48550/arxiv.1905.12558},
	abstract = {Natural gradient descent is a popular optimization method for neural networks that uses the Fisher information matrix to precondition the gradient. Because the true Fisher is computationally expensive, practitioners often use the empirical Fisher instead. We show that the empirical Fisher is not a valid approximation of the Fisher information matrix, and that it does not correspond to the natural gradient. We analyze the difference between the two matrices and show that the empirical Fisher can lead to poor optimization performance. We provide theoretical and empirical evidence that the empirical Fisher is not a reliable substitute for the Fisher information matrix.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 32},
	publisher = {Curran Associates, Inc.},
	author = {Kunstner, Frederik and Hennig, Philipp and Balles, Lukas},
	month = dec,
	year = {2019},
	keywords = {Fisher information, Hessian matrix, Fisher kernel, Heuristics, Mathematics, Applied mathematics, Econometrics, Mathematical economics, Mathematical optimization, Statistics, Computer science, Artificial intelligence, Kernel method, NEURIPS},
}
