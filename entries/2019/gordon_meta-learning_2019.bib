@inproceedings{gordon_meta-learning_2019,
	title = {Meta-{Learning} {Probabilistic} {Inference} for {Prediction}},
	shorttitle = {Meta-{Learning} {Probabilistic} {Inference} for {Prediction}},
	url = {https://openreview.net/pdf?id=HkxStoC5F7},
	abstract = {We propose a meta-learning framework for probabilistic inference. Our approach, which we call VERSA (Versatile Inference for Meta-Learning), learns to perform amortized variational inference. By meta-learning the inference process, VERSA can adapt to new tasks with a single forward pass, while maintaining the benefits of a probabilistic framework, such as uncertainty quantification and the ability to handle missing data. We demonstrate the effectiveness of our approach on a variety of few-shot regression and classification tasks, showing that it achieves state-of-the-art performance while being significantly more computationally efficient than existing methods.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {7th {International} {Conference} on {Learning} {Representations} ({ICLR})},
	publisher = {ICLR},
	author = {Gordon, Jonathan and Bronskill, John and Bauer, Matthias and Nowozin, Sebastian and Turner, Richard},
	month = may,
	year = {2019},
	keywords = {ICLR},
}
