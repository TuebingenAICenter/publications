@article{gautier_unifying_2019,
	title = {A unifying {Perron}-{Frobenius} theorem for nonnegative tensors via multi-homogeneous maps},
	issn = {0895-4798},
	shorttitle = {A unifying {Perron}-{Frobenius} theorem for nonnegative tensors},
	url = {https://arxiv.org/pdf/1801.04215.pdf},
	doi = {10.1137/18M116566X},
	abstract = {We provide a unifying Perron-Frobenius theorem for nonnegative tensors. Our approach is based on the study of multi-homogeneous maps and their spectral properties. We show that the Perron-Frobenius theorem for nonnegative tensors can be derived from the properties of these maps. We also provide a new characterization of the spectral radius of a nonnegative tensor and a new algorithm for its computation.},
	language = {en},
	urldate = {2025-05-14},
	journal = {SIAM Journal on Matrix Analysis and Applications},
	publisher = {Society for Industrial and Applied Mathematics},
	author = {Gautier, Antoine and Tudisco, Francesco and Hein, Matthias},
	year = {2019},
	keywords = {SIMAX},
}
