@misc{mercado_generalized_2019,
	title = {Generalized {Matrix} {Means} for {Semi}-{Supervised} {Learning} with {Multilayer} {Graphs}},
	shorttitle = {Generalized {Matrix} {Means}},
	url = {https://proceedings.neurips.cc/paper/2019/hash/86032088230735233043193242613335-Abstract.html},
	doi = {10.48550/arxiv.1910.13951},
	abstract = {We propose a new framework for semi-supervised learning on multilayer graphs based on generalized matrix means. Given a set of graphs defined on the same set of nodes, we define a multilayer graph Laplacian as a generalized matrix mean of the individual layer Laplacians. This allows us to interpolate between different aggregation schemes such as the arithmetic, geometric and harmonic mean. We show that the proposed framework is flexible and can be adapted to different types of multilayer data. We provide a theoretical analysis of the proposed method and show that it is well-posed. Finally, we demonstrate the effectiveness of our approach on several real-world datasets, showing that it outperforms state-of-the-art methods for semi-supervised learning on multilayer graphs.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Mercado, Pedro and Tudisco, Francesco and Hein, Matthias},
	year = {2019},
	keywords = {Krylov subspace, Subspace topology, Matrix (chemical analysis), Computer science, Graph, Block matrix, Block (permutation group theory), Algorithm, Mathematics, Artificial intelligence, Theoretical computer science, Combinatorics, Iterative method, Eigenvalues and eigenvectors, Materials science, Composite material, NEURIPS},
}
