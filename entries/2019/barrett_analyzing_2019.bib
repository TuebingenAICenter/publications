@misc{barrett_analyzing_2019,
	title = {Analyzing biological and artificial neural networks: challenges with opportunities for synergy?},
	shorttitle = {Analyzing biological and artificial neural networks},
	url = {https://www.sciencedirect.com/science/article/pii/S0959438818301569},
	doi = {10.1016/j.conb.2019.01.007},
	abstract = {Artificial neural networks (ANNs) have recently achieved human-level performance on a variety of complex tasks. This success has led to a surge of interest in using ANNs as models of biological neural networks. However, the differences between biological and artificial systems are substantial, and it is unclear to what extent the success of ANNs can inform our understanding of the brain. In this review, we discuss the challenges of using ANNs to model biological neural networks, and we highlight opportunities for synergy between the two fields. We argue that the most promising path forward is to develop a common language for describing the computations performed by both biological and artificial systems.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Elsevier},
	author = {Barrett, David G. T. and Morcos, Ari S. and Macke, Jakob H.},
	year = {2019},
	keywords = {Computer science, Artificial intelligence, Artificial neural network, Deep neural networks, Computational neuroscience, Machine learning, Cognitive science, Psychology},
}
