@article{bethge_lack_2019,
	title = {Lack of {Robustness} in {Artificial} {Neural} {Networks}},
	url = {https://pure.mpg.de/pubman/faces/ViewItemOverviewPage.jsp?itemId=item_3031700},
	doi = {10.17617/2.3031700},
	abstract = {Deep neural networks have achieved remarkable success in many machine learning tasks. However, they are often not robust to small perturbations of the input, which can lead to incorrect predictions. This lack of robustness is a major concern for the deployment of these models in safety-critical applications. In this paper, we review the current state of research on the robustness of artificial neural networks, discuss the underlying causes of this lack of robustness, and outline potential directions for future research.},
	language = {en},
	urldate = {2025-05-14},
	journal = {MPG.PuRe (Max Planck Society)},
	publisher = {Max Planck Society},
	author = {Bethge, Matthias},
	year = {2019},
	keywords = {Artificial neural network, Robustness (evolution), Artificial intelligence, Computer science, Biology},
}
