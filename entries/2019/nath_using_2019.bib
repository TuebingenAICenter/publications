@article{nath_using_2019,
	title = {Using {DeepLabCut} for 3D markerless pose estimation across species and behaviors},
	issn = {1754-2189},
	shorttitle = {Using {DeepLabCut} for 3D markerless pose estimation},
	url = {https://www.nature.com/articles/s41596-019-0176-0},
	doi = {10.1038/s41596-019-0176-0},
	abstract = {DeepLabCut is a toolbox for markerless pose estimation that is based on transfer learning with deep neural networks. It has been widely used to track various body parts in diverse species. Here, we provide a protocol for using DeepLabCut for 3D markerless pose estimation. We describe how to calibrate cameras, perform 3D triangulation and use the DeepLabCut toolbox to track body parts in 3D space. We also provide guidelines for data labeling, training and evaluation of the networks. The protocol is designed to be accessible to researchers with minimal programming experience.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Nature Protocols},
	publisher = {Nature Portfolio},
	author = {Nath, Tanmay and Mathis, Alexander and Chen, An Chi and Patel, Amir and Bethge, Matthias and Mathis, Mackenzie Weygandt},
	month = jul,
	year = {2019},
	keywords = {Python (programming language), Computer science, Toolbox, Graphical user interface, Artificial intelligence, Pipeline (software), Pose, Deep learning, Machine learning, Human–computer interaction, Classifier (UML), Computer vision, Programming language, NATURE PROTOCOLS},
}
