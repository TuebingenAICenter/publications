@article{suter_robustly_2019,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Robustly {Disentangled} {Causal} {Mechanisms}: {Validating} {Deep} {Representations} for {Interventional} {Robustness}},
	shorttitle = {Robustly {Disentangled} {Causal} {Mechanisms}},
	url = {http://proceedings.mlr.press/v97/suter19a.html},
	abstract = {Disentangled representations are often claimed to be useful for downstream tasks, such as reinforcement learning or transfer learning. However, there is little empirical evidence to support this claim. In this paper, we propose a framework to evaluate disentangled representations based on their robustness to interventions. We show that disentangled representations are more robust to interventions than entangled ones, and that this robustness is a key factor in their performance on downstream tasks. We also propose a new metric for disentanglement that is based on the robustness of the representation to interventions.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 36th International Conference on Machine Learning},
	publisher = {PMLR},
	author = {Suter, R. and Miladinovic, D. and Schölkopf, B. and Bauer, S.},
	editor = {Chaudhuri, Kamalika and Salakhutdinov, Ruslan},
	month = jun,
	year = {2019},
	keywords = {ICML},
}
