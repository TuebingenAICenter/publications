@article{wallis_image_2019,
	title = {Image content is more important than {Bouma}’s {Law} for scene metamers},
	copyright = {CC BY 4.0},
	issn = {2050-084X},
	shorttitle = {Image content is more important than {Bouma}’s {Law}},
	url = {https://elifesciences.org/articles/42512},
	doi = {10.7554/elife.42512},
	abstract = {Peripheral vision is limited by crowding: the difficulty of identifying objects in clutter. A popular model of crowding is based on Bouma’s Law, which states that crowding occurs within a fixed spatial window that scales linearly with eccentricity. However, recent work suggests that crowding might instead be limited by the statistics of the image content. Here, we test these two hypotheses by creating 'scene metamers'—images that are physically different but perceptually indistinguishable from a reference image. We find that image content is a much better predictor of metamerism than Bouma’s Law. Our results suggest that the visual system’s peripheral representation is not limited by a fixed spatial window, but rather by the complexity of the image content.},
	language = {en},
	urldate = {2025-05-14},
	journal = {eLife},
	publisher = {eLife Sciences Publications, Ltd},
	author = {Wallis, Thomas S. A. and Funke, Christina M. and Ecker, Alexander S. and Gatys, Leon A. and Wichmann, Felix A. and Bethge, Matthias},
	year = {2019},
	keywords = {Receptive field, Pooling, Artificial intelligence, Computer vision, Scaling, Computer science, Perception, Segmentation, Human visual system model, Eccentricity (behavior), Visual field, Pyramid (geometry), Crowding, Visual perception, Fidelity, Pattern recognition (psychology), Image (mathematics), Mathematics, Psychology, Cognitive psychology, Geometry, Neuroscience, Social psychology},
}
