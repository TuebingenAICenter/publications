@article{analytis_make-or-break_2019,
	title = {Make-or-{Break}: {Chasing} {Risky} {Goals} or {Settling} for {Safe} {Rewards}?},
	issn = {0364-0213},
	shorttitle = {Make-or-{Break}},
	url = {https://doi.org/10.1111/cogs.12743},
	doi = {10.1111/cogs.12743},
	abstract = {When people face a sequence of choices, they often have to decide between chasing a risky goal—a high-value outcome that is difficult to achieve—or settling for a safe, but lower-value, reward. We study this trade-off in a multi-armed bandit task where participants can choose between a safe option and a risky option that provides a large reward with low probability. We find that people are generally risk-seeking when they are behind on their goals, but become risk-averse when they are ahead. This behavior is consistent with a model of aspiration-based decision-making, where people adjust their risk-taking based on their current progress toward a goal. We show that this strategy is often adaptive, as it allows people to recover from setbacks and achieve their goals in uncertain environments.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Cognitive Science},
	publisher = {Wiley},
	author = {Analytis, Pantelis P. and Wu, Charley M. and Gelastopoulos, Alexandros},
	year = {2019},
	keywords = {Computer science, Heuristic, Rationality, Dynamic decision-making, Mathematical optimization, Operations research, Artificial intelligence, Mathematics},
}
