@inproceedings{wibranek_interactive_2019,
	title = {Interactive {Structure} {Robotic} {Repositioning} of {Vertical} {Elements} in {Man}-{Machine} {Collaborative} {Assembly} through {Vision}-{Based} {Tactile} {Sensing}},
	shorttitle = {Interactive {Structure} {Robotic} {Repositioning}},
	url = {https://www.proceedings.blucher.com.br/article-details/interactive-structure-robotic-repositioning-of-vertical-elements-in-man-machine-collaborative-assembly-through-vision-based-tactile-sensing-34319},
	doi = {10.5151/proceedings-ecaadesigradi2019_387},
	abstract = {This paper presents a robotic system for the collaborative assembly of vertical elements in timber construction. The system uses a vision-based tactile sensor to detect the position and orientation of the elements during the assembly process. The robot is able to reposition the elements in real-time based on the tactile feedback, allowing for a more precise and efficient assembly process. The system is evaluated through a series of experiments, demonstrating its effectiveness in a man-machine collaborative environment.},
