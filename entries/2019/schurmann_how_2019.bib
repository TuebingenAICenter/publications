@article{schurmann_how_2019,
	title = {How {Cognitive} {Models} of {Human} {Body} {Experience} {Might} {Push} {Robotics}},
	copyright = {CC BY 4.0},
	issn = {1662-5218},
	shorttitle = {How {Cognitive} {Models} of {Human} {Body} {Experience} {Might} {Push} {Robotics}},
	url = {https://doi.org/10.3389/fnbot.2019.00014},
	doi = {10.3389/fnbot.2019.00014},
	abstract = {Robots are increasingly interacting with humans in shared environments. To facilitate natural and intuitive interaction, robots need to understand human behavior and, ideally, possess a sense of self similar to humans. In psychology and neuroscience, the concept of body experience describes how humans perceive, represent, and act with their bodies. While these concepts have been studied extensively in humans, their application to robotics is still in its infancy. In this review, we discuss how cognitive models of human body experience can inform the development of robotic systems. We categorize existing approaches into three levels: (1) body schema and body image, (2) multisensory integration, and (3) social and affective body experience. We argue that integrating these concepts into robotic architectures can lead to more robust, adaptive, and socially intelligent robots. Finally, we identify key challenges and future research directions for bridging the gap between human body experience and robotic implementation.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Frontiers in Neurorobotics},
	publisher = {Frontiers Media S.A.},
	author = {Schürmann, T. and Mohler, B. J. and Peters, J. and Beckerle, P.},
	year = {2019},
	keywords = {Neurorobotics},
}
