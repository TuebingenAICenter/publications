@misc{abbati_ares_2019,
	title = {{AReS} and {MaRS}: {Adversarial} and {MMD}-{Minimizing} {Regression} for {SDEs}},
	shorttitle = {{AReS} and {MaRS}},
	url = {http://proceedings.mlr.press/v97/abbati19a.html},
	doi = {10.48550/arxiv.1902.08480},
	abstract = {We consider the problem of learning the drift and diffusion coefficients of a stochastic differential equation (SDE) from discrete-time observations. Existing methods often rely on maximum likelihood estimation, which can be computationally expensive or require restrictive assumptions on the noise structure. We propose two novel approaches: AReS (Adversarial Regression for SDEs) and MaRS (MMD-Minimizing Regression for SDEs). AReS leverages an adversarial training framework to match the distribution of the learned SDE to the data, while MaRS minimizes the Maximum Mean Discrepancy (MMD) between the paths of the learned SDE and the observed data. Both methods are flexible, scalable, and do not require explicit likelihood calculations. We demonstrate the effectiveness of our approaches on several synthetic and real-world datasets, showing that they outperform existing baselines in terms of accuracy and robustness.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Abbati, Gabriele and Wenk, Philippe and Osborne, Michael A. and Krause, Andreas and Schölkopf, Bernhard and Bauer, Stefan},
	editor = {Chaudhuri, Kamalika and Salakhutdinov, Ruslan},
	year = {2019},
	keywords = {Discretization, Robustness (evolution), Computer science, Stochastic differential equation, Inference, Probabilistic logic, Gaussian, Kalman filter, Mathematical optimization, Artificial intelligence, Mathematics, Algorithm, Applied mathematics, ICML},
}
