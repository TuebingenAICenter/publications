@inproceedings{nguyen_loss_2019,
	title = {On the loss landscape of a class of deep neural networks with no bad local valleys},
	shorttitle = {On the loss landscape of a class of deep neural networks},
	url = {https://arxiv.org/abs/1809.10749},
	abstract = {We study the loss landscape of deep neural networks with ReLU activation functions. We show that for a class of deep neural networks, which includes networks with one hidden layer and networks with specific architectures, the loss function has no bad local valleys. A bad local valley is a local minimum that is not a global minimum. Our results provide a theoretical justification for the empirical observation that deep neural networks can be trained to global optimality using simple gradient-based optimization methods.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {International {Conference} on {Learning} {Representations}},
	publisher = {OpenReview},
	author = {Nguyen, Quynh and Mukkamala, Mahesh and Hein, Matthias},
	year = {2019},
	keywords = {ICLR},
}
