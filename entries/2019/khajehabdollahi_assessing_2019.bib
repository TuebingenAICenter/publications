@article{khajehabdollahi_assessing_2019,
	title = {Assessing {Aesthetics} of {Generated} {Abstract} {Images} {Using} {Correlation} {Structure}},
	url = {https://is.mpg.de/al/publications/khajehabdollahi2019},
	doi = {10.1109/SSCI44817.2019.9002779},
	abstract = {The evaluation of generated images is a challenging task, especially for abstract art where no ground truth exists. We propose a novel method to assess the aesthetic quality of generated abstract images based on their correlation structure. We show that the correlation structure of pixel intensities in images can capture aesthetic properties that are consistent with human perception. We demonstrate the effectiveness of our method on a dataset of generated abstract images and show that it outperforms existing methods in predicting human aesthetic ratings.},
	language = {en},
	urldate = {2025-05-14},
	journal = {2019 IEEE Symposium Series on Computational Intelligence (SSCI)},
	publisher = {IEEE},
	author = {Khajehabdollahi, Sina and Martius, Georg and Levina, Anna},
	month = dec,
	year = {2019},
	keywords = {SSCI},
}
