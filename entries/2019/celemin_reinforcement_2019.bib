@article{celemin_reinforcement_2019,
	title = {Reinforcement learning of motor skills using {Policy} {Search} and human corrective advice},
	issn = {0278-3649},
	shorttitle = {Reinforcement learning of motor skills},
	url = {https://is.mpg.de/ei/publications/celeminetal19},
	doi = {10.1177/0278364919871998},
	abstract = {Learning motor skills from scratch using reinforcement learning is often time-consuming and requires a large number of interactions with the environment. To speed up the learning process, human guidance can be used to provide information about the desired behavior. In this paper, we propose a framework for reinforcement learning that incorporates human corrective advice. The human provides feedback in the form of corrections to the agent's actions, which are used to update the policy. We evaluate our approach on several simulated and real-world robotic tasks, showing that it significantly improves the learning efficiency compared to standard reinforcement learning methods.},
	language = {en},
	urldate = {2024-05-22},
	journal = {The International Journal of Robotics Research},
	publisher = {SAGE Publications},
	author = {Celemin, Carlos and Maeda, Guillermo and Peters, Jan and Ruiz-del-Solar, Javier and Kober, Jens},
	year = {2019},
	keywords = {IJRR},
}
