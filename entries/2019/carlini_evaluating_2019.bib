@misc{carlini_evaluating_2019,
	title = {On {Evaluating} {Adversarial} {Robustness}},
	shorttitle = {On {Evaluating} {Adversarial} {Robustness}},
	url = {https://arxiv.org/abs/1902.06705},
	doi = {10.48550/arxiv.1902.06705},
	abstract = {The field of adversarial robustness has seen a surge of interest in recent years, with many defenses proposed against adversarial examples. However, evaluating the robustness of these defenses has proven to be difficult, as many defenses that were initially thought to be robust were later shown to be vulnerable to stronger attacks. In this paper, we discuss the challenges of evaluating adversarial robustness and provide a set of guidelines for researchers to follow when evaluating their defenses. We also provide a library of attacks and defenses to facilitate the evaluation of new defenses.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Carlini, Nicholas and Athalye, Anish and Papernot, Nicolas and Brendel, Wieland and Rauber, Jonas and Tsipras, Dimitris and Goodfellow, Ian and Madry, Aleksander and Kurakin, Alexey},
	year = {2019},
	keywords = {Adversarial system, Robustness (evolution), Computer science, Artificial intelligence},
}
