@incollection{croce_randomized_2019,
	series = {Lecture {Notes} in {Computer} {Science}},
	title = {A {Randomized} {Gradient}-{Free} {Attack} on {ReLU} {Networks}},
	isbn = {978-3-030-12939-2},
	shorttitle = {A {Randomized} {Gradient}-{Free} {Attack} on {ReLU} {Networks}},
	url = {https://doi.org/10.1007/978-3-030-12939-2_16},
	doi = {10.1007/978-3-030-12939-2_16},
	abstract = {We propose a new attack for ReLU networks which does not rely on gradients. Instead, it exploits the fact that ReLU networks are piecewise linear functions. We show that the decision boundary of a ReLU network is composed of hyperplanes and that the network is linear within each region defined by these hyperplanes. Our attack, which we call the Linear Region Attack, finds a point in a different linear region that is closer to the original input than any point found by gradient-based attacks. We demonstrate that our attack is effective against state-of-the-art defenses and that it can be used to certify the robustness of ReLU networks.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Pattern {Recognition}},
	publisher = {Springer},
	author = {Croce, Francesco and Hein, Matthias},
	year = {2019},
	keywords = {Computer science, GCPR},
}
