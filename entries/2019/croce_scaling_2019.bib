@misc{croce_scaling_2019,
	title = {Scaling up the randomized gradient-free adversarial attack reveals overestimation of robustness using established attacks},
	shorttitle = {Scaling up the randomized gradient-free adversarial attack},
	url = {https://link.springer.com/article/10.1007/s11263-019-01213-0},
	doi = {10.1007/s11263-019-01213-0},
	abstract = {The evaluation of the robustness of neural networks against adversarial attacks is a crucial task in machine learning. Currently, the robustness is often estimated by evaluating the performance of a set of established attacks. However, we show that this approach can lead to a significant overestimation of the robustness. We propose a randomized gradient-free attack, which we call the Linear Region Attack, and show that it can find adversarial examples in regions where gradient-based attacks fail. We scale up this attack and show that it outperforms established attacks on a variety of models and datasets. Our results suggest that the robustness of neural networks is often overestimated and that more rigorous evaluation methods are needed.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Springer},
	author = {Croce, Francesco and Rauber, Jonas and Hein, Matthias},
	year = {2019},
	keywords = {Robustness (evolution), Hyperparameter, Computer science, Scaling, Gradient descent, Adversarial system, Mathematical optimization, Artificial intelligence, Artificial neural network, Mathematics, IJCV},
}
