@article{wallis_hole---wall_2019,
	title = {Hole-in-the-wall: {Perception} of 3D shape and affordances from static images in humans and machines},
	issn = {1534-7362},
	shorttitle = {Hole-in-the-wall},
	url = {https://jov.arvojournals.org/article.aspx?articleid=2750559},
	doi = {10.1167/19.10.160b},
	abstract = {How well do humans and machines perceive 3D shape and affordances from static images? We introduce the 'Hole-in-the-wall' task, which requires observers to judge whether a 3D object (a 'key') can pass through a hole in a wall. This task requires an understanding of 3D shape and the physical constraints of the environment. We find that humans are highly accurate at this task, whereas state-of-the-art deep neural networks struggle, even when trained on large datasets of 3D objects. Our results suggest that current computer vision models lack a robust representation of 3D shape and physical affordances.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Vision},
	publisher = {Association for Research in Vision and Ophthalmology},
	author = {Wallis, Thomas S. and Weller, Marlene and Funke, Christina M. and Bethge, Matthias},
	year = {2019},
	keywords = {Computer science, Affordance, Task (project management), sort, Artificial intelligence, Block (permutation group theory), Convolutional neural network, Mental rotation, Binary number, Perception, Computational complexity theory, Computer vision, Sorting, Pattern recognition (psychology), Algorithm, Arithmetic, Mathematics, Human–computer interaction, Psychology, Cognition, JOV},
}
