@misc{schroder_approximate_2019,
	title = {Approximate {Bayesian} {Inference} for a {Mechanistic} {Model} of {Vesicle} {Release} at a {Ribbon} {Synapse}},
	url = {https://proceedings.neurips.cc/paper/2019/hash/0e57098d0318a954d1443e2974a38fac-Abstract.html},
	doi = {10.1101/669218},
	abstract = {Ribbon synapses are specialized structures that allow for the continuous, high-rate release of neurotransmitter vesicles. Mechanistic models of these synapses are often complex and computationally expensive to simulate, making parameter inference difficult. Here, we present an approach for approximate Bayesian inference in a mechanistic model of vesicle release at a ribbon synapse. We use a simulation-based inference method that combines a neural density estimator with a summary statistic network to learn the posterior distribution of the model parameters. We show that our method can accurately recover the parameters of a synthetic model and that it can be applied to experimental data to infer the properties of vesicle release at a ribbon synapse.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Schröder, Cornelius and James, Ben and Lagnado, Leon and Berens, Philipp},
	month = dec,
	year = {2019},
	keywords = {Computer science, Bayesian inference, Bayesian probability, Inference, Artificial intelligence, Parametric statistics, Synapse, Nonlinear system, Biological system, Machine learning, Algorithm, Mathematics, Physics, Neuroscience, Biology, NEURIPS},
}
