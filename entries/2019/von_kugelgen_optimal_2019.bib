@misc{von_kugelgen_optimal_2019,
	title = {Optimal experimental design via {Bayesian} optimization: active causal structure learning for {Gaussian} process networks},
	shorttitle = {Optimal experimental design via {Bayesian} optimization},
	url = {http://tripods.cis.cornell.edu/neurips19_causalml/},
	doi = {10.48550/arxiv.1910.03962},
	abstract = {We consider the problem of active causal structure learning, where the goal is to identify the causal structure of a system using as few interventions as possible. We propose a framework that combines Gaussian process (GP) models with Bayesian optimization (BO) to select informative interventions. Our approach treats the causal structure as a latent variable and uses BO to navigate the space of possible interventions, guided by an acquisition function that quantifies the expected information gain about the causal structure. We demonstrate the effectiveness of our method on synthetic and real-world data, showing that it can significantly reduce the number of interventions required to learn the causal structure compared to random or heuristic-based strategies.},
	language = {en},
	urldate = {2025-05-14},
	author = {von Kügelgen, Julius and Rubenstein, Paul K. and Schölkopf, Bernhard and Weller, Adrian},
	month = dec,
	year = {2019},
	keywords = {Bayesian network, Computer science, Bayesian probability, Prior probability, Gaussian process, Machine learning, Uncountable set, Artificial intelligence, Causal structure, Monte Carlo method, Gaussian, Causal model, Set (abstract data type), Mathematical optimization, Econometrics, Mathematics, Statistics, NEURIPS},
}
