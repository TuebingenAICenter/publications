@article{geiger_coordinating_2019,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Coordinating {Users} of {Shared} {Facilities} via {Data}-driven {Predictive} {Assistants} and {Game} {Theory}},
	shorttitle = {Coordinating {Users} of {Shared} {Facilities}},
	url = {https://proceedings.mlr.press/v115/geiger20a.html},
	abstract = {We consider the problem of coordinating users of shared facilities, such as scientific instruments or meeting rooms. Users have individual preferences and constraints, and they compete for time slots. We propose a system where a predictive assistant learns user preferences from historical data and suggests schedules that are socially optimal. We model the interaction between the assistant and the users as a game, and we show that our approach leads to a stable and efficient allocation of resources. We evaluate our method on real-world data from a shared facility and demonstrate that it significantly improves user satisfaction compared to existing scheduling policies.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Proceedings of the 35th Conference on Uncertainty in Artificial Intelligence (UAI)},
	publisher = {PMLR},
	author = {Geiger, P. and Besserve, M. and Winkelmann, J. and Proissl, C. and Schölkopf, B.},
	editor = {Adams, Ryan P. and Gogate, Vibhav},
	month = jul,
	year = {2019},
	keywords = {UAI},
}
