@inproceedings{lutter_deep_2019,
	title = {Deep {Lagrangian} {Networks} for end-to-end learning of energy-based control for under-actuated systems},
	shorttitle = {Deep {Lagrangian} {Networks}},
	url = {https://is.mpg.de/ei/publications/lutlispet19},
	doi = {10.1109/IROS40897.2019.8968268},
	abstract = {Learning dynamics models for control is a key challenge in robotics. While deep learning has shown great success in learning complex dynamics, it often ignores the underlying physical structure of the system. In this paper, we propose Deep Lagrangian Networks (DeLaN), a deep learning framework that learns the Lagrangian of a system. By encoding the Euler-Lagrange equation into the network architecture, we ensure that the learned dynamics are physically consistent. We demonstrate that DeLaN can learn the dynamics of under-actuated systems from data and can be used for energy-based control. We evaluate our approach on a simulated acrobot and a real-world cart-pole system, showing that DeLaN outperforms standard deep learning approaches in terms of data efficiency and control performance.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {International {Conference} on {Intelligent} {Robots} and {Systems} ({IROS})},
	publisher = {IEEE},
	author = {Lutter, Michael and Listmann, Kim and Peters, Jan},
	month = nov,
	year = {2019},
	keywords = {IROS},
}
