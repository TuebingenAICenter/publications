@article{tump_evolutionary_2019,
	title = {The {Evolutionary} {Dynamics} of {Cooperation} in {Collective} {Search}},
	shorttitle = {The {Evolutionary} {Dynamics} of {Cooperation} in {Collective} {Search}},
	url = {https://mindmodeling.org/cogsci2019/papers/0166/0166.pdf},
	doi = {10.1017/cogsci.2019.166},
	abstract = {How do groups of individuals balance the trade-off between exploring for new information and exploiting known resources? While collective search can be more efficient than individual search, it also introduces the problem of free-riding, where individuals benefit from the information provided by others without contributing their own. We investigate the evolutionary dynamics of cooperation in a collective search task using an agent-based model. We find that cooperation is highly sensitive to the cost of information sharing and the structure of the environment. When the environment is stable, cooperation is easily maintained. However, when the environment is dynamic, cooperation is more fragile and requires specific conditions to persist. Our results provide insights into the conditions that promote or hinder the evolution of cooperation in collective search.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Proceedings of the 41st Annual Conference of the Cognitive Science Society},
	publisher = {Cognitive Science Society},
	author = {Tump, Alan N. and Wu, Charley M. and Bouhlel, I. and Goldstone, Robert L.},
	editor = {Goel, Ashok K. and Seifert, Colleen M. and Freksa, Christian},
	year = {2019},
	keywords = {COGSCI},
}
