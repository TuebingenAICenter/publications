@incollection{kobak_heavy-tailed_2019,
	series = {Lecture {Notes} in {Computer} {Science}},
	title = {Heavy-tailed kernels reveal a finer cluster structure in t-{SNE} visualisations},
	isbn = {978-3-030-46150-8},
	shorttitle = {Heavy-tailed kernels},
	url = {https://link.springer.com/chapter/10.1007/978-3-030-46150-8_8},
	doi = {10.1007/978-3-030-46150-8_8},
	abstract = {t-SNE is a popular method for visualising high-dimensional data. It is well known that the choice of the perplexity parameter affects the visual appearance of the embedding. Here we show that the choice of the kernel in the high-dimensional space is equally important. We demonstrate that using heavy-tailed kernels (such as the Student t-distribution) instead of the standard Gaussian kernel in the high-dimensional space allows t-SNE to reveal a finer cluster structure in the data. We provide a theoretical justification for this observation and illustrate it with several examples.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Machine {Learning} and {Knowledge} {Discovery} in {Databases}},
	publisher = {Springer International Publishing},
	author = {Kobak, Dmitry and Linderman, George C. and Steinerberger, Stefan and Kluger, Yuval and Berens, Philipp},
	month = sep,
	year = {2019},
	keywords = {Computer science, Cluster (spacecraft), Computer graphics (images), Artificial intelligence, Programming language, ECMLPKDD},
}
