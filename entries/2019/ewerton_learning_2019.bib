@article{ewerton_learning_2019,
	title = {Learning {Trajectory} {Distributions} for {Assisted} {Teleoperation} and {Path} {Planning}},
	copyright = {CC BY 4.0},
	issn = {2296-9144},
	shorttitle = {Learning {Trajectory} {Distributions}},
	url = {https://doi.org/10.3389/frobt.2019.00089},
	doi = {10.3389/frobt.2019.00089},
	abstract = {Teleoperation is a key technology for enabling robots to perform complex tasks in unstructured environments. However, teleoperation is often demanding for the human operator, especially when the robot has many degrees of freedom or when the communication channel is subject to latency. To alleviate the burden on the operator, we propose a framework for assisted teleoperation that learns a distribution over successful task trajectories from demonstrations. The learned distribution is used to provide real-time assistance to the operator by biasing the robot's motion toward the demonstrated task space while still allowing the operator to maintain control. We represent the trajectory distribution using a probabilistic movement primitive, which allows for efficient inference and adaptation. We evaluate our approach in a simulated teleoperation task and show that it significantly improves performance and reduces operator effort compared to unassisted teleoperation.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Frontiers in Robotics and AI},
	publisher = {Frontiers Media SA},
	author = {Ewerton, Marc and Arenz, Oleh and Maeda, Guilherme and Koert, Dorothea and Kolev, Zlatko and Takahashi, Mitsuhiro and Peters, Jan},
	year = {2019},
	keywords = {FRONTIERS},
}
