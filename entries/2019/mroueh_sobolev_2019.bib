@inproceedings{mroueh_sobolev_2019,
	title = {Sobolev {Descent}},
	url = {http://proceedings.mlr.press/v89/mroueh19a.html},
	abstract = {We propose Sobolev Descent, a gradient descent algorithm in Sobolev spaces. We show that Sobolev Descent is equivalent to preconditioned gradient descent in the Hilbert space of functions, where the preconditioner is the inverse of the Sobolev operator. We provide a theoretical analysis of the convergence of Sobolev Descent for convex and non-convex objectives. We demonstrate the effectiveness of Sobolev Descent on several machine learning tasks, including training deep neural networks and solving partial differential equations.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Proceedings of the 22nd {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Mroueh, Youssef and Sercu, Tom and Raj, Anant},
	editor = {Chaudhuri, Kamalika and Sugiyama, Masashi},
	month = apr,
	year = {2019},
	keywords = {AISTATS},
}
