@inproceedings{lauri_information_2019,
	title = {Information {Gathering} in {Decentralized} {POMDPs} by {Policy} {Graph} {Improvement}},
	shorttitle = {Information {Gathering} in {Decentralized} {POMDPs}},
	url = {https://dl.acm.org/doi/abs/10.5555/3306127.3331815},
	doi = {10.5555/3306127.3331815},
	abstract = {Decentralized partially observable Markov decision processes (Dec-POMDPs) are a general framework for multiagent planning under uncertainty. However, solving them is NEXP-complete. We consider the problem of information gathering in Dec-POMDPs, where agents must coordinate their actions to reduce uncertainty about the state of the environment. We propose a method for improving policy graphs, which are a compact representation of policies for Dec-POMDPs. Our method uses a gradient-based approach to optimize the policy graph parameters, and we show that it can be used to find effective policies for information gathering tasks. We evaluate our method on several benchmark problems and show that it outperforms existing methods.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {Proceedings of the {International} {Conference} on {Autonomous} {Agents} and {Multiagent} {Systems} ({AAMAS})},
	publisher = {International Foundation for Autonomous Agents and Multiagent Systems},
	author = {Lauri, Mikko and Pajarinen, Joni and Peters, Jan},
	year = {2019},
	keywords = {AAMAS},
}
