@inproceedings{putzky_invert_2019,
	title = {Invert to {Learn} to {Invert}},
	shorttitle = {Invert to {Learn} to {Invert}},
	url = {https://papers.nips.cc/paper/8336-invert-to-learn-to-invert},
	abstract = {Inverse problems are ubiquitous in science and engineering. They involve recovering an unknown signal from indirect, noisy measurements. Recently, deep learning has shown great promise in solving these problems by learning a mapping from measurements to signals. However, these methods often require large amounts of paired training data, which is frequently unavailable. In this paper, we propose a method to learn to solve inverse problems without paired data. We do this by learning to invert the forward model, which is often known. We show that by learning to invert the forward model, we can also learn to solve the inverse problem. We demonstrate the effectiveness of our method on several inverse problems, including image deblurring and super-resolution.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 32},
	publisher = {Curran Associates, Inc.},
	author = {Putzky, Patrick and Welling, Max},
	editor = {Wallach, H. and Larochelle, H. and Beygelzimer, A. and d'Alche-Buc, F. and Fox, E. and Garnett, R.},
	month = dec,
	year = {2019},
	keywords = {NEURIPS},
}
