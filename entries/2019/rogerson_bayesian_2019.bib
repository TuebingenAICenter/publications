@misc{rogerson_bayesian_2019,
	title = {Bayesian hypothesis testing and experimental design for two-photon imaging data},
	copyright = {CC BY 4.0},
	shorttitle = {Bayesian hypothesis testing and experimental design},
	url = {https://journals.plos.org/ploscompbiol/article?id=10.1371/journal.pcbi.1007205},
	doi = {10.1371/journal.pcbi.1007205},
	abstract = {Two-photon calcium imaging is a powerful tool for recording the activity of large populations of neurons. However, the analysis of such data is often hampered by low signal-to-noise ratios and the need for large amounts of data to achieve statistical significance. Here, we present a Bayesian framework for hypothesis testing and experimental design in two-photon imaging. Our approach allows for the quantification of evidence for and against a hypothesis, rather than relying on p-values. We demonstrate that this framework can be used to optimize experimental design, reducing the amount of data required to reach a conclusion. We validate our method on simulated and experimental data, showing that it outperforms traditional frequentist approaches in terms of statistical power and efficiency.},
	language = {en},
	type = {{journalArticle}},
	urldate = {2025-05-14},
	publisher = {Public Library of Science},
	author = {Rogerson, Luke E. and Zhao, Zhijian and Franke, Katrin and Euler, Thomas and Berens, Philipp},
	month = aug,
	year = {2019},
	keywords = {Bayesian probability, Computer science, Artificial intelligence, Information retrieval, Data science, PLOSCB},
}
