@inproceedings{urain_generalized_2019,
	title = {Generalized {Multiple} {Correlation} {Coefficient} as a {Similarity} {Measurement} between {Trajectories}},
	shorttitle = {Generalized {Multiple} {Correlation} {Coefficient}},
	url = {https://is.mpg.de/ei/publications/urapet19},
	doi = {10.1109/IROS40897.2019.8967884},
	abstract = {In this paper, we propose a novel similarity measurement for trajectories, the Generalized Multiple Correlation Coefficient (GMCC). The GMCC is based on the canonical correlation analysis and is able to capture linear and non-linear dependencies between trajectories. We show that the GMCC is invariant to affine transformations, which is a desirable property for trajectory similarity measurements. We evaluate the GMCC on several synthetic and real-world datasets and show that it outperforms existing similarity measurements in terms of accuracy and robustness.},
	language = {en},
	booktitle = {International {Conference} on {Intelligent} {Robots} and {Systems} ({IROS})},
	publisher = {IEEE},
	author = {Urain, J. and Peters, J.},
	month = nov,
	year = {2019},
	keywords = {IROS},
}
