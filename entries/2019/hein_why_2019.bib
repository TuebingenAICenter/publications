@misc{hein_why_2019,
	title = {Why {ReLU} {Networks} {Yield} {High}-{Confidence} {Predictions} {Far} {Away} {From} the {Training} {Data} and {How} to {Mitigate} the {Problem}},
	shorttitle = {Why {ReLU} {Networks} {Yield} {High}-{Confidence} {Predictions}},
	url = {https://arxiv.org/abs/1812.05720},
	doi = {10.1109/CVPR.2019.00013},
	abstract = {Deep neural networks are known to be overconfident on out-of-distribution data. In this paper, we show that for ReLU networks, the confidence of the prediction, measured by the softmax output, is constant along rays starting from the origin if the input is sufficiently far away from the training data. This implies that ReLU networks can yield high-confidence predictions even for inputs that are completely different from the training data. We analyze this phenomenon theoretically and show that it is a consequence of the piecewise linear nature of ReLU networks. We propose a simple and effective method to mitigate this problem by training the network to have low confidence on out-of-distribution data. We demonstrate the effectiveness of our approach on several datasets and architectures.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {IEEE},
	author = {Hein, Matthias and Andriushchenko, Maksym and Bitterwolf, Julian},
	year = {2019},
	keywords = {Training set, Computer science, Classifier (UML), Machine learning, Confidence interval, Artificial neural network, Training (meteorology), Low Confidence, Artificial intelligence, Piecewise linear function, Piecewise, Task (project management), Generalization, Bounded function, Labeled data, Test data, Statistics, Mathematics, Engineering, Geography, CVPR},
}
