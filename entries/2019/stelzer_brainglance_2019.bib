@article{stelzer_brainglance_2019,
	title = {Brainglance: {Visualizing} {Group} {Level} {MRI} {Data} at {One} {Glance}},
	issn = {1662-453X},
	shorttitle = {Brainglance},
	url = {https://is.mpg.de/ei/publications/stelzeretal19},
	doi = {10.3389/fnins.2019.00972},
	abstract = {We present a new visualization tool called Brainglance that allows for a quick and intuitive assessment of group-level MRI data. Brainglance creates a compact representation of the entire brain by combining structural and functional information into a single image. It is particularly useful for quality control and for identifying outliers in large datasets. The tool is implemented as a Python package and is freely available.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Frontiers in Neuroscience},
	publisher = {Frontiers Media SA},
	author = {Stelzer, Johannes and Lacosse, E. and Bause, J. and Scheffler, K. and Lohmann, G.},
	year = {2019},
}
