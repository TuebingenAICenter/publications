@misc{scala_layer_2019,
	title = {Layer 4 of mouse neocortex differs in cell types and circuit organization between sensory areas},
	shorttitle = {Layer 4 of mouse neocortex},
	url = {https://www.nature.com/articles/s41467-019-12058-z},
	doi = {10.1038/s41467-019-12058-z},
	abstract = {The neocortex is organized into layers and areas, but the extent to which cell types and their circuit properties are conserved across areas remains debated. Here we use Patch-seq to characterize the transcriptomic, morphological and physiological properties of 1,197 neurons in layer 4 of the mouse primary visual and somatosensory cortex. We find that the transcriptomic cell types are largely conserved between the two areas. However, the proportions of these cell types differ significantly. Furthermore, we find that the local circuit organization is area-specific: the same cell types exhibit different connectivity patterns in the two areas. Our results suggest that the neocortex is composed of a conserved set of cell types, but that their relative abundance and circuit integration are adapted to the specific requirements of each sensory area.},
	language = {en},
	type = {{journalArticle}},
	urldate = {2025-05-14},
	publisher = {Nature Portfolio},
	author = {Scala, Federico and Kobak, Dmitry and Shen, Shan and Bernaerts, Yves and Laturnus, Sophie and Cadwell, Cathryn R. and Hartmanis, Leonard and Froudarakis, Emmanouil and Castro, Jesus Ramon and Tan, Zheng Huan and Papadopoulos, Stelios and Patel, Saumil S. and Sandberg, Rickard and Berens, Philipp and Jiang, Xiaolong and Tolias, Andreas S.},
	month = sep,
	year = {2019},
	keywords = {Neocortex, Excitatory postsynaptic potential, Neuroscience, Barrel cortex, Inhibitory postsynaptic potential, Somatosensory system, Sensory system, Biology, Cell type, Hepatic stellate cell, Pyramidal cell, Visual cortex, Cerebral cortex, Cortex (anatomy), Cell, Hippocampus, Layer (electronics), Computer science, Nanotechnology, Genetics, Materials science},
}
