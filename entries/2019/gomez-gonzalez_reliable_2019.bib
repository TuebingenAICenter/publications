@article{gomez-gonzalez_reliable_2019,
	title = {Reliable {Real}-{Time} {Ball} {Tracking} for {Robot} {Table} {Tennis}},
	copyright = {CC BY 4.0},
	issn = {2218-6581},
	shorttitle = {Reliable {Real}-{Time} {Ball} {Tracking}},
	url = {https://www.mdpi.com/2218-6581/8/4/90},
	doi = {10.3390/robotics8040090},
	abstract = {In this paper, we present a robust and reliable real-time ball tracking system for robot table tennis. The system is designed to operate in a high-speed environment where the ball moves at velocities of up to 10 m/s. We propose a multi-stage approach that combines a fast, heuristic-based detection method with a robust, model-based tracking algorithm. The detection stage uses a combination of background subtraction and color-based filtering to identify potential ball candidates. The tracking stage employs a Kalman filter to estimate the ball's state and a data association algorithm to handle occlusions and false positives. We evaluate our system on a real robot table tennis setup and demonstrate that it can track the ball with high accuracy and reliability in real-time.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Robotics},
	publisher = {MDPI},
	author = {Gómez-González, Sebastián and Nemmour, Yassine and Schölkopf, Bernhard and Peters, Jan},
	year = {2019},
	keywords = {Computer science, Computer vision, Artificial intelligence, Robustness (evolution), Ball (mathematics), Tracking system, Robot, Heuristics, Object detection, Real-time computing},
}
