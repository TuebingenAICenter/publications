@article{pfister_robustifying_2019,
	title = {Robustifying {Independent} {Component} {Analysis} by {Adjusting} for {Group}-{Wise} {Stationary} {Noise}},
	issn = {1532-4435},
	url = {http://jmlr.org/papers/v20/18-399.html},
	doi = {10.3929/ethz-b-000374036},
	abstract = {Independent Component Analysis (ICA) is a popular method for blind source separation. However, its performance can be severely degraded by the presence of noise that is not independent across observations. We propose a method to robustify ICA by adjusting for group-wise stationary noise. Our approach relies on the assumption that the noise is stationary within groups of observations, while the signals of interest are not. We show that this assumption allows for a consistent estimation of the mixing matrix even in the presence of such noise. We provide theoretical guarantees and demonstrate the effectiveness of our method on both synthetic and real-world data.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Machine Learning Research},
	publisher = {Journal of Machine Learning Research},
	author = {Pfister, Niklas and Weichwald, Sebastian and Bühlmann, Peter and Schölkopf, Bernhard},
	year = {2019},
	keywords = {Component (thermodynamics), Independent component analysis, Group (periodic table), Noise (video), Mathematics, Computer science, Statistics, Artificial intelligence, Physics, Thermodynamics, JMLR},
}
