@article{macke_choice_2019,
	title = {Choice (-history) correlations in sensory cortex: cause or consequence?},
	issn = {0959-4388},
	shorttitle = {Choice (-history) correlations in sensory cortex},
	url = {https://doi.org/10.1016/j.conb.2019.09.005},
	doi = {10.1016/j.conb.2019.09.005},
	abstract = {Correlations between neural activity in sensory cortex and an animal's choice are a hallmark of perceptual decision-making. These choice correlations are often interpreted as evidence that sensory neurons causally contribute to the animal's decision. However, choice correlations can also arise as a consequence of the decision process, for example, through feedback from decision-related areas or through shared history-dependent fluctuations. Here, we review recent evidence that choice correlations in sensory cortex are often not purely sensory in origin, but instead reflect a mixture of feedforward sensory information and feedback signals related to the animal's choice and choice history. We discuss the implications of these findings for our understanding of the role of sensory cortex in decision-making and suggest future directions for disentangling the causal and consequential components of choice correlations.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Current Opinion in Neurobiology},
	publisher = {Elsevier},
	author = {Macke, Jakob H. and Nienborg, Hendrikje},
	year = {2019},
	keywords = {Sensory system, Perception, Neuroscience, Psychology, Stimulus (psychology), Context (archaeology), Cognition, Causal model, Cognitive psychology, Biology, Medicine},
}
