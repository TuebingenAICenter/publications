@article{brendel_approximating_2019,
	title = {Approximating {CNNs} with {Bag}-of-local-{Features} models works surprisingly well on {ImageNet}},
	shorttitle = {Approximating {CNNs} with {Bag}-of-local-{Features} models},
	url = {https://arxiv.org/abs/1904.00760},
	doi = {10.48550/arXiv.1904.00760},
	abstract = {Standard convolutional neural networks (CNNs) are often thought to be good at capturing global shape information. Here, we show that this is not necessarily the case. We introduce a Bag-of-local-Features model that is restricted to classifying images based on local features (e.g., textures, parts) and ignores global shape. We find that this model achieves 81.4\% top-1 accuracy on ImageNet, which is surprisingly close to the performance of standard CNNs. Our results suggest that the success of CNNs on ImageNet is largely driven by local features rather than global shape, and that CNNs are not as good at capturing global shape as previously thought.},
	language = {en},
	urldate = {2025-05-14},
	journal = {International Conference on Learning Representations},
	publisher = {arXiv},
	author = {Brendel, Wieland and Bethge, Matthias},
	year = {2019},
	keywords = {Computer science, Constraint (computer-aided design), Feature (linguistics), Artificial intelligence, Pattern recognition (psychology), Contextual image classification, Deep neural networks, Image (mathematics), Residual neural network, Convolutional neural network, Artificial neural network, Deep learning, Simple (philosophy), Architecture, Machine learning, Mathematics, ICLR},
}
