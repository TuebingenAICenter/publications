@inproceedings{trick_multimodal_2019,
	title = {Multimodal {Uncertainty} {Reduction} for {Intention} {Recognition} in {Human}-{Robot} {Interaction}},
	shorttitle = {Multimodal {Uncertainty} {Reduction} for {Intention} {Recognition}},
	url = {https://is.mpg.de/ei/publications/trikoepetrot19},
	doi = {10.1109/IROS40897.2019.8968171},
	abstract = {Intention recognition is a fundamental requirement for fluent human-robot interaction. In many scenarios, the human's intention is not directly observable and must be inferred from noisy sensor data. While previous approaches often rely on unimodal observations, humans naturally integrate information from multiple modalities to reduce uncertainty. In this paper, we propose a framework for intention recognition that combines information from multiple modalities based on their reliability. We model the human's intention as a latent variable and use a Bayesian framework to update the belief over the intention given multimodal observations. We evaluate our approach in a human-robot collaborative task where the human's intention is to reach for one of several objects. Our results show that the proposed multimodal approach significantly reduces uncertainty and improves the accuracy of intention recognition compared to unimodal baselines.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {International {Conference} on {Intelligent} {Robots} and {Systems} ({IROS})},
	publisher = {IEEE},
	author = {Trick, S. and Koert, D. and Peters, J. and Rothkopf, C. A.},
	month = nov,
	year = {2019},
	keywords = {IROS},
}
