@misc{jitkrittum_kernel_2019,
	title = {Kernel {Mean} {Matching} for {Content} {Addressability} of {GANs}},
	url = {http://proceedings.mlr.press/v97/jitkrittum19a.html},
	doi = {10.48550/arxiv.1905.05882},
	abstract = {Generative Adversarial Networks (GANs) are powerful generative models capable of producing high-quality images. However, they are typically black-box models: given a trained generator, it is difficult to find a latent code that produces an image with specific desired features. In this paper, we propose a method to make GANs content-addressable. Given a target image or a set of images, we want to find a latent code that generates an image similar to the target. We formulate this as a kernel mean matching problem in the latent space. We show that our method is effective for finding latent codes that produce images with desired attributes, and for performing image-to-image translation tasks.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Jitkrittum, Wittawat and Sangkloy, Patsorn and Gondal, Muhammad Waleed and Raj, Amit and Hays, James and Schölkopf, Bernhard},
	editor = {Chaudhuri, Kamalika and Salakhutdinov, Ruslan},
	month = jun,
	year = {2019},
	keywords = {Computer science, Kernel (algebra), Matching (statistics), Set (abstract data type), Generative model, Artificial intelligence, Generative grammar, Content (measure theory), Image (mathematics), Process (computing), Pattern recognition (psychology), Machine learning, Mathematics, ICML},
}
