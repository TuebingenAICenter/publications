@inproceedings{schultheis_receding_2019,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Receding {Horizon} {Curiosity}},
	url = {http://proceedings.mlr.press/v100/schultheis20a.html},
	abstract = {Curiosity-driven exploration is a powerful paradigm for reinforcement learning in environments with sparse rewards. However, most existing approaches are myopic, as they only consider the immediate information gain. In this paper, we propose Receding Horizon Curiosity (RHC), a novel exploration objective that accounts for future information gain over a finite horizon. We derive an efficient approximation of this objective and show that it can be integrated into existing model-based reinforcement learning frameworks. We evaluate our approach on a set of challenging continuous control tasks and demonstrate that it leads to more efficient exploration and faster convergence compared to myopic curiosity-driven exploration methods.},
	language = {en},
	booktitle = {Proceedings of the 3rd {Annual} {Conference} on {Robot} {Learning}},
	publisher = {PMLR},
	author = {Schultheis, M. and Belousov, B. and Abdulsamad, H. and Peters, J.},
	editor = {Kaelbling, Leslie Pack and Kragic, Danica and Sugiura, Komei},
	month = nov,
	year = {2019},
	keywords = {CORL},
}
