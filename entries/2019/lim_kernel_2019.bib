@article{lim_kernel_2019,
	title = {Kernel {Stein} {Tests} for {Multiple} {Model} {Comparison}},
	url = {https://papers.nips.cc/paper/8496-kernel-stein-tests-for-multiple-model-comparison},
	doi = {10.48550/arxiv.1910.12252},
	abstract = {We propose a kernel-based statistical test to compare multiple models given samples from a target distribution. The proposed test, called the Kernel Stein Test for Multiple Model Comparison (KST-MMC), is based on the Stein operator and does not require the normalization constant of the target distribution. We show that the proposed test can be used to compare multiple models simultaneously and control the family-wise error rate. We provide theoretical guarantees on the consistency of the test and demonstrate its effectiveness on several synthetic and real-world datasets.},
	journal = {Advances in Neural Information Processing Systems 32},
	publisher = {Curran Associates, Inc.},
	author = {Lim, Jen Ning and Yamada, Makoto and Schölkopf, Bernhard and Jitkrittum, Wittawat},
	editor = {Wallach, H. and Larochelle, H. and Beygelzimer, A. and d'Alché-Buc, F. and Fox, E. and Garnett, R.},
	month = dec,
	year = {2019},
	keywords = {False positive paradox, False discovery rate, Multiple comparisons problem, Contrast (vision), Selection (genetic algorithm), Model selection, True positive rate, Inference, Word error rate, Kernel (algebra), Computer science, False positive rate, Machine learning, Parametric statistics, Statistics, Artificial intelligence, Statistical hypothesis testing, Mathematics, NEURIPS},
}
