@inproceedings{becker-ehmck_switching_2019,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Switching {Linear} {Dynamics} for {Variational} {Bayes} {Filtering}},
	shorttitle = {Switching {Linear} {Dynamics} for {Variational} {Bayes} {Filtering}},
	url = {http://proceedings.mlr.press/v97/becker-ehmck19a.html},
	abstract = {We propose a novel approach for filtering in switching linear dynamical systems (SLDS). By combining variational inference with a switching linear dynamical model, we derive a filtering algorithm that is both computationally efficient and capable of capturing complex, non-linear dynamics. Our method, which we call Switching Linear Dynamics for Variational Bayes Filtering (SLD-VBF), uses a variational approximation to the posterior distribution of the latent states and the switching variables. We demonstrate the effectiveness of our approach on several challenging synthetic and real-world datasets, showing that it outperforms existing methods in terms of both accuracy and computational efficiency.},
	language = {en},
	booktitle = {Proceedings of the 36th {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Becker-Ehmck, Philipp and Peters, Jan and van der Smagt, Patrick},
	month = jun,
	year = {2019},
	keywords = {ICML},
}
