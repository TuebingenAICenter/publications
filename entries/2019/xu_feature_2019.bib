@article{xu_feature_2019,
	title = {Feature extraction from the {Hermitian} manifold for {Brain}-{Computer} {Interfaces}},
	url = {https://doi.org/10.1109/NER.2019.8717011},
	doi = {10.1109/NER.2019.8717011},
	abstract = {Brain-Computer Interfaces (BCIs) often rely on the estimation of covariance matrices of electroencephalographic (EEG) signals. These matrices are symmetric positive definite (SPD) and lie on a Riemannian manifold. However, in many BCI applications, such as the analysis of cross-spectral density matrices, the matrices are Hermitian positive definite (HPD). In this paper, we extend the Riemannian framework for SPD matrices to the Hermitian manifold. We propose a novel feature extraction method based on the geometry of the HPD manifold and demonstrate its effectiveness on a motor imagery BCI dataset.},
	language = {en},
	urldate = {2025-05-14},
	journal = {9th International IEEE/EMBS Conference on Neural Engineering (NER)},
	publisher = {IEEE},
	author = {Xu, Jiachen and Jayaram, Vinay and Schölkopf, Bernhard and Grosse-Wentrup, Moritz},
	year = {2019},
	keywords = {Brain–computer interface, Hermitian matrix, Benchmark (surveying), Computer science, Set (abstract data type), Manifold (fluid mechanics), Feature extraction, Covariance, Interface (matter), Feature (linguistics), Riemannian manifold, Algorithm, Artificial intelligence, Mathematics, Pure mathematics, Engineering, Electroencephalography, Statistics, NER},
}
