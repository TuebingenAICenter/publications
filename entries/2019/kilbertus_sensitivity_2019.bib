@inproceedings{kilbertus_sensitivity_2019,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {The {Sensitivity} of {Counterfactual} {Fairness} to {Unmeasured} {Confounding}},
	url = {https://proceedings.mlr.press/v115/kilbertus20a.html},
	abstract = {Counterfactual fairness is a popular criterion for algorithmic fairness that relies on causal models to ensure that a decision is independent of a protected attribute in a counterfactual sense. A key assumption in most existing work is that the causal model is fully specified and that there is no unmeasured confounding. In this paper, we relax this assumption and study the sensitivity of counterfactual fairness to unmeasured confounding. We provide a framework to bound the degree of counterfactual unfairness when the causal model is misspecified due to unmeasured common causes. We demonstrate our approach on synthetic and real-world data, showing that it can provide useful bounds on the potential unfairness of a model.},
	language = {en},
	booktitle = {Proceedings of the 35th {Conference} on {Uncertainty} in {Artificial} {Intelligence} ({UAI})},
	publisher = {PMLR},
	author = {Kilbertus, N. and Ball, P. J. and Kusner, M. J. and Weller, A. and Silva, R.},
	editor = {Adams, Ryan P. and Gogate, Vibhav},
	month = jul,
	year = {2019},
	keywords = {UAI},
}
