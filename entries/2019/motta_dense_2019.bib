@article{motta_dense_2019,
	title = {Dense connectomic reconstruction in layer 4 of the somatosensory cortex},
	issn = {0036-8075},
	shorttitle = {Dense connectomic reconstruction in layer 4},
	url = {https://is.mpg.de/ei/publications/mottaetal19},
	doi = {10.1126/science.aay3134},
	abstract = {The mammalian neocortex is organized into layers, but the functional significance of this laminar architecture remains poorly understood. We performed a dense connectomic reconstruction of a 100-micrometer-cubed volume of layer 4 in mouse primary somatosensory cortex. We identified all neurons and their synaptic connections, revealing that the local circuit is dominated by a dense, non-random network of excitatory neurons. This network is organized into a modular structure that is consistent with the functional organization of the cortex. Our results provide a structural basis for understanding the computational role of layer 4 in sensory processing.},
	language = {en},
	urldate = {2024-05-23},
	journal = {Science},
	publisher = {American Association for the Advancement of Science},
	author = {Motta, A. and Berning, M. and Boergens, K. M. and Staffler, B. and Beining, M. and Loomba, S. and Hennig, P. and Wissler, H. and Helmstaedter, M.},
	year = {2019},
	keywords = {Neuropil, Neuroscience, Excitatory postsynaptic potential, Cortex (anatomy), Somatosensory system, Inhibitory postsynaptic potential, Neuron, Hebbian theory, Cerebral cortex, Barrel cortex, Biology, Anatomy, Computer science, Artificial intelligence, Artificial neural network, Central nervous system, SCIENCE},
}
