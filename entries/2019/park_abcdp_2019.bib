@misc{park_abcdp_2019,
	title = {{ABCDP}: {Approximate} {Bayesian} {Computation} {Meets} {Differential} {Privacy}},
	copyright = {© 2021 by the authors. Licensee MDPI, Basel, Switzerland. This article is an open access article distributed under the terms and conditions of the Creative Commons Attribution (CC BY) license (https://creativecommons.org/licenses/by/4.0/).},
	shorttitle = {{ABCDP}},
	url = {https://arxiv.org/abs/1910.05103},
	doi = {10.3390/e23080961},
	abstract = {Approximate Bayesian Computation (ABC) is a popular framework for performing Bayesian inference when the likelihood function is intractable. However, ABC can be vulnerable to privacy attacks if the data used for inference are sensitive. In this paper, we propose ABCDP, a framework that combines ABC with Differential Privacy (DP). We show that by adding noise to the summary statistics in a principled way, we can provide formal privacy guarantees for ABC. We also provide a theoretical analysis of the privacy-utility trade-off and demonstrate the effectiveness of our approach on several synthetic and real-world datasets.},
	language = {en},
	urldate = {2024-05-22},
	publisher = {arXiv},
	author = {Park, M. and Jitkrittum, W.},
	year = {2019},
	keywords = {ENTROPY, arXiv},
}
