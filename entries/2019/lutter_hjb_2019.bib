@inproceedings{lutter_hjb_2019,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {{HJB} {Optimal} {Feedback} {Control} with {Deep} {Differential} {Value} {Functions} and {Action} {Constraints}},
	shorttitle = {{HJB} {Optimal} {Feedback} {Control}},
	url = {http://proceedings.mlr.press/v100/lutter20a.html},
	abstract = {Optimal control is a fundamental problem in robotics. While classical methods provide strong guarantees, they often rely on simplified models or are computationally expensive. Deep reinforcement learning has shown promise in learning complex behaviors but often lacks the stability and interpretability of classical control. In this paper, we propose a novel approach that bridges this gap by learning a deep differential value function that satisfies the Hamilton-Jacobi-Bellman (HJB) equation. Our method, which we call HJB-Net, allows for the integration of action constraints and provides a stable feedback control law. We demonstrate the effectiveness of our approach on several robotic control tasks, showing that it outperforms existing methods in terms of sample efficiency and control performance.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {Proceedings of the 3rd {Annual} {Conference} on {Robot} {Learning}},
	publisher = {PMLR},
	author = {Lutter, Michael and Belousov, Boris and Listmann, Kim and Clever, David and Peters, Jan},
	editor = {Kaelbling, Leslie Pack and Kragic, Danica and Sugiura, Komei},
	month = nov,
	year = {2019},
	keywords = {CORL},
}
