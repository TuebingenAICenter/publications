@article{safavi_univariate_2021,
	title = {From {Univariate} to {Multivariate} {Coupling} {Between} {Continuous} {Signals} and {Point} {Processes}: {A} {Mathematical} {Framework}},
	issn = {0899-7667},
	shorttitle = {From {Univariate} to {Multivariate} {Coupling}},
	url = {https://doi.org/10.1162/neco_a_01389},
	doi = {10.1162/neco_a_01389},
	abstract = {The study of the coupling between continuous signals (e.g., local field potentials) and point processes (e.g., spike trains) is central to understanding neural information processing. While univariate measures such as spike-triggered average or phase-locking value are widely used, they often fail to capture the complexity of neural interactions, particularly in the presence of multiple signals or non-stationary dynamics. We propose a general mathematical framework for quantifying the coupling between continuous signals and point processes, which encompasses both univariate and multivariate scenarios. Our approach is based on the information-theoretic concept of mutual information and its decomposition, allowing for the identification of directed and undirected interactions. We demonstrate the utility of our framework through simulations and applications to experimental data, showing that it provides a more comprehensive and robust characterization of neural coupling than existing methods.},
	language = {en},
	journal = {Neural Computation},
	publisher = {MIT Press},
	author = {Safavi, S. and Logothetis, N. and Besserve, M.},
	year = {2021},
	keywords = {NECO},
}
