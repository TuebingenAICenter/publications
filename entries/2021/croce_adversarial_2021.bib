@misc{croce_adversarial_2021,
	title = {Adversarial robustness against multiple lp-threat models at the price of one and how to quickly fine-tune robust models to another threat model},
	shorttitle = {Adversarial robustness against multiple lp-threat models},
	url = {https://arxiv.org/abs/2105.12508},
	doi = {10.48550/arXiv.2105.12508},
	abstract = {Adversarial training is the standard approach to train models robust against adversarial perturbations. However, it is usually tailored to a specific threat model, e.g., the lp-norm bounded perturbations. In this paper, we show that it is possible to train a single model that is robust against multiple lp-threat models (e.g., l1, l2, and l-infinity) simultaneously with almost no loss in robustness compared to models trained specifically for each threat model. We achieve this by using a multi-target adversarial training approach where we use the worst-case attack across all threat models during training. Furthermore, we propose a fast fine-tuning method that allows to adapt a model trained on one threat model to another one with very few iterations, achieving robustness comparable to training from scratch. We demonstrate the effectiveness of our approach on CIFAR-10 and CIFAR-100.},
	language = {en},
	urldate = {2024-05-22},
	publisher = {arXiv},
	author = {Croce, Francesco and Hein, Matthias},
	month = may,
	year = {2021},
	keywords = {Robustness (evolution), Computer science, Adversarial system, Norm (philosophy), Artificial intelligence, Machine learning, ICML, ICCV},
}
