@misc{shao_model_2021,
	title = {A model of {Ponto}-{Geniculo}-{Occipital} waves supports bidirectional control of cortical plasticity across sleep-stages},
	shorttitle = {A model of {Ponto}-{Geniculo}-{Occipital} waves},
	url = {https://www.biorxiv.org/content/10.1101/2021.03.16.432817v2},
	doi = {10.1101/2021.03.16.432817},
	abstract = {Ponto-Geniculo-Occipital (PGO) waves are phasic neural events occurring during REM sleep, which are thought to play a crucial role in memory consolidation. However, the mechanisms by which PGO waves influence cortical plasticity remain elusive. Here, we propose a computational model of PGO waves based on the interaction between the brainstem, the thalamus, and the cortex. Our model suggests that PGO waves act as a bidirectional switch for cortical plasticity, promoting long-term potentiation (LTP) during REM sleep and long-term depression (LTD) during NREM sleep. This mechanism provides a theoretical framework for understanding how sleep-stage-specific neural activity shapes cortical connectivity and supports memory consolidation.},
	language = {en},
	urldate = {2024-05-23},
	publisher = {bioRxiv},
	author = {Shao, K. and Villegas, J. F. R. and Logothetis, N. K. and Besserve, M.},
	year = {2021},
}
