@article{nemmour_approximate_2021,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Approximate {Distributionally} {Robust} {Nonlinear} {Optimization} with {Application} to {Model} {Predictive} {Control}: {A} {Functional} {Approach}},
	shorttitle = {Approximate {Distributionally} {Robust} {Nonlinear} {Optimization}},
	url = {http://proceedings.mlr.press/v144/nemmour21a.html},
	abstract = {We consider the problem of distributionally robust optimization (DRO) for nonlinear systems. By using a functional approach, we derive a tractable approximation of the DRO problem, which we then apply to model predictive control (MPC). Our approach relies on the use of reproducing kernel Hilbert spaces (RKHS) to represent the uncertainty set, which allows us to handle non-convex objective functions and constraints. We demonstrate the effectiveness of our method on a nonlinear control task, showing that it provides a robust control policy that outperforms standard MPC in the presence of model uncertainty.},
	language = {en},
	number = {144},
	urldate = {2025-05-14},
	journal = {Proceedings of the 3rd Conference on Learning for Dynamics and Control},
	publisher = {PMLR},
	author = {Nemmour, Y. and Schölkopf, B. and Zhu, J.-J.},
	editor = {Jadbabaie, Ali and Lygeros, John and Pappas, George J. and Parrilo, Pablo A. and Recht, Benjamin and Tomlin, Claire J. and Zeilinger, Melanie N.},
	month = jun,
	year = {2021},
	keywords = {Model predictive control, Mathematical optimization, Nonlinear system, Nonlinear model, Computer science, Optimal control, Control (management), Control theory (sociology), Mathematics, Artificial intelligence, L4DC},
}
