@article{schott_selected_2021,
	title = {Selected {Inductive} {Biases} in {Neural} {Networks} {To} {Generalize} {Beyond} the {Training} {Domain}},
	shorttitle = {Selected {Inductive} {Biases} in {Neural} {Networks}},
	url = {https://bethgelab.org/publication/2021_04_schott/},
	abstract = {Deep neural networks have achieved remarkable success in many machine learning tasks. However, they often fail to generalize to data that differs from the training distribution, a phenomenon known as out-of-distribution (OOD) generalization. This thesis investigates the role of inductive biases in neural networks for OOD generalization. We first analyze the effect of architectural choices on the robustness of neural networks to common corruptions. We find that standard convolutional neural networks are biased towards texture rather than shape, which makes them vulnerable to distribution shifts. We then propose a method to improve OOD generalization by incorporating shape-bias into the training process. Finally, we explore the use of generative models to learn representations that are invariant to domain-specific variations, further improving OOD generalization performance.},
	language = {en},
	urldate = {2024-05-22},
	journal = {PhD Thesis},
	publisher = {Universität Tübingen},
	author = {Schott, Lukas},
	year = {2021},
}
