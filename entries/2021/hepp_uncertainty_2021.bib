@article{hepp_uncertainty_2021,
	title = {Uncertainty estimation and explainability in deep learning-based age estimation of the human brain: {Results} from the {German} {National} {Cohort} {MRI} study},
	issn = {0895-6111},
	shorttitle = {Uncertainty estimation and explainability in deep learning-based age estimation},
	url = {https://www.sciencedirect.com/science/article/pii/S0895611121001166?via%3Dihub},
	doi = {10.1016/j.compmedimag.2021.101967},
	abstract = {Deep learning models have shown great potential for age estimation from brain magnetic resonance imaging (MRI). However, their clinical application is often hindered by a lack of uncertainty estimation and interpretability. In this study, we propose a framework for uncertainty estimation and explainability in deep learning-based age estimation of the human brain. We evaluate our approach on a large-scale dataset from the German National Cohort (NAKO) MRI study, consisting of 10,000 subjects. We demonstrate that our model achieves state-of-the-art performance in age estimation while providing reliable uncertainty estimates and meaningful explanations for its predictions. Our results suggest that the proposed framework can enhance the transparency and reliability of deep learning models in neuroimaging, paving the way for their clinical translation.},
	language = {en},
	journal = {Computerized Medical Imaging and Graphics},
	publisher = {Elsevier},
	author = {Hepp, Tobias and Blum, Dominik and Armanious, Karim and Schölkopf, Bernhard and Stern, Darko and Yang, Bin and Gatidis, Sergios},
	month = sep,
	year = {2021},
	keywords = {Convolutional neural network, Neuroimaging, Cohort, Estimation, Artificial intelligence, Population, Human brain, Regression, Magnetic resonance imaging, German population, Computer science, Psychology, Medicine, Neuroscience, Radiology, Pathology},
}
