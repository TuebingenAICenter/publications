@misc{kondmann_spatial_2021,
	title = {Spatial {Context} {Awareness} for {Unsupervised} {Change} {Detection} in {Optical} {Satellite} {Images}},
	url = {https://ieeexplore.ieee.org/document/9627707},
	doi = {10.1109/TGRS.2021.3130842},
	abstract = {Change detection (CD) in optical satellite images is a fundamental task in remote sensing. While deep learning-based methods have achieved remarkable performance, they often rely on large amounts of labeled data, which are expensive and time-consuming to acquire. Unsupervised CD methods, on the other hand, are more flexible but often struggle to capture complex spatial dependencies. In this article, we propose a novel unsupervised CD framework that leverages spatial context awareness to improve the detection performance. Specifically, we introduce a spatial-context-aware module that captures local and global spatial dependencies by combining a self-attention mechanism with a spatial pyramid pooling structure. Furthermore, we propose a novel loss function that encourages the model to learn discriminative features for changed and unchanged pixels without requiring any ground truth labels. Extensive experiments on several benchmark datasets demonstrate that our proposed method outperforms state-of-the-art unsupervised CD methods and achieves competitive results compared to supervised approaches.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {IEEE},
	author = {Kondmann, Lukas and Toker, Aysim and Saha, Sudipan and Schölkopf, Bernhard and Leal-Taixé, Laura and Zhu, Xiao Xiang},
	year = {2021},
	keywords = {Change detection, Pixel, Computer science, Context (archaeology), Spatial contextual awareness, Image resolution, Remote sensing, Artificial intelligence, Satellite, Object detection, Pattern recognition (psychology), Earth observation, Spatial analysis, Computer vision, Geography, TGRS},
}
