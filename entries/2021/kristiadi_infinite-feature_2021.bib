@inproceedings{kristiadi_infinite-feature_2021,
	title = {An {Infinite}-{Feature} {Extension} for {Bayesian} {ReLU} {Nets} {That} {Fixes} {Their} {Asymptotic} {Overconfidence}},
	shorttitle = {An {Infinite}-{Feature} {Extension} for {Bayesian} {ReLU} {Nets}},
	url = {https://proceedings.neurips.cc/paper/2021/file/9be40cee5b0eee1462c82c6964087ff9-Paper.pdf},
	doi = {10.48550/arXiv.2010.02709},
	abstract = {Bayesian neural networks (BNNs) are often praised for their ability to quantify uncertainty. However, it has recently been shown that standard BNNs with ReLU activations are asymptotically overconfident: as the input moves away from the training data, the predictive distribution collapses to a point mass. We show that this behavior is a consequence of the finite-width architecture and the specific form of the ReLU activation. To fix this, we propose an infinite-feature extension for Bayesian ReLU nets. We show that this extension is equivalent to a Gaussian process with a non-stationary kernel that does not suffer from the asymptotic overconfidence problem. We provide a practical, scalable implementation and demonstrate that our method yields well-calibrated uncertainty estimates on out-of-distribution data while maintaining competitive predictive performance.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 34 ({NeurIPS} 2021)},
	publisher = {Curran Associates, Inc.},
	author = {Kristiadi, Augustin and Hein, Matthias and Hennig, Philipp},
	editor = {Ranzato, M. and Beygelzimer, A. and Dauphin, Y. and Liang, P.S. and Wortman Vaughan, J.},
	month = dec,
	year = {2021},
	keywords = {Overconfidence effect, Bayesian probability, Gaussian process, Extension (predicate logic), Limit (mathematics), Mathematics, Applied mathematics, Quadratic equation, Variance (accounting), Feature (linguistics), Gaussian, Computer science, Algorithm, Artificial intelligence, Economics, Physics, Mathematical analysis, Psychology, ICLR, NEURIPS},
}
