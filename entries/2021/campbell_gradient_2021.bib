@inproceedings{campbell_gradient_2021,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {A {Gradient} {Based} {Strategy} for {Hamiltonian} {Monte} {Carlo} {Hyperparameter} {Optimization}},
	shorttitle = {A {Gradient} {Based} {Strategy} for {Hamiltonian} {Monte} {Carlo} {Hyperparameter} {Optimization}},
	url = {https://proceedings.mlr.press/v139/campbell21a.html},
	abstract = {Hamiltonian Monte Carlo (HMC) is a powerful MCMC algorithm, but its performance is highly sensitive to the choice of hyperparameters, such as the step size and the mass matrix. We propose a gradient-based strategy for tuning these hyperparameters by minimizing the expected squared jump distance (ESJD) or maximizing the estimated effective sample size (ESS). We derive unbiased gradient estimators for these objectives using the reparameterization trick, allowing us to optimize hyperparameters online during the sampling process. Our method is computationally efficient, easy to implement, and does not require a separate tuning phase. We demonstrate the effectiveness of our approach on a range of synthetic and real-world problems, showing that it consistently outperforms existing automated tuning methods.},
	language = {en},
	booktitle = {Proceedings of 38th {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Campbell, Andrew and Chen, Wenbo and Stimper, Vincent and Hernández-Lobato, José Miguel and Zhang, Y.},
	editor = {Meila, Marina and Zhang, Tong},
	month = jul,
	year = {2021},
	keywords = {ICML},
}
