@article{li_convolutional_2021,
	title = {Convolutional neural network-assisted recognition of nanoscale {L12} ordered structures in face-centred cubic alloys},
	issn = {2057-3960},
	shorttitle = {Convolutional neural network-assisted recognition of nanoscale {L12} ordered structures},
	url = {https://www.nature.com/articles/s41524-020-00472-7},
	doi = {10.1038/s41524-020-00472-7},
	abstract = {The identification of nanoscale ordered structures in alloys is a challenging task in materials science, particularly when using atom probe tomography (APT) data. Here, we present a convolutional neural network (CNN)-based approach to automatically identify L12 ordered structures in face-centred cubic (fcc) alloys. We demonstrate that the CNN can accurately classify local atomic environments and distinguish between L12-ordered and disordered fcc structures. The method is robust against noise and missing atoms, which are common in experimental APT data. We apply our approach to a Co-Al-W-based superalloy and successfully map the spatial distribution of L12 precipitates. Our results show that the CNN-based method is significantly faster and more objective than conventional manual analysis, providing a powerful tool for the high-throughput characterization of complex alloy systems.},
	language = {en},
	urldate = {2024-05-23},
	journal = {npj Computational Materials},
	publisher = {Nature Portfolio},
	author = {Li, Y. and Zhou, X. and Colnaghi, T. and Wei, Y. and Marek, A. and Li, H. and Bauer, S. and Rampp, M. and Stephenson, L.},
	year = {2021},
	keywords = {NPJ COMPUTATIONAL MATERIALS},
}
