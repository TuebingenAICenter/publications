@misc{goyal_recurrent_2021,
	title = {Recurrent {Independent} {Mechanisms}},
	url = {https://openreview.net/pdf?id=mLcmdlEUxy-},
	doi = {10.48550/arxiv.1909.10893},
	abstract = {The ability to generalize to out-of-distribution data is a hallmark of human intelligence. We hypothesize that this ability is linked to the modular structure of the world, where different causal mechanisms operate independently. In this paper, we propose Recurrent Independent Mechanisms (RIMs), a modular recurrent neural network architecture where the hidden state is partitioned into multiple independent mechanisms that compete to process information. We show that RIMs are more robust to out-of-distribution data and can learn to ignore irrelevant information, leading to better generalization. We evaluate RIMs on a variety of tasks, including synthetic reasoning tasks, language modeling, and reinforcement learning, and show that they outperform standard recurrent architectures.},
	author = {Goyal, Anirudh and Lamb, Alex and Hoffmann, Jordan and Sodhani, Shagun and Levine, Sergey and Bengio, Yoshua and Schölkopf, Bernhard},
	month = may,
	year = {2021},
	keywords = {Bottleneck, Generalization, Modular design, Robustness (evolution), Computer science, Variation (astronomy), Recurrent neural network, Affect (linguistics), Artificial intelligence, Machine learning, Psychology, Artificial neural network, Mathematics, Communication, Chemistry, Programming language, ICLR},
}
