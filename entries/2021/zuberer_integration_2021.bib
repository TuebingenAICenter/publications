@article{zuberer_integration_2021,
	title = {Integration and segregation across large-scale intrinsic brain networks as a marker of sustained attention and task-unrelated thought},
	issn = {1053-8119},
	shorttitle = {Integration and segregation across large-scale intrinsic brain networks},
	url = {https://doi.org/10.1016/j.neuroimage.2020.117610},
	doi = {10.1016/j.neuroimage.2020.117610},
	abstract = {Sustained attention is a fundamental cognitive capacity that fluctuates over time, often leading to task-unrelated thought (TUT). While previous research has linked these fluctuations to activity within specific brain networks, such as the default mode network (DMN) and dorsal attention network (DAN), it remains unclear how the dynamic interplay between these networks—specifically their integration and segregation—relates to attention and TUT. Here, we used a sustained attention task combined with experience sampling to measure TUT, and resting-state and task-based fMRI to examine the relationship between network-level integration/segregation and attentional states. We found that higher integration between the DMN and the DAN was associated with increased TUT, whereas higher segregation between these networks was associated with better sustained attention. These findings suggest that the dynamic balance between integration and segregation across large-scale brain networks is a key marker of attentional states and the propensity for TUT.},
	language = {en},
	urldate = {2025-05-14},
	journal = {NeuroImage},
	publisher = {Elsevier},
	author = {Zuberer, Agnieszka and Kucyi, Aaron and Yamashita, Ayumu and Wu, Charley M. and Walter, Martin and Valera, Eve M. and Esterman, Michael},
	year = {2021},
	keywords = {Task (project management), Psychology, Scale (ratio), Cognitive psychology, Neuroscience, Geography, Cartography, Economics, NEUROIMAGE},
}
