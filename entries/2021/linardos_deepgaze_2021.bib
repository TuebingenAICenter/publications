@misc{linardos_deepgaze_2021,
	title = {{DeepGaze} {IIE}: {Calibrated} prediction in and out-of-domain for state-of-the-art saliency modeling},
	shorttitle = {{DeepGaze} {IIE}},
	url = {https://openaccess.thecvf.com/content/ICCV2021/html/Linardos_DeepGaze_IIE_Calibrated_Prediction_in_and_Out-of-Domain_for_State-of-the-Art_Saliency_ICCV_2021_paper.html},
	doi = {10.1109/ICCV48922.2021.00475},
	abstract = {Saliency models have reached high performance on standard benchmarks. However, it remains unclear how well these models generalize to out-of-domain data and whether their predictions are well-calibrated. In this paper, we introduce DeepGaze IIE, a new state-of-the-art saliency model that achieves superior performance on the MIT Saliency Benchmark. We show that DeepGaze IIE is well-calibrated and generalizes significantly better to out-of-domain data than previous models. We further provide a comprehensive analysis of the factors that contribute to the performance and calibration of saliency models, and we propose a new evaluation protocol for saliency models that accounts for both performance and calibration.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {IEEE},
	author = {Linardos, Akis and Kümmerer, Matthias and Press, Ori and Bethge, Matthias},
	year = {2021},
	keywords = {Benchmark (surveying), Computer science, Artificial intelligence, Generalization, Transfer of learning, Domain (mathematical analysis), Machine learning, Calibration, Key (lock), Protocol (science), Mathematics, Statistics, ICCV},
}
