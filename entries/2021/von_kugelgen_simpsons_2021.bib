@article{von_kugelgen_simpsons_2021,
	title = {Simpson's {Paradox} in {COVID}-19 {Case} {Fatality} {Rates}: {A} {Mediation} {Analysis} of {Age}-{Related} {Causal} {Effects}},
	url = {https://www.computer.org/csdl/journal/ai/5555/01/09404149/1sNm718j25W},
	doi = {10.1109/TAI.2021.3073088},
	abstract = {The COVID-19 pandemic has highlighted the importance of correctly interpreting case fatality rates (CFRs). A common pitfall is the misinterpretation of aggregated data, which can lead to Simpson's paradox, where a trend appears in different groups of data but disappears or reverses when these groups are combined. In this paper, we analyze the CFRs of COVID-19 in different countries and regions, showing that the observed differences in CFRs can be largely explained by the age distribution of the infected population. We use a mediation analysis framework to disentangle the causal effects of age and other factors on the CFR. Our results demonstrate that once age is accounted for, the paradox disappears, and the remaining differences in CFRs are much smaller. We discuss the implications of these findings for public health policy and the importance of causal inference in the analysis of epidemiological data.},
	language = {en},
	journal = {IEEE Transactions on Artificial Intelligence},
	publisher = {IEEE Computer Society},
	author = {von Kügelgen, Julius and Gresele, Luigi and Schölkopf, Bernhard},
	year = {2021},
	keywords = {Case fatality rate, Context (archaeology), Mediation, Coronavirus disease 2019 (COVID-19), Demography, Pandemic, Geography, Demographic economics, Econometrics, Psychology, Population, Medicine, Sociology, Mathematics, Economics, Social science, TAI},
}
