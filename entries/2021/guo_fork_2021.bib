@inproceedings{guo_fork_2021,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Fork or {Fail}: {Cycle}-{Consistent} {Training} with {Many}-to-{One} {Mappings}},
	shorttitle = {Fork or {Fail}},
	url = {http://proceedings.mlr.press/v130/guo21b.html},
	abstract = {Cycle-consistent training is a popular framework for learning mappings between two domains without paired data. While it has achieved impressive results in many applications, it is known to be unstable and prone to mode collapse. In this paper, we identify a fundamental limitation of the standard cycle-consistency loss: it implicitly assumes that the mappings are bijections. When the underlying ground-truth mappings are many-to-one, the cycle-consistency loss can lead to degenerate solutions where the model fails to learn the correct mapping. We refer to this phenomenon as the "forking" problem. We provide a theoretical analysis of this issue and propose a simple yet effective solution, which we call "Fork or Fail" (FoF). FoF introduces a regularization term that encourages the model to learn mappings that are consistent with the underlying many-to-one structure. We demonstrate the effectiveness of our approach on several synthetic and real-world datasets, showing that it significantly improves the stability and performance of cycle-consistent training.},
	language = {en},
	booktitle = {Proceedings of the 24th {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Guo, Q. and Jin, Z. and Wang, Z. and Qiu, X. and Zhang, W. and Zhu, J. and Zhang, Z. and Wipf, D.},
	month = apr,
	year = {2021},
	keywords = {AISTATS},
}
