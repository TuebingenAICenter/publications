@inproceedings{daxberger_bayesian_2021,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Bayesian {Deep} {Learning} via {Subnetwork} {Inference}},
	shorttitle = {Bayesian {Deep} {Learning} via {Subnetwork} {Inference}},
	url = {https://proceedings.mlr.press/v139/daxberger21a.html},
	abstract = {We propose Subnetwork Inference, a framework for Bayesian deep learning that performs inference on a subset of a network's weights while keeping the rest fixed. This approach is motivated by the observation that deep neural networks are often over-parameterized and that a small subnetwork can be sufficient to capture the uncertainty of the model. We show that Subnetwork Inference can be applied to a variety of architectures and inference methods, including Laplace approximation and variational inference. Our experiments demonstrate that Subnetwork Inference achieves competitive performance on uncertainty estimation and out-of-distribution detection tasks while being significantly more computationally efficient than full-network inference.},
	language = {en},
	booktitle = {Proceedings of 38th {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Daxberger, E. and Nalisnick, E. and Allingham, J. and Antorán, J. and Hernández-Lobato, J. M.},
	month = jul,
	year = {2021},
	keywords = {ICML},
}
