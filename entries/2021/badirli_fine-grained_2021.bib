@inproceedings{badirli_fine-grained_2021,
	title = {Fine-{Grained} {Zero}-{Shot} {Learning} with {DNA} as {Side} {Information}},
	shorttitle = {Fine-{Grained} {Zero}-{Shot} {Learning} with {DNA} as {Side} {Information}},
	url = {https://proceedings.neurips.cc/paper/2021/file/a18630ab1c3b9f14454cf70dc7114834-Paper.pdf},
	abstract = {Zero-shot learning (ZSL) aims to recognize objects from classes that were not seen during training. This is typically achieved by mapping visual features to a semantic space, such as attributes or word embeddings. In this paper, we propose using DNA sequences as a novel source of side information for fine-grained ZSL. DNA sequences provide a rich, objective, and evolutionary-based representation of species, which we hypothesize can better capture the fine-grained relationships between classes compared to human-annotated attributes. We propose a framework that learns a mapping from visual features to a DNA-based semantic space. We evaluate our approach on the CUB-200-2011 dataset and show that it achieves competitive performance compared to state-of-the-art methods that use attributes or word embeddings. Furthermore, we demonstrate that our DNA-based approach is more robust to the lack of human-annotated attributes, making it a promising direction for fine-grained ZSL in scenarios where such annotations are difficult or expensive to obtain.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 34 ({NeurIPS} 2021)},
	publisher = {Curran Associates, Inc.},
	author = {Badirli, S. and Akata, Z. and Mohler, G. and Picard, C. and Dundar, M.},
	month = dec,
	year = {2021},
	keywords = {Discriminative model, Margin (machine learning), Computer science, Benchmark (surveying), Artificial intelligence, Bayesian probability, Prior probability, Machine learning, Hierarchy, Task (project management), Word (group theory), Pattern recognition (psychology), Mathematics, NEURIPS},
}
