@inproceedings{de_ross_high-dimensional_2021,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {High-{Dimensional} {Gaussian} {Process} {Inference} with {Derivatives}},
	url = {https://proceedings.mlr.press/v139/de-roos21a.html},
	doi = {10.48550/arxiv.2102.07542},
	abstract = {Gaussian processes (GPs) are a powerful tool for probabilistic regression. However, their standard application is limited by the cubic complexity of the number of observations. When derivative observations are available, the computational cost increases further. We propose a novel approach to GP inference with derivative observations that scales linearly with the number of observations and the number of input dimensions. Our method relies on a sparse approximation of the GP posterior using a set of inducing points and a specific choice of the kernel. We demonstrate the effectiveness of our approach on several synthetic and real-world datasets, showing that it achieves competitive performance while being significantly faster than existing methods.},
	language = {en},
	booktitle = {Proceedings of 38th {International} {Conference} on {Machine} {Learning} ({ICML})},
	publisher = {PMLR},
	author = {de Ross, F. and Gessner, A. and Hennig, P.},
	editor = {Meila, Marina and Zhang, Tong},
	month = jul,
	year = {2021},
	keywords = {Gaussian process, Dimension (graph theory), Inference, Gaussian, Function (biology), Kernel (algebra), Applied mathematics, Derivative (finance), Mathematics, Dilemma, Gaussian function, Gramian matrix, Statistical physics, Algorithm, Computer science, Pure mathematics, Mathematical optimization, Physics, Artificial intelligence, Geometry, Eigenvalues and eigenvectors, Quantum mechanics, Bayesian nonparametrics, optimization, Hamiltonian Monte Carlo, ICML},
}
