@article{schmid_kunstliche_2021,
	title = {Künstliche {Intelligenz}–{Die} dritte {Welle}},
	shorttitle = {Künstliche {Intelligenz}–{Die} dritte {Welle}},
	url = {https://dl.gi.de/handle/20.500.12116/34792},
	doi = {10.18420/inf2020_10},
	abstract = {Die aktuelle Entwicklung der Künstlichen Intelligenz (KI) ist durch eine enorme Dynamik geprägt. Während die erste Welle der KI durch regelbasierte Systeme und die zweite Welle durch statistisches Lernen geprägt waren, zeichnet sich nun eine dritte Welle ab, die die Stärken beider Ansätze vereint. Dieser Beitrag gibt einen Überblick über die aktuelle Situation der KI-Forschung in Deutschland und diskutiert die Herausforderungen und Chancen, die sich aus der Kombination von datengetriebenen und wissensbasierten Ansätzen ergeben.},
	language = {de},
	urldate = {2025-05-14},
	journal = {INFORMATIK 2020},
	publisher = {Gesellschaft für Informatik e.V.},
	author = {Schmid, Ute and Tresp, Volker and Bethge, Matthias and Kersting, Kristian and Stiefelhagen, Rainer},
	year = {2021},
	keywords = {KI},
}
