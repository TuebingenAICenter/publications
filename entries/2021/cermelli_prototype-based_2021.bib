@inproceedings{cermelli_prototype-based_2021,
	title = {Prototype-based {Incremental} {Few}-{Shot} {Segmentation}},
	url = {https://www.bmvc2021-virtualconference.com/assets/papers/0484.pdf},
	doi = {10.48550/arxiv.2012.01415},
	abstract = {Few-shot segmentation aims to segment objects of unseen classes given only a few annotated examples. While existing methods achieve impressive results, they typically assume that all classes are available at training time or that the model is trained on a fixed set of base classes. In this paper, we address the more challenging and realistic scenario of Incremental Few-Shot Segmentation (IFSS), where the model is required to learn new classes sequentially without forgetting the previously learned ones. We propose a novel prototype-based approach that relies on a shared embedding space and a memory-based mechanism to store and update class prototypes. Our method effectively mitigates catastrophic forgetting by leveraging a distillation loss and a prototype-based replay strategy. We evaluate our approach on the PASCAL-5i and COCO-20i datasets, demonstrating that it significantly outperforms existing baselines in the incremental setting.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {32nd {British} {Machine} {Vision} {Conference} ({BMVC})},
	author = {Cermelli, Fabio and Mancini, Massimiliano and Xian, Yongqin and Akata, Zeynep and Caputo, Barbara},
	month = nov,
	year = {2021},
	keywords = {Computer science, Segmentation, Overfitting, Artificial intelligence, Machine learning, Exploit, Benchmark (surveying), Task (project management), Set (abstract data type), Representation (politics), Forgetting, Class (philosophy), Semantics (computer science), Pattern recognition (psychology), Artificial neural network, BMVC},
}
