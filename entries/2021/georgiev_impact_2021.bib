@misc{georgiev_impact_2021,
	title = {On the {Impact} of {Stable} {Ranks} in {Deep} {Nets}},
	shorttitle = {On the {Impact} of {Stable} {Ranks} in {Deep} {Nets}},
	url = {https://arxiv.org/abs/2110.02333},
	abstract = {The rank of weight matrices in deep neural networks is often used as a proxy for their complexity. However, in practice, weight matrices are rarely exactly low-rank, but rather have a spectrum that decays quickly. The stable rank, which is a continuous proxy for the matrix rank, is a more robust measure of the effective dimensionality of the linear transformations. In this paper, we investigate the impact of the stable rank of weight matrices on the training and generalization of deep neural networks. We show that the stable rank is a useful metric for understanding the capacity of deep networks and that it can be used to regularize training. We provide empirical evidence that controlling the stable rank can lead to better generalization and more stable training.},
	language = {en},
	urldate = {2024-05-22},
	publisher = {arXiv},
	author = {Georgiev, B. and Franken, L. and Mukherjee, M. and Arvanitidis, G.},
	year = {2021},
}
