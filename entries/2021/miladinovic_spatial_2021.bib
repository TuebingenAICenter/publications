@inproceedings{miladinovic_spatial_2021,
	title = {Spatial {Dependency} {Networks}: {Neural} {Layers} for {Improved} {Generative} {Image} {Modeling}},
	shorttitle = {Spatial {Dependency} {Networks}},
	url = {https://openreview.net/pdf?id=I4c4K9vBNny},
	abstract = {Generative image models often rely on autoregressive architectures to capture the complex dependencies between pixels. While powerful, these models are computationally expensive due to their sequential nature. We propose Spatial Dependency Networks (SDNs), a novel neural layer that models spatial dependencies by learning a set of local, spatially-varying filters. SDNs can be integrated into existing generative architectures to improve their modeling capabilities while maintaining computational efficiency. We demonstrate the effectiveness of SDNs on a variety of generative modeling tasks, including image synthesis and density estimation, where they consistently outperform or match state-of-the-art methods.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {The 9th {International} {Conference} on {Learning} {Representations} ({ICLR})},
	author = {Miladinović, D. and Stanić, A. and Bauer, S. and Schmidhuber, J. and Buhmann, J. M.},
	month = may,
	year = {2021},
	keywords = {ICLR},
}
