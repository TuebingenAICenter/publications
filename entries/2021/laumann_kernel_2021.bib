@inproceedings{laumann_kernel_2021,
	title = {Kernel {Two}-{Sample} and {Independence} {Tests} for {Non}-{Stationary} {Random} {Processes}},
	shorttitle = {Kernel {Two}-{Sample} and {Independence} {Tests}},
	url = {https://arxiv.org/abs/2010.00271},
	abstract = {We propose a framework for kernel-based two-sample and independence testing for non-stationary random processes. By leveraging the theory of reproducing kernel Hilbert spaces (RKHS) of functions on time-series, we extend existing kernel tests to the non-stationary setting. We show that our tests are consistent and provide a theoretical analysis of their power. We demonstrate the effectiveness of our approach on synthetic and real-world data, including climate and financial time series.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {7th {International} {Conference} on {Time} {Series} and {Forecasting} ({ITISE} 2021)},
	author = {Laumann, Florian and von Kügelgen, Julius and Barahona, Mauricio},
	month = jul,
	year = {2021},
	keywords = {ITISE},
}
