@article{muratore_assessing_2021,
	title = {Assessing {Transferability} {From} {Simulation} to {Reality} for {Reinforcement} {Learning}},
	issn = {0162-8828},
	shorttitle = {Assessing {Transferability} {From} {Simulation} to {Reality}},
	url = {https://ieeexplore.ieee.org/document/8894399},
	doi = {10.1109/TPAMI.2019.2952353},
	abstract = {Reinforcement learning (RL) has shown great promise in solving complex control tasks. However, learning directly on physical systems is often time-consuming, dangerous, and requires constant supervision. Consequently, training in simulation and transferring the resulting policy to the real world is a common paradigm. Unfortunately, the performance in simulation is often not predictive of the performance in reality due to the reality gap. In this paper, we propose a framework to assess the transferability of a policy from simulation to reality. We introduce a measure of transferability based on the discrepancy between the transition dynamics in simulation and reality. We show that this measure can be used to predict the performance drop when transferring a policy. Furthermore, we demonstrate how this measure can be used to guide the design of simulation environments and to select policies that are robust to the reality gap. We evaluate our approach on a variety of robotic tasks, including a cart-pole system and a robotic arm, and show that it outperforms existing methods for assessing transferability.},
	language = {en},
	urldate = {2024-05-23},
	journal = {IEEE Transactions on Pattern Analysis and Machine Intelligence},
	publisher = {IEEE},
	author = {Muratore, Fabio and Gienger, Michael and Peters, Jan},
	year = {2021},
	keywords = {TPAMI},
}
