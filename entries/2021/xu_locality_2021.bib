@inproceedings{xu_locality_2021,
	title = {Locality {Sensitive} {Teaching}},
	url = {https://proceedings.neurips.cc/paper/2021/file/95c3f1a8b262ec7a929a8739e21142d7-Paper.pdf},
	abstract = {Machine teaching aims to find a minimal set of training examples to steer a learner to a target model. Existing methods often require solving a bilevel optimization problem, which is computationally expensive and hard to scale to large datasets or complex models. In this paper, we propose Locality Sensitive Teaching (LST), a novel framework that leverages the locality sensitive hashing (LSH) technique to efficiently select teaching examples. LST approximates the influence of training examples on the learner's parameters by identifying the "local" neighbors in the feature space. We show that LST can significantly reduce the computational cost of teaching while maintaining competitive performance compared to state-of-the-art methods. We demonstrate the effectiveness of LST on various machine learning tasks, including image classification and text sentiment analysis.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 34 ({NeurIPS} 2021)},
	publisher = {Curran Associates, Inc.},
	author = {Xu, Z. and Chen, B. and Li, C. and Liu, W. and Song, L. and Lin, Y. and Shrivastava, A.},
	month = dec,
	year = {2021},
	keywords = {NeurIPS},
}
