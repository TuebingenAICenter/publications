@article{bustamante_armsym_2021,
	title = {{ArmSym}: a virtual human-robot interaction laboratory for assistive robotics},
	shorttitle = {{ArmSym}},
	url = {https://ieeexplore.ieee.org/document/9547225},
	doi = {10.1109/THMS.2021.3106865},
	abstract = {Assistive robotics aims to improve the quality of life of people with motor impairments by providing robotic aids, such as robotic arms or powered wheelchairs. However, the development and evaluation of assistive robotic systems are challenging due to the high cost of hardware, the difficulty of recruiting participants with motor impairments, and the safety risks involved in human-robot interaction. To address these challenges, we present ArmSym, a virtual human-robot interaction laboratory for assistive robotics. ArmSym is a simulation environment that provides a realistic and safe platform for the development and evaluation of assistive robotic systems. It includes a variety of virtual robotic arms, wheelchairs, and environments, as well as a set of tools for simulating human-robot interaction. We demonstrate the utility of ArmSym by evaluating a shared-control system for a robotic arm, showing that the simulation results are consistent with those obtained in a real-world experiment. ArmSym is open-source and available for the research community.},
	language = {en},
	journal = {IEEE Transactions on Human-Machine Systems},
	publisher = {IEEE},
	author = {Bustamante, Samuel and Peters, Jan and Schölkopf, Bernhard and Grosse-Wentrup, Moritz and Jayaram, Vinay},
	month = dec,
	year = {2021},
	keywords = {Robotics, Human–computer interaction, Robot, Testbed, Artificial intelligence, Virtual reality, Wheelchair, Computer science, Robotic arm, Human–robot interaction, Perception, Simulation, Engineering, Psychology, Human-computer interaction, Human-robot interaction, THMS},
}
