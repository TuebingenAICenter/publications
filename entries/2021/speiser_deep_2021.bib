@article{speiser_deep_2021,
	title = {Deep learning enables fast and dense single-molecule localization with high accuracy},
	issn = {1548-7091},
	shorttitle = {Deep learning enables fast and dense single-molecule localization},
	url = {https://www.nature.com/articles/s41592-021-01236-x},
	doi = {10.1038/s41592-021-01236-x},
	abstract = {Single-molecule localization microscopy (SMLM) provides nanometer-scale resolution by localizing individual fluorophores. However, current methods struggle with dense emitter environments, where overlapping point spread functions (PSFs) lead to localization errors or require long acquisition times to ensure sparsity. Here we present DECODE, a deep learning-based approach for SMLM that enables fast and accurate localization of emitters in dense environments. DECODE uses a deep neural network to predict the positions and uncertainties of emitters directly from raw image data. We demonstrate that DECODE achieves high localization accuracy and precision, even in extremely dense conditions, and is significantly faster than existing methods. We apply DECODE to various SMLM datasets, including 3D and multi-color imaging, and show that it enables high-quality reconstructions from shorter acquisition times, thereby reducing photobleaching and increasing temporal resolution.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Nature Methods},
	publisher = {Nature Publishing Group},
	author = {Speiser, A. and Müller, L.-R. and Hoess, P. and Matti, U. and Obara, C. J. and Legant, W. R. and Kreshuk, A. and Macke, J. H. and Ries, J. and Turaga, S. C.},
	month = sep,
	year = {2021},
	keywords = {Deep learning, Benchmark (surveying), Context (archaeology), Software, Range (aeronautics), Pattern recognition (psychology), Image (mathematics), Microscopy, NATURE METHODS},
}
