@misc{frohlich_bayesian_2021,
	title = {Bayesian {Quadrature} on {Riemannian} {Data} {Manifolds}},
	url = {https://proceedings.mlr.press/v139/frohlich21a.html},
	doi = {10.48550/arxiv.2102.06645},
	abstract = {Bayesian Quadrature (BQ) is a powerful framework for probabilistic numerical integration. However, standard BQ methods rely on Euclidean assumptions, which are often violated when data lies on a low-dimensional manifold embedded in a high-dimensional space. We propose a BQ method that accounts for the geometry of the data manifold by using a Riemannian kernel. We derive a closed-form solution for the integral of the kernel, which allows for efficient computation of the BQ estimator. We demonstrate the effectiveness of our approach on several synthetic and real-world datasets, showing that it outperforms standard BQ methods in terms of accuracy and uncertainty quantification.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Fröhlich, Christian and Gessner, Alexandra and Hennig, Philipp and Schölkopf, Bernhard and Arvanitidis, Georgios},
	editor = {Meila, Marina and Zhang, Tong},
	month = jul,
	year = {2021},
	keywords = {Riemannian geometry, Probabilistic logic, Quadrature (astronomy), Computer science, Metric (unit), Nonlinear system, Bayesian probability, Applied mathematics, Information geometry, Range (aeronautics), Numerical integration, Mathematics, Algorithm, Mathematical optimization, Artificial intelligence, Geometry, Mathematical analysis, Scalar curvature, Physics, ICML},
}
