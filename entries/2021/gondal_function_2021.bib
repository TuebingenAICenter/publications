@article{gondal_function_2021,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Function {Contrastive} {Learning} of {Transferable} {Meta}-{Representations}},
	url = {https://proceedings.mlr.press/v139/gondal21a.html},
	doi = {10.48550/arxiv.2010.07093},
	abstract = {We propose a novel framework for learning transferable meta-representations by leveraging the functional structure of tasks. Our approach, Function Contrastive Learning (FCL), learns representations that are invariant to task-specific transformations while being sensitive to the underlying functional relationships between tasks. We demonstrate that FCL achieves state-of-the-art performance on several meta-learning benchmarks, showing improved transferability and robustness compared to existing methods.},
