@misc{wu_inference_2021,
	title = {Inference and search on graph-structured spaces},
	shorttitle = {Inference and search on graph-structured spaces},
	url = {https://doi.org/10.1007/s42113-020-00091-x},
	doi = {10.1007/s42113-020-00091-x},
	abstract = {Many real-world search problems occur in environments where options are related to one another via a graph structure. How do people learn about these structures and use them to guide their search? We propose a model of human search in graph-structured spaces based on Bayesian inference over graph topologies. We test this model in three experiments where participants search for rewards in hidden graphs. We find that participants are able to learn the underlying graph structure and use this knowledge to perform more efficient search compared to a baseline model that ignores the graph structure. Our model captures human behavior better than alternative models, including a model that assumes a flat structure and a model that uses a simple heuristic for graph search. These results suggest that human search is guided by an internal model of the environment's structure, which is updated through experience.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Springer Science and Business Media LLC},
	author = {Wu, Charley M. and Schulz, Eric and Gershman, Samuel J.},
	year = {2021},
	keywords = {Graph, Inference, Computer science, Machine learning, Function (biology), Artificial intelligence, Bayesian inference, Bayesian probability, Theoretical computer science},
}
