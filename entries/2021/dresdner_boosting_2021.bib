@inproceedings{dresdner_boosting_2021,
	title = {Boosting {Variational} {Inference} {With} {Locally} {Adaptive} {Step}-{Sizes}},
	shorttitle = {Boosting {Variational} {Inference} {With} {Locally} {Adaptive} {Step}-{Sizes}},
	url = {https://is.mpg.de/ei/publications/dresdneretal21},
	doi = {10.24963/ijcai.2021/322},
	abstract = {Boosting Variational Inference (BVI) is a popular framework for approximating complex posterior distributions by iteratively adding components to a mixture model. A key challenge in BVI is the selection of the step-size at each iteration. Existing methods either use a fixed step-size, which can be slow to converge, or perform a line search, which can be computationally expensive. In this paper, we propose a novel approach to BVI that uses locally adaptive step-sizes. Our method is based on the observation that the optimal step-size can be estimated by considering the local geometry of the objective function. We derive a closed-form update rule for the step-size that is computationally efficient and does not require line search. We demonstrate the effectiveness of our approach on a variety of Bayesian inference tasks, showing that it consistently outperforms existing BVI methods in terms of convergence speed and final approximation quality.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 30th {International} {Joint} {Conference} on {Artificial} {Intelligence} ({IJCAI})},
	publisher = {International Joint Conferences on Artificial Intelligence Organization},
	author = {Dresdner, G. and Shekhar, S. and Pedregosa, F. and Locatello, F. and Rätsch, G.},
	editor = {Zhou, Zhi-Hua},
	month = aug,
	year = {2021},
	keywords = {IJCAI},
}
