@misc{schroeder_distinct_2021,
	title = {Distinct synaptic transfer functions in same-type photoreceptors},
	copyright = {CC BY 4.0},
	shorttitle = {Distinct synaptic transfer functions in same-type photoreceptors},
	url = {https://elifesciences.org/articles/67851},
	doi = {10.7554/eLife.67851},
	abstract = {In the vertebrate retina, photoreceptors transmit visual information to downstream neurons via ribbon synapses. While it is well established that different types of photoreceptors exhibit distinct synaptic properties, it remains unclear whether individual photoreceptors of the same type are functionally identical. Here, we show that individual zebrafish cone photoreceptors of the same spectral type exhibit distinct synaptic transfer functions. By combining two-photon imaging of synaptic glutamate release with computational modeling, we find that these differences are not random but are systematically related to the cell's position in the retina. We show that this spatial heterogeneity in synaptic transfer functions is driven by differences in the kinetics of vesicle release and the size of the readily releasable pool of vesicles. Our results suggest that the synaptic output of photoreceptors is not uniform but is instead tuned to the local statistics of the visual scene, providing a mechanism for local adaptation in the early visual system.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {eLife Sciences Publications, Ltd},
	author = {Schroeder, Cornelius and Oesterle, Jonathan and Berens, Philipp and Yoshimatsu, Takeshi and Baden, Tom},
	month = jul,
	year = {2021},
	keywords = {Ribbon synapse, Neuroscience, Synapse, Computer science, Active zone, Synaptic vesicle, Sensory system, Biological system, Stimulus (psychology), Biology, Vesicle, ELIFE},
}
