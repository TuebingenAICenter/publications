@inproceedings{adamczewski_dirichlet_2021,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Dirichlet pruning for neural network compression},
	shorttitle = {Dirichlet pruning},
	url = {http://proceedings.mlr.press/v130/adamczewski21a.html},
	abstract = {We propose a novel pruning method for neural networks based on the Dirichlet distribution. By placing a Dirichlet prior on the weights of a layer, we can interpret the pruning process as a Bayesian model selection problem. We show that this approach leads to a simple and effective pruning criterion that can be applied to various network architectures. Our method is computationally efficient and does not require retraining, making it suitable for large-scale models. We demonstrate the effectiveness of our approach on several benchmarks, showing that it achieves competitive compression rates while maintaining high accuracy.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Proceedings of the 24th {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Adamczewski, K. and Park, M.},
	editor = {Banerjee, Arindam and Fukumizu, Kenji},
	month = apr,
	year = {2021},
	keywords = {AISTATS},
}
