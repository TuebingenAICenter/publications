@article{funke_five_2021,
	title = {Five points to check when comparing visual perception in humans and machines},
	issn = {1534-7362},
	shorttitle = {Five points to check},
	url = {https://jov.arvojournals.org/article.aspx?articleid=2772393},
	doi = {10.1167/jov.21.3.16},
	abstract = {Comparing the visual perception of humans and machines is a central task in computer vision and computational neuroscience. However, the results of such comparisons are often difficult to interpret because of the many degrees of freedom in experimental design. In this article, we identify five points that are critical to consider when comparing human and machine perception: (1) the choice of stimuli, (2) the task, (3) the performance metric, (4) the model architecture, and (5) the training data. We discuss how each of these factors can influence the results and provide recommendations for how to design more informative and reproducible comparisons. We hope that this framework will help to standardize the evaluation of machine vision systems and facilitate a more nuanced understanding of the similarities and differences between human and machine perception.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Vision},
	publisher = {Association for Research in Vision and Ophthalmology},
	author = {Funke, Christina M. and Borowski, Judy and Stosio, Karolina and Brendel, Wieland and Wallis, Thomas S. A. and Bethge, Matthias},
	year = {2021},
	keywords = {JOV},
}
