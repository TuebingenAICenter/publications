@misc{pedziwiatr_there_2021,
	title = {There is no evidence that meaning maps capture semantic information relevant to gaze guidance: {Reply} to {Henderson}, {Hayes}, {Peacock}, and {Rehrig} (2021)},
	shorttitle = {There is no evidence that meaning maps capture semantic information},
	url = {https://bethgelab.org/publication/2021_09_pedziwiatra/},
	doi = {10.1016/j.cognition.2021.104741},
	abstract = {Henderson et al. (2021) argue that meaning maps—a computational model of semantic content in scenes—predict gaze guidance independently of low-level image features. We re-evaluate their evidence and show that their conclusions are not supported by their data. Specifically, we demonstrate that the meaning maps used by Henderson et al. are highly correlated with low-level image features, and that once these features are controlled for, the meaning maps explain no additional variance in gaze guidance. We conclude that there is currently no evidence that meaning maps capture semantic information relevant to gaze guidance.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Elsevier},
	author = {Pedziwiatr, Marek A. and Kümmerer, Matthias and Wallis, Thomas S. A. and Bethge, Matthias and Teufel, Christoph},
	year = {2021},
	keywords = {Gaze, Meaning (existential), Psychology, Cognitive science, Semantics (computer science), Cognitive psychology, Linguistics, Psychoanalysis, Computer science, Philosophy, Psychotherapist},
}
