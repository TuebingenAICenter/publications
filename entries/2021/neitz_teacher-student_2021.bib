@article{neitz_teacher-student_2021,
	title = {A teacher-student framework to distill future trajectories},
	url = {https://openreview.net/pdf?id=ECuvULjFQia},
	abstract = {Predicting future trajectories is a core problem in many fields, including robotics, autonomous driving, and climate modeling. While deep learning models have achieved impressive results, they are often computationally expensive and difficult to deploy in real-time settings. In this paper, we propose a teacher-student framework to distill future trajectories. Our approach leverages a powerful teacher model to learn a complex representation of the future, which is then distilled into a lightweight student model. We demonstrate that our student model can achieve performance comparable to the teacher model while being significantly faster and more memory-efficient. We evaluate our framework on several trajectory prediction benchmarks and show that it consistently outperforms existing distillation methods.},
	language = {en},
	journal = {9th International Conference on Learning Representations (ICLR)},
	author = {Neitz, Alexander and Parascandolo, Giambattista and Schölkopf, Bernhard},
	month = may,
	year = {2021},
	keywords = {Observability, Computer science, Set (abstract data type), Artificial intelligence, Machine learning, Dependency (UML), Component (thermodynamics), Sample (material), Trajectory, Mathematics, ICLR},
}
