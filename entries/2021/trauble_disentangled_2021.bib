@misc{trauble_disentangled_2021,
	title = {On {Disentangled} {Representations} {Learned} {From} {Correlated} {Data}},
	url = {https://proceedings.mlr.press/v139/trauble21a.html},
	doi = {10.48550/arxiv.2006.07886},
	abstract = {Disentangled representations are often argued to be a prerequisite for robust and generalizable machine learning. However, most existing methods for learning such representations rely on the assumption that the underlying factors of variation are independent. In this work, we challenge this assumption and investigate the effect of correlated data on the performance of disentanglement methods. We show that correlation can lead to a significant drop in performance and that existing methods are not robust to this setting. We propose a new evaluation framework for disentanglement in the presence of correlated data and demonstrate that our proposed approach can improve the robustness of disentanglement methods.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Träuble, Frederik and Creager, Elliot and Kilbertus, Niki and Locatello, Francesco and Dittadi, Andrea and Goyal, Anirudh and Schölkopf, Bernhard and Bauer, Stefan},
	editor = {Meila, Marina and Zhang, Tong},
	month = jul,
	year = {2021},
	keywords = {Psychology, Computer science, Data science, ICML},
}
