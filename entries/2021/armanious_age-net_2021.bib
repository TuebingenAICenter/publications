@article{armanious_age-net_2021,
	title = {Age-{Net}: {An} {MRI}-{Based} {Iterative} {Framework} for {Brain} {Biological} {Age} {Estimation}},
	shorttitle = {Age-{Net}},
	url = {https://ieeexplore.ieee.org/document/9380560},
	doi = {10.1109/TMI.2021.3066857},
	abstract = {Brain biological age estimation from magnetic resonance imaging (MRI) is a promising biomarker for neurodegenerative diseases. Existing methods typically rely on deep learning models that map MRI scans directly to chronological age. However, these models often suffer from limited interpretability and fail to account for the iterative nature of biological aging. In this paper, we propose Age-Net, an MRI-based iterative framework for brain biological age estimation. Age-Net mimics the biological aging process by iteratively refining the age estimate through a series of learned transformations. We demonstrate that our framework achieves state-of-the-art performance on multiple datasets and provides improved interpretability by highlighting age-related structural changes in the brain.},
	language = {en},
	journal = {IEEE Transactions on Medical Imaging},
	publisher = {IEEE},
	author = {Armanious, Karim and Abdulatif, Sherif and Shi, Wenbin and Salian, Shashank and Kustner, Thomas and Weiskopf, Daniel and Hepp, Tobias and Gatidis, Sergios and Yang, Bin},
	month = jul,
	year = {2021},
	keywords = {TMI},
}
