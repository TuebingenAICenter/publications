@misc{huang_estimating_2021,
	title = {Estimating smooth and sparse neural receptive fields with a flexible spline basis},
	url = {https://nbdt.scholasticahq.com/article/27578-estimating-smooth-and-sparse-neural-receptive-fields-with-a-flexible-spline-basis},
	doi = {10.37016/mr-2020-53},
	abstract = {The estimation of neural receptive fields (RFs) is a fundamental task in systems neuroscience. While linear-nonlinear models are widely used, they often suffer from overfitting when data is limited or the RF is high-dimensional. To address this, we propose a novel approach to estimate RFs using a flexible spline basis. Our method allows for the simultaneous enforcement of smoothness and sparsity, which are key properties of neural RFs. We demonstrate that our approach outperforms standard methods in both simulated and experimental data, providing more accurate and interpretable RF estimates. The method is computationally efficient and can be easily integrated into existing analysis pipelines.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Neurons, Behavior, Data analysis, and Theory},
	author = {Huang, Ziwei and Ran, Yanli and Oesterle, Yannik and Euler, Thomas and Berens, Philipp},
	month = aug,
	year = {2021},
	keywords = {Computer science, Spline (mechanical), Basis function, Hyperparameter, Receptive field, Bayes' theorem, Algorithm, Artificial intelligence, Nonlinear system, ENCODE, Machine learning, Mathematics, Bayesian probability},
}
