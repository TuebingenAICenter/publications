@inproceedings{schmidt_probabilistic_2021,
	title = {A {Probabilistic} {State} {Space} {Model} for {Joint} {Inference} from {Differential} {Equations} and {Data}},
	url = {https://proceedings.neurips.cc/paper/2021/hash/6734fa703f6633ab896eecbdfad8953a-Abstract.html},
	doi = {10.48550/arxiv.2103.10153},
	abstract = {We propose a probabilistic state space model for the joint inference of parameters and latent states of differential equations from noisy, sparse observations. By formulating the differential equation as a Gaussian process prior over the state trajectory, we derive a filtering and smoothing framework that is computationally efficient and provides uncertainty estimates. Our approach is based on a Taylor-series expansion of the differential equation, which allows us to linearize the dynamics and apply the Kalman filter and smoother. We demonstrate the effectiveness of our method on several synthetic and real-world datasets, showing that it outperforms existing methods in terms of accuracy and robustness.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 34},
	publisher = {Curran Associates, Inc.},
	author = {Schmidt, J. and Kraemer, N. and Hennig, P.},
	month = dec,
	year = {2021},
	keywords = {Ode, Computer science, Inference, Ordinary differential equation, Probabilistic logic, Applied mathematics, Algorithm, Differential equation, Mathematical optimization, Mathematics, Artificial intelligence, Mathematical analysis, NEURIPS},
}
