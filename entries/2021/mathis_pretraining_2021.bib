@inproceedings{mathis_pretraining_2021,
	title = {Pretraining boosts out-of-domain robustness for pose estimation},
	isbn = {978-1-7281-6182-2},
	shorttitle = {Pretraining boosts out-of-domain robustness for pose estimation},
	url = {https://bethgelab.org/publication/2021_01_mathis/},
	doi = {10.1109/WACV48630.2021.00193},
	abstract = {Deep learning has revolutionized pose estimation, but models often fail when tested on data from a different distribution than the training set. Here, we investigate the role of pretraining for out-of-domain (OOD) robustness in pose estimation. We systematically evaluate the effect of pretraining on various architectures and datasets. We find that pretraining on large-scale datasets significantly improves OOD robustness, even when the pretraining task is not directly related to pose estimation. Furthermore, we show that the choice of pretraining task and architecture matters, and that transfer learning can be a powerful tool for improving the generalization of pose estimation models.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {2021 {IEEE} {Winter} {Conference} on {Applications} of {Computer} {Vision} ({WACV})},
	publisher = {IEEE},
	author = {Mathis, Alexander and Biasi, Thomas and Schneider, Steffen and Yuksekgonul, Mert and Rogers, Byron and Bethge, Matthias and Mathis, Mackenzie W},
	year = {2021},
	keywords = {Robustness (evolution), Computer science, Pose, Benchmarking, Artificial intelligence, Machine learning, Benchmark (surveying), Transfer of learning, Artificial neural network, Generalization, Pattern recognition (psychology), Mathematics, Biology, WACV},
}
