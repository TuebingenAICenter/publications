@misc{allshire_transferring_2021,
	title = {Transferring {Dexterous} {Manipulation} from {GPU} {Simulation} to a {Remote} {Real}-{World} {TriFinger}},
	shorttitle = {Transferring {Dexterous} {Manipulation}},
	url = {https://arxiv.org/abs/2108.09779},
	doi = {10.48550/arXiv.2108.09779},
	abstract = {We present a system for transferring dexterous manipulation policies from GPU-accelerated simulation to a real-world TriFinger robot. Our approach combines high-throughput parallel simulation with domain randomization and a robust control framework to bridge the reality gap. We demonstrate that policies trained in simulation can successfully perform complex manipulation tasks on the physical robot without any real-world fine-tuning.},
	language = {en},
	urldate = {2024-05-23},
	publisher = {arXiv},
	author = {Allshire, Arthur and Mittal, Mayank and Lodaya, Varun and Makoviychuk, Viktor and Makoviichuk, Denys and Widmaier, Felix and Wüthrich, Manuel and Bauer, Stefan and Handa, Ankur and Garg, Animesh},
	year = {2021},
	keywords = {arXiv},
}
