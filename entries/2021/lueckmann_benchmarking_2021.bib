@inproceedings{lueckmann_benchmarking_2021,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Benchmarking {Simulation}-{Based} {Inference}},
	shorttitle = {Benchmarking {Simulation}-{Based} {Inference}},
	url = {http://proceedings.mlr.press/v130/lueckmann21a.html},
	doi = {10.48550/arxiv.2101.04653},
	abstract = {Simulation-based inference (SBI) allows for Bayesian inference in models where the likelihood is intractable but simulation is possible. Recent years have seen a surge in methods for SBI, particularly those based on neural density estimation. However, these methods are often evaluated on different tasks, using different metrics, and without consistent baselines, making it difficult to assess the state of the art. We introduce a benchmark for SBI, consisting of a diverse set of inference tasks and a standardized evaluation framework. We use this benchmark to evaluate a range of state-of-the-art SBI methods, including neural posterior estimation, neural likelihood estimation, and neural ratio estimation. Our results reveal that while these methods can achieve high performance, their success is highly dependent on the task and the choice of hyperparameters. We provide an open-source library to facilitate future benchmarking and development of SBI methods.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 24th {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Lueckmann, Jan-Matthis and Boelts, Jakob and Greenberg, David S. and Gonçalves, Pedro J. and Macke, Jakob H.},
	month = apr,
	year = {2021},
	keywords = {Benchmarking, Benchmark (surveying), Computer science, Inference, Metric (unit), Machine learning, Set (abstract data type), Artificial neural network, Artificial intelligence, Data mining, Algorithm, AISTATS},
}
