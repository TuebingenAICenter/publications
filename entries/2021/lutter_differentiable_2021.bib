@inproceedings{lutter_differentiable_2021,
	title = {Differentiable {Physics} {Models} for {Real}-world {Offline} {Model}-based {Reinforcement} {Learning}},
	shorttitle = {Differentiable {Physics} {Models}},
	url = {https://doi.org/10.1109/ICRA48506.2021.9561805},
	doi = {10.1109/ICRA48506.2021.9561805},
	abstract = {Model-based reinforcement learning (MBRL) has the potential to solve complex robotic tasks with high sample efficiency. However, learning accurate dynamics models from real-world data is challenging due to noise, partial observability, and the high cost of data collection. In this paper, we propose to incorporate differentiable physics models into the MBRL framework to improve sample efficiency and generalization. We show that by combining a learned differentiable physics engine with a residual model, we can learn accurate dynamics models from limited real-world data. We evaluate our approach on a real-world robotic manipulation task and show that it outperforms state-of-the-art model-free and model-based reinforcement learning methods.},
	language = {en},
	booktitle = {{IEEE} {International} {Conference} on {Robotics} and {Automation} ({ICRA})},
	publisher = {IEEE},
	author = {Lutter, Michael and Silberbauer, Johannes and Watson, Joe and Peters, Jan},
	month = may,
	year = {2021},
	keywords = {ICRA},
}
