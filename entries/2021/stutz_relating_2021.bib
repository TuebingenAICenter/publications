@article{stutz_relating_2021,
	title = {Relating {Adversarially} {Robust} {Generalization} to {Flat} {Minima}},
	shorttitle = {Relating {Adversarially} {Robust} {Generalization} to {Flat} {Minima}},
	url = {https://doi.org/10.1109/iccv48922.2021.00771},
	doi = {10.1109/iccv48922.2021.00771},
	abstract = {Adversarial training is the state-of-the-art for training adversarially robust neural networks. However, it is well-known that adversarial training often leads to a significant drop in standard accuracy. In this paper, we investigate the relationship between adversarial robustness and the flatness of the loss landscape. We show that adversarial training indeed leads to flatter minima in terms of the loss landscape, but that this flatness is not sufficient to explain the gap between standard and robust generalization. We provide a theoretical analysis showing that the flatness of the loss landscape is related to the robustness of the model, but that this relationship is more complex than previously thought. We also provide extensive empirical evidence supporting our theoretical findings.},
	language = {en},
	urldate = {2025-05-14},
	journal = {2021 IEEE/CVF International Conference on Computer Vision (ICCV)},
	publisher = {IEEE},
	author = {Stutz, David and Hein, Matthias and Schiele, Bernt},
	year = {2021},
	keywords = {Overfitting, Maxima and minima, Flatness (cosmology), Robustness (evolution), Adversarial system, Mathematics, Computer science, Generalization, Mathematical optimization, Algorithm, Artificial intelligence, Artificial neural network, Mathematical analysis, ICCV},
}
