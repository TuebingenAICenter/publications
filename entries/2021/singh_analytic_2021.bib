@inproceedings{singh_analytic_2021,
	title = {Analytic {Insights} into {Structure} and {Rank} of {Neural} {Network} {Hessian} {Maps}},
	shorttitle = {Analytic {Insights} into {Structure} and {Rank} of {Neural} {Network} {Hessian} {Maps}},
	url = {https://proceedings.neurips.cc/paper/2021/file/c900ced7451da79502d29aa37ebb7b60-Paper.pdf},
	abstract = {The Hessian of the loss function with respect to the parameters of a neural network is a central object in deep learning, providing insights into the geometry of the loss landscape and the convergence properties of optimization algorithms. Despite its importance, the Hessian is often too large to compute or store, and its spectral properties are not well understood. In this paper, we provide a theoretical analysis of the structure and rank of the Hessian of neural networks. We show that the Hessian can be decomposed into a sum of a low-rank component and a component that depends on the network architecture and the data. We provide bounds on the rank of the Hessian and show that it is often much smaller than the number of parameters. We also provide empirical evidence that our theoretical results hold for a variety of architectures and datasets.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 34},
	publisher = {Curran Associates, Inc.},
	author = {Singh, S. P. and Bachmann, G. and Hofmann, T.},
	editor = {Ranzato, M. and Beygelzimer, A. and Dauphin, Y. and Liang, P.S. and Wortman Vaughan, J.},
	month = dec,
	year = {2021},
	keywords = {NEURIPS},
}
