@article{zilio_are_2021,
	title = {Are intrinsic neural timescales related to sensory processing? {Evidence} from abnormal behavioral states},
	issn = {1053-8119},
	shorttitle = {Are intrinsic neural timescales related to sensory processing?},
	url = {https://www.sciencedirect.com/science/article/pii/S1053811920310648},
	doi = {10.1016/j.neuroimage.2020.117579},
	abstract = {The brain's intrinsic neural timescales (INTs) are thought to reflect the temporal integration window of neural processing. While previous studies have shown that INTs are organized along a sensory-to-association cortical hierarchy, it remains unclear whether they are directly related to sensory processing. Here, we investigated this relationship by examining INTs in patients with disorders of consciousness (DOC), a condition characterized by impaired sensory processing and awareness. We found that INTs were significantly altered in DOC patients compared to healthy controls, particularly in sensory-related cortical areas. Furthermore, the degree of INT alteration was correlated with the level of behavioral impairment, as measured by the Coma Recovery Scale-Revised. These findings suggest that INTs are not only a fundamental property of cortical organization but are also closely linked to the integrity of sensory processing and, by extension, to the level of consciousness.},
	language = {en},
	urldate = {2024-05-22},
	journal = {NeuroImage},
	publisher = {Elsevier},
	author = {Zilio, Federico and Gomez-Pilar, Javier and Cao, S. and Zhang, J. and Zang, D. and Qi, Z. and Tan, J. and Hiromi, T. and Wu, X. and Fogel, Stuart and Huang, Z. and Hohmann, M. R. and Fomina, T. and Synofzik, Matthis and Grosse-Wentrup, Moritz and Owen, Adrian M. and Northoff, Georg},
	year = {2021},
	keywords = {NEUROIMAGE},
}
