@inproceedings{dax_amortized_2021,
	title = {Amortized {Bayes} inference of gravitational waves with normalizing flows},
	shorttitle = {Amortized {Bayes} inference of gravitational waves},
	url = {https://ml4physicalsciences.github.io/2021/files/NeurIPS_ML4PS_2021_66.pdf},
	abstract = {Gravitational wave (GW) astronomy relies on Bayesian inference to estimate the parameters of compact binary coalescences. Current methods, such as Markov Chain Monte Carlo (MCMC) and Nested Sampling, are computationally expensive, often requiring days to analyze a single event. As the sensitivity of detectors increases, the number of detected events will grow, necessitating faster inference methods. We propose a method for amortized Bayesian inference of GW parameters using normalizing flows. Our approach learns the posterior distribution conditioned on the observed data, allowing for near-instantaneous inference once trained. We demonstrate our method on simulated GW signals and show that it produces accurate posterior estimates, comparable to traditional methods, while being orders of magnitude faster.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Fourth {Workshop} on {Machine} {Learning} and the {Physical} {Sciences} at {NeurIPS}},
	author = {Dax, Maximilian and Green, Stephen and Gair, Jonathan and Macke, Jakob and Schölkopf, Bernhard},
	year = {2021},
	keywords = {NEURIPS},
}
