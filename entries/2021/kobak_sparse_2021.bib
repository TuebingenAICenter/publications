@article{kobak_sparse_2021,
	title = {Sparse reduced-rank regression for exploratory visualisation of paired multivariate data},
	issn = {0035-9254},
	shorttitle = {Sparse reduced-rank regression},
	url = {https://academic.oup.com/jrsssc/article-abstract/70/4/980/7034013},
	doi = {10.1111/rssc.12494},
	abstract = {We propose sparse reduced-rank regression (SRRR) as a method for exploratory visualisation of paired multivariate data. SRRR finds a low-dimensional projection of the response variables that is maximally predictable from the predictor variables, while enforcing sparsity on the projection weights. This allows for identifying a small subset of predictor variables that are most relevant for explaining the variation in the response variables. We demonstrate the utility of SRRR on several real-world datasets, including gene expression data and neural activity data, and show that it provides more interpretable visualisations than standard reduced-rank regression or canonical correlation analysis.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of the Royal Statistical Society Series C: Applied Statistics},
	publisher = {Oxford University Press},
	author = {Kobak, Dmitry and Bernaerts, Yves and Weis, Marissa A. and Scala, Federico and Tolias, Andreas S. and Berens, Philipp},
	month = aug,
	year = {2021},
	keywords = {Multivariate statistics, Visualization, Computer science, Set (abstract data type), Rank (graph theory), Data set, Pattern recognition (psychology), Regression, Data mining, Elastic net regularization, Artificial intelligence, Machine learning, Mathematics, Statistics, Feature selection, JRSSC},
}
