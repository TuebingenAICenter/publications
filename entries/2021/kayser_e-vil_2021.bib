@inproceedings{kayser_e-vil_2021,
	title = {e-{ViL}: {A} {Dataset} and {Benchmark} for {Natural} {Language} {Explanations} in {Vision}-{Language} {Tasks}},
	shorttitle = {e-{ViL}},
	url = {https://ieeexplore.ieee.org/document/9710262},
	doi = {10.1109/ICCV48922.2021.00128},
	abstract = {Vision-language models have achieved impressive performance on various tasks. However, they are often criticized for being black boxes, as they do not provide explanations for their predictions. To address this, we introduce e-ViL, a benchmark for natural language explanations in vision-language tasks. e-ViL consists of a large-scale dataset of explanations for vision-language tasks, including visual question answering and visual entailment. We also provide a set of metrics to evaluate the quality of the generated explanations. We evaluate several state-of-the-art vision-language models on e-ViL and show that they struggle to generate high-quality explanations, highlighting the need for further research in this area.},
	language = {en},
	publisher = {IEEE},
	author = {Kayser, Maxime and Camburu, Oana-Maria and Salewski, L. and Emde, C. and Do, V. and Akata, Z. and Lukasiewicz, T.},
	month = oct,
	year = {2021},
	keywords = {Margin (machine learning), Computer science, Benchmark (surveying), USable, Artificial intelligence, Code (set theory), Natural language, Natural language processing, Natural language understanding, Language model, Machine learning, Programming language, World Wide Web, ICCV},
}
