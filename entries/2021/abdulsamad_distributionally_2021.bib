@misc{abdulsamad_distributionally_2021,
	title = {Distributionally {Robust} {Trajectory} {Optimization} {Under} {Uncertain} {Dynamics} via {Relative}-{Entropy} {Trust} {Regions}},
	shorttitle = {Distributionally {Robust} {Trajectory} {Optimization}},
	url = {https://arxiv.org/abs/2103.15388},
	abstract = {Trajectory optimization is a fundamental tool for robot control. However, its performance is often limited by the accuracy of the underlying dynamics model. While robust control methods can account for model uncertainty, they often lead to overly conservative behavior. In this paper, we propose a distributionally robust trajectory optimization framework that optimizes for the worst-case performance within a set of dynamics models defined by a relative-entropy constraint. This approach allows us to systematically trade off performance and robustness. We derive a trust-region-based optimization algorithm that iteratively updates the trajectory and the uncertainty set. We demonstrate the effectiveness of our approach in simulation and on a real robot, showing that it achieves superior performance compared to standard robust control methods.},
	language = {en},
	urldate = {2024-05-23},
	publisher = {arXiv},
	author = {Abdulsamad, H. and Dorau, T. and Belousov, B. and Zhu, J.-J. and Peters, J.},
	year = {2021},
	keywords = {arXiv},
}
