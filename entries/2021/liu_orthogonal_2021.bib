@inproceedings{liu_orthogonal_2021,
	title = {Orthogonal {Over}-{Parameterized} {Training}},
	shorttitle = {Orthogonal {Over}-{Parameterized} {Training}},
	url = {https://openaccess.thecvf.com/content/CVPR2021/papers/Liu_Orthogonal_Over-Parameterized_Training_CVPR_2021_paper.pdf},
	abstract = {Over-parameterization has been shown to be effective for training deep neural networks. However, it often leads to redundant parameters and unstable training. In this paper, we propose Orthogonal Over-Parameterized Training (OOPT), a novel training framework that encourages the weights of over-parameterized layers to be orthogonal. We show that OOPT can effectively reduce the redundancy of over-parameterized layers and improve the training stability. We also provide a theoretical analysis of the proposed method and demonstrate its effectiveness on various computer vision tasks.},
	language = {en},
	booktitle = {Proceedings of the {IEEE}/{CVF} {Conference} on {Computer} {Vision} and {Pattern} {Recognition} ({CVPR})},
	publisher = {Computer Vision Foundation / IEEE},
	author = {Liu, W. and Lin, R. and Liu, Z. and Rehg, J. and Paull, L. and Xiong, L. and Song, L. and Weller, A.},
	month = jun,
	year = {2021},
	keywords = {CVPR},
}
