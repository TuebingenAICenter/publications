@article{amini_enhancing_2021,
	title = {Enhancing the resolution of the angular orientations of the flow controlling blades on a sustainable house by training an artificial neural network},
	shorttitle = {Enhancing the resolution of the angular orientations},
	url = {https://doi.org/10.1007/s12053-021-09931-6},
	doi = {10.1007/s12053-021-09931-6},
	abstract = {In this study, an artificial neural network (ANN) is trained to enhance the resolution of the angular orientations of the flow controlling blades on a sustainable house. The blades are designed to control the airflow around the building to improve natural ventilation and thermal comfort. The ANN is trained using a dataset generated from computational fluid dynamics (CFD) simulations. The results show that the ANN can accurately predict the optimal angular orientations of the blades for different wind conditions, significantly improving the resolution compared to traditional methods.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Energy Efficiency},
	publisher = {Springer Nature},
	author = {Amini, Kasra and Mehrjou, Arash and Mani, Mahmoud},
	month = feb,
	year = {2021},
	keywords = {Artificial Neural Network, Sustainable Architecture, CFD},
}
