@article{karlinsky_tracking_2021,
	title = {Tracking excess mortality across countries during the {COVID}-19 pandemic with the {World} {Mortality} {Dataset}},
	copyright = {CC BY 4.0},
	issn = {2050-084X},
	shorttitle = {Tracking excess mortality across countries},
	url = {https://elifesciences.org/articles/69336},
	doi = {10.7554/eLife.69336},
	abstract = {The COVID-19 pandemic has caused a large number of deaths, but the true toll is difficult to estimate due to differences in testing and reporting practices across countries. Excess mortality—the number of deaths from all causes above what would be expected under normal conditions—is a more reliable measure of the pandemic's impact. Here, we present the World Mortality Dataset, which includes all-cause mortality data for 103 countries and territories. We show that excess mortality is highly correlated with reported COVID-19 deaths, but that the ratio of excess deaths to reported COVID-19 deaths varies widely across countries. We also find that excess mortality is often higher than reported COVID-19 deaths, suggesting that the pandemic has had a larger impact on mortality than official figures indicate.},
	language = {en},
	urldate = {2024-05-23},
	journal = {eLife},
	publisher = {eLife Sciences Publications, Ltd},
	author = {Karlinsky, Ariel and Kobak, Dmitry},
	month = jun,
	year = {2021},
	keywords = {ELIFE},
}
