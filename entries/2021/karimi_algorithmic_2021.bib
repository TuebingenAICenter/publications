@misc{karimi_algorithmic_2021,
	title = {Algorithmic {Recourse}: from {Counterfactual} {Explanations} to {Interventions}},
	shorttitle = {Algorithmic {Recourse}},
	url = {https://doi.org/10.1145/3442188.3445899},
	doi = {10.1145/3442188.3445899},
	abstract = {As machine learning models are increasingly used to inform decisions in high-stakes domains, there is a growing demand for providing explanations to individuals who are unfavorably affected by these decisions. While counterfactual explanations provide a way to inform individuals about what should have been different for them to receive a favorable decision, they often fail to account for the causal structure of the world. In this paper, we argue that counterfactual explanations are not sufficient to provide actionable recourse. We propose a framework for algorithmic recourse that accounts for the causal relationships between features, and we show that our approach can provide more actionable and realistic recommendations than existing methods. We evaluate our approach on several real-world datasets and show that it can provide recourse that is more likely to be achievable by individuals.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {ACM},
	author = {Karimi, Amir-Hossein and Schölkopf, Bernhard and Valera, Isabel},
	year = {2021},
	keywords = {Counterfactual thinking, Psychological intervention, Set (abstract data type), Computer science, Outcome (game theory), Counterfactual conditional, Focus (optics), Subject (documents), Management science, Risk analysis (engineering), Economics, Psychology, Mathematical economics, Business, Social psychology, FACCT},
}
