@misc{von_kugelgen_algorithmic_2021,
	title = {Algorithmic recourse in partially and fully confounded settings through bounding counterfactual effects},
	url = {https://sites.google.com/view/recourse21/home},
	doi = {10.48550/arxiv.2106.11849},
	abstract = {Algorithmic recourse aims to provide individuals with actionable recommendations to change an unfavorable decision made by an automated system. Existing approaches typically assume that the causal model of the environment is fully known and unconfounded. In this work, we relax these assumptions and study algorithmic recourse in settings where the causal structure is only partially known or where unobserved confounders are present. We propose a framework for bounding counterfactual effects in such settings, which allows us to provide robust recourse recommendations that are valid under a range of possible causal models. We demonstrate the effectiveness of our approach on synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	author = {von Kügelgen, Julius and Agarwal, Nikita and Zeitler, Jakob and Mastouri, Afsaneh and Schölkopf, Bernhard},
	month = jul,
	year = {2021},
	keywords = {Counterfactual thinking, Bounding overwatch, Causal structure, Confounding, Computer science, Outcome (game theory), Causal model, Econometrics, Mathematical optimization, Mathematics, Mathematical economics, Artificial intelligence, Psychology, Statistics, ICML},
}
