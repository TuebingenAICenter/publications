@article{meyen_advancing_2021,
	title = {Advancing {Research} on {Unconscious} {Priming}: {When} can {Scientists} {Claim} an {Indirect} {Task} {Advantage}?},
	issn = {0096-3445},
	shorttitle = {Advancing {Research} on {Unconscious} {Priming}},
	url = {http://tml.cs.uni-tuebingen.de/team/luxburg/publications/MeyenEtal2021.pdf},
	doi = {10.1037/xge0001065},
	abstract = {In research on unconscious priming, the indirect task advantage (ITA) is a common criterion for claiming that a prime was processed unconsciously. The ITA is observed when the effect of a prime is larger in an indirect task (e.g., a categorization task) than in a direct task (e.g., a prime-discrimination task). However, the ITA is often misinterpreted. In this article, we show that the ITA is not a valid indicator of unconscious processing. We demonstrate that the ITA can be observed even if the prime is processed consciously, and that it can be absent even if the prime is processed unconsciously. We discuss the implications of these findings for research on unconscious priming and suggest alternative criteria for claiming unconscious processing.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Journal of Experimental Psychology: General},
	publisher = {American Psychological Association},
	author = {Meyen, Sascha and Zerweck, Iris and Amado, Catarina and von Luxburg, Ulrike and Franz, Volker H.},
	year = {2021},
	keywords = {Unconscious mind, Consciousness, Priming (agriculture), Psychology, Cognitive psychology, Stimulus (psychology), Cognition, Repetition priming, Subliminal stimuli, Social psychology, Neuroscience, Psychoanalysis, Lexical decision task, Fallacy, Epistemology, JEPG},
}
