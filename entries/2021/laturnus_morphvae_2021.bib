@misc{laturnus_morphvae_2021,
	title = {{MorphVAE}: {Generating} {Neural} {Morphologies} from 3D-{Walks} using a {Variational} {Autoencoder} with {Spherical} {Latent} {Space}},
	shorttitle = {{MorphVAE}},
	url = {https://icml.cc/virtual/2021/spotlight/10060},
	doi = {10.48550/arXiv.2106.07468},
	abstract = {The reconstruction and generation of neural morphologies is a fundamental task in computational neuroscience. Current generative models for neural morphologies often rely on complex, domain-specific representations or struggle to capture the global structure of the neurons. Here, we propose MorphVAE, a variational autoencoder that learns a generative model of neural morphologies represented as 3D-walks. We use a spherical latent space to account for the rotational invariance of the data and show that our model can generate realistic neural morphologies that capture the global structure of the neurons. We demonstrate the effectiveness of our approach on a dataset of retinal ganglion cells and show that it outperforms existing methods in terms of reconstruction quality and generative diversity.},
	language = {en},
	type = {{conferencePaper}},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Laturnus, Sophie and Berens, Philipp},
	month = jul,
	year = {2021},
	keywords = {Autoencoder, Space (punctuation), Artificial neural network, Computer science, Statistical physics, Latent variable, Artificial intelligence, Pattern recognition (psychology), Mathematics, Physics, ICML},
}
