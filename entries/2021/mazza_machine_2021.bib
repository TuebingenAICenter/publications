@article{mazza_machine_2021,
	title = {Machine learning time-local generators of open quantum dynamics},
	issn = {2643-1564},
	url = {https://link.aps.org/doi/10.1103/PhysRevResearch.3.023084},
	doi = {10.1103/PhysRevResearch.3.023084},
	abstract = {We present a machine-learning-based approach to reconstruct the time-local generator of the dynamics of an open quantum system from time-series data of observables. The method relies on the representation of the generator in the Lindblad form, where the Hamiltonian and the dissipators are parameterized by neural networks. We demonstrate the performance of our approach by reconstructing the dynamics of a driven-dissipative spin chain and a system of interacting bosons. Our results show that the method is capable of capturing the non-Markovian nature of the dynamics and is robust against noise in the data.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Physical Review Research},
	publisher = {American Physical Society},
	author = {Mazza, Paolo P. and Zietlow, Dominik and Carollo, Federico and Andergassen, Sabine and Martius, Georg and Lesanovsky, Igor},
	month = apr,
	year = {2021},
	keywords = {PRR},
}
