@article{funke_five_2021-2,
	title = {Five points to check when comparing visual representations},
	shorttitle = {Five points to check},
	url = {https://brendel-group.github.io/publication/2021_01_funke/},
	doi = {10.48550/arXiv.2107.05657},
	abstract = {Comparing representations of visual information in biological and artificial systems is a central task in computational neuroscience and machine learning. However, the field lacks a consensus on how to perform such comparisons. We identify five common pitfalls in the comparison of visual representations and provide recommendations for how to avoid them. We hope that this checklist will help to improve the robustness and interpretability of future studies.},
	language = {en},
	urldate = {2024-05-22},
	journal = {NeurIPS 2021 Workshop on Shared Visual Representations in Human and Machine Intelligence},
	publisher = {arXiv},
	author = {Funke, Christina M. and Borowski, Julian and Stosio, Karolina and Brendel, Wieland and Wallis, Thomas S. A. and Bethge, Matthias},
	year = {2021},
	keywords = {ARXIV, NEURIPS},
}
