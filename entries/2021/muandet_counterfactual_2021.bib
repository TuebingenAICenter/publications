@article{muandet_counterfactual_2021,
	title = {Counterfactual {Mean} {Embeddings}},
	issn = {1532-4435},
	url = {https://jmlr.org/papers/v22/20-185.html},
	abstract = {We propose a framework for counterfactual inference based on kernel mean embeddings of distributions. By representing causal mechanisms as conditional mean embeddings, we can perform counterfactual reasoning without assuming a specific parametric form for the structural causal model. Specifically, we show that the counterfactual distribution can be expressed as a transformation of the conditional mean embedding of the outcome given the cause. This approach allows us to estimate counterfactuals from observational data and a limited amount of interventional data, or even from observational data alone under certain assumptions. We provide theoretical guarantees for the consistency of our estimator and demonstrate its effectiveness on several synthetic and real-world datasets.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Journal of Machine Learning Research},
	publisher = {JMLR},
	author = {Muandet, Krikamol and Kanagawa, Motonobu and Saengkyongam, Sorawit and Marukatat, Sanparith},
	year = {2021},
	keywords = {JMLR},
}
