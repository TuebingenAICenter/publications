@article{kummerer_new_2021,
	title = {New enhancements to the {DeepGaze} models for a better understanding of human scanpaths},
	issn = {1534-7362},
	shorttitle = {New enhancements to the {DeepGaze} models},
	url = {https://jov.arvojournals.org/article.aspx?articleid=2777142},
	doi = {10.1167/jov.21.9.2568},
	abstract = {The DeepGaze models have been very successful in predicting human fixation density maps. However, they do not predict scanpaths, i.e., the sequence of fixations. Here, we present two enhancements to the DeepGaze IIE model that allow it to predict scanpaths. First, we introduce a new readout mechanism that allows the model to predict the next fixation based on the current fixation. Second, we introduce a new loss function that encourages the model to predict scanpaths that are similar to human scanpaths. We evaluate our model on the MIT Saliency Benchmark and show that it outperforms the state-of-the-art models in predicting human scanpaths.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Vision},
	publisher = {Association for Research in Vision and Ophthalmology (ARVO)},
	author = {Kümmerer, Matthias and Linardos, Akis and Bethge, Matthias},
	year = {2021},
	keywords = {Fixation (population genetics), Computer science, Artificial intelligence, Deep learning, ENCODE, Artificial neural network, Deep neural networks, Pattern recognition (psychology), Machine learning, Gene, Biology, JOV},
}
