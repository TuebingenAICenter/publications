@misc{sontakke_causal_2021,
	title = {Causal {Curiosity}: {RL} {Agents} {Discovering} {Self}-supervised {Experiments} for {Causal} {Representation} {Learning}},
	shorttitle = {Causal {Curiosity}},
	url = {https://proceedings.mlr.press/v139/sontakke21a.html},
	doi = {10.48550/arxiv.2010.03110},
	abstract = {We propose a framework for causal representation learning where an agent learns to discover causal structure by performing self-supervised experiments. The agent is equipped with a curiosity-driven reinforcement learning objective that encourages it to perform interventions that maximize information gain about the underlying causal structure of the environment. We show that this approach allows the agent to learn disentangled representations that are robust to distribution shifts and generalize to unseen tasks. We evaluate our method on a variety of causal environments and demonstrate that it outperforms existing self-supervised and reinforcement learning baselines.},
	language = {en},
	publisher = {PMLR},
	author = {Sontakke, Sumedh and Mehrjou, Arash and Itti, Laurent and Schölkopf, Bernhard},
	editor = {Meila, Marina and Zhang, Tong},
	month = jul,
	year = {2021},
	keywords = {Curiosity, Categorization, Computer science, Lift (data mining), Artificial intelligence, Representation (politics), Reinforcement learning, Causal model, Causal structure, Machine learning, Psychology, Social psychology, Mathematics, ICML},
}
