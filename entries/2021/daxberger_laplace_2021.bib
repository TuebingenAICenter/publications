@inproceedings{daxberger_laplace_2021,
	title = {Laplace {Redux} — {Effortless} {Bayesian} {Deep} {Learning}},
	shorttitle = {Laplace {Redux}},
	url = {https://proceedings.neurips.cc/paper/2021/file/a7c9585703d275249f30a088cebba0ad-Paper.pdf},
	doi = {10.48550/arxiv.2106.14806},
	abstract = {Bayesian deep learning is a powerful framework for uncertainty estimation and model selection. However, it is often perceived as computationally expensive and difficult to implement. We present Laplace, a library for the Laplace approximation in deep learning. It provides a simple, modular, and efficient interface to transform pre-trained neural networks into Bayesian models. Laplace is compatible with standard PyTorch workflows and supports various approximations of the Hessian, including Kronecker-factored, diagonal, and full-matrix variants. We demonstrate the effectiveness of our approach on various tasks, including uncertainty estimation, model selection, and continual learning.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 34 ({NeurIPS} 2021)},
	publisher = {Curran Associates, Inc.},
	author = {Daxberger, Erik and Kristiadi, Augustin and Immer, Alexander and Eschenhagen, Runa and Bauer, Matthias and Hennig, Philipp},
	editor = {Ranzato, M. and Beygelzimer, A. and Dauphin, Y. and Liang, P.S. and Wortman Vaughan, J.},
	month = dec,
	year = {2021},
	keywords = {Artificial intelligence, Deep learning, Computer science, Machine learning, Hessian matrix, Bayesian probability, Bayesian optimization, MNIST database, Deep neural networks, Bayes' theorem, Simplicity, Mathematics, Applied mathematics, NEURIPS},
}
