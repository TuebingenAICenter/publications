@inproceedings{mohammadi_scaling_2021,
	title = {Scaling {Guarantees} for {Nearest} {Counterfactual} {Explanations}},
	shorttitle = {Scaling {Guarantees} for {Nearest} {Counterfactual} {Explanations}},
	url = {https://doi.org/10.1145/3461702.3462514},
	doi = {10.1145/3461702.3462514},
	abstract = {Counterfactual explanations are a popular tool for providing recourse to individuals affected by automated decision-making systems. A counterfactual explanation for an individual is a nearest point in the feature space that flips the decision of the model. While finding such points is often formulated as an optimization problem, existing methods lack formal guarantees on the quality of the found counterfactuals, such as their distance to the original input or their validity. In this paper, we propose a framework to provide formal guarantees for nearest counterfactual explanations. We show that for a wide class of models, including deep neural networks, finding the nearest counterfactual is equivalent to solving a constrained optimization problem. We then provide a method to compute the exact nearest counterfactual for a given input, and a method to compute a lower bound on the distance to the nearest counterfactual. We demonstrate the effectiveness of our approach on several real-world datasets and show that it can provide meaningful guarantees for counterfactual explanations.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Proceedings of the 2021 {AAAI}/{ACM} {Conference} on {AI}, {Ethics}, and {Society}},
	publisher = {ACM},
	author = {Mohammadi, K. and Karimi, A.-H. and Barthe, G. and Valera, I.},
	month = may,
	year = {2021},
	keywords = {AIES},
}
