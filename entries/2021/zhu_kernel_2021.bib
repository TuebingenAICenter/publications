@misc{zhu_kernel_2021,
	title = {Kernel {Distributionally} {Robust} {Optimization}: {Generalized} {Duality} {Theorem} and {Stochastic} {Approximation}},
	shorttitle = {Kernel {Distributionally} {Robust} {Optimization}},
	url = {http://proceedings.mlr.press/v130/zhu21a.html},
	abstract = {Distributionally Robust Optimization (DRO) aims to find a decision that performs well under the worst-case distribution within an ambiguity set. In this paper, we consider an ambiguity set defined by a ball of probability distributions centered at a reference distribution, measured by the Maximum Mean Discrepancy (MMD). We derive a generalized duality theorem for this MMD-based DRO problem, which allows us to reformulate the inner maximization problem as a finite-dimensional convex optimization problem. Based on this duality, we propose a stochastic approximation algorithm to solve the DRO problem using only samples from the reference distribution. We provide convergence guarantees for the proposed algorithm and demonstrate its effectiveness on several machine learning tasks.},
	language = {en},
	publisher = {PMLR},
	author = {Zhu, Jia-Jie and Jitkrittum, Wittawat and Diehl, Moritz and Schölkopf, Bernhard},
	editor = {Banerjee, Arindam and Fukumizu, Kenji},
	year = {2021},
	keywords = {Duality (order theory), Kernel (algebra), Mathematical optimization, Mathematics, Stochastic optimization, Applied mathematics, Approximation algorithm, Discrete mathematics, Robust optimization, Computer science, Combinatorics, AISTATS},
}
