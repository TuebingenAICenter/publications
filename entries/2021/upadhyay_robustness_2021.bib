@inproceedings{upadhyay_robustness_2021,
	title = {Robustness via {Uncertainty}-aware {Cycle} {Consistency}},
	shorttitle = {Robustness via {Uncertainty}-aware {Cycle} {Consistency}},
	url = {https://proceedings.neurips.cc/paper/2021/file/ede7e2b6d13a41ddf9f4bdef84fdc737-Paper.pdf},
	doi = {10.48550/arxiv.2110.12467},
	abstract = {Deep learning models are known to be vulnerable to adversarial perturbations. While adversarial training is a common defense, it often comes at the cost of clean accuracy and requires expensive adversarial example generation during training. In this paper, we propose a novel defense mechanism, Uncertainty-aware Cycle Consistency (UCC), which improves model robustness without requiring adversarial training. Our approach leverages the cycle consistency property of data transformations to learn robust representations. We further introduce an uncertainty-aware mechanism that allows the model to selectively rely on consistent transformations, effectively filtering out noisy or adversarial inputs. We demonstrate that our method achieves competitive robustness against various adversarial attacks while maintaining high clean accuracy across multiple benchmarks.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 34},
	publisher = {Curran Associates, Inc.},
	author = {Upadhyay, U. and Chen, Y. and Akata, Z.},
	month = dec,
	year = {2021},
	keywords = {Robustness (evolution), Outlier, Computer science, Artificial intelligence, Probabilistic logic, Gaussian, Pixel, Machine learning, Computer vision, Data mining, Algorithm, Pattern recognition (psychology), NEURIPS},
}
