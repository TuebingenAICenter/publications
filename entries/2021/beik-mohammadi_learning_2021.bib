@inproceedings{beik-mohammadi_learning_2021,
	title = {Learning {Riemannian} {Manifolds} for {Geodesic} {Motion} {Skills}},
	shorttitle = {Learning {Riemannian} {Manifolds} for {Geodesic} {Motion} {Skills}},
	url = {https://www.roboticsproceedings.org/rss17/p082.pdf},
	doi = {10.15607/RSS.2021.XVII.082},
	abstract = {Learning motion skills from demonstrations is a fundamental problem in robotics. Many approaches rely on Euclidean metrics to compute distances between trajectories, which often fails to capture the underlying geometry of the task space. In this paper, we propose a framework to learn a Riemannian manifold from demonstrations, where the geodesic distance reflects the task-specific constraints. We model the metric tensor as a function of the state, which allows us to learn complex, non-linear geometries. We show that our approach can be used to learn motion skills that are robust to perturbations and can generalize to new start and goal configurations. We evaluate our method on a variety of simulated and real-world robotic tasks, demonstrating its effectiveness compared to state-of-the-art methods.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {Robotics: {Science} and {Systems} {XVII}},
	publisher = {Robotics: Science and Systems Foundation},
	author = {Beik-Mohammadi, H. and Hauberg, S. and Arvanitidis, G. and Neumann, G. and Rozo, L.},
	editor = {Shell, Dylan A. and Toussaint, Marc and Hsieh, M. Ani},
	month = jul,
	year = {2021},
	keywords = {RSS},
}
