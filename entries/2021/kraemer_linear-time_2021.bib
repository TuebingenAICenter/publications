@inproceedings{kraemer_linear-time_2021,
	title = {Linear-{Time} {Probabilistic} {Solution} of {Boundary} {Value} {Problems}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2021/hash/5ca3e9b122f61f8f06494c97b1afccf3-Abstract.html},
	doi = {10.48550/arxiv.2106.07761},
	abstract = {Probabilistic numerical methods for differential equations provide a quantification of the uncertainty arising from the discretization of the solution. However, existing methods for boundary value problems (BVPs) typically scale cubically with the number of discretization points, which limits their applicability to high-resolution problems. In this paper, we propose a novel probabilistic solver for linear BVPs that scales linearly with the number of discretization points. We achieve this by formulating the BVP as a Gaussian process regression problem with a structured covariance matrix, which allows for efficient inference using Kalman filtering and smoothing. We demonstrate the performance of our method on a range of BVP benchmarks and show that it provides well-calibrated uncertainty estimates at a fraction of the computational cost of existing methods.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 34},
	publisher = {Curran Associates, Inc.},
	author = {Kraemer, N. and Hennig, P.},
	editor = {Ranzato, M. and Beygelzimer, A. and Dauphin, Y. and Liang, P.S. and Wortman Vaughan, J.},
	month = dec,
	year = {2021},
	keywords = {Probabilistic logic, Computer science, Solver, Mathematical optimization, Markov chain, Boundary value problem, USable, Hyperparameter, Boundary (topology), Probabilistic analysis of algorithms, Algorithm, Applied mathematics, Mathematics, Machine learning, Artificial intelligence, Mathematical analysis, NEURIPS},
}
