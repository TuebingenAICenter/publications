@article{schwab_real-time_2021,
	title = {Real-time {Prediction} of {COVID}-19 related {Mortality} using {Electronic} {Health} {Records}},
	copyright = {© The Author(s) 2021},
	issn = {2041-1723},
	shorttitle = {Real-time {Prediction} of {COVID}-19 related {Mortality}},
	url = {https://www.nature.com/articles/s41467-020-20816-7},
	doi = {10.1038/s41467-020-20816-7},
	abstract = {The COVID-19 pandemic has placed an unprecedented burden on healthcare systems worldwide. To manage this burden, clinicians need tools to identify patients at high risk of mortality early in their hospital stay. Here, we present a machine learning model that predicts the risk of mortality for COVID-19 patients in real-time using electronic health records. We trained our model on a cohort of 299 patients from a hospital in Germany and validated it on a cohort of 1,157 patients from a hospital in Switzerland. Our model achieves an area under the receiver operating characteristic curve (AUROC) of 0.92 (95\% CI 0.88–0.96) for the prediction of mortality. We show that our model can identify patients at high risk of mortality up to 48 hours before the event occurs. Our results suggest that machine learning models can be used to support clinical decision-making in the management of COVID-19 patients.},
	language = {en},
	journal = {Nature Communications},
	publisher = {Nature Portfolio},
	author = {Schwab, Patrick and Mehrjou, Arash and Parbhoo, Sonali and Celi, Leo Anthony and Hetzel, Jürgen and Höfer, Markus and Schölkopf, Bernhard and Bauer, Stefan},
	year = {2021},
	keywords = {Medicine, Case fatality rate, Cohort, Confidence interval, Medical record, Coronavirus disease 2019 (COVID-19), Cohort study, Emergency medicine, Health care, Transmission (telecommunications), Risk assessment, Disease, Intensive care medicine, Internal medicine, Epidemiology, Infectious disease (medical specialty), NCOMMS},
}
