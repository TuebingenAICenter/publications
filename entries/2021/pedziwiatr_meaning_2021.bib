@misc{pedziwiatr_meaning_2021,
	title = {Meaning maps and saliency models based on deep convolutional neural networks are insensitive to image meaning when predicting human fixations},
	shorttitle = {Meaning maps and saliency models},
	url = {https://www.sciencedirect.com/science/article/pii/S0010027720302845},
	doi = {10.1016/j.cognition.2020.104465},
	abstract = {Recent work has suggested that human eye movements are guided by the 'meaning' of a scene, and that this guidance is distinct from low-level image features. This claim has been supported by the success of 'meaning maps'—spatial representations of image meaning—in predicting human fixations. Here, we test whether meaning maps and deep convolutional neural network (DCNN) saliency models are truly sensitive to image meaning. We find that both meaning maps and DCNN models are highly sensitive to low-level image features that are correlated with meaning, but that they are largely insensitive to meaning itself. When we control for low-level features, the predictive power of meaning maps and DCNN models drops significantly. Our results suggest that the apparent success of these models in predicting human fixations is largely driven by their sensitivity to low-level image features, rather than a genuine understanding of image meaning.},
	language = {en},
	type = {{journalArticle}},
	urldate = {2025-05-14},
	publisher = {Elsevier},
	author = {Pedziwiatr, Marek A. and Kümmerer, Matthias and Wallis, Thomas S. A. and Bethge, Matthias and Teufel, Christoph},
	year = {2021},
	keywords = {Meaning (existential), Convolutional neural network, Artificial intelligence, Computer science, Image (mathematics), Pattern recognition (psychology), Natural language processing, Psychology},
}
