@misc{wuthrich_robot_2021,
	title = {A {Robot} {Cluster} for {Reproducible} {Research} in {Dexterous} {Manipulation}},
	shorttitle = {A {Robot} {Cluster} for {Reproducible} {Research} in {Dexterous} {Manipulation}},
	url = {https://arxiv.org/abs/2109.10957},
	abstract = {Reproducibility is a cornerstone of the scientific method. In robotics, however, reproducibility is notoriously difficult to achieve due to the complexity of hardware, the sensitivity of algorithms to environmental conditions, and the lack of standardized experimental setups. To address this, we present a robot cluster for reproducible research in dexterous manipulation. The cluster consists of 10 identical robot setups, each equipped with a high-degree-of-freedom robotic hand and a variety of sensors. We provide a standardized software stack, a set of benchmark tasks, and a cloud-based infrastructure for data collection and experiment management. We demonstrate the utility of the cluster by reproducing several state-of-the-art results in dexterous manipulation and by conducting a large-scale study on the effect of environmental variations on learning performance.},
	language = {en},
	urldate = {2024-05-23},
	publisher = {arXiv},
	author = {Wüthrich, M. and Widmaier, F. and Bauer, S. and Funk, N. and Urain, J. and Peters, J. and Watson, J. and Chen, C. and Srinivasan, K. and Zhang, J. and Zhang, J. and Walter, M. R. and Madan, R. and Schaff, C. and Maeda, T. and Yoneda, T. and Yarats, D. and Allshire, A. and Gordon, E. K. and Bhattacharjee, T. and Srinivasa, S. S. and Garg, A. and Buchholz, A. and Stark, S. and Steinbrenner, T. and Akpo, J. and Joshi, S. and Agrawal, V. and Schölkopf, B.},
	year = {2021},
}
