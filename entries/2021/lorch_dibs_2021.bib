@misc{lorch_dibs_2021,
	title = {{DiBS}: {Differentiable} {Bayesian} {Structure} {Learning}},
	shorttitle = {{DiBS}},
	url = {https://proceedings.neurips.cc/paper/2021/file/ca6ab34959489659f8c3776aaf1f8efd-Paper.pdf},
	doi = {10.3929/ethz-b-000521340},
	abstract = {Learning the structure of Bayesian networks from observational data is a fundamental challenge in machine learning. While score-based structure learning is often formulated as a combinatorial optimization problem, recent advances in continuous constrained optimization have enabled the use of gradient-based methods. However, these approaches typically focus on finding a single maximum a posteriori (MAP) graph, failing to capture the uncertainty inherent in the structure learning process. In this work, we propose Differentiable Bayesian Structure Learning (DiBS), a framework for Bayesian structure learning that leverages differentiable optimization to perform posterior inference over the space of directed acyclic graphs (DAGs). DiBS defines a continuous latent space of graphs and learns a posterior distribution over this space using particle-based variational inference. We demonstrate that DiBS is scalable, achieves state-of-the-art performance in terms of posterior approximation quality, and provides well-calibrated uncertainty estimates.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Lorch, Lars and Rothfuss, Jonas and Schölkopf, Bernhard and Krause, Andreas},
	editor = {Ranzato, M. and Beygelzimer, A. and Dauphin, Y. and Liang, P. S. and Wortman Vaughan, J.},
	year = {2021},
	keywords = {Inference, Bayesian network, Posterior probability, Computer science, Artificial intelligence, Bayesian inference, Differentiable function, Machine learning, Graph, Bayesian probability, Graphical model, Variable-order Bayesian network, Algorithm, Mathematics, Theoretical computer science, NEURIPS},
}
