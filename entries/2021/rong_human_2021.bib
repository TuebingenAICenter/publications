@inproceedings{rong_human_2021,
	title = {Human {Attention} in {Fine}-grained {Classification}},
	shorttitle = {Human {Attention} in {Fine}-grained {Classification}},
	url = {https://www.bmvc2021-virtualconference.com/assets/papers/0421.pdf},
	doi = {10.48550/arxiv.2111.01628},
	abstract = {Fine-grained classification is a challenging task due to the subtle differences between classes. While deep learning models have achieved impressive performance, they often rely on spurious correlations rather than the discriminative features used by humans. In this paper, we investigate the role of human attention in fine-grained classification. We collect a new dataset of human attention maps for fine-grained images and analyze the correlation between human attention and model performance. We further propose a novel attention-based loss function that encourages models to focus on regions that are important for human classification. Our experiments demonstrate that incorporating human attention significantly improves the performance and interpretability of fine-grained classification models.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {32nd {British} {Machine} {Vision} {Conference} ({BMVC})},
	author = {Rong, Y. and Xu, W. and Akata, Z. and Kasneci, E.},
	month = nov,
	year = {2021},
	keywords = {Gaze, Computer science, Artificial intelligence, Deep learning, Process (computing), Machine learning, Data science, BMVC},
}
