@misc{augustin_out-distribution_2021,
	title = {Out-distribution aware {Self}-training in an {Open} {World} {Setting}},
	shorttitle = {Out-distribution aware {Self}-training},
	url = {https://arxiv.org/abs/2012.12372},
	doi = {10.48550/arXiv.2012.12372},
	abstract = {Self-training is a powerful semi-supervised learning technique that has recently been shown to achieve state-of-the-art results on ImageNet. However, standard self-training assumes that the unlabeled data comes from the same distribution as the labeled data. In this paper, we consider the open world setting where the unlabeled data contains samples from classes not present in the labeled set, i.e., out-distribution (OOD) data. We show that standard self-training fails in this setting as the model is forced to assign OOD samples to known classes, which leads to a degradation of performance. We propose a novel self-training framework that is OOD-aware. It uses an OOD detector to identify and reject OOD samples during the self-training process. We demonstrate that our method significantly outperforms standard self-training and other baselines on several datasets in the open world setting.},
	language = {en},
	urldate = {2024-05-23},
	publisher = {arXiv},
	author = {Augustin, Maximilian and Hein, Matthias},
	year = {2021},
	keywords = {Leverage (statistics), Computer science, Labeled data, Artificial intelligence, Machine learning, Classifier (UML), Training set, Task (project management), Semi-supervised learning, Real world data, Data mining, Data science, Engineering, arXiv},
}
