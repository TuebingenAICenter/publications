@misc{lavin_simulation_2021,
	title = {Simulation {Intelligence}: {Towards} a {New} {Generation} of {Scientific} {Methods}},
	shorttitle = {Simulation {Intelligence}},
	url = {https://arxiv.org/abs/2112.03235},
	doi = {10.48550/arxiv.2112.03235},
	abstract = {Scientific discovery is increasingly driven by the integration of simulation and machine learning. We propose a new paradigm, Simulation Intelligence (SI), which leverages the strengths of both: the interpretability and physical grounding of simulations, and the predictive power and efficiency of machine learning. SI aims to accelerate scientific discovery by enabling the automated design, execution, and analysis of simulations, and by facilitating the integration of simulation-based models with experimental data. We discuss the core components of SI, its potential applications across scientific domains, and the challenges that must be addressed to realize its full potential.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Lavin, Alexander and Krakauer, David C. and Zenil, Héctor and Gottschlich, Justin and Mattson, Tim and Brehmer, Johann and Anandkumar, Anima and Choudry, Sanjay and Rocki, Kamil and Baydin, Atılım Güneş and Prunkl, Carina and Paige, Brooks and Isayev, Olexandr and Peterson, Erik and McMahon, Peter L. and Macke, Jakob H. and Cranmer, K. and Zhang, Jiaxin and Wainwright, Haruko and Hanuka, Adi and Veloso, Manuela and Assefa, Samuel and Zheng, Stephan and Pfeffer, Avi},
	month = dec,
	year = {2021},
	keywords = {Computer science, Artificial intelligence, Inference, Data science, Big data, Interdependence, Field (mathematics), Machine learning, Programming paradigm, Profiling (computer programming), Data mining, Programming language},
