@misc{scherrer_learning_2021,
	title = {Learning {Neural} {Causal} {Models} with {Active} {Interventions}},
	url = {https://is.mpg.de/ei/publications/scherrer21},
	doi = {10.48550/arxiv.2109.02429},
	abstract = {Causal discovery from observational data is a notoriously difficult problem, as many causal structures are observationally equivalent. Interventions can help to resolve these ambiguities, but they are often costly or difficult to perform. In this work, we propose a framework for learning causal models that actively selects interventions to efficiently identify the underlying causal structure. We introduce a novel objective function that combines a causal discovery loss with an information-theoretic acquisition function, allowing the model to learn both the causal structure and the optimal intervention policy simultaneously. We demonstrate the effectiveness of our approach on a variety of synthetic and real-world causal discovery tasks, showing that it significantly outperforms existing methods in terms of sample efficiency and accuracy.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {ETH Zurich},
	author = {Scherrer, Nino},
	month = nov,
	year = {2021},
	keywords = {Causal inference, Directed acyclic graph, Computer science, Differentiable function, Inference, Machine learning, Artificial intelligence, Artificial neural network, Causal structure, Identification (biology), Causal model, Process (computing), Observational study, Algorithm, Mathematics, Econometrics},
}
