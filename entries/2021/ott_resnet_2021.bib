@inproceedings{ott_resnet_2021,
	title = {{ResNet} {After} {All}: {Neural} {ODEs} and {Their} {Numerical} {Solution}},
	shorttitle = {{ResNet} {After} {All}},
	url = {https://openreview.net/pdf?id=HxzSxSxLOJZ},
	doi = {10.48550/arxiv.2007.15386},
	abstract = {Neural Ordinary Differential Equations (Neural ODEs) have been proposed as a continuous-depth generalization of residual networks. While they offer elegant theoretical properties, their practical application is often hindered by the computational cost of the numerical solvers required for the forward and backward passes. In this work, we show that the training of Neural ODEs can be interpreted as a specific form of residual network training. We leverage this connection to provide a rigorous analysis of the numerical stability and convergence of Neural ODEs. We demonstrate that standard solvers can be unstable and propose a more robust approach based on adaptive step-size control. Our experiments show that our proposed method leads to significant improvements in both training speed and generalization performance on a variety of benchmarks.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {The {Ninth} {International} {Conference} on {Learning} {Representations} ({ICLR} 2021)},
	author = {Ott, K. and Katiyar, P. and Hennig, P. and Tiemann, M.},
	month = may,
	year = {2021},
	keywords = {Ode, Ordinary differential equation, Solver, Discretization, Computer science, Artificial neural network, Residual, Applied mathematics, Numerical analysis, Algorithm, Field (mathematics), Differential equation, Mathematical optimization, Mathematics, Artificial intelligence, Mathematical analysis, ICLR},
}
