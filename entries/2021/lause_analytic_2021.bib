@misc{lause_analytic_2021,
	title = {Analytic {Pearson} residuals for normalization of single-cell {RNA}-seq {UMI} data},
	copyright = {© The Author(s) 2021},
	shorttitle = {Analytic {Pearson} residuals},
	url = {https://genomebiology.biomedcentral.com/articles/10.1186/s13059-021-02451-7},
	doi = {10.1186/s13059-021-02451-7},
	abstract = {Single-cell RNA-seq data are typically normalized by scaling counts to a fixed library size and log-transforming them. This approach is heuristic and does not account for the heteroscedastic nature of count data. Here, we propose using Pearson residuals from regularized negative binomial regression to normalize UMI count data. This method is analytically tractable, computationally efficient, and effectively removes the dependence of mean expression on sequencing depth while stabilizing the variance. We demonstrate that our approach outperforms standard normalization methods in downstream tasks such as principal component analysis, clustering, and trajectory inference.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {BioMed Central},
	author = {Lause, Jan and Berens, Philipp and Kobak, Dmitry},
	month = sep,
	year = {2021},
	keywords = {Overdispersion, Normalization (sociology), Count data, Statistics, Heteroscedasticity, Mathematics, Poisson distribution, Negative binomial distribution, Computer science},
}
