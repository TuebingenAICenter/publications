@misc{vankadara_recovery_2021,
	title = {Recovery {Guarantees} for {Kernel}-based {Clustering} under {Non}-parametric {Mixture} {Models}},
	shorttitle = {Recovery {Guarantees} for {Kernel}-based {Clustering}},
	url = {http://tml.cs.uni-tuebingen.de/team/luxburg/publications/Vankadara2021.pdf},
	doi = {10.48550/arxiv.2110.09476},
	abstract = {Kernel-based clustering methods such as spectral clustering are widely used in practice. However, theoretical guarantees for these methods are often limited to specific data models like the stochastic block model or Gaussian mixture models. In this paper, we provide recovery guarantees for kernel-based clustering under a general non-parametric mixture model. We show that if the kernel is chosen appropriately, the kernel-based clustering algorithm can recover the underlying clusters with high probability. Our results hold for a wide range of kernels and do not require the clusters to be well-separated in the original space. We also provide a lower bound on the number of samples required for consistent clustering.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Vankadara, Leena and Bordt, Sebastian and von Luxburg, Ulrike and Ghoshdastidar, Debarghya},
	year = {2021},
	keywords = {Cluster analysis, Computer science, Kernel (algebra), Kernel embedding of distributions, Variable kernel density estimation, Data mining, Kernel method, Mathematics, Artificial intelligence, AISTATS},
}
