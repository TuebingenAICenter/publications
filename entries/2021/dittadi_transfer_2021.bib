@misc{dittadi_transfer_2021,
	title = {On the {Transfer} of {Disentangled} {Representations} in {Realistic} {Settings}},
	url = {https://openreview.net/pdf?id=8VXvj1QNRl1},
	doi = {10.48550/arxiv.2010.14407},
	abstract = {Disentangled representations are often hypothesized to be beneficial for downstream tasks, especially in terms of sample efficiency and robustness to distribution shifts. However, empirical evidence for this claim in realistic settings is still limited. In this work, we perform a large-scale study of the transfer performance of disentangled representations across a variety of datasets, models, and tasks. We find that while disentanglement is often correlated with better transfer performance, it is not a sufficient condition for it. Furthermore, we show that simple baselines often perform as well as or better than state-of-the-art disentanglement methods in terms of transfer performance. Our results suggest that the relationship between disentanglement and transfer is more complex than previously thought and that future research should focus on more specific inductive biases for transfer.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {International Conference on Learning Representations},
	author = {Dittadi, Andrea and Träuble, Frederik and Locatello, Francesco and Wüthrich, Manuel and Agrawal, Vaibhav and Winther, Ole and Bauer, Stefan and Schölkopf, Bernhard},
	month = may,
	year = {2021},
	keywords = {Transfer (computing), Computer science, Parallel computing, ICLR},
}
