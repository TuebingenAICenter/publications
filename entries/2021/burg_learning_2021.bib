@misc{burg_learning_2021,
	title = {Learning divisive normalization in primary visual cortex},
	copyright = {CC BY 4.0},
	url = {https://journals.plos.org/ploscompbiol/article?id=10.1371/journal.pcbi.1009028},
	doi = {10.1371/journal.pcbi.1009028},
	abstract = {Divisive normalization is a canonical computation in sensory neuroscience, thought to be a fundamental building block of neural processing. While it has been shown to account for a wide range of phenomena in the visual cortex, it is unclear how such a computation could be learned by a neural circuit. Here, we show that divisive normalization emerges naturally in deep convolutional neural networks trained on natural images to perform object recognition. We find that the normalization parameters learned by these networks are consistent with those observed in the primary visual cortex of macaques. Our results suggest that divisive normalization is an efficient strategy for processing natural images and that it can be learned through experience.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Public Library of Science},
	author = {Burg, Max F. and Cadena, Santiago A. and Denfield, George H. and Walker, Edgar Y. and Tolias, Andreas S. and Bethge, Matthias and Ecker, Alexander S.},
	year = {2021},
	keywords = {Visual cortex, Normalization (sociology), Computer science, Artificial intelligence, Neuroscience, Pattern recognition (psychology), Psychology, Receptive field, Convolutional neural network, Computational model, Nonlinear system, Visual processing, Macaque, Sensory system, Perception},
}
