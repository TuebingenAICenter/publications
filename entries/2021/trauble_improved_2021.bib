@article{trauble_improved_2021,
	title = {An improved equation of state for air plasma simulations},
	issn = {1070-6631},
	shorttitle = {An improved equation of state for air plasma simulations},
	url = {https://doi.org/10.1063/5.0044008},
	doi = {10.1063/5.0044008},
	abstract = {We present an improved equation of state (EOS) for air plasma simulations in the temperature range of 300–30 000 K and pressures up to 1000 atm. The model is based on the minimization of the Gibbs free energy and accounts for the dissociation and ionization of the air species. We compare our results with existing models and experimental data, showing that our EOS provides a more accurate description of the thermodynamic properties of air plasma, particularly in the transition regions between different ionization states. The model is computationally efficient and suitable for use in large-scale computational fluid dynamics simulations.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Physics of Fluids},
	publisher = {AIP Publishing},
	author = {Träuble, F. and Millmore, S. T. and Nikiforakis, N.},
	month = mar,
	year = {2021},
	keywords = {POF},
}
