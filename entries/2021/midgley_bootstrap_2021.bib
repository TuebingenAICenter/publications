@inproceedings{midgley_bootstrap_2021,
	title = {Bootstrap {Your} {Flow}},
	shorttitle = {Bootstrap {Your} {Flow}},
	url = {https://arxiv.org/abs/2111.11510},
	abstract = {Normalizing flows are a powerful class of generative models that learn a transformation from a simple base distribution to a complex target distribution. However, they are often limited by the choice of the base distribution and the expressivity of the transformation. In this work, we propose a novel method to improve the performance of normalizing flows by bootstrapping the base distribution. We show that our method can be applied to a variety of flow-based models and leads to improved performance on several density estimation tasks.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {1st {ELLIS} {Machine} {Learning} for {Molecule} {Discovery} {Workshop}},
	author = {Midgley, L. I. and Stimper, V. and Simm, G. N. C. and Hernández-Lobato, J. M.},
	month = dec,
	year = {2021},
}
