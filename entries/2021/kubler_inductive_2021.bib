@misc{kubler_inductive_2021,
	title = {The {Inductive} {Bias} of {Quantum} {Kernels}},
	url = {https://proceedings.neurips.cc/paper/2021/file/69adc1e107f7f7d035d7baf04342e1ca-Paper.pdf},
	doi = {10.48550/arxiv.2106.03747},
	abstract = {Quantum machine learning models are often motivated by the hope that they can learn patterns that are hard to learn for classical models. A central question is therefore to understand the inductive bias of quantum models, i.e., the assumptions they make about the data to generalize. In this work, we study the inductive bias of quantum kernels, which are defined by the inner product of quantum feature maps. We show that the inductive bias of a quantum kernel is determined by the geometry of the quantum feature map in the Hilbert space. Specifically, we show that quantum kernels can be interpreted as classical kernels on the space of quantum states, and that their inductive bias is related to the ability of the quantum feature map to map data to a low-dimensional subspace of the Hilbert space. We further show that this inductive bias can be beneficial for learning tasks where the data has a specific structure, such as when the data is generated by a quantum process.},
	language = {en},
	publisher = {Curran Associates, Inc.},
	author = {Kübler, Jonas M. and Buchholz, Simon and Schölkopf, Bernhard},
	editor = {Ranzato, M. and Beygelzimer, A. and Dauphin, Y. and Liang, P.S. and Wortman Vaughan, J.},
	month = dec,
	year = {2021},
	keywords = {Reproducing kernel Hilbert space, Quantum, ENCODE, Hilbert space, Quantum algorithm, Computer science, Kernel (algebra), Mathematics, Function (biology), Pure mathematics, Quantum mechanics, Physics, NEURIPS},
}
