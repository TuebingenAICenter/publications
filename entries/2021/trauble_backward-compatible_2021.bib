@misc{trauble_backward-compatible_2021,
	title = {Backward-{Compatible} {Prediction} {Updates}: {A} {Probabilistic} {Approach}},
	shorttitle = {Backward-{Compatible} {Prediction} {Updates}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2021/hash/012d9fe15b2493f21902cd55603382ec-Abstract.html},
	doi = {10.48550/arxiv.2107.01057},
	abstract = {Machine learning models are frequently updated to improve their performance. However, in many real-world applications, such updates can be disruptive if the new model's predictions are inconsistent with the old model's predictions. This is particularly problematic in systems where downstream components rely on the stability of the model's output. We propose a framework for backward-compatible prediction updates that allows for improving the performance of a model while maintaining consistency with the predictions of a legacy model. Our approach is based on a probabilistic formulation that allows us to trade off performance and compatibility. We demonstrate the effectiveness of our approach on several image classification tasks and show that it can significantly improve compatibility without sacrificing performance.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Träuble, Frederik and von Kügelgen, Julius and Kleindessner, Matthäus and Locatello, Francesco and Schölkopf, Bernhard and Gehler, Peter},
	editor = {Ranzato, M. and Beygelzimer, A. and Dauphin, Y. and Liang, P.S. and Wortman Vaughan, J.},
	month = dec,
	year = {2021},
	keywords = {Computer science, Benchmark (surveying), Probabilistic logic, Key (lock), Consistency (knowledge bases), Pace, Set (abstract data type), Downstream (manufacturing), Machine learning, Data mining, Perspective (graphical), Artificial intelligence, NEURIPS},
}
