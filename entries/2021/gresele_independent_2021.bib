@misc{gresele_independent_2021,
	title = {Independent mechanisms analysis, a new concept?},
	shorttitle = {Independent mechanisms analysis, a new concept?},
	url = {https://proceedings.neurips.cc/paper/2021/file/edc27f139c3b4e4bb29d1cdbc45663f9-Paper.pdf},
	doi = {10.48550/arxiv.2106.05200},
	abstract = {The principle of independent mechanisms (IM) is a cornerstone of causal modeling, stating that the causal generative process of a system is composed of autonomous modules that do not inform or influence each other. While this principle has been highly influential in causal discovery, it has not yet been fully leveraged for representation learning. In this work, we propose Independent Mechanisms Analysis (IMA), a framework for learning representations that are composed of independent causal mechanisms. We show that IMA can be formulated as a blind source separation problem where the sources are the independent mechanisms. We provide theoretical identifiability results for IMA, showing that under certain conditions, the underlying causal mechanisms can be recovered from observations. We also propose a practical algorithm for IMA and demonstrate its effectiveness on synthetic and real-world data.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Gresele, Luigi and von Kügelgen, Julius and Stimper, Vincent and Schölkopf, Bernhard and Besserve, Michel},
	editor = {Ranzato, M. and Beygelzimer, A. and Dauphin, Y. and Liang, P.S. and Wortman Vaughan, J.},
	month = dec,
	year = {2021},
	keywords = {Identifiability, Computer science, Independent component analysis, Representation (politics), Latent variable, Independence (probability theory), Generative grammar, Generative model, Blind signal separation, Causality (physics), Mixing (physics), Machine learning, Artificial intelligence, Theoretical computer science, Mathematics, Statistics, NEURIPS},
}
