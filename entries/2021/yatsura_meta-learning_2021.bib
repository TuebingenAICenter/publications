@misc{yatsura_meta-learning_2021,
	title = {Meta-{Learning} the {Search} {Distribution} of {Black}-{Box} {Random} {Search} {Based} {Adversarial} {Attacks}},
	shorttitle = {Meta-{Learning} the {Search} {Distribution}},
	url = {https://arxiv.org/abs/2111.01714},
	doi = {10.48550/arxiv.2111.01714},
	abstract = {Black-box adversarial attacks are a critical tool for evaluating the robustness of machine learning models when the attacker has no access to the model's gradients. Random search based attacks are a popular class of such attacks due to their simplicity and effectiveness. However, they often require a large number of queries to find an adversarial example. In this paper, we propose a meta-learning approach to improve the efficiency of random search based attacks. We learn a search distribution that is adapted to the specific model and input, allowing the attack to focus its search on regions of the input space that are more likely to contain adversarial examples. We demonstrate that our approach significantly reduces the number of queries required to find adversarial examples compared to state-of-the-art black-box attacks on several benchmark datasets.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Yatsura, Maksym and Metzen, Jan Hendrik and Hein, Matthias},
	year = {2021},
	keywords = {Computer science, Robustness (evolution), Black box, White box, Machine learning, Artificial intelligence, Data mining, NEURIPS},
}
