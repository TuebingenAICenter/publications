@misc{werner_informed_2021,
	title = {Informed {Equation} {Learning}},
	shorttitle = {{InformedEQL}},
	url = {https://arxiv.org/abs/2105.06331},
	doi = {10.48550/arxiv.2105.06331},
	abstract = {Symbolic regression aims to find a mathematical expression that fits a given dataset. While modern methods can handle large search spaces, they often struggle with noisy data and require large amounts of data to converge to the correct expression. We propose Informed Equation Learning (InformedEQL), a framework that incorporates domain knowledge into the symbolic regression process. InformedEQL allows for the inclusion of constraints on the structure of the learned equations, such as physical laws or known properties of the system. We demonstrate that InformedEQL can significantly improve the accuracy and interpretability of the learned models, especially in data-scarce or noisy regimes.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Werner, Matthias and Junginger, Andrej and Hennig, Philipp and Martius, Georg},
	year = {2021},
	keywords = {Logarithm, Domain (mathematical analysis), Computer science, Property (philosophy), Limit (mathematics), Artificial intelligence, Simple (philosophy), Feature engineering, Gravitational singularity, Machine learning, Domain knowledge, Applied mathematics, Theoretical computer science, Mathematics, Deep learning, Mathematical analysis},
}
