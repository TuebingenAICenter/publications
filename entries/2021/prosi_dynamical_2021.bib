@misc{prosi_dynamical_2021,
	title = {The dynamical regime and its importance for evolvability, task performance and generalization},
	shorttitle = {The dynamical regime},
	url = {https://doi.org/10.1162/isal_a_00412},
	doi = {10.1162/isal_a_00412},
	abstract = {The dynamical regime of a neural network, often characterized by the sensitivity of its output to small perturbations in the input, is known to influence its learning capabilities. However, the relationship between the dynamical regime and the ability of a network to evolve, perform tasks, and generalize remains poorly understood. Here, we investigate this relationship by evolving recurrent neural networks to perform a variety of tasks. We find that networks evolved in the critical regime, at the edge of chaos, exhibit superior evolvability, task performance, and generalization compared to networks evolved in the ordered or chaotic regimes. Our results suggest that the critical regime provides a favorable landscape for evolution, allowing for the emergence of complex and robust behaviors.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {MIT Press},
	author = {Prosi, Jan and Khajehabdollahi, Sina and Giannakakis, Emmanouil and Martius, Georg and Levina, Anna},
	month = jul,
	year = {2021},
	keywords = {Criticality, Evolvability, Attractor, Computer science, Adaptability, Self-organized criticality, Dynamical systems theory, Initialization, Dissipative system, Resilience (materials science), Statistical physics, Ecology, Mathematics, Biology, Physics, ALIFE},
}
