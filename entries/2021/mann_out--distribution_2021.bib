@article{mann_out--distribution_2021,
	title = {Out-of-distribution generalization of internal models is correlated with reward},
	url = {https://bethgelab.org/publication/2021_01_mann/},
	abstract = {Deep reinforcement learning (RL) agents often fail to generalize to out-of-distribution (OOD) environments. While recent work has focused on improving generalization through data augmentation or architectural changes, the relationship between the internal representations learned by these agents and their generalization performance remains poorly understood. In this work, we investigate the internal models of RL agents trained on a variety of tasks and environments. We find that the OOD generalization performance of these agents is strongly correlated with the reward they receive during training. Furthermore, we show that this correlation is mediated by the quality of the internal representations, which we quantify using a novel measure of representation alignment. Our results suggest that improving the quality of internal representations is a promising avenue for enhancing the OOD generalization of RL agents.},
	language = {en},
	urldate = {2025-05-14},
	journal = {International Conference on Learning Representations},
	author = {Mann, Khushdeep Singh and Schneider, Steffen and Chiappa, Alberto and Lee, Jin Hwa and Bethge, Matthias and Mathis, Alexander and Mathis, Mackenzie},
	year = {2021},
	keywords = {Generalization, Computer science, Distribution (mathematics), Econometrics, Artificial intelligence, Mathematics, ICLR},
}
