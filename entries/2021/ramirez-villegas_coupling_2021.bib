@article{ramirez-villegas_coupling_2021,
	title = {Coupling of hippocampal theta and ripples with pontogeniculooccipital waves},
	shorttitle = {Coupling of hippocampal theta and ripples},
	url = {https://doi.org/10.1038/s41586-020-2914-4},
	doi = {10.1038/s41586-020-2914-4},
	abstract = {The hippocampus is essential for memory consolidation, a process that is thought to rely on the coordination of neuronal activity across distributed brain networks. During rapid eye movement (REM) sleep, hippocampal theta oscillations and sharp-wave ripples are prominent, but their relationship with the brainstem-generated pontogeniculooccipital (PGO) waves—which are considered to be the hallmark of REM sleep—remains poorly understood. Here we show that PGO waves are tightly coupled to hippocampal theta and ripples in the macaque brain. We find that PGO waves are associated with a transient increase in hippocampal theta power and a modulation of ripple occurrence. Furthermore, we demonstrate that PGO waves are associated with a specific sequence of neuronal firing in the hippocampus, which suggests that PGO waves may facilitate the transfer of information between the hippocampus and the neocortex during REM sleep. Our results provide a new framework for understanding the role of PGO waves in memory consolidation and suggest that the coordination of hippocampal and brainstem activity is a fundamental feature of REM sleep.},
	language = {en},
	journal = {Nature},
	publisher = {Nature},
	author = {Ramirez-Villegas, J. and Besserve, M. and Murayama, Y. and Evrard, H. and Oeltermann, A. and Logothetis, N.},
	month = jan,
	year = {2021},
	keywords = {NATURE},
}
