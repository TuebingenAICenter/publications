@article{dumont_schutte_overcoming_2021,
	title = {Overcoming {Barriers} to {Data} {Sharing} with {Medical} {Image} {Generation}: {A} {Comprehensive} {Evaluation}},
	issn = {2398-6352},
	shorttitle = {Overcoming {Barriers} to {Data} {Sharing} with {Medical} {Image} {Generation}},
	url = {https://www.nature.com/articles/s41746-021-00507-3},
	doi = {10.1038/s41746-021-00507-3},
	abstract = {Data sharing in medical imaging is often hindered by privacy concerns and the sensitivity of patient data. Generative models have been proposed as a solution to this problem by creating synthetic data that can be shared without compromising patient privacy. However, the utility and privacy of these synthetic images are often not rigorously evaluated. In this work, we provide a comprehensive evaluation of generative models for medical image synthesis. We evaluate the utility of synthetic images in terms of their visual quality and their usefulness for downstream tasks, such as classification. Furthermore, we assess the privacy of the generated images by evaluating the risk of membership inference attacks. Our results show that while generative models can produce high-quality synthetic images, there is a trade-off between utility and privacy. We provide recommendations for the evaluation of generative models in medical imaging to ensure that synthetic data can be safely and effectively shared.},
	language = {en},
	urldate = {2024-05-22},
	journal = {npj Digital Medicine},
	publisher = {Nature Portfolio},
	author = {DuMont Schütte, A. and Hetzel, J. and Gatidis, S. and Hepp, T. and Dietz, B. and Bauer, S. and Schwab, P.},
	month = sep,
	year = {2021},
	keywords = {NPJ DIGITAL MEDICINE},
}
