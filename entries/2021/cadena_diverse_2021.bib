@article{cadena_diverse_2021,
	title = {A diverse task-driven characterization of early and mid-level representations of the primate ventral stream},
	url = {https://bethgelab.org/publication/2021_01_cadena/},
	abstract = {The primate ventral stream is a hierarchical system of visual areas that process information from simple features to complex objects. While deep convolutional neural networks (CNNs) have been successful in modeling these representations, it remains unclear which specific tasks and architectures best capture the neural responses in early and mid-level visual areas. Here, we perform a large-scale task-driven characterization of the primate ventral stream by training 13 different deep neural network architectures on 10 diverse visual tasks. We evaluate these models on their ability to predict neural responses in primary visual cortex (V1) and area V4 of the macaque. We find that while task performance is a strong predictor of neural response, the specific task and architecture significantly influence the model's ability to capture neural representations. Our results suggest that a diverse set of tasks is necessary to fully characterize the ventral stream and that mid-level representations are particularly sensitive to the task objective.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Computational and Systems Neuroscience Meeting (COSYNE 2021)},
	author = {Cadena, Santiago A. and Willeke, Konstantin and Restivo, K. and Denfield, G. and Walker, E. Y. and Sinz, Fabian and Bethge, Matthias and Tolias, Andreas S. and Ecker, Alexander S.},
	year = {2021},
	keywords = {COSYNE},
}
