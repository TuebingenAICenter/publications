@article{tosatto_upper_2021,
	title = {An {Upper} {Bound} of the {Bias} of {Nadaraya}-{Watson} {Kernel} {Regression} under {Lipschitz} {Assumptions}},
	copyright = {© 2021 by the authors. Licensee MDPI, Basel, Switzerland. This article is an open access article distributed under the terms and conditions of the Creative Commons Attribution (CC BY) license (https://creativecommons.org/licenses/by/4.0/).},
	issn = {2571-905X},
	url = {https://www.mdpi.com/2571-905X/4/1/1},
	doi = {10.3390/stats4010001},
	abstract = {The Nadaraya-Watson estimator is a well-known non-parametric method for regression. While its asymptotic properties are well-studied, finite-sample bounds are often loose or require strong assumptions. In this paper, we derive a new upper bound on the bias of the Nadaraya-Watson estimator under the assumption that the regression function is Lipschitz continuous. We show that this bound is tighter than existing ones and holds for a wide range of kernel functions. We also provide a discussion on the implications of our result for the choice of the bandwidth parameter.},
	language = {en},
	journal = {Stats},
	publisher = {MDPI},
	author = {Tosatto, Samuele and Akrour, Riad and Peters, Jan},
	year = {2021},
	keywords = {STATS},
}
