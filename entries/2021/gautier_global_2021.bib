@article{gautier_global_2021,
	title = {The {Global} {Convergence} of the {Nonlinear} {Power} {Method} for {Mixed}-{Subordinate} {Matrix} {Norms}},
	issn = {0885-7474},
	shorttitle = {The {Global} {Convergence} of the {Nonlinear} {Power} {Method}},
	url = {https://doi.org/10.1007/s10915-021-01524-w},
	doi = {10.1007/s10915-021-01524-w},
	abstract = {The nonlinear power method is a generalization of the classical power method for the computation of the largest eigenvalue and corresponding eigenvector of a matrix. It is used to compute the induced p,q-norm of a matrix, which is a fundamental problem in numerical linear algebra with applications in data analysis, machine learning, and control theory. In this paper, we study the convergence properties of the nonlinear power method for mixed-subordinate matrix norms. We prove that the method converges globally to a stationary point of the objective function for any initial point in the unit sphere. Furthermore, we show that the method converges to a local maximum under mild conditions on the matrix. We also provide a detailed analysis of the convergence rate and illustrate the performance of the method with numerical experiments.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Scientific Computing},
	publisher = {Springer Science and Business Media LLC},
	author = {Gautier, Antoine and Hein, Matthias and Tudisco, Francesco},
	year = {2021},
	keywords = {Iterated function, Mathematics, Convergence (economics), Matrix (chemical analysis), Norm (philosophy), Algorithm, Computation, Applied mathematics, Combinatorics, Mathematical analysis, Chemistry, JSC},
}
