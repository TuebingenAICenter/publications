@article{park_conditional_2021,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Conditional {Distributional} {Treatment} {Effect} with {Kernel} {Conditional} {Mean} {Embeddings} and {U}-{Statistic} {Regression}},
	shorttitle = {Conditional {Distributional} {Treatment} {Effect}},
	url = {https://proceedings.mlr.press/v139/park21c.html},
	abstract = {We propose a novel framework for estimating the conditional distributional treatment effect (CDTE), which captures the full conditional distribution of the treatment effect given covariates. Our approach leverages kernel conditional mean embeddings to represent conditional distributions as elements in a reproducing kernel Hilbert space. We then formulate the estimation of the CDTE as a regression problem in this space, which we solve using U-statistic regression. This allows us to avoid density estimation and to handle complex, non-Gaussian treatment effects. We provide theoretical guarantees for the consistency of our estimator and demonstrate its effectiveness on both synthetic and real-world datasets.},
	language = {en},
	number = {139},
	urldate = {2025-05-14},
	journal = {Proceedings of the 38th International Conference on Machine Learning},
	publisher = {PMLR},
	author = {Park, Junhyung and Shalit, Uri and Schölkopf, Bernhard and Muandet, Krikamol},
	editor = {Meila, Marina and Zhang, Tong},
	month = jul,
	year = {2021},
	keywords = {Statistic, Conditional expectation, Kernel (algebra), Mathematics, Statistics, Conditional probability distribution, Regression, Kernel regression, Test statistic, Conditional probability, Econometrics, Artificial intelligence, Computer science, Pattern recognition (psychology), Statistical hypothesis testing, Combinatorics, ICML},
}
