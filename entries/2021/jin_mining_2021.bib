@article{jin_mining_2021,
	title = {Mining the {Cause} of {Political} {Decision}-{Making} from {Social} {Media}: {A} {Case} {Study} of {COVID}-19 {Policies} across the {US} {States}},
	shorttitle = {Mining the {Cause} of {Political} {Decision}-{Making} from {Social} {Media}},
	url = {https://aclanthology.org/2021.findings-emnlp.27},
	doi = {10.18653/v1/2021.findings-emnlp.27},
	abstract = {Political decision-making is a complex process influenced by many factors. In this paper, we propose a framework to mine the causes of political decision-making from social media. We apply this framework to study the COVID-19 policies across the US states. We find that social media discourse is a strong predictor of political decisions, and that the causal relationship between social media and policy-making is bidirectional. Our results suggest that social media can be used as a tool to understand and predict political decision-making.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Findings of the Association for Computational Linguistics: EMNLP},
	publisher = {Association for Computational Linguistics},
	author = {Jin, Z. and Peng, Z. and Vaidhya, T. and Schölkopf, B. and Mihalcea, R.},
	editor = {Moens, Marie-Francine and Huang, Xuanjing and Specia, Lucia and Yih, Scott Wen-tau},
	month = nov,
	year = {2021},
	keywords = {EMNLP},
}
