@article{kehrer_self-tuning_2021,
	title = {Self-tuning serverless task farming using proactive elasticity control},
	shorttitle = {Self-tuning serverless task farming},
	url = {https://is.mpg.de/al/publications/kehrerzietlowetal2021-serverlesstaskfarming},
	doi = {10.1007/s10586-020-03158-3},
	abstract = {Serverless computing has emerged as a promising paradigm for executing parallel applications in the cloud. However, the inherent limitations of serverless platforms, such as restricted execution time and memory, pose challenges for long-running and resource-intensive tasks. Task farming is a common pattern for parallelizing such workloads, but managing the elasticity of serverless workers is complex. In this paper, we present a self-tuning approach for serverless task farming that employs proactive elasticity control. Our approach dynamically adjusts the number of serverless workers based on the workload characteristics and the performance requirements of the application. We evaluate our approach using a variety of benchmarks and demonstrate that it significantly improves performance and reduces costs compared to static and reactive elasticity strategies.},
	language = {en},
	urldate = {2024-05-23},
	journal = {Cluster Computing},
	publisher = {Springer},
	author = {Kehrer, Stefan and Zietlow, Dominik and Scheffold, Jochen and Blochinger, Wolfgang},
	year = {2021},
	keywords = {serverless, task farming, elasticity},
}
