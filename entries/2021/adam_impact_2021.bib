@article{adam_impact_2021,
	title = {The {Impact} of {Action} {Effects} on {Infants}’ {Predictive} {Gaze} {Shifts} for a {Non}-{Human} {Grasping} {Action} at 7, 11, and 18 {Months}},
	copyright = {CC BY 4.0},
	issn = {1664-1078},
	shorttitle = {The {Impact} of {Action} {Effects} on {Infants}’ {Predictive} {Gaze} {Shifts}},
	url = {https://www.frontiersin.org/article/10.3389/fpsyg.2021.695550},
	doi = {10.3389/fpsyg.2021.695550},
	abstract = {Infants’ ability to predict the outcomes of observed actions is a cornerstone of social cognition. While it is well-established that infants can predict the goals of human actions, it remains unclear whether they can also predict the effects of non-human actions and how this ability develops. In this study, we investigated 7-, 11-, and 18-month-old infants’ predictive gaze shifts toward the effects of a non-human grasping action. Infants observed a robotic claw grasping one of two objects, which then produced a distinct sound effect. We found that 18-month-olds, but not 7- or 11-month-olds, showed predictive gaze shifts toward the object that was about to be grasped, suggesting that the ability to predict the effects of non-human actions emerges between 11 and 18 months of age. These findings provide new insights into the development of action understanding and the role of action effects in infants’ predictive processing.},
	language = {en},
	journal = {Frontiers in Psychology},
	publisher = {Frontiers Media S.A.},
	author = {Adam, Maurits and Gumbsch, Christian and Butz, Martin V. and Elsner, Birgit},
	year = {2021},
	keywords = {FRONTIERS},
}
