@article{scholkopf_toward_2021,
	title = {Toward {Causal} {Representation} {Learning}},
	issn = {0018-9219},
	shorttitle = {Toward {Causal} {Representation} {Learning}},
	url = {https://ieeexplore.ieee.org/stamp/stamp.jsp?arnumber=9363924},
	doi = {10.1109/JPROC.2021.3058954},
	abstract = {Machine learning has made tremendous progress in finding statistical patterns in large-scale data. However, current methods often fail to generalize to new environments or to provide causal explanations. We argue that the next step in the evolution of machine learning is to move from statistical to causal models. We propose a framework for causal representation learning, which aims to discover the causal variables and their relationships from raw data. We discuss the challenges and opportunities in this field, and we outline a research agenda for the coming years.},
	language = {en},
	urldate = {2024-05-23},
	journal = {Proceedings of the IEEE},
	publisher = {IEEE},
	author = {Schölkopf, Bernhard and Locatello, Francesco and Bauer, Stefan and Ke, Nan Rosemary and Kalchbrenner, Nal and Goyal, Anirudh and Bengio, Yoshua},
	year = {2021},
	keywords = {Representation (politics), Computer science, Cognitive science, Artificial intelligence, Cognitive psychology, Psychology, Political science, Spurious relationship, Identifiability, Invariant (physics), Machine learning, Pointwise, Nonlinear system, Feature learning, Mathematics, PIEEE},
}
