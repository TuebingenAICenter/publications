@misc{wuthrich_regret_2021,
	title = {Regret {Bounds} for {Gaussian}-{Process} {Optimization} in {Large} {Domains}},
	shorttitle = {Regret {Bounds} for {Gaussian}-{Process} {Optimization}},
	url = {https://proceedings.neurips.cc/paper/2021/file/3cec07e9ba5f5bb252d13f5f431e4bbb-Paper.pdf},
	doi = {10.48550/arxiv.2104.14113},
	abstract = {Gaussian process (GP) optimization is a popular framework for global optimization of expensive-to-evaluate functions. While standard regret bounds for GP optimization depend on the size of the domain, many practical applications involve large or even continuous domains. In this paper, we provide new regret bounds for GP optimization that are independent of the domain size. We achieve this by leveraging the smoothness of the GP sample paths, which we characterize using the Lipschitz constant of the GP. Our bounds are based on a novel analysis of the GP posterior variance, which we show can be bounded by a term that depends only on the smoothness of the kernel and the number of observations. We demonstrate the effectiveness of our bounds on several synthetic and real-world optimization problems.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Wüthrich, Manuel and Schölkopf, Bernhard and Krause, Andreas},
	editor = {Ranzato, M. and Beygelzimer, A. and Dauphin, Y. and Liang, P.S. and Wortman Vaughan, J.},
	month = dec,
	year = {2021},
	keywords = {Regret, Mathematics, Cardinality (data modeling), Upper and lower bounds, Function (biology), Mathematical optimization, Lipschitz continuity, Domain (mathematical analysis), Covariance, Gaussian, Constant (computer programming), Gaussian process, Bellman equation, Bayesian optimization, Applied mathematics, Computer science, Statistics, Mathematical analysis, NEURIPS},
}
