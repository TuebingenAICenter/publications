@inproceedings{lutter_value_2021,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Value {Iteration} in {Continuous} {Actions}, {States} and {Time}},
	shorttitle = {Value {Iteration} in {Continuous} {Actions}, {States} and {Time}},
	url = {https://proceedings.mlr.press/v139/lutter21a.html},
	abstract = {Value iteration is a fundamental algorithm for solving Markov decision processes. However, it is typically restricted to discrete state and action spaces. In this paper, we propose a novel value iteration algorithm for continuous state and action spaces. We leverage the Hamilton-Jacobi-Bellman equation to derive a continuous-time value iteration update. By parameterizing the value function and the policy with neural networks, we can solve the resulting optimization problem efficiently. We demonstrate the effectiveness of our approach on several continuous control tasks, showing that it outperforms existing methods in terms of sample efficiency and final performance.},
	language = {en},
	booktitle = {Proceedings of 38th {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Lutter, M. and Mannor, S. and Peters, J. and Fox, D. and Garg, A.},
	editor = {Meila, Marina and Zhang, Tong},
	month = jul,
	year = {2021},
	keywords = {ICML},
}
