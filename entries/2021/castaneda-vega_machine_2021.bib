@article{castaneda-vega_machine_2021,
	title = {Machine learning identifies stroke features between species},
	copyright = {© Ivyspring International Publisher},
	issn = {1838-7640},
	shorttitle = {Machine learning identifies stroke features between species},
	url = {https://www.thno.org/v11p3017.htm},
	doi = {10.7150/thno.51887},
	abstract = {Translational research in stroke is hampered by the lack of reliable biomarkers that can be compared between preclinical models and patients. We aimed to identify common stroke features between mice and humans using machine learning (ML) on longitudinal PET imaging data. Methods: We performed longitudinal [18F]DPA-752 PET imaging in a mouse model of transient middle cerebral artery occlusion (tMCAO) and in stroke patients. We developed a ML pipeline to classify stroke-affected versus healthy tissue based on PET intensity profiles. We then evaluated the cross-species transferability of the ML models. Results: The ML models achieved high classification accuracy in both species (AUC 0.9). We identified a common signature of stroke-affected tissue characterized by increased [18F]DPA-752 uptake, which was consistent between mice and humans. The cross-species transferability was successful, as models trained on mouse data could classify human stroke lesions and vice versa. Conclusion: Our results demonstrate that ML can identify common stroke features between species using PET imaging, providing a promising tool for translational stroke research.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Theranostics},
	publisher = {Ivyspring International Publisher},
	author = {Castaneda-Vega, S. and Katiyar, P. and Russo, F. and Patzwaldt, K. and Schnabel, L. and Mathes, S. and Hempel, J.-M. and Kohlhofer, U. and Gonzalez-Menendez, I. and Quintanilla-Martinez, L. and Ziemann, U. and la Fougere, C. and Ernemann, U. and Pichler, B. J. and Disselhorst, J. A. and Poli, S.},
	year = {2021},
	keywords = {Stroke, Machine Learning, PET Imaging, Translational Research},
}
