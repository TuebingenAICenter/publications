@misc{pintor_fast_2021,
	title = {Fast {Minimum}-norm {Adversarial} {Attacks} through {Adaptive} {Norm} {Constraints}},
	shorttitle = {Fast {Minimum}-norm {Adversarial} {Attacks}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2021/hash/a709909b1ea5c2bee24248203b1728a5-Abstract.html},
	doi = {10.48550/arxiv.2102.12827},
	abstract = {Adversarial attacks are typically formulated as constrained optimization problems, where the goal is to find the minimum perturbation that changes the model's prediction. While several methods have been proposed to solve this problem, they often rely on fixed-norm constraints (e.g., L2 or L-infinity) or require expensive hyperparameter tuning to find the minimum-norm perturbation. In this paper, we propose a new approach to generate minimum-norm adversarial attacks by adaptively adjusting the norm constraint during the optimization process. Our method, which we call Adaptive Norm Constraint (ANC) attack, is computationally efficient and does not require prior knowledge of the target norm. We demonstrate that ANC can find smaller perturbations than state-of-the-art methods on several benchmark datasets and models, while being significantly faster.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Pintor, Maura and Roli, Fabio and Brendel, Wieland and Biggio, Battista},
	year = {2021},
	keywords = {Hyperparameter, Adversarial system, Norm (philosophy), Perturbation (astronomy), Computation, Computer science, Sample complexity, Mathematical optimization, Mathematics, Algorithm, Artificial intelligence, Physics, NEURIPS},
}
