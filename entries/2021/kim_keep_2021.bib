@inproceedings{kim_keep_2021,
	title = {Keep {CALM} and {Improve} {Visual} {Feature} {Attribution}},
	shorttitle = {Keep {CALM}},
	url = {https://is.mpg.de/ei/publications/kimchoakaoh21},
	doi = {10.1109/ICCV48922.2021.00824},
	abstract = {Visual feature attribution methods aim to explain model predictions by highlighting important input features. While many methods have been proposed, they often suffer from noise and lack of faithfulness. In this paper, we propose CALM (Class-specific Attribution with Localized Masking), a novel attribution method that improves the faithfulness of feature attribution. CALM leverages class-specific information to generate more accurate and localized attributions. We demonstrate the effectiveness of our method on various benchmarks, showing that it outperforms existing state-of-the-art methods in terms of faithfulness and visual quality.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {International {Conference} on {Computer} {Vision} ({ICCV})},
	publisher = {IEEE},
	author = {Kim, J. M. and Choe, J. and Akata, Z. and Oh, S. J.},
	month = oct,
	year = {2021},
	keywords = {Discriminative model, Computer science, Artificial intelligence, Attribution, Graph, Class (philosophy), Feature (linguistics), Pattern recognition (psychology), Machine learning, Psychology, Theoretical computer science, ICCV},
}
