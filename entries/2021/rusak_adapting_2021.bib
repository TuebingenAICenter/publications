@misc{rusak_adapting_2021,
	title = {Adapting {ImageNet}-scale models to complex distribution shifts with self-learning},
	shorttitle = {Adapting {ImageNet}-scale models},
	url = {https://brendel-group.github.io/publication/2021_04_rusak/},
	doi = {10.1109/ICCV48922.2021.00995},
	abstract = {Deep neural networks are known to be brittle to distribution shifts. While many methods have been proposed to improve robustness, they often require access to the target distribution during training or are limited to simple synthetic corruptions. In this paper, we propose a self-learning approach to adapt ImageNet-scale models to complex, real-world distribution shifts without access to labels or the target distribution during training. Our method, which we call Self-Learning Adaptation (SLA), leverages the model's own predictions on the target distribution to iteratively refine its representations. We show that SLA significantly improves robustness to a wide range of distribution shifts, including natural corruptions, style changes, and domain shifts, while maintaining high performance on the original ImageNet validation set. We further demonstrate that SLA is complementary to existing robustness techniques and can be used to boost their performance.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {IEEE},
	author = {Rusak, Evgenia and Schneider, Steffen and Gehler, Peter and Bringmann, Oliver and Brendel, Wieland and Bethge, Matthias},
	year = {2021},
	keywords = {Robustness (evolution), Robustification, Computer science, Machine learning, Artificial intelligence, Domain adaptation, Benchmark (surveying), Adaptation (eye), Hyperparameter, Entropy (arrow of time), Range (aeronautics), Simple (philosophy), Minification, ICLR, ICCV},
}
