@inproceedings{paulus_rao-blackwellizing_2021,
	title = {Rao-{Blackwellizing} the {Straight}-{Through} {Gumbel}-{Softmax} {Gradient} {Estimator}},
	shorttitle = {Rao-{Blackwellizing} the {Straight}-{Through} {Gumbel}-{Softmax} {Gradient} {Estimator}},
	url = {https://openreview.net/pdf?id=Mk6PZtgAgfq},
	abstract = {The Gumbel-Softmax estimator is a popular tool for learning in models with discrete latent variables. It relies on a continuous relaxation of the categorical distribution, which is often combined with a straight-through (ST) estimator to obtain discrete samples during the forward pass. While the ST estimator is computationally efficient and easy to implement, it is known to be biased. In this paper, we propose a Rao-Blackwellized version of the ST estimator. We show that our estimator is a lower-variance unbiased estimator of the gradient of the relaxed objective, and that it can be computed with little additional overhead. We demonstrate the effectiveness of our approach on a variety of tasks, including discrete variational autoencoders and structured prediction.},
	language = {en},
	booktitle = {The {Ninth} {International} {Conference} on {Learning} {Representations}},
	author = {Paulus, Max B. and Maddison, Chris J. and Krause, Andreas},
	month = may,
	year = {2021},
	keywords = {ICLR},
}
