@inproceedings{schneider_cockpit_2021,
	title = {Cockpit: {A} {Practical} {Debugging} {Tool} for the {Training} of {Deep} {Neural} {Networks}},
	shorttitle = {Cockpit},
	url = {https://proceedings.neurips.cc/paper/2021/file/ae3539867aaeec609a4260c6feb725f4-Paper.pdf},
	doi = {10.48550/arxiv.2102.06604},
	abstract = {Training deep neural networks is notoriously difficult. Practitioners often rely on trial and error, intuition, and a handful of scalar metrics like the training loss or accuracy to monitor the optimization process. This is insufficient for diagnosing why training fails or how it can be improved. We introduce Cockpit, a tool that provides practitioners with a rich set of visual and quantitative insights into the training process. Cockpit is designed to be practical: it is easy to use, integrates into existing PyTorch workflows, and is computationally efficient. We demonstrate its utility by diagnosing common training pathologies and by providing insights into the optimization dynamics of deep learning models.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 34},
	publisher = {Curran Associates, Inc.},
	author = {Schneider, F. and Dangel, F. and Hennig, P.},
	editor = {Ranzato, M. and Beygelzimer, A. and Dauphin, Y. and Liang, P.S. and Wortman Vaughan, J.},
	month = dec,
	year = {2021},
	keywords = {Debugging, Troubleshooting, Computer science, Cockpit, Deep learning, Leverage (statistics), Artificial intelligence, Machine learning, Heuristics, Artificial neural network, Process (computing), Software, Software engineering, Identification (biology), Usability, Human–computer interaction, Programming language, Operating system, Engineering, NEURIPS},
}
