@inproceedings{biggio_neural_2021,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Neural {Symbolic} {Regression} that {Scales}},
	shorttitle = {Neural {Symbolic} {Regression} that {Scales}},
	url = {https://proceedings.mlr.press/v139/biggio21a.html},
	abstract = {Symbolic regression is the task of finding a mathematical expression that best fits a given dataset. While it is a powerful tool for scientific discovery, existing methods often struggle to scale to high-dimensional data or complex expressions. We propose a novel approach that combines neural networks with symbolic regression to overcome these limitations. Our method, which we call Neural Symbolic Regression that Scales (NSRS), uses a neural network to learn a distribution over symbolic expressions, which is then optimized using reinforcement learning. We demonstrate that NSRS can scale to high-dimensional problems and discover complex expressions that are beyond the reach of existing methods.},
	language = {en},
	booktitle = {Proceedings of 38th {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Biggio, Luca and Bendinelli, Tommaso and Neitz, Alexander and Lucchi, Aurelien and Parascandolo, Giambattista},
	editor = {Meila, Marina and Zhang, Tong},
	month = jul,
	year = {2021},
	keywords = {ICML},
}
