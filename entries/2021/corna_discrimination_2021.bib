@article{corna_discrimination_2021,
	title = {Discrimination of simple objects decoded from the output of retinal ganglion cells upon sinusoidal electrical stimulation},
	copyright = {© 2021 IOP Publishing Ltd},
	issn = {1741-2552},
	shorttitle = {Discrimination of simple objects decoded from the output of retinal ganglion cells},
	url = {https://doi.org/10.1088/1741-2552/ac0679},
	doi = {10.1088/1741-2552/ac0679},
	abstract = {Retinal implants aim to restore vision by electrically stimulating retinal ganglion cells (RGCs). However, the spatial resolution of current devices is limited by the broad activation of RGCs. Here, we investigate whether sinusoidal electrical stimulation can improve the discrimination of simple objects. We recorded the activity of RGCs in the isolated mouse retina using high-density microelectrode arrays. We show that sinusoidal stimulation at different frequencies and phases can be used to encode information about the shape and position of simple objects. We decoded the identity of these objects from the RGC population activity using a linear classifier. Our results demonstrate that sinusoidal stimulation can improve the discrimination of simple objects compared to standard pulse-based stimulation, suggesting that temporal modulation of electrical stimulation could enhance the performance of retinal prostheses.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Journal of Neural Engineering},
	publisher = {IOP Publishing},
	author = {Corna, A. and Ramesh, P. and Jetter, F. and Lee, M.-J. and Macke, J. H. and Zeck, G.},
	month = jun,
	year = {2021},
	keywords = {Stimulation, Retina, Phosphene, Stimulus (psychology), Pulsatile flow, Neuroscience, Multielectrode array, Microelectrode, Neuroprosthetics, Photic Stimulation, Visual prosthesis, Retinal, Retinal ganglion cell, Computer science, Biomedical engineering, Artificial intelligence, Visual perception, Physics, Biology, Medicine, Electrode, Perception, Psychology, JNE},
}
