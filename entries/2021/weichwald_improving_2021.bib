@article{weichwald_improving_2021,
	title = {Improving 1-year mortality prediction in {ACS} patients using machine learning},
	issn = {2048-8726},
	shorttitle = {Improving 1-year mortality prediction in {ACS} patients},
	url = {https://academic.oup.com/ehjacc/article/10/8/855/6312636},
	doi = {10.1093/ehjacc/zuab030},
	abstract = {Aims: Risk stratification in patients with acute coronary syndromes (ACS) is essential for clinical decision-making. We aimed to improve 1-year mortality prediction in ACS patients by applying machine learning (ML) to a comprehensive set of clinical and laboratory variables. Methods and results: We included 1945 patients with ACS from the SPUM-ACS cohort. We compared the performance of a random forest (RF) model with the Global Registry of Acute Coronary Events (GRACE) score for predicting 1-year all-cause mortality. The RF model was trained on 128 clinical and laboratory variables, including novel biomarkers. The primary outcome was 1-year all-cause mortality. The RF model achieved an area under the receiver operating characteristic curve (AUC) of 0.86 (95\% CI 0.81–0.91), which was significantly higher than the GRACE score (AUC 0.78, 95\% CI 0.72–0.84, P 0.001). The RF model also showed superior calibration and clinical utility in decision curve analysis. The most important predictors were age, N-terminal pro-B-type natriuretic peptide, and high-sensitivity cardiac troponin T. Conclusion: Machine learning significantly improves 1-year mortality prediction in ACS patients compared with the established GRACE score. Our findings suggest that integrating a broad range of clinical and laboratory data into ML models can enhance risk stratification in ACS patients.},
	language = {en},
	urldate = {2024-05-22},
	journal = {European Heart Journal. Acute Cardiovascular Care},
	publisher = {Oxford University Press},
	author = {Weichwald, Sebastian and Candreva, Andrea and Burkholz, Regina and Klingenberg, Raban and Räber, Lorenz and Heg, Dik and Manka, Robert and Gencer, Baris and Mach, François and Nanchen, David and Rodondi, Nicolas and Windecker, Stephan and Laaksonen, Reijo and Hazen, Stanley L. and von Eckardstein, Arnold and Ruschitzka, Frank and Lüscher, Thomas F. and Buhmann, Joachim M. and Matter, Christian M.},
	month = oct,
	year = {2021},
	keywords = {EHJACC},
}
