@article{landgraf_reinforcement_2021,
	title = {A {Reinforcement} {Learning} {Approach} to {View} {Planning} for {Automated} {Inspection} {Tasks}},
	copyright = {CC BY 4.0},
	issn = {1424-8220},
	shorttitle = {A {Reinforcement} {Learning} {Approach} to {View} {Planning}},
	url = {https://doi.org/10.3390/s21062030},
	doi = {10.3390/s21062030},
	abstract = {Automated inspection tasks require a sequence of sensor poses to cover the surface of an object completely. This problem is known as the Next-Best-View (NBV) planning problem. While classical approaches rely on geometric heuristics, we propose a reinforcement learning (RL) approach to learn a policy for view planning. We formulate the NBV problem as a Markov decision process and train a deep Q-network to select the next sensor pose. To handle the continuous state and action spaces, we use a discretized representation of the object surface and the sensor poses. We evaluate our approach in simulation on a set of CAD models and compare it to a state-of-the-art heuristic approach. Our results show that the RL agent learns to plan efficient inspection sequences and outperforms the heuristic approach in terms of coverage and path length.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Sensors},
	publisher = {MDPI},
	author = {Landgraf, Christian and Meese, Bernd and Pabst, Michael and Martius, Georg and Huber, Marco F.},
	year = {2021},
	keywords = {Reinforcement learning, Benchmark (surveying), Computer science, Field (mathematics), Robot, Set (abstract data type), Interface (matter), CAD, Artificial intelligence, Software engineering, Engineering drawing, Engineering, Operating system},
}
