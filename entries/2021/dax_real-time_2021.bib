@article{dax_real-time_2021,
	title = {Real-time gravitational wave science with neural posterior estimation},
	issn = {0031-9007},
	shorttitle = {Real-time gravitational wave science},
	url = {https://link.aps.org/doi/10.1103/PhysRevLett.127.241103},
	doi = {10.1103/PhysRevLett.127.241103},
	abstract = {We present a method for gravitational-wave inference based on neural posterior estimation. By training deep neural networks to amortize the cost of Bayesian inference, we can perform parameter estimation for compact binary coalescences in milliseconds, once the network is trained. We demonstrate our method on simulated data from a network of ground-based detectors, showing that it produces accurate posterior distributions that are consistent with those obtained from traditional sampling-based methods. Our approach enables real-time gravitational-wave science, which is crucial for multi-messenger astronomy.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Physical Review Letters},
	publisher = {American Physical Society},
	author = {Dax, Maximilian and Green, Stephen R. and Gair, Jonathan and Macke, Jakob H. and Buonanno, Alessandra and Schölkopf, Bernhard},
	month = dec,
	year = {2021},
	keywords = {PRL},
}
