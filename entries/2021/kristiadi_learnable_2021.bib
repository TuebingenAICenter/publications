@inproceedings{kristiadi_learnable_2021,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Learnable {Uncertainty} under {Laplace} {Approximations}},
	shorttitle = {Learnable {Uncertainty} under {Laplace} {Approximations}},
	url = {https://proceedings.mlr.press/v161/kristiadi21a.html},
	doi = {10.48550/arxiv.2010.02720},
	abstract = {The Laplace approximation is a classic method for Bayesian inference in deep learning. However, it is often criticized for being inaccurate, especially in high-dimensional parameter spaces. We show that this is largely due to the standard practice of using a fixed, often poorly-tuned, prior. We propose to learn the prior's precision parameter by maximizing the marginal likelihood, which is made tractable by the Laplace approximation. This simple change significantly improves the quality of the uncertainty estimates, as measured by calibration and out-of-distribution detection, while maintaining the computational efficiency of the Laplace approximation. We demonstrate the effectiveness of our approach on a variety of tasks, including image classification and regression.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of {Machine} {Learning} {Research}},
	publisher = {AUAI Press},
	author = {Kristiadi, Augustin and Hein, Matthias and Hennig, Philipp},
	editor = {de Campos, Cassio P. and Maathuis, Marloes H. and Quaeghebeur, Erik},
	month = jul,
	year = {2021},
	keywords = {Laplace transform, Laplace's method, Hessian matrix, Formalism (music), Artificial neural network, Laplace's equation, Applied mathematics, Mathematical optimization, Mathematics, Uncertainty quantification, Approximations of π, Computer science, Inverse Laplace transform, Algorithm, Artificial intelligence, Machine learning, Mathematical analysis, Approximations of ΀, UAI},
