@article{loktyushin_mrzero_2021,
	title = {{MRzero} - {Automated} discovery of {MRI} sequences using supervised learning},
	shorttitle = {{MRzero}},
	url = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/mrm.28727},
	doi = {10.1002/mrm.28727},
	abstract = {Purpose: To introduce a framework for the automated discovery of MRI sequences using supervised learning, termed MRzero. Methods: The framework is based on a differentiable simulation of the Bloch equations, which allows for the backpropagation of errors from the image domain to the sequence parameters. This enables the optimization of sequence parameters using gradient-based methods. We demonstrate the framework by optimizing sequences for T1 and T2 mapping, as well as for fast imaging. Results: The optimized sequences show improved performance compared to standard sequences in terms of image quality and acquisition time. The framework is flexible and can be applied to a wide range of MRI applications. Conclusion: MRzero provides a powerful tool for the automated design of MRI sequences, potentially accelerating the development of new imaging techniques.},
	language = {en},
	journal = {Magnetic Resonance in Medicine},
	publisher = {Wiley},
	author = {Loktyushin, Alexander and Herz, Kai and Dang, Nam and Glang, Felix and Deshmane, Anish and Weinmüller, Stephan and Doerfler, Arnd and Schölkopf, Bernhard and Scheffler, Klaus and Zaiss, Moritz},
	year = {2021},
	keywords = {Computer science, Artificial intelligence, Artificial neural network, Sequence (biology), Pattern recognition (psychology), Function (biology), Algorithm, Computer vision, MRM},
}
