@misc{zimmermann_how_2021,
	title = {How {Well} do {Feature} {Visualizations} {Support} {Causal} {Understanding} of {CNN} {Activations}?},
	shorttitle = {How {Well} do {Feature} {Visualizations} {Support} {Causal} {Understanding}?},
	url = {https://proceedings.neurips.cc/paper/2021/hash/618faa1728eb2ef6e3733645273ab145-Abstract.html},
	doi = {10.48550/arxiv.2106.12447},
	abstract = {Feature visualization is a popular technique for interpreting convolutional neural networks (CNNs). It aims to provide human-understandable insights into what a neuron or layer has learned by generating an input image that maximizes the corresponding activation. However, it remains unclear whether these visualizations actually support a causal understanding of the network's internal representations. In this work, we propose a psychophysical framework to test this hypothesis. We conduct a series of experiments where human participants are asked to predict the effect of specific image manipulations on the activation of a target neuron, both with and without the help of feature visualizations. We find that feature visualizations do not significantly improve human performance in predicting the causal effect of image manipulations on neuron activations. Our results suggest that current feature visualization techniques may be less effective for causal understanding than commonly assumed, and highlight the need for more rigorous evaluation of interpretability methods.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Zimmermann, Roland S. and Borowski, Judy and Geirhos, Robert and Bethge, Matthias and Wallis, Thomas S. A. and Brendel, Wieland},
	year = {2021},
	keywords = {Interpretability, Computer science, Convolutional neural network, Feature (linguistics), Visualization, Artificial intelligence, Maximization, Task (project management), Machine learning, Pattern recognition (psychology), Human–computer interaction, Psychology, NEURIPS},
}
