@article{kart_deep_2021,
	title = {Deep {Learning}-{Based} {Automated} {Abdominal} {Organ} {Segmentation} in the {UK} {Biobank} and {German} {National} {Cohort} {Magnetic} {Resonance} {Imaging} {Studies}},
	issn = {0020-9996},
	shorttitle = {Deep {Learning}-{Based} {Automated} {Abdominal} {Organ} {Segmentation}},
	url = {https://is.mpg.de/ei/publications/kartetal21},
	doi = {10.1097/RLI.0000000000000755},
	abstract = {Objectives: To develop and validate a deep learning-based framework for automated segmentation of abdominal organs in large-scale magnetic resonance imaging (MRI) studies. Materials and Methods: We developed a deep learning-based framework for the automated segmentation of 6 abdominal organs (liver, spleen, right kidney, left kidney, gallbladder, and pancreas) in abdominal MRI. The framework was trained on a multi-institutional dataset of 100 manually annotated abdominal MRI scans. We evaluated the performance of the framework on 2 independent test sets: 100 scans from the UK Biobank and 100 scans from the German National Cohort. Results: The proposed framework achieved high segmentation accuracy for all organs, with Dice similarity coefficients ranging from 0.82 to 0.96. The segmentation performance was consistent across both the UK Biobank and the German National Cohort datasets. Conclusion: The developed deep learning-based framework enables accurate and automated segmentation of abdominal organs in large-scale MRI studies, facilitating large-scale quantitative analysis of abdominal organ morphology.},
	language = {en},
	urldate = {2024-05-23},
	journal = {Investigative Radiology},
	publisher = {Lippincott Williams \& Wilkins},
	author = {Kart, T. and Fischer, M. and Küstner, T. and Hepp, T. and Bamberg, F. and Winzeck, S. and Glocker, B. and Rueckert, D. and Gatidis, S.},
	month = jun,
	year = {2021},
}
