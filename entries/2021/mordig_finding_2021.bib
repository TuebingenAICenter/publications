@misc{mordig_finding_2021,
	title = {Finding {Stable} {Matchings} in {PhD} {Markets} with {Consistent} {Preferences} and {Cooperative} {Partners}},
	shorttitle = {Finding {Stable} {Matchings} in {PhD} {Markets}},
	url = {https://arxiv.org/abs/2102.11834},
	doi = {10.48550/arXiv.2102.11834},
	abstract = {We study the problem of finding stable matchings in PhD markets, where students and supervisors have preferences over each other. In many such markets, preferences are not arbitrary but exhibit a degree of consistency. We introduce a model of consistent preferences and show that, under this model, the set of stable matchings can be found efficiently. We also consider the case where partners can cooperate to improve their outcomes and show that this can lead to more stable matchings. Our results provide a theoretical foundation for understanding the dynamics of PhD markets and suggest strategies for improving the matching process.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Mordig, Maximilian and Della Vecchia, Riccardo and Cesa-Bianchi, Nicolo and Scholkopf, Bernhard},
	year = {2021},
	keywords = {Matching (statistics), Extension (predicate logic), Computer science, Stable marriage problem, Lexicographical order, Work (physics), Optimal matching, Contrast (vision), Mathematical economics, Microeconomics, Economics, Mathematics, Combinatorics, Artificial intelligence, Engineering, Programming language, Business, Statistics},
}
