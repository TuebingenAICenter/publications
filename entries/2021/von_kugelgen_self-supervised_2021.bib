@misc{von_kugelgen_self-supervised_2021,
	title = {Self-supervised learning with data augmentations provably isolates content from style},
	shorttitle = {Self-supervised learning with data augmentations provably isolates content from style},
	url = {https://proceedings.neurips.cc/paper/2021/file/8929c70f8d710e412d38da624b21c3c8-Paper.pdf},
	doi = {10.48550/arxiv.2106.04619},
	abstract = {Self-supervised learning (SSL) with data augmentations has recently achieved remarkable success in learning representations. However, the theoretical underpinnings of why these methods work remain poorly understood. In this paper, we propose a generative model for data augmentations and show that, under this model, contrastive learning and other SSL methods can provably identify the underlying factors of variation. Specifically, we show that SSL learns to separate 'content' (the information shared across augmentations) from 'style' (the information specific to an augmentation). We provide a theoretical framework that explains how the choice of data augmentations determines which features are learned, and we validate our theoretical findings with experiments on synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {von Kügelgen, Julius and Sharma, Yash and Gresele, Luigi and Brendel, Wieland and Schölkopf, Bernhard and Besserve, Michel and Locatello, Francesco},
	editor = {Ranzato, M. and Beygelzimer, A. and Dauphin, Y. and Liang, P.S. and Wortman Vaughan, J.},
	month = dec,
	year = {2021},
	keywords = {Latent variable, Discriminative model, Identifiability, Computer science, Generative model, Invariant (physics), Feature learning, Representation (politics), Latent variable model, Artificial intelligence, Component (thermodynamics), Machine learning, Invertible matrix, Observer (physics), Generative grammar, Theoretical computer science, Mathematics, NEURIPS},
}
