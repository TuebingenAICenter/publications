@misc{prabhoo_ncore_2021,
	title = {{NCoRE}: {Neural} {Counterfactual} {Representation} {Learning} for {Combinations} of {Treatments}},
	shorttitle = {{NCoRE}},
	url = {https://arxiv.org/abs/2103.11175},
	abstract = {Estimating the causal effect of multiple treatments is a fundamental problem in many fields, including medicine and policy-making. While existing methods for causal inference often focus on a single treatment, real-world scenarios frequently involve combinations of treatments. In this paper, we propose NCoRE, a novel framework for counterfactual representation learning that is specifically designed to handle combinations of treatments. NCoRE learns a shared representation that captures the underlying structure of the data while accounting for the dependencies between treatments. We demonstrate the effectiveness of our approach on both synthetic and real-world datasets, showing that it outperforms existing methods in estimating the causal effects of treatment combinations.},
	language = {en},
	urldate = {2024-05-23},
	publisher = {arXiv},
	author = {Prabhoo, S. and Bauer, S. and Schwab, P.},
	year = {2021},
	keywords = {arXiv},
}
