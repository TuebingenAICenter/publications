@misc{croce_mind_2021,
	title = {Mind the box: l1-{APGD} for sparse adversarial attacks on image classifiers},
	shorttitle = {Mind the box},
	url = {https://arxiv.org/abs/2103.01208},
	doi = {10.48550/arxiv.2103.01208},
	abstract = {We consider the problem of finding sparse adversarial perturbations for image classifiers, which corresponds to the l1-constrained adversarial attack problem. While l1-attacks are important for evaluating the robustness of models against sparse noise, they are significantly harder to optimize than l0- or l-infinity-attacks. We propose a new attack, l1-APGD, which is based on the Auto-Projected Gradient Descent (APGD) framework. We show that l1-APGD is a strong and efficient attack that outperforms existing methods on a variety of datasets and models. We also provide a new, more robust evaluation protocol for l1-robustness.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Croce, Francesco and Hein, Matthias},
	year = {2021},
	keywords = {Robustness (evolution), Gradient descent, Adversarial system, Computer science, Mathematics, Classifier (UML), Artificial intelligence, Algorithm, Pattern recognition (psychology), Mathematical optimization, Artificial neural network, ICML},
}
