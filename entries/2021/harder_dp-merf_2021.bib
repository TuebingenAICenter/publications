@inproceedings{harder_dp-merf_2021,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {{DP}-{MERF}: {Differentially} {Private} {Mean} {Embeddings} with {Random} {Features} for {Practical} {Privacy}-{Preserving} {Data} {Generation}},
	shorttitle = {{DP}-{MERF}},
	url = {http://proceedings.mlr.press/v130/harder21a.html},
	abstract = {We propose DP-MERF, a method for differentially private data generation. Our approach is based on the mean embedding of distributions, which represents a probability distribution as a point in a reproducing kernel Hilbert space. By using random features to approximate the kernel, we can compute a finite-dimensional representation of the mean embedding. We show that by adding noise to these random features, we can satisfy differential privacy while maintaining the ability to generate synthetic data that preserves the statistical properties of the original dataset. We demonstrate the effectiveness of our method on several real-world datasets, showing that it outperforms existing differentially private data generation methods in terms of utility and scalability.},
	language = {en},
	booktitle = {Proceedings of the 24th {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Harder, Frederik and Adamczewski, Kamil and Park, Mijung},
	editor = {Banerjee, Arindam and Fukumizu, Kenji},
	month = apr,
	year = {2021},
	keywords = {AISTATS},
}
