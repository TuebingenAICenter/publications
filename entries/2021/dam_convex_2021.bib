@inproceedings{dam_convex_2021,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Convex {Regularization} in {Monte}-{Carlo} {Tree} {Search}},
	shorttitle = {Convex {Regularization} in {Monte}-{Carlo} {Tree} {Search}},
	url = {https://proceedings.mlr.press/v139/dam21a.html},
	abstract = {Monte-Carlo Tree Search (MCTS) is a powerful algorithm for sequential decision making. However, MCTS often suffers from high variance in its value estimates, especially in large state spaces. In this paper, we propose to use convex regularization to improve the stability and performance of MCTS. We introduce a regularized version of the Upper Confidence Bound (UCB) algorithm, which we call Regularized-UCB (R-UCB). We show that R-UCB is equivalent to a specific form of MCTS with a regularized objective function. We provide theoretical guarantees for the convergence of R-UCB and demonstrate its effectiveness on a variety of benchmarks, including the game of Go and several Atari games.},
	language = {en},
	urldate = {2024-05-23},
	booktitle = {Proceedings of 38th {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Dam, T. and D'Eramo, C. and Peters, J. and Pajarinen, J.},
	month = jul,
	year = {2021},
	keywords = {ICML},
}
