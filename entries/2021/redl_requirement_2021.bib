@article{redl_requirement_2021,
	title = {Requirement of {DNMT1} to orchestrate epigenomic reprogramming for {NPM}-{ALK}-driven lymphomagenesis},
	issn = {2575-1077},
	shorttitle = {Requirement of {DNMT1} to orchestrate epigenomic reprogramming},
	url = {https://dx.doi.org/10.26508/lsa.202000794},
	doi = {10.26508/lsa.202000794},
	abstract = {NPM-ALK is a potent oncogenic driver in anaplastic large cell lymphoma (ALCL). Here, we show that NPM-ALK expression induces a profound epigenomic reprogramming characterized by global DNA hypomethylation and focal hypermethylation. We identify the DNA methyltransferase 1 (DNMT1) as a critical mediator of this process. DNMT1 is highly expressed in ALCL and its depletion impairs lymphoma cell growth and survival in vitro and in vivo. Mechanistically, DNMT1 is required to maintain the hypermethylated state of tumor suppressor genes and to prevent the activation of a retroviral gene expression program. Our data suggest that NPM-ALK-driven lymphomagenesis relies on a DNMT1-dependent epigenomic landscape, highlighting DNMT1 as a potential therapeutic target in ALCL.},
	language = {en},
	urldate = {2024-05-23},
	journal = {Life Science Alliance},
	publisher = {Life Science Alliance},
	author = {Redl, Elisa and Sheibani-Tezerji, Raheleh and Cardona, Crhistian de Jesus and Hamminger, Patricia and Timelthaler, Gerald and Hassler, Melanie Rosalia and Zrimsek, Masa and Lagger, Sabine and Dillinger, Thomas and Hofbauer, Lorena and Draganic, Kristina and Tiefenbacher, Andreas and Kothmayer, Michael and Dietz, Charles H. and Ramsahoye, Bernard H. and Kenner, Lukas and Bock, Christoph and Seiser, Christian and Ellmeier, Wilfried and Schweikert, Gabriele and Egger, Gerda},
	year = {2021},
}
