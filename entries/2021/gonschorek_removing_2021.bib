@article{gonschorek_removing_2021,
	title = {Removing {Inter}-{Experimental} {Variability} from {Functional} {Data} in {Systems} {Neuroscience}},
	url = {https://proceedings.neurips.cc/paper_files/paper/2021/hash/1e5eeb40a3fce716b244599862fd2200-Abstract.html},
	abstract = {In systems neuroscience, the ability to combine data across experiments is crucial for building robust models of neural function. However, inter-experimental variability—often caused by differences in recording conditions, animal preparations, or equipment—can obscure the underlying biological signals. Here, we present a method to remove inter-experimental variability from functional data. Our approach is based on a generative model that disentangles biological signals from experimental noise. We demonstrate that our method effectively removes inter-experimental variability while preserving the relevant biological information, leading to improved performance in downstream analysis tasks such as cell type classification and neural encoding modeling.},
	journal = {Advances in Neural Information Processing Systems},
	publisher = {Curran Associates, Inc.},
	author = {Gonschorek, Dominic and Höfling, Larissa and Szatko, Klaudia P. and Franke, Katrin and Schubert, Timm and Dunn, Benjamin and Berens, Philipp and Klindt, David and Euler, Thomas},
	month = dec,
	year = {2021},
	keywords = {Computer science, Benchmark (surveying), Artificial intelligence, Generalization, Machine learning, SIGNAL (programming language), Experimental data, Systems neuroscience, Pattern recognition (psychology), Neuroscience, NEURIPS},
}
