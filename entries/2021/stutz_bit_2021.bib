@misc{stutz_bit_2021,
	title = {Bit {Error} {Robustness} for {Energy}-{Efficient} {DNN} {Accelerators}},
	shorttitle = {Bit {Error} {Robustness}},
	url = {https://arxiv.org/abs/2006.13977},
	doi = {10.48550/arxiv.2006.13977},
	abstract = {Deep Neural Networks (DNNs) are increasingly deployed on energy-constrained edge devices. To reduce energy consumption, DNN accelerators often operate at reduced supply voltages, which increases the probability of bit errors in the underlying memory (e.g., SRAM). While DNNs are known to be somewhat robust to noise, bit errors in weights can lead to catastrophic performance degradation. In this paper, we analyze the robustness of DNNs to bit errors in weights. We show that bit errors in the exponent of floating-point representations are significantly more harmful than errors in the mantissa. Based on this observation, we propose a simple yet effective training objective that encourages robustness to bit errors. Our approach is hardware-agnostic and does not require architectural changes. We demonstrate that our method significantly improves the robustness of various DNN architectures on CIFAR-10 and ImageNet, allowing for lower supply voltages and thus higher energy efficiency without sacrificing accuracy.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {MLSys},
	author = {Stutz, David and Chandramoorthy, Nandhini and Hein, Matthias and Schiele, Bernt},
	year = {2021},
	keywords = {Robustness (evolution), Computer science, Quantization (signal processing), Energy consumption, Static random-access memory, Voltage, Efficient energy use, Clipping (morphology), Artificial neural network, Computer hardware, Algorithm, Artificial intelligence, Electrical engineering, Engineering, MLSYS},
}
