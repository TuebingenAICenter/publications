@inproceedings{tosatto_contextual_2021,
	title = {Contextual {Latent}-{Movements} {Off}-{Policy} {Optimization} for {Robotic} {Manipulation} {Skills}},
	shorttitle = {{CL}-{MOPO}},
	url = {https://doi.org/10.1109/ICRA48506.2021.9561870},
	doi = {10.1109/ICRA48506.2021.9561870},
	abstract = {Learning complex robotic manipulation skills requires the ability to generalize across different task contexts. While reinforcement learning has shown great potential, it often struggles with high-dimensional action spaces and the need for sample efficiency. In this paper, we propose Contextual Latent-Movements Off-Policy Optimization (CL-MOPO), a framework that combines latent space movement primitives with off-policy reinforcement learning. By learning a latent representation of movement primitives, we reduce the dimensionality of the action space, while the off-policy optimization allows for efficient learning from previously collected data. We evaluate our approach on a set of simulated robotic manipulation tasks and demonstrate that it outperforms state-of-the-art methods in terms of sample efficiency and generalization performance.},
	language = {en},
	booktitle = {2021 {IEEE} {International} {Conference} on {Robotics} and {Automation} ({ICRA})},
	publisher = {IEEE},
	author = {Tosatto, Samuele and Chalvatzaki, Georgia and Peters, Jan},
	month = may,
	year = {2021},
	keywords = {ICRA},
}
