@misc{arvanitidis_geometrically_2021,
	title = {Geometrically {Enriched} {Latent} {Spaces}},
	url = {http://proceedings.mlr.press/v130/arvanitidis21a.html},
	doi = {10.48550/arxiv.2008.00565},
	abstract = {Latent variable models are typically defined by a mapping from a simple latent space to a complex data space. While this allows for efficient sampling, it often results in latent spaces that lack geometric structure, making it difficult to perform meaningful operations such as interpolation or distance computation. We propose to enrich the latent space with a Riemannian metric that is induced by the generative model. This allows us to define a geometry that is consistent with the data manifold, enabling us to perform geodesic computations and define meaningful distances in the latent space. We demonstrate the effectiveness of our approach on a variety of generative models and show that it leads to improved interpretability and performance in downstream tasks.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Arvanitidis, Georgios and Hauberg, Søren and Schölkopf, Bernhard},
	editor = {Banerjee, Arindam and Fukumizu, Kenji},
	month = apr,
	year = {2021},
	keywords = {Ambient space, Manifold (fluid mechanics), Metric (unit), Space (punctuation), Generator (circuit theory), Interpretability, Metric space, Topology (electrical circuits), Euclidean space, Mathematics, Computer science, Domain (mathematical analysis), Pure mathematics, Theoretical computer science, Combinatorics, Artificial intelligence, Mathematical analysis, Physics, AISTATS},
}
