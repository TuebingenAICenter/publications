@misc{parascandolo_learning_2021,
	title = {Learning explanations that are hard to vary},
	url = {https://openreview.net/pdf?id=hb1sDDSLbV},
	doi = {10.48550/arxiv.2009.00329},
	abstract = {We propose a novel objective for learning causal representations that are robust to distribution shifts. Our approach is inspired by the philosophical principle that good explanations should be hard to vary, meaning that they should not be easily adaptable to fit arbitrary data. We formalize this by introducing a penalty on the sensitivity of the model's predictions to changes in the input, which encourages the model to learn features that are invariant across different environments. We demonstrate the effectiveness of our method on several synthetic and real-world datasets, showing that it outperforms existing methods in terms of robustness to distribution shifts and generalization performance.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {International Conference on Learning Representations},
	author = {Parascandolo, Giambattista and Neitz, Alexander and Orvieto, Antonio and Gresele, Luigi and Schölkopf, Bernhard},
	year = {2021},
	keywords = {Spurious relationship, Memorization, Computer science, Maxima and minima, Simple (philosophy), Consistency (knowledge bases), Invariant (physics), Artificial intelligence, Set (abstract data type), Context (archaeology), Machine learning, Algorithm, Theoretical computer science, Mathematics, Epistemology, ICLR},
}
