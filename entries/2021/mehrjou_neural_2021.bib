	publisher = {PMLR},
	author = {Mehrjou, Arash and Ghavamzadeh, Mohammad and Schölkopf, Bernhard},
	editor = {Jadbabaie, Ali and Lygeros, John and Pappas, George J. and Parrilo, Pablo A. and Recht, Benjamin and Tomlin, Claire J. and Zeilinger, Melanie N.},
	month = jun,
	year = {2021},
	keywords = {Lyapunov function, Control theory (sociology), Controller (irrigation), Control-Lyapunov function, Computer science, Stability (learning theory), Lyapunov redesign, Lyapunov stability, Dynamical systems theory, Metric (unit), Reinforcement learning, Nonlinear system, Function (biology), Control engineering, Control (management), Mathematical optimization, Mathematics, Artificial intelligence, Machine learning, Engineering, L4DC},
