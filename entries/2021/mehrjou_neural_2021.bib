@article{mehrjou_neural_2021,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Neural {Lyapunov} {Redesign}},
	url = {https://proceedings.mlr.press/v144/mehrjou21a.html},
	doi = {10.13140/rg.2.2.36245.65762},
	abstract = {We propose a framework to learn a Lyapunov function and a stabilizing controller for a nonlinear dynamical system. Our approach, called Neural Lyapunov Redesign (NLR), uses a neural network to parameterize the Lyapunov function and another to parameterize the controller. We use the Lyapunov redesign method to derive a control law that guarantees stability of the closed-loop system. We show that our method can be used to stabilize a wide range of nonlinear systems, including those with unknown dynamics. We demonstrate the effectiveness of our approach on several benchmark control problems.},
	language = {en},
	urldate = {2025-05-14},
