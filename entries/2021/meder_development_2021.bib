@misc{meder_development_2021,
	title = {Development of directed and random exploration in children},
	shorttitle = {Development of directed and random exploration in children},
	url = {https://doi.org/10.1111/desc.13095},
	doi = {10.1111/desc.13095},
	abstract = {Exploration is essential for learning and decision-making, yet little is known about how the strategies children use to explore develop. We investigated the development of directed exploration (seeking information to reduce uncertainty) and random exploration (introducing stochasticity to explore) in children aged 4–12 years using a multi-armed bandit task. We found that both directed and random exploration are present in early childhood and follow distinct developmental trajectories. Directed exploration increases with age, whereas random exploration decreases. These findings suggest that children become more efficient at targeted information seeking as they grow older, while their tendency to explore randomly declines, potentially reflecting a shift toward more goal-directed behavior. Our results provide a computational account of the development of exploration, highlighting the distinct roles of directed and random strategies in children's learning.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Wiley},
	author = {Meder, Björn and Wu, Charley M. and Schulz, Eric and Ruggeri, Azzurra},
	year = {2021},
	keywords = {Randomness, Exploit, Generalization, Task (project management), Sampling (signal processing), Computer science, Process (computing), Similarity (geometry), Range (aeronautics), Trajectory, Artificial intelligence, Machine learning, Outcome (game theory), Psychology, Mathematics, Statistics, Engineering},
}
