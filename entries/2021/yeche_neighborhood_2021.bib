@inproceedings{yeche_neighborhood_2021,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Neighborhood {Contrastive} {Learning} {Applied} to {Online} {Patient} {Monitoring}},
	shorttitle = {Neighborhood {Contrastive} {Learning} {Applied} to {Online} {Patient} {Monitoring}},
	url = {https://proceedings.mlr.press/v139/yeche21a.html},
	abstract = {Online patient monitoring in intensive care units requires robust representations of physiological time series. These data are irregularly sampled, multivariate, and often contain long periods of missing values. We propose Neighborhood Contrastive Learning (NCL), a self-supervised framework that learns representations by contrasting a sample with its neighbors in the latent space. NCL leverages the temporal structure of the data by defining neighbors based on temporal proximity and similarity in the feature space. We evaluate NCL on the task of predicting mortality and length of stay in the ICU using the MIMIC-III dataset. Our method outperforms state-of-the-art self-supervised and supervised baselines, demonstrating the effectiveness of NCL for learning from irregularly sampled time series.},
	language = {en},
	booktitle = {Proceedings of 38th {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Yèche, H. and Dresdner, G. and Locatello, F. and Hüser, M. and Rätsch, G.},
	editor = {Meila, Marina and Zhang, Tong},
	month = jul,
	year = {2021},
	keywords = {ICML},
}
