@misc{mastakouri_necessary_2021,
	title = {Necessary and sufficient conditions for causal feature selection in time series with latent common causes},
	shorttitle = {Necessary and sufficient conditions for causal feature selection},
	url = {https://proceedings.mlr.press/v139/mastakouri21a.html},
	doi = {10.48550/arxiv.2005.08543},
	abstract = {Causal feature selection aims to identify the subset of features that are direct causes of a target variable. In time series, this task is complicated by the presence of latent common causes, which can induce spurious correlations. We provide necessary and sufficient conditions for identifying the direct causes of a target variable from a set of observed time series, in the presence of latent common causes. We show that under certain assumptions, the direct causes can be identified by testing for conditional independence. We also provide an algorithm for causal feature selection and demonstrate its performance on synthetic and real-world data.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Mastakouri, Atalanti A. and Schölkopf, Bernhard and Janzing, Dominik},
	editor = {Meila, Marina and Zhang, Tong},
	month = jul,
	year = {2021},
	keywords = {Series (stratigraphy), Feature (linguistics), Computer science, Selection (genetic algorithm), Feature selection, Econometrics, Mathematics, Artificial intelligence, Biology, Linguistics, Philosophy, ICML},
}
