@article{pedziwiatr_object-context_2021,
	title = {Object-context inconsistencies affect gaze behavior differently than predicted by contextualized meaning maps},
	issn = {1534-7362},
	shorttitle = {Object-context inconsistencies},
	url = {https://doi.org/10.1167/jov.21.9.2928},
	doi = {10.1167/jov.21.9.2928},
	abstract = {Previous research has shown that objects that are inconsistent with their context (e.g., a toaster in a forest) attract more attention than consistent objects. This effect is often explained by the violation of expectations or the increased informativeness of the inconsistent object. Recently, meaning maps have been proposed as a way to quantify the semantic informativeness of image regions and have been shown to predict gaze behavior well. However, it is unclear whether meaning maps can account for the effect of object-context inconsistencies on gaze behavior. Here, we investigated this question by comparing human gaze behavior on images containing consistent and inconsistent objects with predictions from contextualized meaning maps. We found that while meaning maps predicted gaze behavior well for both consistent and inconsistent images, they failed to account for the specific effect of object-context inconsistency on gaze behavior. Our results suggest that object-context inconsistencies affect gaze behavior through mechanisms that are not fully captured by current models of semantic informativeness.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Journal of Vision},
	publisher = {Association for Research in Vision and Ophthalmology},
	author = {Pedziwiatr, Marek A. and Kümmerer, Matthias and Wallis, Thomas S. A. and Bethge, Matthias and Teufel, Christoph},
	year = {2021},
	keywords = {Gaze, Meaning (existential), Context (archaeology), Cognitive psychology, Psychology, Artificial intelligence, Set (abstract data type), Computer science, Eye tracking, Object (grammar), Consistency (knowledge bases), Affect (linguistics), Communication, Geography, JOV},
}
