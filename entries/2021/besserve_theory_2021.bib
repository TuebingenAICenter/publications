@misc{besserve_theory_2021,
	title = {A {Theory} of {Independent} {Mechanisms} for {Extrapolation} in {Generative} {Models}},
	shorttitle = {A {Theory} of {Independent} {Mechanisms} for {Extrapolation} in {Generative} {Models}},
	url = {https://ojs.aaai.org/index.php/AAAI/article/view/16833},
	doi = {10.1609/aaai.v35i8.16833},
	abstract = {We study the problem of extrapolation in generative models, where a model trained on a specific distribution is required to perform well on a different, unseen distribution. We propose a theory of independent mechanisms (IM) for extrapolation, which posits that the causal mechanisms generating the data are independent and that this independence is preserved under distribution shifts. We show that this principle allows for identifying the causal structure of the data-generating process and for predicting the effect of interventions. We provide theoretical guarantees for the identifiability of the causal model and demonstrate the effectiveness of our approach on synthetic and real-world datasets.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {AAAI Press},
	author = {Besserve, Michel and Sun, Rémy and Janzing, Dominik and Schölkopf, Bernhard},
	year = {2021},
	keywords = {Identifiability, Extrapolation, Generative grammar, Computer science, Generative model, Independence (probability theory), Machine learning, Context (archaeology), Graph, Artificial intelligence, Conditional independence, Theoretical computer science, Econometrics, Mathematics, AAAI},
}
