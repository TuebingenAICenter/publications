@misc{ilanchezian_interpretable_2021,
	title = {Interpretable {Gender} {Classification} from {Retinal} {Fundus} {Images} {Using} {BagNets}},
	shorttitle = {Interpretable gender classification from retinal fundus images using {BagNets}},
	url = {https://link.springer.com/chapter/10.1007/978-3-030-87199-4_45},
	doi = {10.1007/978-3-030-87199-4_45},
	abstract = {Deep learning models have achieved high performance in medical image analysis, but their black-box nature limits their clinical adoption. In this work, we investigate the use of BagNets, a class of models that classify images based on local features, for gender classification from retinal fundus images. We show that BagNets achieve performance comparable to standard convolutional neural networks while providing inherent interpretability through heatmaps that highlight the local features contributing to the classification. Our results suggest that BagNets are a promising tool for interpretable medical image analysis.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Springer International Publishing},
	author = {Ilanchezian, Indu and Kobak, Dmitry and Faber, Hanna and Ziemssen, Focke and Berens, Philipp and Ayhan, Murat Seckin},
	month = sep,
	year = {2021},
	keywords = {Fundus (uterus), Computer science, Artificial intelligence, Retinal, Class (philosophy), Computer vision, Pattern recognition (psychology), Ophthalmology, Medicine, MICCAI},
}
