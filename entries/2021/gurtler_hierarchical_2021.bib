@inproceedings{gurtler_hierarchical_2021,
	title = {Hierarchical {Reinforcement} {Learning} with {Timed} {Subgoals}},
	shorttitle = {{HiTS}},
	url = {https://proceedings.neurips.cc/paper/2021/file/b59c21a078fde074a6750e91ed19fb21-Paper.pdf},
	doi = {10.48550/arxiv.2112.03100},
	abstract = {Hierarchical Reinforcement Learning (HRL) aims to solve long-horizon tasks by decomposing them into subtasks. A common challenge is the definition of subgoals and the coordination between the high-level policy, which selects subgoals, and the low-level policy, which executes them. We propose Hierarchical Reinforcement Learning with Timed Subgoals (HiTS), a novel HRL framework that introduces a temporal constraint on subgoals. By predicting not only the desired state but also the time horizon for reaching it, the high-level policy gains explicit control over the temporal abstraction. We show that this simple extension significantly improves the stability and performance of HRL. HiTS achieves state-of-the-art results on a variety of challenging continuous control tasks, including sparse-reward environments and long-horizon navigation tasks.},
	language = {en},
	booktitle = {Advances in {Neural} {Information} {Processing} {Systems} 34},
	publisher = {Curran Associates, Inc.},
	author = {Gürtler, N. and Büchler, D. and Martius, G.},
	editor = {Ranzato, M. and Beygelzimer, A. and Dauphin, Y. and Liang, P. S. and Wortman Vaughan, J.},
	month = dec,
	year = {2021},
	keywords = {Computer science, Reinforcement learning, Reinforcement, Human–computer interaction, Artificial intelligence, Engineering, Structural engineering, NEURIPS},
}
