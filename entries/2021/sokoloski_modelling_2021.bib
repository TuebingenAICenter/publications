@article{sokoloski_modelling_2021,
	title = {Modelling the neural code in large populations of correlated neurons},
	copyright = {CC BY 4.0},
	issn = {2050-084X},
	shorttitle = {Modelling the neural code},
	url = {https://elifesciences.org/articles/64615},
	doi = {10.7554/eLife.64615},
	abstract = {The neural code is often studied by characterizing the responses of individual neurons to stimuli. However, neurons in the brain are highly interconnected, and their responses are often correlated. These correlations can have a profound impact on the information that can be encoded by a population of neurons. Here, we present a framework for modelling the neural code in large populations of correlated neurons. Our approach is based on a latent variable model that captures the structure of neural correlations while remaining computationally tractable. We demonstrate the utility of our framework by applying it to data from the primary visual cortex of macaques. We show that our model can accurately predict the responses of large populations of neurons and that it provides insights into the structure of neural correlations and their impact on information encoding.},
	language = {en},
	urldate = {2024-05-23},
	journal = {eLife},
	publisher = {eLife Sciences Publications, Ltd},
	author = {Sokoloski, Samuel and Aschner, Adam and Coen-Cagli, Ruben},
	month = oct,
	year = {2021},
	keywords = {ELIFE},
}
