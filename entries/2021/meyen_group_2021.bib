@article{meyen_group_2021,
	title = {Group decisions based on confidence weighted majority voting},
	copyright = {© The Author(s) 2021},
	issn = {2365-7464},
	shorttitle = {Group decisions based on confidence weighted majority voting},
	url = {https://doi.org/10.1186/s41235-021-00279-0},
	doi = {10.1186/s41235-021-00279-0},
	abstract = {In many situations, groups of people make decisions by voting. A common rule is the majority rule. However, majority rule ignores the confidence of the individual voters. In this paper, we investigate whether group decisions can be improved by using confidence-weighted majority voting. We propose a model for confidence-weighted majority voting and compare it to standard majority voting. We show that confidence-weighted majority voting can improve the accuracy of group decisions, especially when the individual voters have different levels of expertise or when the task is difficult. We also discuss the conditions under which confidence-weighted majority voting is most effective.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Cognitive Research: Principles and Implications},
	publisher = {Springer Nature},
	author = {Meyen, Sascha and Sigg, Dorothee and von Luxburg, Ulrike and Franz, Volker},
	year = {2021},
	keywords = {Voting, Group (periodic table), Majority rule, Confidence interval, Group decision-making, Aggregate (composite), Psychology, Computer science, Statistics, Social psychology, Econometrics, Artificial intelligence, Mathematics},
}
