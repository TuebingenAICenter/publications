@article{rahaman_dynamic_2021,
	title = {Dynamic {Inference} with {Neural} {Interpreters}},
	url = {https://proceedings.neurips.cc/paper/2021/file/5b4e9aa703d0bfa11041debaa2d1b633-Paper.pdf},
	abstract = {We propose Neural Interpreters, a framework for modular and compositional computation. Neural Interpreters consist of a set of reusable neural modules and a controller that dynamically selects and executes these modules to solve a given task. This allows the model to adapt its computation to the input, leading to improved generalization and interpretability. We demonstrate the effectiveness of our approach on a variety of tasks, including symbolic reasoning, image classification, and reinforcement learning, where it outperforms monolithic baselines and existing modular architectures.},
	language = {en},
	journal = {Advances in Neural Information Processing Systems 34},
	publisher = {Curran Associates, Inc.},
	author = {Rahaman, Nasim and Gondal, Muhammad Waleed and Joshi, Shruti and Gehler, Peter and Bengio, Yoshua and Locatello, Francesco and Schölkopf, Bernhard},
	editor = {Ranzato, M. and Beygelzimer, A. and Dauphin, Y. and Liang, P.S. and Wortman Vaughan, J.},
	month = dec,
	year = {2021},
	keywords = {Computer science, Inference, Artificial neural network, Interpreter, Artificial intelligence, Leverage (statistics), Unary operation, Transformer, Generalization, Reuse, Machine learning, Programming language, Mathematics, NEURIPS},
}
