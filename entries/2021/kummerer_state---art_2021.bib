@misc{kummerer_state---art_2021,
	title = {State-of-the-{Art} in {Human} {Scanpath} {Prediction}},
	shorttitle = {State-of-the-{Art} in {Human} {Scanpath} {Prediction}},
	url = {https://arxiv.org/abs/2102.12239},
	doi = {10.48550/arXiv.2102.12239},
	abstract = {Predicting where humans look next is a fundamental problem in computer vision and cognitive science. While saliency prediction has seen tremendous progress due to deep learning, scanpath prediction—the prediction of the sequence of fixations—has lagged behind. This is partly due to the lack of a standardized evaluation framework. In this paper, we provide a comprehensive review of the state-of-the-art in human scanpath prediction. We introduce a new benchmark, the MIT Scanpath Benchmark, and evaluate a wide range of models on it. We find that while some models perform well on specific metrics, no single model dominates across all metrics. We discuss the implications of these findings and suggest future directions for the field.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {arXiv},
	author = {Kümmerer, Matthias and Bethge, Matthias},
	year = {2021},
	keywords = {Benchmarking, Computer science, Benchmark (surveying), Artificial intelligence, Machine learning, Fixation (population genetics), Predictive power, Field (mathematics), Population},
}
