@misc{liu_iterative_2021,
	title = {Iterative {Teaching} by {Label} {Synthesis}},
	url = {https://proceedings.neurips.cc/paper/2021/file/b5488aeff42889188d03c9895255cecc-Paper.pdf},
	doi = {10.48550/arxiv.2110.14432},
	abstract = {Machine teaching aims to find the optimal training set to make a learner converge to a target model as quickly as possible. Existing teaching methods often assume that the teacher can select examples from a fixed pool or synthesize examples from the input space. However, in many real-world scenarios, the teacher may only be able to provide labels for a fixed set of inputs. In this paper, we propose Iterative Teaching by Label Synthesis (ITLS), a novel teaching framework that allows the teacher to synthesize labels for a fixed set of inputs to guide the learner. We formulate ITLS as a bilevel optimization problem and solve it by alternating between updating the learner's parameters and optimizing the synthesized labels. We show that ITLS can be interpreted as a form of iterative teaching, where the teacher iteratively refines the labels to improve the learner's performance. We demonstrate the effectiveness of ITLS on various machine learning tasks, including image classification and robust learning, and show that it outperforms existing teaching methods.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Liu, Weiyang and Liu, Zhen and Wang, Hanchen and Paull, Liam and Schölkopf, Bernhard and Weller, Adrian},
	editor = {Ranzato, M. and Beygelzimer, A. and Dauphin, Y. and Liang, P.S. and Wortman Vaughan, J.},
	month = dec,
	year = {2021},
	keywords = {Computer science, Selection (genetic algorithm), Contrast (vision), Value (mathematics), Algorithm, Theoretical computer science, Artificial intelligence, Machine learning, NEURIPS},
}
