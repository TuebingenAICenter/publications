@misc{seitzer_causal_2021,
	title = {Causal {Influence} {Detection} for {Improving} {Efficiency} in {Reinforcement} {Learning}},
	shorttitle = {Causal {Influence} {Detection}},
	url = {https://proceedings.neurips.cc/paper/2021/file/c1722a7941d61aad6e651a35b65a9c3e-Paper.pdf},
	doi = {10.17617/3.68TEG2},
	abstract = {In reinforcement learning, agents often have to deal with high-dimensional observations that contain information irrelevant to the task. We propose Causal Influence Detection (CID), a method that learns to identify which parts of the environment are causally influenced by the agent's actions. By focusing on these parts, the agent can ignore irrelevant information, which significantly improves sample efficiency and generalization. We demonstrate the effectiveness of CID on a variety of tasks, including complex control problems and environments with distracting visual input.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Seitzer, Maximilian and Schölkopf, Bernhard and Martius, Georg},
	editor = {Ranzato, M. and Beygelzimer, A. and Dauphin, Y. and Liang, P. S. and Wortman Vaughan, J.},
	month = dec,
	year = {2021},
	keywords = {Reinforcement learning, Computer science, Measure (data warehouse), Artificial intelligence, Machine learning, Data mining, NEURIPS},
}
