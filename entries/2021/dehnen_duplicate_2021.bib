@article{dehnen_duplicate_2021,
	title = {Duplicate {Detection} of {Spike} {Events}: {A} {Relevant} {Problem} in {Human} {Single}-{Unit} {Recordings}},
	copyright = {© 2021 by the authors. Licensee MDPI, Basel, Switzerland. This article is an open access article distributed under the terms and conditions of the Creative Commons Attribution (CC BY) license (https://creativecommons.org/licenses/by/4.0/).},
	issn = {2076-3425},
	shorttitle = {Duplicate {Detection} of {Spike} {Events}},
	url = {https://www.mdpi.com/2076-3425/11/6/761/htm},
	doi = {10.3390/brainsci11060761},
	abstract = {In human single-unit recordings, the identification of action potentials (spikes) is a crucial step for understanding the neural basis of cognition and behavior. However, the presence of duplicate spike events—multiple detections of the same action potential—can lead to biased results and incorrect interpretations of neural activity. In this paper, we address the problem of duplicate detection in human single-unit recordings. We propose a method for detecting and removing duplicate spike events based on the similarity of their waveforms and their temporal proximity. We demonstrate the effectiveness of our method on both simulated and real human single-unit data, showing that it significantly improves the quality of the spike sorting results. Our approach is computationally efficient and can be easily integrated into existing spike sorting pipelines.},
	language = {en},
	urldate = {2025-05-14},
	journal = {Brain Sciences},
	publisher = {MDPI},
	author = {Dehnen, Gert and Kehl, M. S. and Darcher, Alana and Müller, Tamara and Macke, Jakob H. and Borger, Valeri and Surges, Rainer and Mormann, Florian},
	year = {2021},
	keywords = {Spike (software development), Computer science, Noise (video), Waveform, Electroencephalography, Artificial intelligence, Pattern recognition (psychology), Speech recognition, Machine learning, Neuroscience, Biology},
}
