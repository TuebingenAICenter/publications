@misc{rahaman_spatially_2021,
	title = {Spatially {Structured} {Recurrent} {Modules}},
	shorttitle = {S2RMs},
	url = {https://openreview.net/pdf?id=5l9zj5G7vDY},
	doi = {10.48550/arxiv.2007.06533},
	abstract = {We propose Spatially Structured Recurrent Modules (S2RMs), a novel architecture for processing visual information. S2RMs are composed of a set of recurrent modules that operate on local patches of an image. These modules are spatially arranged in a grid and communicate with their neighbors, allowing the model to learn spatial dependencies and capture long-range interactions. We demonstrate that S2RMs achieve state-of-the-art performance on several visual reasoning tasks and exhibit strong generalization capabilities to unseen spatial configurations.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {International Conference on Learning Representations},
	author = {Rahaman, Nasim and Goyal, Anirudh and Gondal, Muhammad Waleed and Wüthrich, Manuel and Bauer, Stefan and Sharma, Yash and Bengio, Yoshua and Schölkopf, Bernhard},
	month = may,
	year = {2021},
	keywords = {Leverage (statistics), Computer science, Modular design, Artificial intelligence, Process (computing), Machine learning, Domain (mathematical analysis), Theoretical computer science, Mathematics, Generalization, ICLR},
}
