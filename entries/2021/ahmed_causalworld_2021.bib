@misc{ahmed_causalworld_2021,
	title = {{CausalWorld}: {A} {Robotic} {Manipulation} {Benchmark} for {Causal} {Structure} and {Transfer} {Learning}},
	shorttitle = {{CausalWorld}},
	url = {https://openreview.net/pdf?id=SK7A5pdrgov},
	doi = {10.48550/arxiv.2010.04296},
	abstract = {We introduce CausalWorld, a benchmark for causal structure and transfer learning in a robotic manipulation setting. The benchmark consists of a set of robotic manipulation tasks that are based on a common underlying causal structure, which can be intervened upon. This allows for the evaluation of causal discovery and transfer learning algorithms in a controlled environment. We provide a set of baseline results and discuss the challenges and opportunities for future research.},
