@article{dietz_detection_2021,
	title = {Detection of diabetes from whole-body {MRI} using deep learning},
	issn = {2379-3708},
	shorttitle = {Detection of diabetes from whole-body {MRI}},
	url = {https://insight.jci.org/articles/view/146999},
	doi = {10.1172/jci.insight.146999},
	abstract = {Type 2 diabetes (T2D) is a major health burden, and early detection is crucial for preventing complications. We hypothesized that whole-body MRI (WB-MRI) contains information about the metabolic state of a person that can be used to detect T2D. We developed a deep learning model to classify T2D status from WB-MRI scans of 1,322 participants from the German Diabetes Study. Our model achieved an area under the receiver operating characteristic curve (AUROC) of 0.86 for the detection of T2D. The model's performance was robust across different subgroups and was not driven by a single organ or tissue type. Our results demonstrate that WB-MRI, in combination with deep learning, can be used to detect T2D, providing a potential tool for early diagnosis and risk stratification.},
	language = {en},
	urldate = {2024-05-22},
	journal = {JCI Insight},
	publisher = {American Society for Clinical Investigation},
	author = {Dietz, B. and Machann, J. and Agrawal, V. and Heni, M. and Schwab, P. and Dienes, J. and Reichert, S. and Birkenfeld, A. L. and Häring, H.-U. and Schick, F. and Stefan, N. and Fritsche, A. and Preissl, H. and Schölkopf, B. and Bauer, S. and Wagner, R.},
	month = sep,
	year = {2021},
}
