@misc{geirhos_partial_2021,
	title = {Partial success in closing the gap between human and machine vision},
	shorttitle = {Partial success in closing the gap},
	url = {https://proceedings.neurips.cc/paper/2021/hash/c8877cff22082a16395a57e97232bb6f-Abstract.html},
	doi = {10.48550/arxiv.2106.07411},
	abstract = {Deep neural networks have achieved human-level performance on many computer vision tasks. However, it is widely believed that they still rely on different features than humans, as evidenced by their vulnerability to adversarial attacks and their reliance on texture rather than shape. Here, we show that this gap can be partially closed by training models on a larger, more diverse dataset and by using a more robust training procedure. We find that these models are more similar to humans in their reliance on shape, their robustness to common corruptions, and their error patterns. Our results suggest that the gap between human and machine vision is not insurmountable and can be reduced by better training data and procedures.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Curran Associates, Inc.},
	author = {Geirhos, Robert and Narayanappa, Kantharaju and Mitzkus, Benjamin and Thieringer, Tizian and Bethge, Matthias and Wichmann, Felix A. and Brendel, Wieland},
	year = {2021},
	keywords = {Computer science, Artificial intelligence, Machine learning, Robustness (evolution), Convolutional neural network, NEURIPS},
}
