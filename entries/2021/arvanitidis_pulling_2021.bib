@misc{arvanitidis_pulling_2021,
	title = {Pulling back information geometry},
	shorttitle = {Pulling back information geometry},
	url = {https://arxiv.org/abs/2106.05367},
	doi = {10.48550/arXiv.2106.05367},
	abstract = {Information geometry is a powerful framework for studying the geometry of statistical models. However, the standard approach relies on the Fisher information metric, which is often computationally intractable for modern deep generative models. In this paper, we propose a new approach to information geometry that relies on pulling back a metric from a simpler space to the parameter space of a complex model. This allows us to define a Riemannian metric on the parameter space that is both computationally efficient and captures the geometry of the data distribution. We demonstrate the effectiveness of our approach on a variety of tasks, including generative modeling, uncertainty estimation, and manifold learning.},
	language = {en},
	urldate = {2024-05-22},
	publisher = {arXiv},
	author = {Arvanitidis, Georgios and González Duque, Michael and Pouplin, Antoine and Kalatzis, Dimitrios and Hauberg, Søren},
	year = {2021},
	keywords = {AISTATS},
}
