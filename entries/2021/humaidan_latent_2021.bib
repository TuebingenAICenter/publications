@misc{humaidan_latent_2021,
	title = {Latent {Event}-{Predictive} {Encodings} through {Counterfactual} {Regularization}},
	shorttitle = {Latent {Event}-{Predictive} {Encodings}},
	url = {https://arxiv.org/abs/2105.05894},
	doi = {10.48550/arxiv.2105.05894},
	abstract = {Predictive processing theories suggest that the brain constantly generates predictions about upcoming sensory input. While many models focus on predicting the next state, we argue that learning to predict the consequences of counterfactual interventions is crucial for developing robust, causal representations. We propose a novel architecture that learns latent event-predictive encodings by regularizing the latent space with counterfactual predictions. Our model is trained to predict the outcome of an action, given a current state and a counterfactual intervention. We evaluate our approach on a set of grid-world environments and show that it learns more robust and interpretable representations compared to standard predictive models. Furthermore, we demonstrate that our model can effectively generalize to unseen counterfactual scenarios.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {Cognitive Science Society},
	author = {Humaidan, Dania and Otte, Sebastian and Gumbsch, Christian and Wu, Charley M. and Butz, Martin V.},
	editor = {Fitch, T. and Lamm, C. and Leder, H. and Teßmar-Raible, K.},
	year = {2021},
	keywords = {Counterfactual thinking, Computer science, Regularization (linguistics), Artificial intelligence, Surprise, Machine learning, Event (particle physics), Psychology, Communication, COGSCI},
}
