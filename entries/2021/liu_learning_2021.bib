@misc{liu_learning_2021,
	title = {Learning with {Hyperspherical} {Uniformity}},
	url = {http://proceedings.mlr.press/v130/liu21d.html},
	doi = {10.48550/arxiv.2103.01649},
	abstract = {Deep neural networks are often trained with a cross-entropy loss, which can lead to feature collapse where features of the same class are mapped to the same point. To address this, we propose a hyperspherical uniformity loss that encourages features to be uniformly distributed on the hypersphere. We show that this loss can be interpreted as a regularization term that promotes feature diversity and improves generalization. We provide theoretical analysis and empirical evidence on various benchmarks to demonstrate the effectiveness of our approach.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {PMLR},
	author = {Liu, Weiyang and Lin, Rongmei and Liu, Zhen and Xiong, Li and Schölkopf, Bernhard and Weller, Adrian},
	editor = {Banerjee, Arindam and Fukumizu, Kenji},
	month = apr,
	year = {2021},
	keywords = {Artificial neural network, Regularization (linguistics), Generalization, Computer science, Parameterized complexity, Inductive bias, Deep neural networks, Dimension (graph theory), Nonlinear system, Artificial intelligence, Popularity, Function (biology), Algorithm, Mathematics, Physics, Pure mathematics, AISTATS},
}
