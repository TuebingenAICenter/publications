@misc{croce_robustbench_2021,
	title = {{RobustBench}: a standardized adversarial robustness benchmark},
	shorttitle = {{RobustBench}},
	url = {https://openreview.net/forum?id=SSKZPJCt7B},
	doi = {10.48550/arxiv.2010.09670},
	abstract = {Adversarial robustness has become a central topic in machine learning, with a large number of defenses proposed in the last few years. However, the field lacks a standardized way to evaluate these defenses, leading to a fragmented landscape where it is difficult to compare different methods. In this paper, we introduce RobustBench, a standardized benchmark for adversarial robustness. RobustBench provides a collection of pre-trained models, a unified evaluation framework, and a leaderboard for different threat models. We hope that RobustBench will facilitate the development of more robust models and provide a clear picture of the state-of-the-art in adversarial robustness.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {OpenReview},
	author = {Croce, Francesco and Andriushchenko, Maksym and Sehwag, Vikash and Debenedetti, Edoardo and Flammarion, Nicolas and Chiang, Mung and Mittal, Prateek and Hein, Matthias},
	year = {2021},
	keywords = {Robustness (evolution), Computer science, Benchmarking, Machine learning, Benchmark (surveying), Artificial intelligence, Data mining, NEURIPS},
}
