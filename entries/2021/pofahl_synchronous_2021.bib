@article{pofahl_synchronous_2021,
	title = {Synchronous activity patterns in the dentate gyrus during immobility},
	copyright = {CC BY 4.0},
	issn = {2050-084X},
	url = {https://elifesciences.org/articles/65786},
	doi = {10.7554/eLife.65786},
	abstract = {The dentate gyrus (DG) is thought to perform pattern separation, a computation that requires sparse and decorrelated neuronal activity. However, the DG also exhibits synchronous activity patterns, such as sharp-wave ripples, which are associated with memory consolidation. Here, we show that the DG exhibits a distinct form of synchronous activity during immobility, which we term 'dentate spikes'. Dentate spikes are large-amplitude, population-wide events that are distinct from sharp-wave ripples. They are associated with a transient increase in the firing rate of granule cells and interneurons, and are accompanied by a characteristic local field potential signature. Dentate spikes are highly synchronous across the DG and are associated with a transient increase in the firing rate of granule cells and interneurons. We show that dentate spikes are associated with a transient increase in the firing rate of granule cells and interneurons, and are accompanied by a characteristic local field potential signature. Our results suggest that dentate spikes represent a distinct mode of DG activity that may be involved in the processing of information during immobility.},
	language = {en},
	urldate = {2025-05-14},
	journal = {eLife},
	publisher = {eLife Sciences Publications, Ltd},
	author = {Pofahl, M. and Nikbakht, N. and Haubrich, A. N. and Nguyen, T. and Masala, N. and Distler, F. and Braganza, O. and Macke, J. H. and Ewell, L. A. and Golcuk, K. and Beck, H.},
	month = mar,
	year = {2021},
	keywords = {Dentate gyrus, Entorhinal cortex, Hippocampal formation, Neuroscience, Population, Optogenetics, Granule cell, Hippocampus, Biology, Medicine, ELIFE},
}
