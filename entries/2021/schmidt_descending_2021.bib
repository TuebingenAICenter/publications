@inproceedings{schmidt_descending_2021,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Descending through a {Crowded} {Valley} - {Benchmarking} {Deep} {Learning} {Optimizers}},
	shorttitle = {Descending through a {Crowded} {Valley}},
	url = {https://proceedings.mlr.press/v139/schmidt21a.html},
	doi = {10.48550/arxiv.2007.01547},
	abstract = {The choice of optimizer is a crucial part of training deep neural networks. While many new optimizers are proposed every year, their relative performance is often unclear due to inconsistent benchmarking practices. We perform a large-scale empirical study of 15 popular deep learning optimizers on a diverse set of 14 tasks. We find that no single optimizer consistently outperforms others across all tasks. Furthermore, we show that the performance of most optimizers is highly sensitive to the choice of hyperparameters, and that a well-tuned SGD often performs as well as or better than more complex adaptive methods. Our results highlight the importance of rigorous benchmarking and suggest that the field should focus on developing more robust and easier-to-tune optimization algorithms.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of 38th {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Schmidt, Robin M. and Schneider, Frank and Hennig, Philipp},
	editor = {Meila, Marina and Zhang, Tong},
	month = jul,
	year = {2021},
	keywords = {Benchmarking, Heuristics, Computer science, Benchmark (surveying), Machine learning, Artificial intelligence, Range (aeronautics), Ranking (information retrieval), Suite, Deep learning, Hyperparameter, ICML},
}
