@inproceedings{raj_explicit_2021,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Explicit {Regularization} of {Stochastic} {Gradient} {Methods} through {Duality}},
	url = {http://proceedings.mlr.press/v130/raj21a.html},
	abstract = {Stochastic gradient descent (SGD) is the workhorse of modern machine learning. While its convergence properties are well-understood, its implicit regularization properties—why it generalizes well despite over-parameterization—remain a subject of intense study. In this paper, we propose a new perspective on the regularization of SGD by studying its dual. We show that for a wide class of problems, the dual of SGD is equivalent to a stochastic gradient method on the dual objective, which is explicitly regularized. This allows us to characterize the implicit regularization of SGD through the lens of explicit regularization in the dual. We provide theoretical guarantees for this equivalence and demonstrate its utility in understanding the generalization behavior of SGD in various settings, including linear regression and kernel methods.},
	language = {en},
	booktitle = {Proceedings of the 24th {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Raj, A. and Bach, F.},
	editor = {Banerjee, Arindam and Fukumizu, Kenji},
	month = apr,
	year = {2021},
	keywords = {AISTATS},
}
