@inproceedings{immer_scalable_2021,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Scalable {Marginal} {Likelihood} {Estimation} for {Model} {Selection} in {Deep} {Learning}},
	shorttitle = {Scalable {Marginal} {Likelihood} {Estimation}},
	url = {https://proceedings.mlr.press/v139/immer21a.html},
	abstract = {The marginal likelihood is a powerful tool for model selection, but it is notoriously difficult to compute for deep neural networks. We propose a scalable method to estimate the marginal likelihood using the Laplace approximation. Our method is based on a Kronecker-factored approximation of the Hessian, which allows us to compute the marginal likelihood with the same computational complexity as training a network. We demonstrate that our method can be used for model selection in deep learning, including hyperparameter tuning and architecture search, and that it outperforms existing methods in terms of both accuracy and computational efficiency.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {Proceedings of 38th {International} {Conference} on {Machine} {Learning}},
	publisher = {PMLR},
	author = {Immer, Alexander and Bauer, Matthias and Fortuin, Vincent and Rätsch, Gunnar and Khan, Mohammad Emtiyaz},
	editor = {Meila, Marina and Zhang, Tong},
	month = jul,
	year = {2021},
	keywords = {ICML},
}
