@article{fruh_weakly_2021,
	title = {Weakly supervised segmentation of tumor lesions in {PET}-{CT} hybrid imaging},
	shorttitle = {Weakly supervised segmentation of tumor lesions},
	url = {https://doi.org/10.1117/1.JMI.8.5.054003},
	doi = {10.1117/1.JMI.8.5.054003},
	abstract = {Accurate segmentation of tumor lesions in PET-CT images is a prerequisite for quantitative analysis and therapy monitoring. Deep learning-based segmentation methods typically require large amounts of pixel-wise annotated data, which is time-consuming and expensive to obtain. We propose a weakly supervised approach for the segmentation of tumor lesions in PET-CT images that only requires image-level labels, i.e., information about the presence or absence of a lesion. Our method is based on a multiple instance learning framework and utilizes a class activation mapping approach to generate pseudo-masks for the lesions. We evaluate our method on a dataset of 100 PET-CT scans and show that it achieves competitive results compared to fully supervised methods, while significantly reducing the annotation effort.},
	language = {en},
	urldate = {2024-05-22},
	journal = {Journal of Medical Imaging},
	publisher = {SPIE},
	author = {Früh, M. and Fischer, M. and Schilling, A. and Gatidis, S. and Hepp, T.},
	month = oct,
	year = {2021},
	keywords = {JMI},
}
