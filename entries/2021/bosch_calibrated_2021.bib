@inproceedings{bosch_calibrated_2021,
	series = {Proceedings of {Machine} {Learning} {Research}},
	title = {Calibrated {Adaptive} {Probabilistic} {ODE} {Solvers}},
	shorttitle = {Calibrated {Adaptive} {Probabilistic} {ODE} {Solvers}},
	url = {http://proceedings.mlr.press/v130/bosch21a.html},
	doi = {10.48550/arxiv.2012.08202},
	abstract = {Probabilistic numerical methods for ordinary differential equations (ODEs) provide a quantification of the uncertainty arising from the discretization of the continuous problem. However, existing methods often suffer from poor calibration: the reported uncertainty does not accurately reflect the true error. We propose a new class of adaptive probabilistic ODE solvers that are calibrated by construction. We achieve this by interpreting the step-size control mechanism as a Bayesian filtering problem. This allows us to derive a step-size adaptation rule that is consistent with the probabilistic model of the solution. We demonstrate that our method provides reliable uncertainty estimates and competitive performance on a range of benchmark problems.},
	language = {en},
	urldate = {2025-05-14},
	booktitle = {Proceedings of the 24th {International} {Conference} on {Artificial} {Intelligence} and {Statistics}},
	publisher = {PMLR},
	author = {Bosch, N. and Hennig, P. and Tronarp, F.},
	editor = {Banerjee, Arindam and Fukumizu, Kenji},
	month = apr,
	year = {2021},
	keywords = {Ode, Solver, Runge–Kutta methods, Computer science, Ordinary differential equation, Benchmarking, Applied mathematics, Mathematical optimization, Probabilistic logic, Measure (data warehouse), Covariance, Initial value problem, Function (biology), Mathematics, Algorithm, Differential equation, Statistics, Mathematical analysis, Artificial intelligence, Data mining, AISTATS},
}
