@inproceedings{watson_neural_2021,
	title = {Neural {Linear} {Models} with {Functional} {Gaussian} {Process} {Priors}},
	shorttitle = {Neural {Linear} {Models} with {Functional} {Gaussian} {Process} {Priors}},
	url = {https://openreview.net/forum?id=BhaTCbceYDX},
	abstract = {We propose a novel Bayesian neural network architecture, the Neural Linear Model with Functional Gaussian Process Priors (NLM-FGPP). By placing a functional Gaussian process prior over the last layer of a neural network, we obtain a model that is both flexible and tractable. We show that the NLM-FGPP can be trained efficiently using variational inference and that it outperforms standard Bayesian neural networks on a variety of regression tasks.},
	language = {en},
	urldate = {2024-05-22},
	booktitle = {3rd {Symposium} on {Advances} in {Approximate} {Bayesian} {Inference}},
	author = {Watson, J. and Lin, J. A. and Klink, P. and Peters, J.},
	month = jan,
	year = {2021},
	keywords = {AABI},
}
