@misc{yoshimatsu_ancestral_2021,
	title = {Ancestral circuits for vertebrate color vision emerge at the first retinal synapse},
	shorttitle = {Ancestral circuits for vertebrate color vision},
	url = {https://www.science.org/doi/full/10.1126/sciadv.abj6815},
	doi = {10.1126/sciadv.abj6815},
	abstract = {Color vision is a fundamental sensory modality that allows animals to distinguish objects based on the spectral composition of light. While the molecular basis of color vision—the expression of distinct opsins—is well understood, the circuit-level mechanisms that transform these signals into color-opponent channels remain elusive. Here, we show that in the zebrafish retina, color-opponent signals emerge at the first synapse, between photoreceptors and bipolar cells. We find that this is achieved through a combination of selective connectivity and distinct synaptic properties of different photoreceptor types. Our results suggest that the fundamental circuit architecture for color vision is conserved across vertebrates and that the emergence of color-opponent signals at the first retinal synapse is a key evolutionary innovation that enabled the diversification of color vision.},
	language = {en},
	urldate = {2025-05-14},
	publisher = {American Association for the Advancement of Science},
	author = {Yoshimatsu, Takeshi and Bartel, Philipp and Schröder, Cornelius and Janiak, Filip K. and St-Pierre, François and Berens, Philipp and Baden, Tom},
	month = oct,
	year = {2021},
	keywords = {Achromatic lens, Chromatic scale, Retinal, Biology, Retina, Color vision, Optics, Physics, Neuroscience, Botany},
}
