@inproceedings{chen_distilling_2021,
	title = {Distilling {Audio}-{Visual} {Knowledge} by {Compositional} {Contrastive} {Learning}},
	shorttitle = {Distilling {Audio}-{Visual} {Knowledge}},
	url = {https://openaccess.thecvf.com/content/CVPR2021/papers/Chen_Distilling_Audio-Visual_Knowledge_by_Compositional_Contrastive_Learning_CVPR_2021_paper.pdf},
	doi = {10.1109/CVPR46437.2021.00695},
	abstract = {Audio-visual learning aims to learn representations that capture the correspondence between audio and visual signals. Existing methods typically learn a joint embedding space by contrasting positive audio-visual pairs against negative ones. However, they often ignore the compositional nature of audio-visual events, where an event is composed of multiple objects and sounds. In this paper, we propose a novel framework, Compositional Contrastive Learning (CCL), to distill audio-visual knowledge by explicitly modeling the compositional structure of audio-visual events. Specifically, we introduce a compositional contrastive loss that encourages the model to learn representations that are invariant to the composition of audio and visual components. We further propose a cross-modal distillation strategy to transfer knowledge from a pre-trained audio-visual model to a student model. Extensive experiments on multiple benchmarks demonstrate that our method achieves state-of-the-art performance on various audio-visual tasks, including audio-visual retrieval, audio-visual classification, and audio-visual event localization.},
	language = {en},
	booktitle = {Proceedings of the {IEEE}/{CVF} {Conference} on {Computer} {Vision} and {Pattern} {Recognition} ({CVPR})},
	publisher = {Computer Vision Foundation / IEEE},
	author = {Chen, Y. and Xian, Y. and Koepke, A. S. and Akata, Z.},
	month = jun,
	year = {2021},
	keywords = {Modalities, Computer science, Embedding, Benchmark (surveying), Natural language processing, Modality (human–computer interaction), Modal, Semantics (computer science), Representation (politics), Artificial intelligence, Variety (cybernetics), Audio visual, Code (set theory), Task (project management), Machine learning, Multimedia, Programming language, CVPR},
}
